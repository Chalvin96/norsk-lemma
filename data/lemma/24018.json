  "cross_reference": null,
  "definitions": [
    {
      "text": "svinge eller slå et skarpt redskap mot eller inn i noe eller noen",
      "translation": "to swing or strike with a sharp tool into or against something or someone",
      "examples": [
        "løfte øksa og hogge til",
        "motstanderne ble hogd ned",
        "hogge ved",
        "hogge hull på isen",
        "snekkeren hogg til et emne",
        "bokstavene var hogd inn i fjellet",
        "båten var hogd ut av en trestamme",
        "hogge seg i foten",
        "hogge seg vei gjennom krattet"
      ]
    },
    {
      "text": "slå, bite, gripe",
      "translation": "to strike, bite, or grip",
      "examples": [
        "hogge tennene i kjøttet",
        "ormen hogg i støvelen min",
        "hogge kloa i noe",
        "hun hogg tak i ham"
      ]
    },
    {
      "text": "om fartøy: stampe, stange",
      "translation": "for a vessel: to pitch or lurch",
      "examples": [
        "skipet hogg i den grove sjøen",
        "båten lå og hogg mot bryggekanten"
      ]
    }
  ]
}
