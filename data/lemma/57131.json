  "cross_reference": null,
  "definitions": [
    {
      "text": "føre et spisst redskap inn i noe eller noen",
      "translation": "to insert a pointed tool into something or someone",
      "examples": [
        "stikke kniven i noen",
        "stikke noen ned",
        "stikke hull på noe",
        "stikke spaden i jorda",
        "stikke seg på en nål",
        "hun stikker ham med nålen i foten",
        "myggen stakk som besatt"
      ]
    },
    {
      "text": "gi en følelse av å bli berørt av noe spisst",
      "translation": "to cause a sensation of being touched by something sharp",
      "examples": [
        "sola stakk",
        "mørke, stikkende øyne"
      ]
    },
    {
      "text": "få en plutselig innskytelse",
      "translation": "to have a sudden impulse",
      "examples": [
        "hva var det som stakk henne?"
      ]
    },
    {
      "text": "føle en plutselig smerte",
      "translation": "to feel a sudden pain",
      "examples": [
        "det stakk i tanna"
      ]
    },
    {
      "text": "bevege, føre",
      "translation": "to move, to guide",
      "examples": [
        "stikke hånden borti noe",
        "stikke noe til side",
        "stikke nesen ut av vinduet",
        "hun stikker papirene ned i veska",
        "han stakk til henne en pakke"
      ]
    },
    {
      "text": "gå raskt, smette",
      "translation": "to move quickly, to dart",
      "examples": []
    },
    {
      "text": "dra, fare",
      "translation": "to go, to travel",
      "examples": [
        "stikke bort i butikken etter noe",
        "komme stikkende",
        "røyskatten stakk inn i muren"
      ]
    },
    {
      "text": "være synlig eller framstående i en viss retning fra en skjult posisjon",
      "translation": "to be visibly prominent in a certain direction from a hidden position",
      "examples": [
        "høye fjell stakk ende til værs",
        "gresstuster stikker opp av snøen",
        "mobilen stakk opp av lomma",
        "hodet stikker ut av vinduet",
        "føttene stikker fram under dyna",
        "tennene stikker ned fra overleppa"
      ]
    },
    {
      "text": "i ballspill: treffe med ball",
      "translation": "in ball games: to hit with the ball",
      "examples": [
        "hun var flink til å stikke motspillerne"
      ]
    },
    {
      "text": "i kortspill: legge på høyere kort enn dem eller det som ligger der før",
      "translation": "in card games: to play a higher card than those already played or on the table",
      "examples": [
        "stikke tieren med kongen"
      ]
    }
  ]
