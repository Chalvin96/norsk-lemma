  "definitions": [
    {
      "text": "komme imot noe eller noen som kommer i motsatt retning",
      "translation": "to come towards something or someone moving in the opposite direction",
      "examples": [
        "møte motgåande trafikk",
        "møtende trafikk"
      ]
    },
    {
      "text": "komme til et møte til avtalt tid og sted eller treffes tilfeldig",
      "translation": "to arrive at a meeting at an agreed time and place or to meet by chance",
      "examples": []
    },
    {
      "text": "treffe, støte på",
