      ]
    },
    {
      "text": "brukt for å omfatte alle, samtlige",
      "translation": "used to encompass all, every single one",
      "examples": [
        "hver dag",
        "hvert forsøk lyktes",
        "hver tredje lørdag har hun vakt",
        "kongen håndhilste på hver eneste gjest",
