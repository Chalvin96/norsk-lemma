    {
      "text": "ha stor glede av",
      "translation": "to derive great pleasure from",
      "examples": []
    },
    {
      "text": "kjenne velbehag og lyst av",
      "translation": "to feel pleasure and desire from",
      "examples": [
        "nyte den vakre utsikten",
        "han nøt virkelig livet",
        "vi må nyte finværet når vi har det",
        "jeg nyter morgenen med utsikt over fjorden"
      ]
    },
    {
      "text": "få eller ha nytte eller fordel av",
      "translation": "to have the benefit or advantage of",
      "examples": [
        "hun nyter stor tillit i befolkningen",
        "nyte visse rettigheter"
      ]
    },
    {
      "text": "smake, spise, innta eller lignende, ofte med stort velvære",
      "translation": "to taste, eat, consume, often with great enjoyment",
      "examples": [
        "de nøt et glass vin til maten",
        "hun nyter alltid en sigarett etter middag",
        "nyte rusmidler"
