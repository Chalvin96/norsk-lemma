  "cross_reference": null,
  "definitions": [
    {
      "text": "føre noe inn i, i mot eller gjennom noe med stor kraft",
      "translation": "",
      "examples": []
    },
    {
      "text": "renne, drive, kjøre",
      "translation": "",
      "examples": [
        "støte stokken i golvet",
        "han støter spydet i målskiva"
      ]
    },
    {
      "text": "føre noe vekk fra seg med stor kraft",
      "translation": "push, shove",
      "examples": []
    },
    {
      "text": "skyve, puffe",
      "translation": "",
      "examples": [
        "de støtte båten fra land",
        "støtte kule",
        "de støtte opp døra"
      ]
    },
    {
      "text": "knuse med noe hardt",
      "translation": "",
      "examples": [
        "støte hull på isen med en jernstang",
        "støte krydderet i stykker i en morter"
      ]
    },
    {
      "text": "treffe en hindring",
      "translation": "",
      "examples": []
    },
    {
      "text": "renne mot noe",
      "translation": "",
      "examples": [
        "båten støtte på grunn",
        "bilene støtte sammen"
      ]
    },
    {
      "text": "blåse kort og kraftig",
      "translation": "blow briefly and strongly",
      "examples": [
        "støte i et horn",
        "støte i nesen"
      ]
    },
    {
      "text": "gjøre noen fornærmet",
      "translation": "",
      "examples": []
    },
    {
      "text": "forulempe, krenke",
      "translation": "",
      "examples": [
        "jeg mente ikke å støte deg",
        "bli støtt over noe",
        "virke støtende",
        "en støtende bemerkning"
      ]
    }
  ]
