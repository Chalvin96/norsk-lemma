  "cross_reference": null,
  "definitions": [
    {
      "text": "om dyr: reise seg på bakbeina",
      "translation": "of animals: to rear up on hind legs",
      "examples": [
        "hesten steilet"
      ]
    },
    {
      "text": "lette opp framhjulet og balansere på bakhjulet på sykkel eller motorsykkel",
      "translation": "to lift the front wheel and balance on the rear wheel of a bicycle or motorcycle",
      "examples": []
    },
    {
      "text": "om fly: gå inn for bratt stiging, så det mister fart og styring",
      "translation": "of an aircraft: to enter too steep a climb, so that it loses speed and control",
      "examples": []
    },
    {
      "text": "reagere med sterk forferdelse",
      "translation": "to react with strong dismay",
      "examples": [
        "jeg steilet da jeg fikk høre prisen"
      ]
    }
  ]
