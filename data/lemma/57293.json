  "definitions": [
    {
      "text": "lysende stripe på nattehimmelen dannet av et himmellegeme som blir glødende når det kommer inn i atmosfæren",
      "translation": "luminous streak in the night sky formed by a celestial body that becomes incandescent as it enters the atmosphere",
      "examples": []
    },
    {
      "text": "pinne som er innsatt med et stoff som gnistrer når en tenner på det",
      "translation": "stick inserted with a substance that sparks when lit",
      "examples": [
        "på nyttårsaften holdt vi stjerneskudd mens vi så på rakettene"
      ]
    },
    {
      "text": "i overført betydning: nykommer som er i ferd med å etablere seg og bli berømt",
      "translation": "newcomer who is in the process of establishing themselves and becoming famous",
      "examples": [
        "22-åringen er årets stjerneskudd på landslaget"
      ]
    }
  ]
