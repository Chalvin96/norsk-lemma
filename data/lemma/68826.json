    {
      "text": "ha greie på",
      "translation": "to be aware of",
      "examples": [
        "la noen få vite hva en mener",
        "jeg visste ikke at de hadde flyttet",
        "vet du hvordan det gikk?",
        "det kan være løgn, for alt jeg vet",
