  "definitions": [
    {
      "text": "tid da en person er på prøve, for eksempel i en stilling eller som løslatt fra fengsel",
      "translation": "time when a person is on trial, in a position or released from prison",
      "examples": [
        "etter prøvetiden fikk han fast stilling",
        "dommen er på 45 dagers betinget fengsel med en prøvetid på to år"
      ]
    },
    {
      "text": "tid da en har noe på prøve",
      "translation": "time when one has something on trial",
      "examples": [
        "de begynte å abonnere fast på avisen etter at prøvetiden var slutt"
      ]
    },
    {
      "text": "tid brukt til å øve inn noe, særlig et teaterstykke",
      "translation": "time spent practicing something, especially a play",
      "examples": [
        "forestillingen hadde fem ukers prøvetid"
      ]
    }
  ]
