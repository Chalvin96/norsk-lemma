  "definitions": [
    {
      "text": "person som er mentalt forstyrret, vettløs eller fra seg",
      "translation": "person who is mentally disturbed, senseless, or beside themselves",
      "examples": [
        "han løp rundt som en galning hele natten",
        "noen galninger mener at mennesket ikke har vært på månen"
      ]
    },
    {
      "text": "ustyrlig, løssluppen person",
