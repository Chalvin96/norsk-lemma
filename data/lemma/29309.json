  "definitions": [
    {
      "text": "slenge, vippe",
      "translation": "to toss, to tip",
      "examples": [
        "kippe fisken opp i båten"
      ]
    },
    {
      "text": "få av eller på seg (klær eller sko) i en fart",
      "translation": "to put on or take off (clothes or shoes) quickly",
      "examples": [
        "kippe på seg skoene",
        "kippe av seg tøflene"
      ]
    },
    {
      "text": "om skotøy: gli opp og ned langs hælen når en går",
      "translation": "of footwear: to slip up and down along the heel when walking",
      "examples": [
        "skoene kipper"
      ]
    }
  ]
