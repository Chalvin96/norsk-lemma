  "definitions": [
    {
      "text": "om klær: som har mistet mye farge og fasong på grunn av mye eller hard vask",
      "translation": "for clothes: having lost much color and shape due to much hard washing",
      "examples": [
        "en utvasket bukse"
      ]
    },
    {
      "text": "som er skylt vekk",
      "translation": "that has been washed away",
      "examples": [
        "utvasket elvesand"
      ]
    },
    {
      "text": "som er utvunnet ved spyling eller lignende",
      "translation": "extracted by rinsing",
      "examples": [
        "utvasket gull"
      ]
    },
    {
      "text": "som er renset ved skylling",
      "translation": "cleaned by rinsing",
      "examples": [
        "et utvasket sår"
      ]
    }
  ]
