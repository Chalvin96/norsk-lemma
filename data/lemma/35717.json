  "definitions": [
    {
      "text": "kalle til seg med sang eller hauking",
      "translation": "call to oneself with song or hawking",
      "examples": []
    },
    {
      "text": "rope til seg",
      "translation": "call to oneself by shouting",
      "examples": [
        "lokke på kuene"
      ]
    },
    {
      "text": "forsøke å påvirke ved å overtale, friste eller narre",
      "translation": "attempt to influence by persuading, tempting, or deceiving",
      "examples": [
        "lokke noen til å gjøre noe",
        "la seg lokke",
        "firmaet lokker med god lønn",
        "de ble lokket i en felle",
        "en film som lokker fram smilet"
      ]
    },
    {
      "text": "virke fristende eller dragende",
      "translation": "seem tempting or attractive",
      "examples": [
        "pengene lokker",
        "skiløypene lokket"
      ]
    }
