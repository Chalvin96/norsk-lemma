    {
      "text": "tom for krefter og energi",
      "translation": "empty of strength and energy",
      "examples": []
    },
    {
      "text": "matt, slapp, sliten",
      "translation": "dull, listless, tired",
      "examples": [
        "bli trøtt og sliten av arbeidet",
        "være trøtt i beina etter den lange gåturen"
      ]
    },
    {
      "text": "som kjenner trang til å sove",
      "translation": "feeling the need to sleep",
      "examples": [
        "bli trøtt av medisinene",
        "et trøtt smil",
        "ha trøtte øyne",
        "filmen gjorde ham så trøtt at han sovnet"
      ]
    },
    {
      "text": "som har gått lei noe",
      "translation": "having had enough of something",
      "examples": [
        "være trøtt av skolen",
        "hun er trøtt av det ensformige livet sitt"
      ]
    },
    {
      "text": "som gjør en trøtt trett",
      "translation": "that makes one tired",
      "examples": []
    },
    {
      "text": "uinteressant, kjedelig",
      "translation": "uninteresting, boring",
      "examples": [
