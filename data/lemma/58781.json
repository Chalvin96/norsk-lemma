  "definitions": [
    {
      "text": "bevege noe i bue",
      "translation": "to move something in an arc",
      "examples": [
        "svinge sverdet",
        "hun svingte øksa",
        "han svinger armene langs siden"
      ]
    },
    {
      "text": "føre noe i en ny retning",
      "translation": "to lead something in a new direction",
      "examples": []
    },
    {
      "text": "endre retning",
      "translation": "to change direction",
      "examples": []
    },
    {
      "text": "snu, dreie, vende",
      "translation": "to turn, to veer, to rotate",
      "examples": [
        "svinge båten rundt",
        "båten svingte rundt neset",
        "bilen svingte opp foran døra",
        "svinge rundt på hælen",
        "svinge på rattet"
      ]
    },
    {
      "text": "bevege seg fram og tilbake",
      "translation": "to move back and forth",
      "examples": [
        "pendelen svinger",
        "grenene svingte i vinden"
      ]
    },
    {
      "text": "veksle mellom ulike tilstander",
      "translation": "to alternate between different states",
      "examples": [
        "prisene svingte sterkt",
        "svinge mellom håp og fortvilelse",
        "folkemeningen svinger igjen",
        "svingende priser",
        "svingende humør"
      ]
    },
    {
      "text": "om musikk: ha rytmisk driv",
      "translation": "to have rhythmic drive",
      "examples": [
        "bandet fikk det til å svinge",
        "musikken svinger til tider riktig bra",
        "svingende jazz",
        "svingende pianospill"
      ]
    },
    {
      "text": "i overført betydning: være preget av driv og intensitet",
      "translation": "to be characterized by drive and intensity",
      "examples": [
        "en roman det svinger skikkelig av"
      ]
    },
    {
      "text": "brukt i ed",
      "translation": "used in an oath",
      "examples": [
        "ha deg ut, for svingende!"
      ]
    }
  ]
