  "definitions": [
    {
      "text": "lete etter noe eller noen som har forsvunnet",
      "translation": "look for something or someone who has disappeared",
      "examples": []
    },
    {
      "text": "prøve å finne",
      "translation": "try to find",
      "examples": [
        "søke etter overlevende",
        "politiet søker etter mistenkte",
        "hjelpemannskaper har søkt i hele natt"
      ]
    },
    {
      "text": "lete etter noe eller noen som en har lyst på eller behov for",
      "translation": "look for something or someone that one desires or needs",
      "examples": []
    },
    {
      "text": "forsøke å skaffe seg",
      "translation": "attempt to obtain",
      "examples": [
        "de søkte ly for uværet",
        "bedriften har søkt etter nye medarbeidere",
        "hun søker etter oppskrifter på internett"
      ]
    },
    {
      "text": "henvende seg til noen for å få hjelp, støtte eller lignende",
      "translation": "approach someone for help, support, or similar",
      "examples": [
        "søke hjelp",
        "søke jobb",
        "barnet søker trøst hos moren",
        "søkende mennesker"
      ]
    },
    {
      "text": "sette kursen mot",
      "translation": "set course towards",
      "examples": []
    },
    {
      "text": "begi seg til",
      "translation": "go to",
      "examples": [
        "søke lege",
        "laksen søker opp i elvene for å gyte",
        "båtene søkte havn"
      ]
    },
    {
      "text": "skriftlig anmode om å få stilling, stipend eller lignende",
      "translation": "apply in writing for a position, scholarship",
      "examples": [
        "søke en stilling",
        "søke på jobber",
        "søke asyl",
        "søke om utsettelse",
        "hun søker om å få dekket reiseutgiftene"
      ]
    },
    {
      "text": "forsøke, prøve, ville",
      "translation": "attempt, try, want",
      "examples": [
        "boka søker å gi en framstilling av livet i storbyslummen"
      ]
    }
