  "cross_reference": null,
  "definitions": [
    {
      "text": "komme ned på bakken (eller vannoverflaten) fra lufta",
      "translation": "to come down to the ground (or water surface) from the air",
      "examples": [
        "flyet har landet",
        "ørnen landet på hustaket",
        "lande på alle fire"
      ]
    },
    {
      "text": "komme inn til land fra sjøen",
      "translation": "to come ashore from the sea",
      "examples": [
        "Leiv Eiriksson landet i Vinland"
      ]
    },
    {
      "text": "i overført betydning: komme i normal sinnstilstand etter en sterk opplevelse",
      "translation": "to regain normal state of mind after a strong experience",
      "examples": [
        "først nå har hun landet etter VM-gullet"
      ]
    },
    {
      "text": "i overført betydning: komme fram til (noe abstrakt)",
      "translation": "to arrive at (something abstract)",
      "examples": []
    },
    {
      "text": "ende",
      "translation": "to end up",
      "examples": [
        "vi landet på forslaget fra komitélederen"
      ]
    },
    {
      "text": "føre ned på bakken (eller vannoverflaten) fra lufta",
      "translation": "to bring down to the ground (or water surface) from the air",
      "examples": [
        "piloten landet flyet trygt"
      ]
    },
    {
      "text": "føre i land fra fartøy",
      "translation": "to bring ashore from a vessel",
      "examples": [
        "forbud mot å lande fangsten utenlands"
      ]
    },
    {
      "text": "i overført betydning: sikre seg",
      "translation": "to secure",
      "examples": [
        "arbeide hardt for å få landet avtalen"
      ]
    }
  ]
