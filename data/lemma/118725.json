  "definitions": [
    {
      "text": "det at visse hunndyr (for eksempel ku eller simle) føder kalv",
      "translation": "the act of certain female animals (e.g., a cow or doe) giving birth to a calf",
      "examples": [
        "det nærmer seg kalving for husdyra utpå våren",
        "etter årets kalving teller moskusstammen rundt 200 dyr"
      ]
