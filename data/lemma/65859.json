  "definitions": [
    {
      "text": "utelukke, ekskludere",
      "translation": "to exclude, to ostracize",
      "examples": [
        "mobbe og utstøte noen fra vennegjengen",
        "hun ble utstøtt av det gode selskap",
        "han følte seg som en utstøtt"
      ]
    },
    {
      "text": "plutselig komme med sterke lyder",
      "translation": "to suddenly emit strong sounds",
      "examples": [
        "utstøte varsellyder",
        "barna utstøtte ville skrik"
      ]
