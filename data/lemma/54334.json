    },
    {
      "text": "i overført betydning: (for) sterke ord eller tiltak",
      "translation": "strong words or measures",
      "examples": [
        "redaktøren brukte sleggen mot det politiske rotet",
        "treneren tok fram sleggen i pausen"
      ]
    },
    {
      "text": "i idrett: kuleformet redskap med ståltråd og håndtak til å kaste",
      "translation": "spherical implement with steel wire and a handle for throwing",
      "examples": [
        "kaste slegge",
        "ha norgesrekorden i slegge"
      ]
    },
    {
      "text": "i overført betydning: arm eller bein med stor muskelkraft",
      "translation": "arm or leg with great muscle power",
      "examples": [
