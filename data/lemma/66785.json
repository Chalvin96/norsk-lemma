  "definitions": [
    {
      "text": "lysreflekterende, rød trekant som stilles opp for å varsle om havarert bil som kan være farlig for andre trafikanter",
      "translation": "light-reflecting, red triangle set up to warn of a broken-down car that could be dangerous to other road users",
      "examples": [
        "det er påbudt å ha varseltrekant i bilen"
      ]
    }
