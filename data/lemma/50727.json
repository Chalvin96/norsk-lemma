  "definitions": [
    {
      "text": "mål som et lag ufrivillig skaffer motparten ved å sende ballen i eget mål",
      "translation": "a goal that a team unintentionally scores for the opposing side by sending the ball into its own goal",
      "examples": [
        "backen laget selvmål"
      ]
    },
    {
      "text": "i overført betydning: handling som ødelegger for en selv",
      "translation": "an action that harms oneself",
      "examples": [
        "saken er et politisk selvmål for partiet"
      ]
    }
  ]
