    {
      "text": "som er tøyd eller strammet ut",
      "translation": "that which is stretched or tightened",
      "examples": []
    },
    {
      "text": "fast, strak, utspent",
      "translation": "firm, taut, stretched",
      "examples": [
        "stram line"
      ]
    },
    {
      "text": "som slutter fast til",
      "translation": "that fits closely",
      "examples": [
        "beltet var for stramt",
        "kjolen satt stramt over hoftene"
      ]
    },
    {
      "text": "rank, spenstig",
      "translation": "erect, sprightly",
      "examples": [
        "en stram fyr",
        "gjøre stram honnør"
      ]
    },
    {
      "text": "som tar seg godt ut",
      "translation": "that looks good",
      "examples": []
    },
    {
      "text": "elegant, fjong",
      "translation": "elegant, dapper",
      "examples": [
        "han var virkelig stram i den nye dressen"
      ]
    },
    {
      "text": "spent, stiv",
      "translation": "tense, stiff",
      "examples": [
        "et stramt drag om munnen",
        "bli stram i maska"
      ]
    },
    {
      "text": "om mat: som smaker eller lukter skarpt og ramt",
      "translation": "of food: that tastes or smells sharp and pungent",
      "examples": []
    },
    {
      "text": "sterk",
      "translation": "strong",
      "examples": [
