  "definitions": [
    {
      "text": "be om noe på en myndig måte",
      "translation": "to ask for something authoritatively",
      "examples": []
    },
    {
      "text": "forlange at noe blir gjort, satt i verk eller lignende",
      "translation": "to demand that something be done or put into effect",
      "examples": []
    },
    {
      "text": "gjøre krav på",
      "translation": "to claim",
      "examples": [
        "kreve betaling",
        "kreve tilbake et lån",
        "hun krevde erstatning",
        "de krever oppreisning",
        "sjefen krever full innsats",
        "kreve sin rett"
      ]
    },
    {
      "text": "være nødvendig for at noe skal eksistere, fungere eller lykkes",
      "translation": "to be necessary for something to exist, function, or succeed",
      "examples": []
    },
    {
      "text": "fordre, forutsette",
      "translation": "to require, presuppose",
      "examples": [
        "situasjonen krever handling",
        "arbeidet krever orden og innsikt"
      ]
    },
    {
      "text": "forårsake et stort tap",
      "translation": "to cause a great loss",
      "examples": [
        "ulykken krevde mange menneskeliv"
      ]
    }
