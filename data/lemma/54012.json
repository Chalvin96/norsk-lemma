  "definitions": [
    {
      "text": "flomme, fosse",
      "translation": "flood, surge",
      "examples": [
        "sjøen skyller over rekka"
      ]
    },
    {
      "text": "føre eller rive med seg",
      "translation": "carry or sweep along",
      "examples": [
        "bølgene skylte en mann over bord",
        "vrakgods var skylt i land"
      ]
    },
    {
      "text": "i overført betydning: spre seg",
      "translation": "in a figurative sense: spread",
      "examples": []
    },
    {
      "text": "gjøre seg stadig med gjeldende",
      "translation": "become increasingly current",
      "examples": [
        "sinnet skylte gjennom henne",
        "eldrebølgen skyller over landet"
      ]
    },
    {
      "text": "rense i eller med vann",
      "translation": "rinse with water",
      "examples": [
        "skylle tøy",
        "hun skyller saltet av fisken",
        "han skylte hendene grundig"
      ]
    }
  ]
