  "definitions": [
    {
      "text": "det å ha rett og mulighet til å handle, uttale seg og tenke som en ønsker, uten tvang eller restriksjoner",
      "translation": "the right and ability to act, speak, and think as one wishes, without coercion or restrictions",
      "examples": [
        "ha sin fulle frihet",
        "frihet under ansvar",
        "dikterisk frihet",
        "ha frihet til å ytre seg"
      ]
    },
    {
      "text": "suverenitet, selvstyre sjølstyre",
      "translation": "sovereignty, self-governance",
      "examples": []
    },
    {
      "text": "jamfør frihetsdag og frihetskamp",
      "translation": "day of freedom and struggle for freedom",
      "examples": [
        "kjempe for landets frihet",
        "de gav sitt liv for Europas frihet og demokrati"
      ]
    },
    {
      "text": "det å ikke være i fangenskap",
      "translation": "not being in captivity",
      "examples": []
    },
    {
      "text": "anledning til å ferdes fritt",
      "translation": "opportunity to move freely",
      "examples": [
        "et liv i frihet",
        "i ti år arbeidet hun for sin manns frihet"
      ]
    },
    {
      "text": "det å være uten",
      "translation": "being without",
      "examples": []
    },
    {
      "text": "det å slippe",
      "translation": "getting rid of",
      "examples": [
        "frihet fra tortur",
        "frihet fra konvensjoner"
      ]
    }
