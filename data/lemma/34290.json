  "definitions": [
    {
      "text": "få til å ligge, plassere i vannrett stilling",
      "translation": "to cause to lie, place in a horizontal position",
      "examples": [
        "legge duk på bordet",
        "legge barna til faste tider",
        "hun legger hånden på skulderen hans"
      ]
    },
    {
      "text": "sette eller stille fra seg",
      "translation": "to set or place down",
      "examples": []
    },
    {
      "text": "plassere i en viss orden",
      "translation": "to place in a certain order",
      "examples": [
        "legge bandasje på såret",
        "legge kabal",
        "høna legger egg hver dag",
        "legge armen rundt noen"
      ]
    },
    {
      "text": "dekke, kle",
      "translation": "to cover, to clad",
      "examples": [
        "legge fliser på badet",
        "legge papp på taket"
      ]
    },
    {
      "text": "utforme, bygge, lage",
      "translation": "to design, build, make",
      "examples": [
        "legge en ny vei",
        "legge planer",
        "han la grunnen til et samarbeid",
        "legge vin"
      ]
    },
    {
      "text": "ta veien, dra",
      "translation": "to take the road, to go",
      "examples": []
    },
    {
      "text": "styre, stevne",
      "translation": "to steer, to head",
      "examples": [
        "legge av sted",
        "legge på sprang",
        "skipet legger til kai"
      ]
    },
    {
      "text": "fastsette, pålegge",
      "translation": "to establish, to impose",
      "examples": [
        "legge avgift på forbruk",
        "legge forpliktelser på styret",
        "de legger press på myndighetene"
      ]
    },
    {
      "text": "bruke, ofre",
      "translation": "to use, to dedicate",
      "examples": [
        "han kan godt legge arbeidstimer i dette"
