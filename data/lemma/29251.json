  "definitions": [
    {
      "text": "ringe med (kirke)klokke med raske slag, slik at lyden går i ett",
      "translation": "to ring (church) bells with rapid strokes, so that the sound is continuous",
      "examples": [
        "kirkeklokkene kimte jula inn"
      ]
    },
    {
      "text": "ringe sterkt og vedvarende",
      "translation": "to ring loudly and persistently",
      "examples": [
        "dørklokka kimte"
      ]
