  "cross_reference": null,
  "definitions": [
    {
      "text": "ta opp væske eller løs masse med øse ause eller lignende",
      "translation": "scoop up liquid or loose mass with a ladle",
      "examples": [
        "øse opp suppe",
        "øse vann over barnets hode i dåpen"
      ]
    },
    {
      "text": "tømme (særlig for vann)",
      "translation": "empty (especially of water)",
      "examples": [
        "øse båten"
      ]
    },
    {
      "text": "styrte, strømme, hølje",
      "translation": "pour down, stream, pour heavily",
      "examples": [
        "regnet øste ned",
        "det øser og pøser"
      ]
    },
    {
      "text": "i overført betydning: komme med en flom av ord (i følelsesutbrudd)",
      "translation": "in a figurative sense: come with a flood of words (in emotional outbursts)",
      "examples": [
        "øse frustrasjonen ut av seg"
      ]
    },
    {
      "text": "i overført betydning: ta for seg",
      "translation": "help oneself to",
      "examples": []
    },
    {
      "text": "gjøre seg nytte av (noe som fins i store mengder)",
      "translation": "make use of (something that exists in large quantities)",
      "examples": []
    },
    {
      "text": "bruke",
      "translation": "use",
      "examples": [
        "ha rike kilder å øse av",
        "øse på med ny kunnskap",
        "øse ut penger"
      ]
    }
  ]
