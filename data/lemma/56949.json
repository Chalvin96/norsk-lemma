  "definitions": [
    {
      "text": "tilberede mat med sterk varme og uten vann",
      "translation": "prepare food with strong heat and without water",
      "examples": []
    },
    {
      "text": "til forskjell fra koke",
      "translation": "boil",
      "examples": [
        "steke fisk",
        "steke flesk i panne",
        "de stekte lam på spidd",
        "han steker brødet i stekeovnen",
        "stekt egg",
        "stekt makrell"
      ]
    },
    {
      "text": "brukt i kraftuttrykk og banning:",
      "translation": "used in strong expressions and swearing",
      "examples": [
        "nå må du faen steike meg passe deg!"
      ]
    },
    {
      "text": "utsette for sterk varme",
      "translation": "expose to strong heat",
      "examples": [
        "sitte og steke seg i sola"
      ]
    },
    {
      "text": "om varmekilde: gi fra seg sterk varme",
      "translation": "about a heat source: give off strong heat",
      "examples": []
    },
    {
      "text": "jamfør stekende steikende",
      "translation": "scorching scorching",
      "examples": [
        "sola stekte hele dagen"
      ]
    }
