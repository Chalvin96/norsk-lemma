    },
    {
      "text": "prøve å fange eller få tak i",
      "translation": "to try to catch or get hold of",
      "examples": [
        "ligningsmyndighetene jakter på skattesnytere"
      ]
    },
    {
      "text": "streve for å skaffe seg",
      "translation": "to strive to acquire",
      "examples": []
    },
    {
      "text": "trå, hige",
      "translation": "to pursue, to covet",
      "examples": [
        "jakte etter gods og gull"
