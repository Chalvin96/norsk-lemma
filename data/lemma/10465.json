    {
      "text": "som kan tolkes på to måter",
      "translation": "that can be interpreted in two ways",
      "examples": [
        "et begrep med dobbelt betydning"
      ]
    },
    {
      "text": "to ganger så mye",
      "translation": "twice as much",
      "examples": [
