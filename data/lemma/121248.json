  "definitions": [
    {
      "text": "steke steike lenge nok til at stekeemnet holder fasongen, men ikke er gjennomstekt eller har brun skorpe",
      "translation": "bake long enough for the baked item to hold its shape, but not be cooked through or have a brown crust",
