    },
    {
      "text": "jamfør teigblanding",
      "translation": "patchwork",
      "examples": []
    },
    {
      "text": "i overført betydning: del, sektor (av arbeid, virksomhet, samfunnsliv)",
      "translation": "in a figurative sense: part, sector (of work, activity, social life)",
      "examples": [
