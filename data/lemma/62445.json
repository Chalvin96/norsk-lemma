  "definitions": [
    {
      "text": "kostbar, utsmykket (og opphøyd) stol for høytstående person, regjerende monark, pave eller lignende",
      "translation": "a ceremonial, ornate chair for a monarch, pope, or other high-ranking person",
      "examples": [
        "en trone med armlener utformet som to løver",
        "stå for Guds trone"
      ]
    },
    {
      "text": "stilling eller autoritet som øverste statsoverhode",
      "translation": "the position of supreme head of state",
      "examples": [
        "være nummer to i arverekken til den britiske tronen",
        "partiet forsøker å gjenerobre tronen"
      ]
    },
    {
      "text": "ledende eller dominerende posisjon (i idrett eller annen konkurransesituasjon)",
      "translation": "a leading or dominant position in sports or other competition",
      "examples": [
        "langdistanseløperen er i ferd med å forlate tronen"
