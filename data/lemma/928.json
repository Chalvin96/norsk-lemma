  "definitions": [
    {
      "text": "komme eller ende i en ny posisjon, for eksempel i fengsel",
      "translation": "to come or end up in a new position, for example in prison",
      "examples": [
        "laget åkte ned enda en divisjon",
        "hun stod på sikker plass i valget og åkte inn i bystyret",
        "han åker inn og ut av fengsel",
        "han smuglet sprit og åkte rett inn"
      ]
    },
    {
      "text": "fare, gli glide",
      "translation": "to go, slide, glide",
      "examples": [
        "varebilen åkte rett i grøfta",
        "åke til Oslo"
      ]
    }
  ]
