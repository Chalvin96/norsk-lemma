  "definitions": [
    {
      "text": "om (del av) plante: bli vissen",
      "translation": "wither (of plants)",
      "examples": []
    },
    {
      "text": "skrumpe inn og forsvinne",
      "translation": "shrivel up and disappear",
      "examples": [
        "blomstene visnet",
        "plantene visner og dør i varmen"
      ]
    },
    {
      "text": "om person eller kroppsdel: miste kraft og førlighet",
      "translation": "lose strength and sensation (of person or body part)",
      "examples": []
    },
    {
      "text": "bli lammet",
      "translation": "become paralyzed",
      "examples": []
    },
    {
      "text": "forfalle",
      "translation": "decay",
      "examples": [
        "armen visnet bort av slaget",
        "føttene visnet av tretthet",
        "sykdommen fører til at muskulaturen visner bort"
      ]
    },
    {
      "text": "i overført betydning: gradvis bli borte",
      "translation": "gradually disappear",
      "examples": [
        "smilet hennes visner",
        "håpet visnet bort"
      ]
    }
