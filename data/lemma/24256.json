  "cross_reference": null,
  "definitions": [
    {
      "text": "presse luft kraftig og høylytt opp fra lungene for å fjerne slim, fremmedlegemer og lignende fra de nedre luftveiene",
      "translation": "expel air forcefully and loudly from the lungs to clear mucus or foreign bodies from the lower airways",
      "examples": [
        "hoste og harke",
        "hoste opp slim",
        "han har hostet i flere uker"
      ]
    },
    {
      "text": "i overført betydning: gi støtvise og kraftige lyder, ofte som tegn på at noe fungerer dårlig",
      "translation": "make sputtering and loud noises, often indicating poor functioning",
      "examples": [
        "motoren hostet og trakk ujevnt"
      ]
    }
  ]
