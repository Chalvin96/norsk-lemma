  "definitions": [
    {
      "text": "delta i slagsmål eller kamp (med våpen)",
      "translation": "participate in a brawl or fight (with weapons)",
      "examples": [
        "kjempe på tørre never",
        "kjempe ved fronten",
        "Frankrike kjempet på de alliertes side",
        "bevegelsen kjemper for sin egen stat"
      ]
    },
    {
      "text": "kappes, konkurrere",
      "translation": "compete, contest",
      "examples": [
        "kjempe om førsteplassen"
      ]
    },
    {
      "text": "streve hardt for å oppnå, endre eller forsvare noe",
      "translation": "strive hard to achieve, change, or defend something",
      "examples": [
        "kjempe for retten sin",
        "kjempe for en god sak",
        "kjempe mot noe",
        "kjempe seg fram i verden",
        "kjempe en håpløs kamp"
      ]
    },
    {
      "text": "prøve å overvinne problemer eller vonde følelser",
      "translation": "try to overcome problems or bad feelings",
      "examples": [
        "ha mange vansker å kjempe med",
        "kjempe med gråten"
      ]
    }
  ]
