  "cross_reference": null,
  "definitions": [
    {
      "text": "det at en avis eller journalist kommer først med en (viktig) nyhet",
      "translation": "the act of a newspaper or journalist being the first to publish (an important) news item",
      "examples": [
        "saken om den korrupte politikeren var et skikkelig skup",
        "paparazzoen var på jakt etter neste skup"
      ]
    },
    {
      "text": "det at en får tak i, finner eller kjøper noe svært verdifullt, sjelden eller liknende",
      "translation": "the act of obtaining, finding, or buying something very valuable, rare, or similar",
      "examples": []
    },
    {
      "text": "kupp, varp",
      "translation": "bargain, steal",
      "examples": [
        "fotballaget gjorde et skup med den nye spilleren",
        "den handelen var et skikkelig skup"
      ]
    }
  ]
