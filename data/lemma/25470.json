  "cross_reference": null,
  "definitions": [
    {
      "text": "produksjonsform der yrkesutøvere med faglig utdanning og praktisk erfaring framstiller noe i mindre omfang, hovedsakelig ved hjelp av håndverktøy handverktøy",
      "translation": "form of production where professionals with vocational training and practical experience produce something on a small scale, mainly using hand tools",
      "examples": [
        "yrkene i håndverk og industri"
      ]
    },
    {
      "text": "fag eller yrke basert på håndverk handverk",
      "translation": "trade or profession based on craftsmanship",
      "examples": [
        "lære et gammelt håndverk",
        "steinhogging er et utdøende håndverk"
      ]
    },
    {
      "text": "i overført betydning: del av et arbeid eller en virksomhet som krever grunnleggende teknikk og ferdigheter",
      "translation": "part of a work or activity that requires basic technique and skills",
      "examples": [
        "å skrive romaner er et krevende håndverk",
        "dette var et stykke godt politisk håndverk"
      ]
    },
    {
      "text": "resultat av et håndverksmessig arbeid",
      "translation": "result of a craftsman's work",
      "examples": [
        "skapet er et solid stykke håndverk",
        "diktene hans bærer mer preg av håndverk enn av ånd"
      ]
    }
  ]
