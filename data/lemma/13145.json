  "cross_reference": null,
  "definitions": [
    {
      "text": "ha i sinne, ha til hensikt",
      "translation": "to have in mind, to intend",
      "examples": []
    },
    {
      "text": "akte, tenke",
      "translation": "to intend, to think",
      "examples": [
        "esle seg til byen",
        "esle å starte en bedrift"
      ]
    },
    {
      "text": "tiltenke et visst formål",
      "translation": "to intend for a certain purpose",
      "examples": []
    },
    {
      "text": "sette av, velge ut",
      "translation": "to set aside, to select",
      "examples": [
        "det største eplet er eslet til deg",
        "esle noen en gave",
        "være eslet til konge"
      ]
    },
    {
      "text": "la være igjen",
      "translation": "to leave behind",
      "examples": []
    },
    {
      "text": "levne, spare, reservere",
      "translation": "to leave over, to spare, to reserve",
      "examples": [
        "esle mat",
        "esle unna litt tømmer"
      ]
    }
  ]
