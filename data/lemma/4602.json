  "definitions": [
    {
      "text": "smittsom sykdom som de fleste barn får, og som de siden vanligvis er immune mot",
      "translation": "infectious disease that most children get, and to which they are usually immune afterwards",
      "examples": [
        "kusma og meslinger er barnesykdommer"
