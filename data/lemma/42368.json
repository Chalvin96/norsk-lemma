  "definitions": [
    {
      "text": "(være den første til å) bli klar over at et naturfenomen eller sted fins",
      "translation": "(be the first to) become aware that a natural phenomenon or place exists",
      "examples": [
        "Ørsted oppdaget elektromagnetismen",
        "Eirik Raude oppdaget Grønland"
      ]
    },
    {
      "text": "få øye på",
      "translation": "spot",
      "examples": []
    },
    {
      "text": "bli var",
      "translation": "notice",
      "examples": [
        "plutselig oppdaget han en mann fra hjemstedet"
      ]
    },
    {
      "text": "(være den første til å) legge merke til noe enestående, for eksempel et talent eller et sted med spesielle kvaliteter",
      "translation": "(be the first to) notice something unique, e.g. a talent or a place with special qualities",
      "examples": [
        "hun ble oppdaget av en talentspeider",
        "den engelske pressen har oppdaget Lofoten"
      ]
    }
