  "cross_reference": null,
  "definitions": [
    {
      "text": "synlig forbrenningsprodukt som stiger opp i lufta, og som består av gasser, damp og faste partikler",
      "translation": "visible combustion product rising into the air, consisting of gases, vapor, and solid particles",
      "examples": [
        "røyken steg opp fra skorsteinen"
      ]
    },
    {
      "text": "(det å røyke) tobakk eller sigarett",
      "translation": "(the act of smoking) tobacco or cigarettes",
      "examples": [
        "ta seg en røyk",
        "kjøpe en pakke røyk",
        "rulle seg en røyk",
        "stumpe røyken"
      ]
    }
  ]
