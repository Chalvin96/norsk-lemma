  "definitions": [
    {
      "text": "vikle en tauende så den ikke rakner",
      "translation": "to whip a rope end so it doesn't fray",
      "examples": []
    },
    {
      "text": "rigge et fartøy",
      "translation": "to rig a vessel",
      "examples": []
    },
    {
      "text": "utstyre med takkelasje",
      "translation": "to equip with rigging",
      "examples": []
    },
    {
      "text": "i lagidrett: angripe en motspiller og ta ballen eller pucken fra hen",
      "translation": "in team sports: to tackle an opponent and take the ball or puck from them",
      "examples": []
    },
    {
      "text": "i overført betydning: ordne opp i",
      "translation": "to sort out",
      "examples": []
    },
    {
      "text": "greie, mestre",
      "translation": "to manage, to cope with",
      "examples": [
        "takle et problem",
        "hun taklet situasjonen godt"
