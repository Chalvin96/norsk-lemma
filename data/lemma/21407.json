  "definitions": [
    {
      "text": "felle tårer ved sinnsbevegelse (og samtidig gi fra seg klagende lyd, hikst eller hulk)",
      "translation": "shed tears due to emotion (and simultaneously make a plaintive sound, sob, or wail)",
      "examples": [
        "begynne å gråte",
        "barnet gråter av fortvilelse",
        "vinneren gråt av glede",
        "vi har grått mye de siste dagene",
        "gråte seg i søvn",
        "dette er ikke noe å gråte for",
        "situasjonen er til å gråte av",
        "jeg trenger en skulder å gråte på"
      ]
    }
