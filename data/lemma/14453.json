  "cross_reference": null,
  "definitions": [
    {
      "text": "gjøre fast ved å binde, stifte, lime, knytte eller lignende",
      "translation": "to make fast by binding, stapling, gluing, tying, or similar",
      "examples": [
        "feste tråden",
        "feste beltet rundt livet",
        "feste søljene på bunaden",
        "de festet lasten godt på lasteplanet"
      ]
    },
    {
      "text": "i overført betydning: holde fast",
      "translation": "in a figurative sense: to hold fast",
      "examples": [
        "feste blikket på tavla",
        "feste lit til styret"
      ]
    },
    {
      "text": "bygsle tomt eller jord",
      "translation": "to lease land or ground",
      "examples": []
    },
    {
      "text": "om eldre forhold: ta i tjeneste",
      "translation": "regarding: to take into service",
      "examples": []
    },
    {
      "text": "ansette, engasjere",
      "translation": "to hire, to engage",
      "examples": [
        "feste tjenere"
      ]
    },
    {
      "text": "om eldre forhold: trolove (seg med)",
      "translation": "regarding older customs: to betroth (to)",
      "examples": [
        "feste en jente"
      ]
    }
  ]
