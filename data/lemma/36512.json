  "definitions": [
    {
      "text": "sekkformet utvidelse av fordøyelseskanalen",
      "translation": "sac-shaped expansion of the digestive tract",
      "examples": [
        "kua har fire mager"
      ]
    },
    {
      "text": "fellesbetegnelse for magesekk og tarmkanal",
      "translation": "general term for stomach and intestinal tract",
      "examples": [
        "ha vondt i magen",
        "luft i magen"
      ]
    },
    {
      "text": "avføring",
      "translation": "digestion",
      "examples": [
        "ha dårlig mage",
        "treg mage",
        "hard mage",
        "løs mage"
      ]
    },
    {
      "text": "overkroppens forside mellom brystet og underlivet",
      "translation": "front of the torso between the chest and the lower abdomen",
      "examples": [
        "ligge på magen",
        "mage og rygg",
        "gå med bar mage"
      ]
    },
    {
      "text": "utbuling av mage mave, særlig på grunn av fedme eller graviditet",
      "translation": "bulge of the abdomen, especially due to obesity or pregnancy",
      "examples": []
    },
    {
      "text": "(stor) vom",
      "translation": "(large) paunch",
      "examples": [
        "begynne å få mage",
        "kvinner med barn i magen"
      ]
    },
    {
      "text": "i overført betydning: område i mageregionen, der en synes å merke følelser som spenning, uro og lignende",
      "translation": "area in the abdominal region where one feels emotions like tension, unease",
      "examples": [
        "kjenne et sug i magen",
