  "definitions": [
    {
      "text": "presse, skyve eller bøye med fysisk makt",
      "translation": "press, push, or bend with physical force",
      "examples": [
        "tvinge inn en kile",
        "han tvang opp døra"
      ]
    },
    {
      "text": "få noen til å gjøre noe mot hens vilje eller ønske",
      "translation": "make someone do something against their will or desire",
      "examples": []
    },
    {
      "text": "bruke tvang",
      "translation": "use coercion",
      "examples": []
    },
    {
      "text": "jamfør tvingende og tvungen",
      "translation": "coercive and forced",
      "examples": [
        "tvinge barna til å spise opp",
        "forholdene tvang landsungdommen til byene",
        "hun tvang seg til å le"
      ]
    },
    {
      "text": "få fram et resultat ved å bruke makt eller pressmidler",
      "translation": "achieve a result by using force or pressure",
      "examples": [
        "tvinge fram et svar",
        "de tvang avgjørelsen gjennom",
        "de tvinger folk til å tilstå"
      ]
    }
  ]
