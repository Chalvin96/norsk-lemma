  "cross_reference": null,
  "definitions": [
    {
      "text": "jevnt fordelt tyngde i ett eller flere legemer i forhold til et midtpunkt",
      "translation": "evenly distributed weight in one or more bodies in relation to a center point",
      "examples": [
        "de to gjenstandene er i likevekt når vektstanga er vannrett"
      ]
    },
    {
      "text": "det at to eller flere aspekter er tilpasset hverandre i styrke, makt eller påvirkning",
      "translation": "the state of two or more aspects being adapted to each other in strength, power, or influence",
      "examples": [
        "forstyrre likevekten i naturen ved å utrydde en dyreart",
        "likevekten mellom regjering og storting"
      ]
    },
    {
      "text": "indre ro, harmoni",
      "translation": "inner peace, harmony",
      "examples": [
        "bringe en person ut av likevekt",
        "hun mister likevekten når hun blir sint"
      ]
    },
    {
      "text": "i språkvitenskap: det at trykket i et ord er (omtrent) like sterkt på to (korte) stavelser",
      "translation": "in : the pressure in a word being (approximately) equally strong on two (short) syllables",
      "examples": []
    }
  ]
