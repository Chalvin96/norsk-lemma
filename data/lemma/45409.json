    {
      "text": "magnetisere et metallstykke slik at det får magnetiske poler",
      "translation": "magnetize a piece of metal so that it has magnetic poles",
      "examples": []
    },
    {
      "text": "lage spenningsforskjell for eksempel i galvanisk elementer eller elektrolytisk celler",
      "translation": "create a voltage difference in galvanic elements or electrolytic cells",
      "examples": []
    },
    {
      "text": "bryte eller reflektere elektromagnetisk bølger (for eksempel lysstråler) på en viss måte",
      "translation": "refract or reflect electromagnetic waves (light rays) in a specific way",
      "examples": [
        "briller med polariserte glass"
      ]
    },
    {
      "text": "i overført betydning: legge vekt på motsetninger og ulikheter slik at ytterliggående synsmåter får større tilslutning",
      "translation": "emphasize contradictions and differences so that extreme viewpoints gain more support",
      "examples": [
        "partiet er polarisert i en høyrefløy og en venstrefløy",
