  "definitions": [
    {
      "text": "hjul som settes i bevegelse av kraftkilde kraftkjelde i et maskineri, og som ofte overfører kraft til andre hjul",
      "translation": "wheel that is set in motion by a power source in a machine, and which often transmits power to other wheels",
      "examples": [
        "ha kjetting på drivhjulene på traileren",
        "det var drivhjulet på den nederste delen av skiheisen som løsnet"
      ]
    },
    {
      "text": "i overført betydning: det som får noe til å skje eller noen til å handle på en bestemt måte",
      "translation": "in a figurative sense: that which causes something to happen or someone to act in a certain way",
      "examples": []
    },
    {
      "text": "person som får ting til å skje",
      "translation": "person who makes things happen",
      "examples": []
    },
    {
      "text": "drivkraft, drivfjær drivfjør",
      "translation": "driving force, mainspring",
      "examples": [
        "oljen har vært drivhjulet i norsk økonomi"
      ]
