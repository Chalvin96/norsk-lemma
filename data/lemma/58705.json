  "definitions": [
    {
      "text": "brenne noe lett (i overflaten) så det får skade",
      "translation": "to burn something lightly (on the surface) so it gets damaged",
      "examples": [
        "svi håret sitt",
        "svi fingertuppene på ovnen",
        "gloa svidde hull i duken",
        "sola svidde avlingen"
      ]
    },
    {
      "text": "brenne inn (et merke)",
      "translation": "to burn in (a mark)",
      "examples": [
        "elevene får svi navnet sitt på et tresykke"
      ]
    },
    {
      "text": "koke så det danner seg skorper",
      "translation": "to boil so that a crust forms",
      "examples": [
        "han har svidd grøten"
      ]
    }
  ]
