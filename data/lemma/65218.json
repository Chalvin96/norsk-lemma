  "definitions": [
    {
      "text": "på eller ved utsiden av hus, bygning eller lignende",
      "translation": "on the outside of a house, building",
      "examples": []
    },
    {
      "text": "bortenfor eller på andre siden av et avgrenset område",
      "translation": "beyond or on the other side of a defined area",
      "examples": []
    },
    {
      "text": "ikke innenfor",
      "translation": "not inside",
      "examples": [
        "de ventet utenfor huset",
        "være utenfor rekkevidde",
        "stå utenfor porten",
        "arbeide utenfor kommunen",
        "livet utenfor fensgelsmurene"
      ]
    },
    {
      "text": "i overført betydning: bortenfor eller på andre siden av et område, felt, tema og lignende",
      "translation": "beyond or on the other side of an area, field, topic",
      "examples": [
        "utenfor fare",
        "hun talte fullstendig utenfor manus",
        "pasienten er utenfor livsfare",
        "barn utenfor ekteskap"
      ]
    },
    {
      "text": "uten tilhørighet eller deltakelse i en gruppe",
      "translation": "without belonging to or participating in a group",
      "examples": []
    },
    {
      "text": "ikke med i",
      "translation": "not part of",
      "examples": [
        "stå utenfor NATO",
        "falle utenfor arbeidsmarkedet"
      ]
    },
    {
      "text": "brukt som adverb: på utsiden",
      "translation": "on the outside",
      "examples": [
        "bli med utenfor",
        "utenfor skinte sola"
      ]
    }
  ]
