  "definitions": [
    {
      "text": "(stillere) strøm (i elv eller større bekk) som på grunn av naturlig hindring skjærer ut fra hovedstrømmen og bøyer tilbake",
      "translation": "(calmer) current (in a river or larger stream) that, due to a natural obstacle, cuts away from the main current and bends back",
      "examples": [
        "båten ble liggende i en bakevje"
