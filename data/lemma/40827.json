  "definitions": [
    {
      "text": "gjøre en kort og rask bøyning med hodet, særlig som tegn på samtykke, oppmuntring eller som hilsen",
      "translation": "to make a short, quick bend of the head, especially as a sign of agreement, encouragement, or greeting",
      "examples": [
        "hun nikket bekreftende",
        "han nikket så vidt god dag",
        "jeg var så trøtt at jeg satt og nikket",
        "blomstene nikker i vinden"
      ]
    },
    {
      "text": "i fotball: spille ballen med hodet",
      "translation": "in football: to play the ball with the head",
      "examples": [
        "nikke ballen i mål",
        "han nikket til motstanderen i ansiktet"
      ]
    }
  ]
