  "definitions": [
    {
      "text": "salt, vannklar dråpe som skilles ut av tårekjertelen, og som renner ut av øyet ved sinnsbevegelser eller fysiske påkjenninger",
      "translation": "salty, clear drop secreted by the tear gland, which runs out of the eye due to emotional or physical strain",
      "examples": [
        "han bestemte seg til å tørke tårene",
        "de hang i så snørr og tårer rant",
        "de ble rørt til tårer over all hjelpsomheten",
        "hun slo seg så tårene spratt",
        "han lo så tårene trillet",
        "hun fikk tårer i øynene av medlidenhet",
        "han felte mange tårer på grunn av henne",
        "felle tårer over noe",
        "hun så på det med tårer i øynene",
        "øynene hans ble fylt av tårer"
      ]
    },
