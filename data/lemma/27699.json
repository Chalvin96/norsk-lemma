  "definitions": [
    {
      "text": "hvert av to døgn i året da natt og dag er like lange",
      "translation": "each of two days of the year when night and day are of equal length",
      "examples": []
    },
    {
      "text": "jamfør høstjevndøgn høstjamdøgn og vårjevndøgn vårjamdøgn",
      "translation": "autumn equinox and spring equinox",
      "examples": []
    },
    {
      "text": "helt døgn",
      "translation": "full day",
      "examples": [
        "ligge værfast i fem jevndøgn"
      ]
    }
  ]
