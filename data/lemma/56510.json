  "definitions": [
    {
      "text": "vende seg til noen for å få avklart noe som er uvisst",
      "translation": "turn to someone to clarify something uncertain",
      "examples": [
        "\"hva gjør du?\" spør han",
        "hun spurte om veien",
        "han har spurt om planene våre"
      ]
    },
    {
      "text": "be om informasjon, mening, råd, tillatelse eller lignende",
      "translation": "ask for information, opinion, advice, permission",
      "examples": [
        "han spør om hjelp",
        "hun spurte om han kunne gå fra bordet",
        "han måtte spørre sjefen om fri",
        "spør du meg, er dette den beste plata noensinne"
      ]
    },
    {
      "text": "stille spørsmål ved eksamen eller lignende",
      "translation": "ask questions on an exam",
      "examples": [
        "han ble spurt om unionsoppløsningen til eksamen",
        "læreren spør alle i leksa"
      ]
    }
