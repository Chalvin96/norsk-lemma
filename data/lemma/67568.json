  "definitions": [
    {
      "text": "sette i bevegelse rundt en (tenkt) akse slik at en annen side kommer fram eller opp",
      "translation": "",
      "examples": []
    },
    {
      "text": "snu, dreie",
      "translation": "",
      "examples": [
        "vende høyet",
        "vende seg langsomt rundt",
        "vende blikket oppover",
        "vende ansiktet mot noen",
        "de vendte seg mot henne og smilte",
        "vende på hodet",
        "han vendte seg bort"
      ]
    },
    {
      "text": "ta en ny retning",
      "translation": "",
      "examples": [
        "vende kursen sørover",
        "vende og gå tilbake",
        "det lønner seg å vende i tide"
      ]
    },
    {
      "text": "peke i en viss retning",
      "translation": "",
      "examples": [
        "rommet vender ut mot sjøen",
        "vende håndflatene oppover",
        "vende våpenet mot noen",
        "stolene stod vendt mot scenen"
      ]
    },
    {
      "text": "forflytte seg",
      "translation": "",
      "examples": []
    },
    {
      "text": "reise, dra, komme",
      "translation": "",
      "examples": [
        "nå er det vel på tide å vende hjemover?",
        "trekkfuglene vender sørover om høsten"
      ]
    },
    {
      "text": "få til å endre seg",
      "translation": "",
      "examples": []
    },
    {
      "text": "snu til det bedre",
      "translation": "",
      "examples": [
        "vende en negativ utvikling",
        "vende kampen til seier"
      ]
    },
    {
      "text": "sikte inn",
      "translation": "",
