    {
      "text": "stenge ute eller nekte deltakelse i noe",
      "translation": "to shut out or deny participation in something",
      "examples": [
        "mange kvinner er utelukket fra yrkeslivet",
        "bli utelukket fra foreningen"
      ]
    },
    {
      "text": "regne som umulig",
      "translation": "to consider impossible",
