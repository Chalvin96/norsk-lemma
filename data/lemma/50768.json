  "cross_reference": null,
  "definitions": [
    {
      "text": "(skudd i) børse som er satt opp med snor til avtrekkeren som løsner skuddet når noen (for eksempel et dyr eller en tyv) kommer borti den",
      "translation": "(shot from) a rifle set up with a string to the trigger that fires the shot when someone (an animal or a thief) touches it",
      "examples": [
        "legge ut selvskudd",
        "bli drept av selvskudd"
      ]
    }
