  "definitions": [
    {
      "text": "lage ost ved å varme opp og syrne melk slik at ostestoffet skiller seg ut",
      "translation": "to make cheese by heating and souring milk so that the casein separates",
      "examples": [
        "det er blitt ystet og lagret mang en ost ved ysteriet"
      ]
    },
    {
      "text": "koke inn myse-, melke- eller fløteblandinger og slik få fram visse slag brunost",
      "translation": "to boil down whey, milk, or cream mixtures to produce certain types of brown cheese",
