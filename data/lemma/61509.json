  "cross_reference": null,
  "definitions": [
    {
      "text": "ha den høyeste eller beste rangeringen",
      "translation": "to have the highest or best ranking",
      "examples": [
        "etter siste serieomgang topper Brann tabellen",
        "desember topper listen når det er flest branner i landet",
        "han toppet listen over de rikeste i landet"
      ]
    },
    {
      "text": "overgå, slå",
      "translation": "to surpass, to beat",
      "examples": []
    },
    {
      "text": "være bedre enn",
      "translation": "to be better than",
      "examples": [
        "denne bragden kan vi vanskelig toppe"
      ]
    },
    {
      "text": "lage en topp på",
      "translation": "to make a top on",
      "examples": []
    },
    {
      "text": "plassere øverst",
      "translation": "to place at the top",
      "examples": [
        "topp kaken med friske bær",
        "salaten var toppet med valnøtter"
      ]
    },
    {
      "text": "lage eller utvikle topp eller aks",
      "translation": "to form or develop a top or shoot",
      "examples": [
        "treet topper seg",
        "knip av de øverste skuddene slik at planten topper seg bedre"
      ]
    },
    {
      "text": "fjerne eller hogge toppen av",
      "translation": "to remove or cut off the top of",
      "examples": [
        "toppe et tre"
      ]
    }
  ]
