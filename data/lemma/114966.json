  "definitions": [
    {
      "text": "bil som følger ett eller flere andre kjøretøy for å vise vei eller gi økt sikkerhet",
      "translation": "car that follows one or more other vehicles to show the way or provide increased safety",
      "examples": [
        "en følgebil kjørte foran med advarsel om bred last"
      ]
    },
    {
      "text": "bil med personer som følger en idrettsutøver, særlig syklist, for å bistå med veiledning, utstyr eller lignende",
      "translation": "car with people following an athlete, especially a cyclist, to assist with guidance, equipment, or similar",
      "examples": [
        "bagasjen fraktes i følgebil"
      ]
    }
  ]
