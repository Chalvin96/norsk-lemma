  "definitions": [
    {
      "text": "om luft: være i strømmende bevegelse",
      "translation": "of air: to be in flowing movement",
      "examples": [
        "blåse friskt",
        "det blåser fra havet",
        "vinden blåser mot land"
      ]
    },
    {
      "text": "om vind: få noe til å velte eller til å fare gjennom lufta",
      "translation": "of wind: to cause something to overturn or fly through the air",
      "examples": [
        "vindkastet blåste bussen av veien"
      ]
    },
    {
      "text": "bli ført av vinden eller en annen luftstrøm",
      "translation": "to be carried by the wind or another air current",
      "examples": [
        "hatten blåste på sjøen",
        "taket blåste av huset"
      ]
    },
    {
      "text": "puste ut gjennom munn eller nesebor",
      "translation": "to exhale through the mouth or nostrils",
      "examples": [
        "oksen blåste i nesen",
        "blåse sigarrøyk ut i rommet",
        "han bare blåste av det jeg sa"
      ]
    },
    {
      "text": "frambringe toner eller lydsignaler ved å puste luft i musikkinstrument eller annen innretning",
      "translation": "to produce tones or sound signals by blowing air into a musical instrument or other device",
      "examples": [
        "blåse på horn",
        "dommeren blåste i fløyta",
        "blåse en solo"
      ]
    },
    {
      "text": "lage noe ved å la luftstrøm forme en flytende masse",
      "translation": "to make something by letting an air current shape a liquid mass",
      "examples": [
        "blåse såpebobler",
        "blåse glass"
      ]
    },
    {
      "text": "sende ut luftstrøm med et redskap eller annen innretning",
      "translation": "to send out an air current with a tool or other device",
      "examples": [
        "blåse håret tørt med føner"
      ]
    }
  ]
}
