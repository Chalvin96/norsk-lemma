  "definitions": [
    {
      "text": "skylle i kokende vann for å løsne hår, skall og lignende",
      "translation": "to rinse in boiling water to loosen hair, skin",
      "examples": [
        "hun skåldet griselabbene",
        "skålde tomatene for å fjerne skinnet",
        "skåldede mandler"
      ]
    },
    {
      "text": "forbrenne seg på kokende vann, vanndamp eller lignende",
      "translation": "to burn oneself on boiling water, steam",
      "examples": [
        "pass deg så du ikke blir skåldet i dusjen"
      ]
    }
  ]
