  "definitions": [
    {
      "text": "sige eller gli nedover",
      "translation": "to sink or slide down",
      "examples": [
        "hjulene sank ned i søla",
        "grumset synker til bunns",
        "synke dypt ned i sofaen",
        "båten sprang lekk og sank"
      ]
    },
    {
      "text": "bli lavere",
      "translation": "to become lower",
      "examples": [
        "priser og lønninger sank",
        "nivået har sunket betraktelig",
        "temperaturen synker",
        "sangen steg og sank",
        "synkende temperaturer"
      ]
    },
    {
      "text": "sige sammen",
      "translation": "to sink down",
      "examples": []
    },
    {
      "text": "falle, segne",
      "translation": "to fall, to collapse",
      "examples": [
        "synke sammen",
        "synke i kne",
        "byggverket sank i grus"
      ]
    },
    {
      "text": "gli inn eller trenge seg dypt inn",
      "translation": "to slide in, to penetrate deeply",
      "examples": [
        "kniven sank inn i ryggen hans"
      ]
    },
    {
      "text": "fortape seg",
      "translation": "to lose oneself",
      "examples": [
