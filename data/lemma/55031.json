  "definitions": [
    {
      "text": "prate, samtale",
      "translation": "to chat, converse",
      "examples": []
    },
    {
      "text": "jamfør snakkes",
      "translation": "to talk together",
      "examples": [
        "snakke med hverandre",
        "vi snakket sammen på telefon",
        "jeg snakker på vegne av flere",
        "snakke om andre ting",
        "det er ikke noe å snakke om",
        "vi har aldri snakket om det"
      ]
    },
    {
      "text": "skravle",
      "translation": "to chatter",
      "examples": [
        "snakke i ett kjør",
        "snakke seg fra noe",
        "han snakker i vei om hobbyen sin"
      ]
    },
    {
      "text": "bruke sin taleevne",
      "translation": "to use one's ability to speak",
      "examples": [
        "barnet kunne ikke snakke ennå",
        "snakke rent",
        "snakke russisk",
        "snakk høyere!"
      ]
    },
    {
      "text": "drøfte",
      "translation": "to discuss",
      "examples": [
        "snakke forretninger"
      ]
    },
    {
      "text": "sladre",
      "translation": "to gossip",
      "examples": [
        "de snakket om henne over hele byen"
      ]
    },
    {
      "text": "brukt i utrop om noe storartet",
      "translation": "used in an exclamation about something great",
      "examples": [
        "snakk om flaks!",
        "du snakker om flott forestilling!"
      ]
    }
  ]
