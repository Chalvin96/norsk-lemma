  "definitions": [
    {
      "text": "få noe til bruk en viss tid",
      "translation": "to get something for use for a certain time",
      "examples": [
        "låne penger",
        "låne bøker på biblioteket",
        "hun lånte bilen av moren sin"
      ]
    },
    {
      "text": "i overført betydning: hente eller ta opp i seg noe fra et annet sted eller et annet domene",
      "translation": "to fetch or take in something from another place or domain",
      "examples": [
        "ordet er lånt fra engelsk",
        "bandet låner elementer fra jazzen"
      ]
    },
    {
      "text": "i subtraksjon: forhøye sifferet en ønsker å subtrahere fra med ti, og samtidig forminske sifferet til venstre med én",
      "translation": "in subtraction: to increase the digit you want to subtract from by ten, and at the same time decrease the digit to the left by one",
      "examples": [
        "5 minus 9 går ikke, så vi må låne fra tallet foran"
      ]
    },
    {
      "text": "la noen få bruke noe en viss tid",
      "translation": "to let someone use something for a certain time",
      "examples": [
        "kan du låne meg en tier?",
        "hun lånte bort sykkelen sin",
        "bankene låner ut penger",
        "låne navnet sitt til et opprop"
      ]
    }
  ]
