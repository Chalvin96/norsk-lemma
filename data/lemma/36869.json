  "definitions": [
    {
      "text": "ikke ha, være uten, savne, trenge",
      "translation": "to not have, be without, miss, need",
      "examples": [
        "mangle mat",
        "mangle erfaring",
        "mangle retningssans",
        "hun manglet to poeng på å komme inn",
        "vertinnen sørget for at gjestene ikke manglet noe",
        "det skyldes manglende vilje"
      ]
    },
    {
      "text": "være borte, ikke finnes, skorte",
      "translation": "to be gone, not exist, be lacking",
      "examples": [
        "det mangler tre personer",
        "det mangler en skrue i motoren",
        "det manglet ikke på advarsler"
      ]
    },
    {
      "text": "være i veien med",
      "translation": "to be in the way of",
      "examples": [
        "det mangler henne ingenting"
