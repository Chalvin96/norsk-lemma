  "definitions": [
    {
      "text": "gi uttrykk for lattermild sinnsstemning ved å bevege munnvikene til side",
      "translation": "to express a cheerful mood by moving the corners of the mouth sideways",
      "examples": [
        "hun smiler til ham",
        "han smilte hånlig",
        "hun bare smilte av det",
        "hun er smilende og glad",
        "en smilende gutt"
      ]
    },
    {
      "text": "vise seg god og vennlig",
      "translation": "to appear good and friendly",
      "examples": [
        "lykken smiler til dem",
        "bygda lå der og smilte i sommerdagen"
      ]
    }
  ]
