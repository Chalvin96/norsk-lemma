  "definitions": [
    {
      "text": "i språkvitenskap: ending som danner en bøye form av ordet den står til, og som ikke virker inn på hvilken ordklasse ordet tilhører",
      "translation": "in linguistics: an ending that forms an inflected form of a word and does not change the word class",
      "examples": []
    },
    {
      "text": "til forskjell fra avledningsending avleiingsending",
      "translation": "inflectional ending",
      "examples": [
        "i ‘bygder’ er ‘er’ en bøyningsending"
      ]
