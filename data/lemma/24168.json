    {
      "text": "ta sats og sprette opp i eller gjennom lufta",
      "translation": "to leap up into the air",
      "examples": []
    },
    {
      "text": "bykse, jumpe",
      "translation": "to bound, to jump",
      "examples": [
        "hoppe over gjerdet",
        "hoppe ned fra en stein",
