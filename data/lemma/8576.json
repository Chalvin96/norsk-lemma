  "definitions": [
    {
      "text": "i språkvitenskap: endelse som danner en bøye form av ordet den står til, og som ikke virker inn på hvilken ordklasse ordet tilhører",
      "translation": "in linguistics: ending that forms an inflected form of a word to which it is attached, and which does not affect the word class of the word",
      "examples": []
    },
