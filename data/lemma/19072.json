    {
      "text": "åpne munnen",
      "translation": "to open one's mouth",
      "examples": []
    },
    {
      "text": "ha munnen vidåpen",
      "translation": "to have one's mouth wide open",
      "examples": [
        "gap opp!",
        "gape kjeven av ledd",
        "barnet gaper høyt når det får grøt"
      ]
    },
    {
      "text": "stirre dumt eller forundret (med åpen munn)",
      "translation": "to stare stupidly or in amazement (with an open mouth)",
      "examples": [
        "han ble sittende og gape"
      ]
    },
    {
      "text": "rope, skråle",
      "translation": "to shout, yell",
      "examples": [
        "gå rundt og gape og kjefte",
        "fylliker som gapte og sang"
      ]
    },
    {
      "text": "være vidåpen",
      "translation": "to be wide open",
      "examples": []
    },
    {
      "text": "sprike",
      "translation": "to gape, be wide open",
      "examples": [
        "hullet gapte imot henne",
