  "cross_reference": null,
  "definitions": [
    {
      "text": "det å få et stoff til å blande seg med et annet stoff, slik at blandingen blir ensartet",
      "translation": "the act of causing a substance to mix with another substance, so that the mixture becomes uniform",
      "examples": [
        "oppløsningen av salt i vann skjer ganske raskt"
      ]
    },
    {
      "text": "det å få noe til å skille seg i ulike bestanddeler",
      "translation": "the act of causing something to separate into different components",
      "examples": []
    },
    {
      "text": "oppsplitting, dekomponering",
      "translation": "splitting up, decomposition",
      "examples": [
        "en tid med moralsk oppløsning"
      ]
    },
    {
      "text": "om fotografi, optisk instrument eller datagrafikk: mål på skarphet eller evne til å gjengi detaljer",
      "translation": "regarding photography, optical instrument, computer graphics: measure of sharpness, ability to reproduce details",
      "examples": [
        "satellittbilder med høy oppløsning",
        "oppløsningen på bildet er avhengig av terminalskjermen"
      ]
