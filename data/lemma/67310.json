  "definitions": [
    {
      "text": "få til å våkne",
      "translation": "to cause to wake up",
      "examples": [
        "vekk meg klokka sju!",
        "vekke (opp) hele huset",
        "bli vekket av tordenvær",
        "vekke opp fra de døde"
      ]
    },
    {
      "text": "kalle til liv",
      "translation": "to bring to life",
      "examples": []
    },
    {
      "text": "få til å tenke seg om",
      "translation": "to make someone think",
      "examples": [
        "vekke til live gamle skikker",
        "vekke ens interesse for noe",
        "bli vakt",
        "vekke folk til ettertanke",
        "en vekkende tale"
      ]
    },
    {
      "text": "være årsak til, framkalle",
      "translation": "to be the cause of, to evoke",
      "examples": [
        "vekke anstøt, begeistring, interesse, mistanke, oppsikt, strid"
      ]
