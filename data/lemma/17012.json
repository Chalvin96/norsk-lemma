  "definitions": [
    {
      "text": "stilling for offiser, knyttet til et lands ambassade, som fungerer som en forbindelse mellom forsvar i hjemlandet og i landet han eller hun er i",
      "translation": "position for an officer attached to a country's embassy, serving as a liaison between the defense forces of the home country and the country to which they are assigned",
