    },
    {
      "text": "føre hardt mot eller ned i",
      "translation": "to move hard towards or down into",
      "examples": [
        "de drylte løs på hverandre",
        "få hodet drylt ned i asfalten",
        "dryle toalettveska ned i den fulle kofferten"
      ]
    },
    {
      "text": "bevege seg raskt",
      "translation": "to move quickly",
      "examples": [
