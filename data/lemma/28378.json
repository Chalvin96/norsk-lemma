  "definitions": [
    {
      "text": "føde kalv",
      "translation": "to give birth to a calf",
      "examples": [
        "kua som skal kalve, blir satt i egen binge",
        "i mai skal reinen kalve"
      ]
    },
    {
      "text": "om isfjell eller bre: briste slik at større stykker faller av",
      "translation": "of an iceberg or glacier: to break off in large pieces",
      "examples": [
        "plutselig kan et isfjell kalve"
      ]
    },
    {
      "text": "kantre, velte",
      "translation": "to capsize, to overturn",
      "examples": [
        "han kalvet og slo seg"
      ]
    }
