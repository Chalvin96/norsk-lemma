  "definitions": [
    {
      "text": "åndelig kraft hos et menneske som gjør at det kan tenke, føle og ville",
      "translation": "spiritual power in a human that enables them to think, feel, and will",
      "examples": [
        "få ro i sjelen",
        "legge hele sin sjel i noe"
      ]
    },
    {
      "text": "åndelig del av et menneske sett ut fra et religiøst synspunkt eller i forhold til Gud, og som blir regnet for å være udødelig",
      "translation": "spiritual part of a human seen from a religious viewpoint in relation to God, and considered to be immortal",
      "examples": [
        "be for sin sjels frelse",
        "sverge ved sin sjels salighet"
      ]
    },
    {
      "text": "person eller produkt som får i gang noe (handling eller følelser)",
      "translation": "person or product that initiates something (action or feelings)",
      "examples": [
        "være sjelen i et foretakende",
        "diktene hans mangler sjel"
      ]
    },
    {
      "text": "menneske, individ",
      "translation": "person, individual",
      "examples": [
        "være en enkel sjel",
        "jeg har ikke fortalt en sjel om dette"
      ]
    }
  ]
