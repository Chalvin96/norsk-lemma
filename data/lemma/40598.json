  "definitions": [
    {
      "text": "brukt som uttrykk for at en nekter, avslår, avviser eller protesterer mot noe",
      "translation": "used to express refusal, rejection, or protest",
      "examples": [
        "nei takk!",
        "nei, det er ikke sant",
        "nei, det vil jeg ikke",
        "kommer du? – Nei"
      ]
    },
    {
      "text": "brukt som innledning til en vending når en snakker, eller for å motsi noe som har gått forut",
      "translation": "used to introduce a statement that contradicts something previously said",
      "examples": [
        "nei, da var det bedre før i tiden",
        "nei, nå får det være nok!"
      ]
    },
    {
      "text": "brukt i uttrykk for resignasjon",
      "translation": "used to express resignation",
      "examples": [
        "nei nei, når det ikke nytter, så"
      ]
    },
    {
      "text": "brukt i påminning",
      "translation": "used as a reminder",
      "examples": [
        "nei, nå må vi gå"
      ]
    },
    {
      "text": "brukt sist i en setning for å ta opp igjen en nekting:",
      "translation": "used at the end of a sentence to reiterate a refusal",
      "examples": [
        "det stod ikke bra til, nei"
      ]
    },
    {
      "text": "brukt i utrop og følelsesutbrudd",
      "translation": "used in exclamations and emotional outbursts",
      "examples": [
        "nei så menn om jeg vil!",
        "nei, så fin den var!",
        "nei og nei, det var da trist!"
      ]
    }
