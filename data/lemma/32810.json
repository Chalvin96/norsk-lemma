  "definitions": [
    {
      "text": "rom for passasjerer i jernbanevogn, trikk eller bil",
      "translation": "compartment for passengers in a train carriage, tram, or car",
      "examples": [
        "bilen har en rommelig kupé",
        "kupeen var trang og røykfylt"
      ]
    },
    {
      "text": "lukket personbil som skråner bakover med to eller fire seter og (ofte) to dører, mindre enn en sedan",
      "translation": "closed passenger car that slopes backward with two or four seats and (often) two doors, smaller than a sedan",
      "examples": []
    },
