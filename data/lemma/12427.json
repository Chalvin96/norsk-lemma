  "definitions": [
    {
      "text": "sideordnende, disjunktiv konjunksjon",
      "translation": "coordinating, disjunctive conjunction",
      "examples": []
    },
    {
      "text": "brukt for å sideordne to ledd som gjensidig utelukker hverandre (eksklusiv disjunksjon):",
      "translation": "used to coordinate two elements that mutually exclude each other (exclusive disjunction)",
      "examples": [
        "verken – eller",
        "enten – eller",
        "vær stille, eller så ...",
        "et være eller ikke være",
        "nå eller aldri",
        "pengene eller livet"
      ]
    },
    {
      "text": "brukt for å sideordne to ledd som ikke gjensidig utelukker hverandre (inklusiv disjunksjon):",
      "translation": "used to coordinate two elements that do not mutually exclude each other (inclusive disjunction)",
      "examples": [
        "bruk en knapp eller lignende",
        "lite eller ingenting",
        "få eller ingen",
        "mer eller mindre gjennomtenkt",
        "av en eller annen merkelig grunn"
      ]
    },
    {
      "text": "brukt for å binde sammen ledd som betyr det samme:",
      "translation": "used to connect elements that mean the same thing",
      "examples": [
        "Bibelen eller Den hellige skrift",
        "ingen hvisking eller tisking"
      ]
    }
