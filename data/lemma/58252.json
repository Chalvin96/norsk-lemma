  "definitions": [
    {
      "text": "dra inn gjennom munn eller nese",
      "translation": "draw in through the mouth or nose",
      "examples": [
        "suge på pipa",
        "suge inn lukten av vår",
        "mange rovdyr suger blodet av byttet sitt"
      ]
    },
    {
      "text": "smatte, slikke",
      "translation": "smack, lick",
      "examples": [
        "suge på drops"
      ]
    },
    {
      "text": "trekke til seg",
      "translation": "absorb",
      "examples": [
        "pumpa suger ikke som den skal",
        "støvsugeren suger godt",
        "mattene suger opp all fuktighet",
        "Oslo-gryta har sugd til seg folk fra hele landet",
        "suge i seg hvert ord",
        "suge til seg kunnskap"
      ]
    },
    {
      "text": "verke, rive",
      "translation": "ache, tear",
