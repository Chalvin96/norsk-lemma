  "definitions": [
    {
      "text": "åndelig opplevelse der en person er nær ved å dø og har minner fra opplevelsen",
      "translation": "spiritual experience where a person is close to death and has memories from the experience",
      "examples": [
        "under nær-døden-opplevelsen så hun bestefaren komme mot henne omgitt av et hvitt lys"
      ]
    },
    {
      "text": "følelse av å være nær ved å dø, for eksempel ved en ulykke eller nestenulykke",
      "translation": "feeling of being close to death, due to an accident or near-accident",
      "examples": []
    },
    {
      "text": "farefull eller nervepirrende opplevelse",
      "translation": "dangerous or nerve-wracking experience",
      "examples": [
        "toppturen var en rekke av adrenalinkick og nær-døden-opplevelser",
        "mange har hatt en nær-døden-opplevelse på denne rasutsatte strekningen"
      ]
    },
    {
      "text": "i overført betydning: det at en organisasjon, institusjon eller lignende står i fare for å forsvinne eller bli nedlagt",
      "translation": "the fact that an organization, institution is in danger of disappearing or being closed down",
      "examples": [
        "utestedet hadde en nær-døden-opplevelse, men har nå blitt populært igjen"
      ]
    }
  ]
