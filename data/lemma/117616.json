  "definitions": [
    {
      "text": "innretning til å låse hjul med for å hindre kjøretøy i å kjøre",
      "translation": "device for locking wheels to prevent a vehicle from moving",
      "examples": [
        "Statens vegvesen setter hjullås på vogntoget, slik at ikke sjåføren kan kjøre videre"
      ]
    },
    {
      "text": "om eldre forhold: låsmekanisme på håndskytevåpen der avtrekket løser ut en fjær som setter et riflete hjul eller en trinse i bevegelse som så roterer mot et svovelkisstykke i hanen slik at friksjonen fører til gnister som tenner fengkruttet",
      "translation": "in older contexts: locking mechanism on a handgun where the trigger releases a spring that sets a grooved wheel in motion, which then rotates against a pyrite piece in the hammer, causing friction to create sparks that ignite the priming powder",
      "examples": []
    }
  ]
