  "definitions": [
    {
      "text": "overnaturlig vesen som har makt over naturen og menneskene (og som blir æret og tilbedt)",
      "translation": "supernatural being with power over nature and humans (and who is honored and worshipped)",
      "examples": [
        "Olympens guder",
        "romerske guder",
        "de norrøne gudene"
      ]
    },
    {
      "text": "(brukt som egennavn) i monoteistisk religioner, særlig kristendommen: allmektig skaper som rår over verden og menneskene",
      "translation": "(used as a proper noun) in monotheistic religions, especially Christianity: almighty creator who rules over the world and humans",
      "examples": []
    },
    {
      "text": "personliggjort åndelig kraft som mennesker ber til",
      "translation": "personified spiritual power to which humans pray",
      "examples": [
        "tro på Gud",
        "be til Gud",
        "takke og prise Gud",
        "i Guds navn",
        "Guds rike er nær",
        "troen på Jesus som Guds sønn",
        "Gud skapte himmelen og jorden",
        "lære at alle mennesker er Guds barn"
      ]
    },
    {
      "text": "brukt i utrop og andre mer eller mindre faste uttrykk",
      "translation": "used in exclamations and other more or less fixed expressions",
      "examples": [
        "gud hjelpe meg",
        "å gud, som du skremte meg",
        "du gode gud for en bok",
        "det er et guds under at ingen ble skadd",
        "det var en guds lykke at det ikke gikk verre"
      ]
    }
  ]
