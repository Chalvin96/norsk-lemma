  "definitions": [
    {
      "text": "som er bestemt eller avhengig av en eller flere faktorer",
      "translation": "determined or dependent on one or more factors",
      "examples": [
        "forståelsen er historisk betinget",
        "humoren er kulturelt betinget"
      ]
    },
    {
      "text": "som det er knyttet visse forbehold eller begrensninger til",
      "translation": "to which certain reservations or limitations are attached",
      "examples": [
        "være betinget optimist foran sesongen",
        "forestillingen fikk en betinget suksess",
        "få betinget ros"
      ]
    }
