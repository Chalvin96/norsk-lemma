  "definitions": [
    {
      "text": "ligge i bevisstløs hviletilstand",
      "translation": "to lie in an unconscious state of rest",
      "examples": []
    },
    {
      "text": "ligge i søvn",
      "translation": "to lie in sleep",
      "examples": []
    },
    {
      "text": "motsatt våke vake",
      "translation": "to be awake",
      "examples": [
        "vi sov lenge i morges",
        "har du ikke sovet i natt?",
        "jeg fikk ikke sove i natt",
        "ungene sitter og sover i baksetet",
        "sov godt!"
      ]
    },
    {
      "text": "være sløv eller uoppmerksom",
      "translation": "to be sluggish or inattentive",
      "examples": []
    },
    {
      "text": "følge dårlig med",
      "translation": "to follow poorly",
      "examples": [
        "sitte og sove i timene"
      ]
    },
    {
      "text": "ikke være i bruk",
      "translation": "to not be in use",
      "examples": [
