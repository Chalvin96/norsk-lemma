  "definitions": [
    {
      "text": "berøre noe eller noen med leppene som uttrykk for kjærlighet, ærbødighet, vennskap eller lignende",
      "translation": "to touch something or someone with the lips as an expression of love, reverence, friendship",
      "examples": [
        "kysse hverandre til farvel",
        "kysse vertinnen på hånden",
        "kysse et helgenbilde",
        "kysse og kline"
      ]
    },
    {
      "text": "brukt for å uttrykke forakt",
      "translation": "used to express contempt",
      "examples": [
        "kyss meg bak!",
        "kyss meg i ræva!",
        "kyss meg på mandag!"
      ]
    }
  ]
