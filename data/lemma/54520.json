  "cross_reference": null,
  "definitions": [
    {
      "text": "få til å slokne slukne",
      "translation": "to cause to go out",
      "examples": [
        "slokke lyset",
        "hun slokker lampen",
        "de har slokket brannen",
        "de slokket bålet",
        "lykta slokker ikke ordentlig"
      ]
    },
    {
      "text": "få til å forsvinne",
      "translation": "to cause to disappear",
      "examples": [
        "slokke et håp"
      ]
    },
    {
      "text": "brukt som adjektiv: uten liv og glans",
      "translation": "used as: without life and luster",
      "examples": [
        "blikket var tomt og slokket"
      ]
    },
    {
      "text": "gjøre svakere eller mindre",
      "translation": "to weaken or lessen",
      "examples": []
    },
    {
      "text": "gjøre slutt på",
      "translation": "to put an end to",
      "examples": [
        "slokke tørsten",
        "prøve å slokke sine sorger med alkohol"
      ]
    }
  ]
}
