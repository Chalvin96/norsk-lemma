  "definitions": [
    {
      "text": "spre rykter og upålitelige historier",
      "translation": "to spread rumors and unreliable stories",
      "examples": []
    },
    {
      "text": "fare med sladder",
      "translation": "to engage in gossip",
      "examples": [
        "sladre om naboen"
      ]
    },
    {
      "text": "prate om dagligdagse emner",
      "translation": "to chat about everyday topics",
      "examples": [
        "sitte og sladre sammen",
        "de sladret over kaffen"
      ]
    },
    {
      "text": "fortelle, ofte til autoriteter, om ulovlige ting som andre har gjort og kan straffes for",
      "translation": "to tell, often to authorities, about illegal things that others have done and can be punished for",
      "examples": []
    },
    {
      "text": "angi, tyste",
      "translation": "to inform on, to snitch",
      "examples": [
        "sladre til politiet",
        "sladre på kameratene sine"
      ]
    },
    {
      "text": "fortelle om noe ukjent eller skjult",
      "translation": "to tell about something unknown or hidden",
      "examples": [
        "minen sladrer om at hun ikke vil ha noen spørsmål"
      ]
    }
  ]
