  "definitions": [
    {
      "text": "dyrke, vende seg til (og vise religiøs ærefrykt for) en gud eller et guddommelig vesen",
      "translation": "worship, turn to (and show religious awe for) a god or divine being",
      "examples": [
        "tilbe Faderen i ånd og sannhet",
        "tilbe hellige steiner"
      ]
    },
    {
      "text": "i overført betydning: være sterkt forelsket i, sverme for",
      "translation": "be strongly in love with, adore",
      "examples": [
        "tilbe en kvinne"
      ]
    }
  ]
