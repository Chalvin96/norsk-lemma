        "en krabbe med brunrødt skall"
      ]
    },
    {
      "text": "ytterste lag på frukt, frø eller grønnsak",
      "translation": "outer layer of fruit, seed, or vegetable",
      "examples": [
        "revet skall fra sitron",
        "små druer med tykt skall"
      ]
    },
    {
      "text": "hylster, lag",
      "translation": "casing, layer",
      "examples": [
        "et skall av betong"
      ]
    },
    {
      "text": "flak av noe hardt",
      "translation": "flake of something hard",
      "examples": [
        "slå et skall av tannen"
      ]
    },
    {
      "text": "i overført betydning: stengsel som beskytter mot omverdenen",
      "translation": "barrier protecting from the outside world",
      "examples": [
        "hun trakk seg inn i skallet sitt"
      ]
    },
    {
      "text": "i overført betydning: noe tomt, innholdsløst",
      "translation": "something empty, hollow",
      "examples": [
