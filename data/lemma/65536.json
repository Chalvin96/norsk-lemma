  "definitions": [
    {
      "text": "frigjøre, sette i virksomhet, la komme til uttrykk",
      "translation": "release, set in motion, let come to expression",
      "examples": [
        "eksperimentet utløste strømbrudd",
        "deflasjon utløser arbeidsledighet",
        "konkurransen var slutt og spenningen dermed utløst"
      ]
    },
    {
      "text": "få i gang eller være årsak til",
      "translation": "initiate or be the cause of",
      "examples": [
        "utløse krig",
        "forlaget utløste protester"
      ]
    },
    {
      "text": "få tilbake mot betaling",
      "translation": "redeem by payment",
      "examples": []
    },
    {
      "text": "løse ut eller løse inn",
      "translation": "redeem (something pawned)",
      "examples": [
        "utløse noe som er pantsatt"
      ]
    }
  ]
