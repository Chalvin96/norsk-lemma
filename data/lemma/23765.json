    {
      "text": "som hører til eller er karakteristisk for hjemstedet eller hjemlandet",
      "translation": "belonging to or characteristic of one's hometown or home country",
      "examples": [
        "vår hjemlige andedam",
        "jeg trives best under hjemlige forhold",
        "snakke sin hjemlige dialekt"
      ]
    },
    {
      "text": "som minner om hjemmet eller hjemstedet",
      "translation": "reminiscent of home or hometown",
      "examples": []
    },
    {
      "text": "som får en til å føle seg hjemme",
      "translation": "making one feel at home",
      "examples": []
    },
    {
      "text": "hyggelig, hjemmekoselig",
      "translation": "cozy, homely",
