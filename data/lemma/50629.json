  "definitions": [
    {
      "text": "står til et pronomen for å framheve at det nettopp er den pronomenet betegner, det er snakk om: personlig",
      "translation": "emphasizing that it is precisely the pronoun that is meant",
      "examples": [
        "han sa det selv",
        "selv stod de bare og så på",
        "der kan du se selv",
        "jeg tvilte ofte på meg selv",
        "du må spørre deg selv om det er dette du vil"
      ]
    },
    {
      "text": "står til et substantiv for å framheve at det nettopp er det substantivet betegner, det er snakk om: den virkelige eller egentlige",
      "translation": "emphasizing that it is precisely the noun that is meant: the real or actual",
      "examples": []
    },
    {
      "text": "den rette",
      "translation": "the right",
      "examples": [
        "selve gården er dårlig, men skogen er bra",
        "selve byen er ikke så stor",
        "selve grunnfjellet stikker opp"
      ]
    },
    {
      "text": "på egen hånd",
      "translation": "on one's own",
      "examples": []
    },
    {
      "text": "uten hjelp eller påvirkning utenfra",
      "translation": "without help or outside influence",
      "examples": [
        "han vil gjøre alt selv",
        "de har bygd huset helt selv"
      ]
    },
    {
      "text": "i egen person",
      "translation": "in person",
      "examples": [
        "er han selv hjemme?",
        "kongen selv var til stede",
        "jeg tror det var selve fanden",
        "hun er ærligheten selv"
      ]
    },
    {
      "text": "brukt som adverb: til og med",
      "translation": "used as: even",
      "examples": [
        "selv han ble redd",
        "alle, selv barna, var med",
        "selv for deg blir dette for mye"
      ]
    }
  ]
