  "definitions": [
    {
      "text": "yte hjelp, berge, redde",
      "translation": "provide help, save, rescue",
      "examples": [
        "de hjelper hverandre",
        "hjelpe til med gårdsarbeidet",
        "hjelpe folk i havsnød",
