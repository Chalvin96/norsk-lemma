    {
      "text": "ta på eller manøvrere med fingrene",
      "translation": "handle or manipulate with fingers",
      "examples": []
    },
    {
      "text": "fingre, plukke, fikle",
      "translation": "fiddle, tinker, play with",
      "examples": [
        "tukle med glidelåsen",
        "sitte og tukle med håret sitt"
      ]
    },
    {
      "text": "i overført betydning: forandre til det verre",
      "translation": "change for the worse",
      "examples": []
    },
    {
      "text": "forringe, ødelegge øydelegge",
      "translation": "spoil, ruin, damage",
      "examples": [
        "tukle med naturen",
        "dessverre ble lovverket tuklet med"
      ]
    },
    {
      "text": "beføle med en seksuell hensikt",
      "translation": "grope with sexual intent",
      "examples": []
    },
    {
      "text": "tafse, klå",
      "translation": "paw, grope",
