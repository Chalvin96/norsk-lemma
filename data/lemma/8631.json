  "definitions": [
    {
      "text": "bokstavtegn c",
      "translation": "letter sign c",
      "examples": []
    },
    {
      "text": "uttales som s foran i, y, æ, ø og med få unntak foran e og som k foran a, o, u og foran konsonant, unntatt h",
      "translation": "pronounced as s before i, y, æ, ø and with few exceptions before e, and as k before a, o, u and before consonants, except h",
      "examples": [
        "liten c",
        "stor C",
        "C er tredje bokstaven i alfabetet"
      ]
    },
    {
      "text": "(note for) første tone i C-durskalaen",
      "translation": "first tone in the C major scale",
      "examples": []
    },
    {
      "text": "jamfør C-dur og c-moll",
      "translation": "C major and C minor",
      "examples": [
        "lav c",
        "høy c",
        "trestrøken c"
      ]
    },
    {
      "text": "merke på at noe kommer som nummer tre",
      "translation": "mark that something comes as number three",
      "examples": [
        "oppgang C",
        "del C"
      ]
    },
    {
      "text": "tredje beste karakter ved høyskoler og universiteter (på en skala fra A til F)",
      "translation": "third best grade at colleges and universities (on a scale from A to F)",
      "examples": [
        "han fikk karakteren C"
      ]
    }
