  "cross_reference": null,
  "definitions": [
    {
      "text": "kontrollere og sørge for at en lov, en regel, et forbud eller lignende blir overholdt, eventuelt ved bruk av makt",
      "translation": "to control and ensure that a law, a rule, a prohibition is observed, possibly by the use of force",
      "examples": [
        "håndheve regelverket",
        "håndheve forbudet mot å bære kniv på offentlig sted",
        "håndheve rettighetene som følger av arbeidsmiljøloven"
      ]
    }
  ]
