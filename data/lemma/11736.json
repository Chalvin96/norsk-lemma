  "definitions": [
    {
      "text": "del av kapitalen i et foretak som tilhører eierne",
      "translation": "part of a company's capital belonging to the owners",
      "examples": [
        "bundet egenkapital",
        "bokført egenkapital"
      ]
    },
    {
      "text": "egne penger som kan finansiere (en del av) en større eiendel eller eiendom",
      "translation": "own money that can finance (part of) a larger asset or property",
      "examples": [
        "ha for lite egenkapital til å få boliglån"
      ]
    }
  ]
