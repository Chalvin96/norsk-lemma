  "definitions": [
    {
      "text": "tilføre kroppen væske gjennom munnen",
      "translation": "to supply the body with liquid through the mouth",
      "examples": [
        "drikke en kopp te",
        "jeg drikker aldri brus",
        "husk å drikke nok vann!",
        "snart har jeg drukket fem kopper kaffe",
        "hun drakk en liten slurk av flaska"
      ]
    },
    {
      "text": "nyte alkohol",
      "translation": "to consume alcohol",
      "examples": []
    },
    {
      "text": "misbruke alkohol",
      "translation": "to abuse alcohol",
      "examples": [
        "verken røyke eller drikke",
        "de var ute og drakk i går",
        "drikke seg full",
        "drikke seg til mot",
        "drikke med måte",
        "jeg skal aldri begynne å drikke igjen!"
      ]
    },
    {
      "text": "om eldre forhold: feire høytid eller merkedag med drikkelag",
      "translation": "in older contexts: to celebrate a holiday or anniversary with a drinking party",
      "examples": [
        "drikke jul",
        "drikke gravøl"
      ]
    },
    {
      "text": "suge til seg",
      "translation": "to absorb",
      "examples": [
        "drikke av visdommens brønn",
        "bilen drikker mye bensin"
      ]
    }
  ]
