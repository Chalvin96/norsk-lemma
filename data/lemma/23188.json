  "cross_reference": null,
  "definitions": [
    {
      "text": "få noe til å henge",
      "translation": "to cause something to hang",
      "examples": [
        "henge jakka på knaggen",
        "henge kniven i beltet",
        "de hengte opp bildene",
        "han har hengt opp klesvasken"
      ]
    },
    {
      "text": "ta livet av noen ved kvelning i et reip som henger ned",
      "translation": "to kill someone by strangulation with a rope that hangs down",
      "examples": [
        "henge den dødsdømte fangen"
      ]
    },
    {
      "text": "la del av kroppen henge eller gli ned",
      "translation": "to let part of the body hang or droop",
      "examples": []
    },
    {
      "text": "bøye ned",
      "translation": "to bend down",
      "examples": [
        "hesten henger hodet ned"
      ]
    },
    {
      "text": "feste noe",
      "translation": "to attach something",
      "examples": []
    },
    {
      "text": "gjøre fast",
      "translation": "to make fast",
      "examples": [
        "henge kroken på snøret"
      ]
    }
  ]
