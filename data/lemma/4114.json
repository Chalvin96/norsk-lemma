  "cross_reference": null,
  "definitions": [
    {
      "text": "(indre eller bakre) gårdsrom i en bygård",
      "translation": "(inner or rear) courtyard in a city building",
      "examples": [
        "leke i bakgården"
      ]
    },
    {
      "text": "bygning bak en annen bygning som ligger ut mot gata",
      "translation": "building behind another building facing the street",
      "examples": [
        "bo i bakgården"
      ]
    },
    {
      "text": "i overført betydning: lite attraktivt område",
      "translation": ": unattractive area",
      "examples": [
        "disse slumstrøkene er byens bakgård"
      ]
    },
    {
      "text": "i overført betydning: område som domineres av en rik og mektig stat",
      "translation": "in a figurative sense: area dominated by a rich and powerful state",
      "examples": [
        "Latin-Amerika omtales som USAs bakgård"
      ]
    }
