      ]
    },
    {
      "text": "floke",
      "translation": "tangle",
      "examples": [
        "skjorta var tullet sammen som en liten ball"
      ]
    },
    {
      "text": "handle dumt eller planløst",
      "translation": "act foolishly, aimlessly",
      "examples": []
    },
    {
      "text": "rote omkring, surre, vase",
      "translation": "mess around, potter, dawdle",
      "examples": [
        "jeg har bare gått og tullet på jobben i dag",
        "tulle seg bort i noe ulovlig"
      ]
    },
    {
      "text": "ta feil, si noe dumt",
      "translation": "be mistaken, say something foolish",
      "examples": [
        "nei, nå tuller jeg visst"
      ]
    },
    {
      "text": "ikke mene alvor",
      "translation": "not be serious",
      "examples": []
    },
    {
      "text": "tøyse, vase",
      "translation": "fool around, mess about",
      "examples": [
