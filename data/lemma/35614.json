  "definitions": [
    {
      "text": "det å måle dybde i sjø eller vann med loddline eller annen dybdemåler",
      "translation": "the act of measuring depth in the sea with a sounding line or other depth gauge",
      "examples": [
        "utstyr til lodding av store havdyp"
      ]
    },
    {
      "text": "det å søke etter fisk med lodd eller ekkolodd",
      "translation": "the act of searching for fish with a sounding lead or echo sounder",
      "examples": [
        "lodding etter sild og brisling"
      ]
    },
    {
      "text": "i overført betydning: det å danne seg et inntrykk av noe en ikke kan observere direkte",
      "translation": "the act of forming an impression of something that cannot be directly observed",
      "examples": [
        "lodding av stemningen"
      ]
    },
    {
      "text": "det å bruke loddline, laser eller annet for å sørge for at noe blir loddrett",
      "translation": "the act of using a sounding line, laser, or other device to ensure something is plumb",
      "examples": [
        "bruke laser til lodding"
      ]
    },
    {
      "text": "det å binde sammen to metallstykker med flytende metall",
      "translation": "the act of joining two metal pieces with molten metal",
      "examples": [
        "bruke tinn til lodding"
      ]
    },
    {
      "text": "sted der noe er lodde",
      "translation": "place where something is plumbed",
      "examples": [
        "gå opp i loddingen"
      ]
    }
  ]
