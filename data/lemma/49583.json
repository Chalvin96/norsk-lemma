  "cross_reference": null,
  "definitions": [
    {
      "text": "kampmetode ved arbeidskonflikter, under okkupasjon eller overfor en fiende, som består i å hindre produksjon og skape kaos og vansker ved for eksempel å sette ned arbeidstempoet eller ødelegge kommunikasjoner, bygninger eller lignende",
      "translation": "method of struggle in labor disputes, or against an enemy during occupation, consisting of hindering production and creating chaos and difficulties by slowing down the work pace, destroying communications, buildings",
      "examples": [
        "de utførte sabotasje mot strømforsyningen",
        "fabrikken er blitt utsatt for sabotasje"
      ]
    },
    {
      "text": "det å omgå eller ikke rette seg etter et påbud",
      "translation": "circumventing or not obeying an order",
      "examples": [
        "tenåringen driver sabotasje mot alle forsøk på å begrense skjermtiden"
      ]
    }
  ]
