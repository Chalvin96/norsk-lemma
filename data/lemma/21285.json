  "definitions": [
    {
      "text": "om visse dyr, særlig gris: gi fra seg korte strupelyder uten å åpne munnen",
      "translation": "of certain animals, especially pigs: to make short guttural sounds without opening the mouth",
      "examples": [
        "grisen grynter"
      ]
    },
    {
      "text": "om person: gi fra seg uartikulerte lyder for å uttrykke misnøye",
      "translation": "of a person: to make inarticulate sounds to express dissatisfaction",
      "examples": [
        "han bare gryntet til svar"
      ]
    }
  ]
