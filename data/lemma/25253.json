  "definitions": [
    {
      "text": "som når et langt stykke oppover (i vertikal retning)",
      "translation": "reaching far upwards (in a vertical direction)",
      "examples": []
    },
    {
      "text": "som har stor høyde høgde",
      "translation": "having great height",
      "examples": [
        "et høyt gjerde",
        "høye bølger",
        "han er høyere enn henne",
        "verdens høyeste fjell",
        "treet er 10 m høyt",
        "hoppe høyt av glede"
      ]
    },
    {
      "text": "som er langt oppe, i stor vertikal avstand oppover (sett eller regnet fra et visst nivå)",
      "translation": "located far up, at a great vertical distance upwards (seen or calculated from a certain level)",
      "examples": [
        "et høyt punkt",
        "sola står høyt på himmelen",
        "høyt oppe på veggen",
        "høyt henger de og sure er de, sa reven om rognebærene"
      ]
    },
    {
      "text": "som ligger langt oppe på en tenkt eller eksisterende skala",
      "translation": "located far up on an imagined or existing scale",
      "examples": []
    },
    {
      "text": "tallmessig stor eller betydelig",
      "translation": "numerically large or significant",
      "examples": [
        "høy temperatur",
        "høy kvalitet",
        "høye utgifter",
        "nå en høy alder",
        "ha høyt blodtrykk",
        "et høyt nummer",
        "være høyt begavet"
      ]
    },
    {
      "text": "om lyd: som ligger langt oppe på toneskalaen",
      "translation": "of sound: located far up on the musical scale",
      "examples": [
        "en høy tone"
      ]
    },
    {
      "text": "om lyd: sterk, kraftig",
      "translation": "of sound: loud, strong",
      "examples": [
        "høy musikk",
        "snakke med høy stemme",
        "lese høyt",
        "rope høyt om hjelp"
      ]
    },
    {
      "text": "med rang eller posisjon over andre",
      "translation": "having rank or position above others",
      "examples": [
        "ha høy rang",
        "ha et høyt verv i organisasjonen",
        "ha høye tanker om seg selv"
      ]
    },
    {
      "text": "ruset av narkotisk stoff, særlig hallusinogener",
      "translation": "intoxicated by narcotic substance, especially hallucinogens",
      "examples": [
