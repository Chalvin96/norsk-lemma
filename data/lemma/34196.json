  "cross_reference": null,
  "definitions": [
    {
      "text": "føre med seg eller etter seg i hånden eller i et bånd",
      "translation": "lead or drag along by hand or by a leash",
      "examples": [
        "lede hunden i bånd"
      ]
    },
    {
      "text": "gi en viss retning",
      "translation": "give a certain direction",
      "examples": [
        "lede kloakken ut i sjøen",
        "han leder samtalen inn på et nytt emne",
        "et ledende spørsmål"
      ]
    },
    {
      "text": "styre eller stå i spissen for",
      "translation": "manage or be at the head of",
      "examples": [
        "lede en bedrift",
        "sjefen ledet møtet",
        "innta en ledende stilling"
      ]
    },
    {
      "text": "føre videre elektrisitet eller varme",
      "translation": "conduct electricity or heat",
      "examples": [
        "vann leder elektrisitet"
      ]
    },
    {
      "text": "ligge best an i konkurranse",
      "translation": "be in the best position in a competition",
      "examples": [
        "hun ledet fra start til mål"
      ]
    }
  ]
