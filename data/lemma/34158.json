  "definitions": [
    {
      "text": "uttrykke munterhet eller glede (eller hån) med lyder gjennom munnen mens en smiler",
      "translation": "express amusement, joy (or mockery) with sounds through the mouth while smiling",
      "examples": []
    },
    {
      "text": "skratte, flire, humre",
      "translation": "laugh, chuckle, giggle",
      "examples": [
        "begynne å le",
        "le hjertelig",
        "le hånlig",
        "folk smiler og ler til hverandre",
        "vi pratet og lo",
        "le så tårene triller",
        "hun kan le litt av det i dag",
        "narr meg ikke til å le!",
        "le på riktig sted",
        "le noen rett opp i ansiktet",
        "en leende og munter mann"
      ]
