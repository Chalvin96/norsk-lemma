  "definitions": [
    {
      "text": "vei som fører inn til noe fra baksiden",
      "translation": "road leading to something from the back",
      "examples": []
    },
    {
      "text": "hemmelig (skjult) vei",
      "translation": "secret (hidden) road",
      "examples": [
        "snike seg ut bakveien"
      ]
    },
    {
      "text": "i overført betydning: skjult inngang eller tilgang til noe",
      "translation": "in a figurative sense: hidden entrance or access to something",
      "examples": [
        "skaffe seg løyve via korrupte bakveier"
      ]
    }
