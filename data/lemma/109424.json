  "definitions": [
    {
      "text": "bredde av et frekvensområde for overføring av analog eller digital signaler, målt i hertz",
      "translation": "width of a frequency range for the transmission of analog or digital signals, measured in hertz",
      "examples": [
        "standard båndbredde på en telefonkanal er 3100 Hz"
      ]
    },
    {
      "text": "mål på kapasitet til å overføre digital data målt i bit per sekund",
      "translation": "measure of capacity to transmit digital data measured in bits per second",
      "examples": [
        "internettleverandøren lover deg rikelig med båndbredde"
      ]
    }
  ]
