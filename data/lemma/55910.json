  "definitions": [
    {
      "text": "stikke noe, særlig fleskestrimler, i kjøtt som skal stekes",
      "translation": "to stuff something, especially strips of fat, into meat to be roasted",
      "examples": [
        "spekke en stek",
        "spekk fileten godt med persille"
      ]
    },
    {
      "text": "fylle fuger",
      "translation": "to fill joints",
      "examples": [
        "spekke en mur"
      ]
    },
    {
      "text": "fylle rikelig",
      "translation": "to fill abundantly",
      "examples": [
        "programmet var spekket med gode innslag"
      ]
    },
    {
      "text": "brukt som adjektiv: full",
      "translation": "used as an adjective: full",
      "examples": []
    },
    {
      "text": "jamfør fullspekket fullspekka",
      "translation": "packed full",
