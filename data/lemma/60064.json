  "definitions": [
    {
      "text": "visuelt språk (med betydningsbærende tegn og grammatiske regler) som uttrykkes ved hjelp av håndbevegelser, mimikk og kroppsholdning, særlig brukt i kommunikasjon mellom eller med døve",
      "translation": "visual language (with meaningful signs and grammatical rules) expressed through hand movements, facial expressions, and body posture, especially used in communication between or with deaf people",
      "examples": [
        "norsk tegnspråk er Norges nasjonale tegnspråk",
        "hun behersker både norsk og amerikansk tegnspråk"
      ]
    },
    {
      "text": "måte å kommunisere på ved hjelp av geberde og mimikk",
      "translation": "way of communicating using gestures and facial expressions",
      "examples": [
        "han kan ikke noe særlig norsk, så det ble mye tegnspråk"
      ]
    }
