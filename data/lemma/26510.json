      ]
    },
    {
      "text": "vinne penger, premier eller lignende i et løp",
      "translation": "win money, prizes in a race",
      "examples": [
        "alpinisten har passert 200 000 kroner innkjørt i år"
      ]
    },
    {
      "text": "om bruksdyr: temmet så det kan kjøres med",
      "translation": "for draft animals: tamed so it can be driven",
      "examples": [
        "hestene var innkjørte og skulle gå i tospann"
      ]
    },
    {
      "text": "prøve ut og gjøre skikket til vanlig drift",
      "translation": "test and make fit for normal operation",
      "examples": [
