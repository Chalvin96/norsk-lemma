  "definitions": [
    {
      "text": "om vann, is, vind og lignende: tære, oppløse eller bryte ned jordoverflaten og forflytte det oppløste materialet",
      "translation": "concerning water, ice, wind, and similar: to wear away, dissolve, or break down the earth's surface and move the dissolved material",
      "examples": []
    },
    {
      "text": "lage erosjon",
      "translation": "to cause erosion",
      "examples": [
        "sjøvannet har erodert steinen og gravd ut huler"
      ]
    },
    {
      "text": "bli oppløst og ført bort av vann, vind, is eller lignende",
      "translation": "to be dissolved and carried away by water, wind, ice, or similar",
      "examples": [
        "steinen er i ferd med å erodere bort",
        "kystområder som eroderer"
      ]
    },
    {
      "text": "gradvis slite ned tann, vev eller lignende ved kjemisk eller fysisk påvirkning",
      "translation": "to gradually wear down teeth, tissue, or similar through chemical or physical influence",
      "examples": [
        "emaljen på tennene blir erodert bort"
      ]
    },
    {
      "text": "om metall: gradvis slites ned ved mekanisk påvirkning av strømmende væsker eller gasser, forurensning eller lignende",
      "translation": "concerning metal: to be gradually worn down by mechanical influence of flowing liquids or gases, pollution, or similar",
      "examples": [
        "ubåten eroderer med årene"
      ]
    }
  ]
