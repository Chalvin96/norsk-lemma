  "definitions": [
    {
      "text": "teppe som er satt sammen av lapper i forskjellige farger",
      "translation": "quilt made of patches of different colors",
      "examples": [
        "hekle ruter og sy dem sammen til et lappeteppe"
      ]
    },
    {
      "text": "i overført betydning: noe som er satt sammen av deler som er ganske forskjellige",
      "translation": "in a figurative sense: something composed of very different parts",
      "examples": [
        "landskapet er et lappeteppe av skoger og åkre",
        "landet er et lappeteppe av forskjellige kulturer og språk"
      ]
