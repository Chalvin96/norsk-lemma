  "definitions": [
    {
      "text": "knute på bånd, lisse eller lignende med to løkker og to løse ender, brukt til pynt eller når en knytter skolisser, gavebånd eller annet",
      "translation": "knot on ribbon, lace with two loops and two loose ends, used for decoration or when tying shoelaces, gift ribbon or other",
      "examples": [
        "knytte sløyfer",
        "ha sløyfe i håret",
        "ha hvit skjorte med svart sløyfe i halsen",
        "hesten fikk hvit sløyfe på utstillingen"
      ]
    },
    {
      "text": "buet bevegelse, bane eller linje som minner om løkkene i en sløyfe",
      "translation": "curved movement, path or line resembling the loops of a bow",
      "examples": [
        "grusveien går i sløyfe ned mot bygda",
        "kablene er lagt i sløyfe"
      ]
    },
    {
      "text": "løkkeformet tog- eller trikkeskinne som lar tog eller trikk snu",
      "translation": "loop-shaped railway or tram track that allows trains or trams to turn around",
      "examples": []
    },
    {
      "text": "stadig gjentakelse av film- eller lydklipp",
      "translation": "constant repetition of film or audio clips",
      "examples": [
        "filmsnutten spilles i sløyfe"
      ]
    },
    {
      "text": "tynn list, for eksempel under lektene på tak med takstein",
      "translation": "thin strip under the battens on a roof with tiles",
