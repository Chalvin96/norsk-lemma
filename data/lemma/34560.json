  "definitions": [
    {
      "text": "flate blad på trær eller busker",
      "translation": "flat leaves on trees and bushes",
      "examples": [
        "rake løv",
        "løvet spretter",
        "det grønne løvet på trærne",
        "så stille at ikke et løv rører på seg"
