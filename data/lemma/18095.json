  "definitions": [
    {
      "text": "melde noen som frisk (og arbeidsfør) igjen",
      "translation": "to declare someone healthy (and fit for work) again",
      "examples": [
        "bli friskmeldt etter sykmeldingen",
        "hun skrives ikke ut fra sykehuset før hun er friskmeldt"
      ]
    },
    {
      "text": "i overført betydning: erklære noe som godt og normalt etter at det har vært i en dårlig tilstand",
      "translation": "to declare something good and normal after it has been in a bad state",
      "examples": [
        "vassdraget er friskmeldt",
        "det vil ta lang tid før økonomien er friskmeldt"
      ]
    }
  ]
