  "definitions": [
    {
      "text": "kutte forbindelse mellom en maskindel og drivkraft",
      "translation": "to cut the connection between a machine part and the drive",
      "examples": [
        "frikoble drivhjulene",
        "frikoble girkassen fra motoren"
      ]
    },
    {
      "text": "i overført betydning: være uten forbindelse",
      "translation": "to be without connection",
      "examples": [
        "toppidretten kan ikke frikobles fra politikken",
        "norsk økonomi er ikke frikoblet fra resten av verden"
      ]
    }
  ]
