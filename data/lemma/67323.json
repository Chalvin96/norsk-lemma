  "definitions": [
    {
      "text": "gjeldsbrev der underskriveren (trassenten) oppfordrer en annen (trassaten) til å betale et visst beløp til den rette vekselhaveren (remittenden) eller til seg selv innen en fastsatt tid",
      "translation": "promissory note where the signer (drawer) asks another party (drawee) to pay a certain amount to the rightful holder (payee) or to themselves within a specified time",
      "examples": []
    },
    {
      "text": "gjeldsbrev der underskriveren forplikter seg til å betale et visst beløp til en annen innen en fastsatt tid",
      "translation": "promissory note where the signer undertakes to pay a certain amount to another party within a specified time",
      "examples": [
        "blankoveksel, dagveksel, domisilveksel",
        "trekke, utstede en veksel på en bank",
        "akseptere, endossere, diskontere, prolongere, honorere, innløse en veksel",
        "veksel med fast løpetid",
        "vekselen forfaller i dag",
        "trekke veksler på ens gjestfrihet"
      ]
    },
    {
      "text": "tversgående, kort bjelke i bygningskonstruksjon",
      "translation": "transverse, short beam in a building structure",
      "examples": [
        "fjernstyrt veksel"
      ]
    },
    {
      "text": "veksling, skifte",
      "translation": "exchange, change",
