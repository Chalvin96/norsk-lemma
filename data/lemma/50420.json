  "cross_reference": null,
  "definitions": [
    {
      "text": "bevege seg ved hjelp av seil og vind",
      "translation": "move by means of sails and wind",
      "examples": []
    },
    {
      "text": "reise eller frakte med seilskip eller annet fartøy",
      "translation": "navigate",
      "examples": [
        "et skip seilte forbi",
        "skuta seiler godt",
        "de seilte langs land",
        "seile langs hele kysten",
        "vil du seile meg over fjorden?",
        "seile etter landemerker"
      ]
    },
    {
      "text": "være regelmessig (i rute) på sjøen",
      "translation": "be regular (on a route) at sea",
      "examples": [
        "han seilte i fem år som stuert",
        "båten seiler på Sør-Amerika"
      ]
    },
    {
      "text": "flyte, drive med vind og strøm",
      "translation": "float, drift with wind and current",
      "examples": [
        "stokken seilte nedover elva"
      ]
    },
    {
      "text": "fare glidende gjennom lufta",
      "translation": "glide through the air",
      "examples": []
    },
    {
      "text": "flyte på vinger, sveve",
      "translation": "float on wings, soar",
      "examples": [
        "en ørn seilte høyt oppe i det blå",
        "papirflyet seilte gjennom klasserommet",
        "ballen seilte rett over målet",
        "måken kom seilende inn vinduet"
      ]
    },
    {
      "text": "ake, skli",
      "translation": "sled, slide",
      "examples": [
        "han gikk over ende og seilte bortover isen",
        "ølglasset seilte nedover bardisken",
        "bøkene kom seilende inn på skrivebordet mitt"
      ]
    },
    {
      "text": "gå",
      "translation": "go",
      "examples": [
        "han seiler gjennom rommet",
        "fruen kom seilende inn"
      ]
    },
    {
      "text": "falle, kantre",
      "translation": "fall, capsize",
      "examples": [
        "seile over ende",
        "hun seilte rett i seng"
      ]
    },
    {
      "text": "drive eller røre seg lett og uanstrengt fra en ting til en annen",
      "translation": "move or drift lightly and effortlessly from one thing to another",
      "examples": [
        "han seiler gjennom livet",
        "hun seilte fra en jobb til den neste"
      ]
    }
  ]
}
