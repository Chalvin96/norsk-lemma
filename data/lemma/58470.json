  "definitions": [
    {
      "text": "dure svakt",
      "translation": "to drone faintly",
      "examples": [
        "fluene surret i solveggen",
        "det surret av alle slags tungemål"
      ]
    },
    {
      "text": "steke ved svak varme",
      "translation": "to fry at low heat",
      "examples": [
        "småørret surret i rømme"
      ]
    },
    {
      "text": "løpe rundt",
      "translation": "to run around",
      "examples": [
        "rokkehjulet surret og gikk",
        "disse tankene surret i hodet ustanselig"
      ]
    },
    {
      "text": "rote, tulle",
      "translation": "to mess around, to fool",
      "examples": [
        "du bare surrer",
        "surre rundt med kompisene"
      ]
    }
  ]
