    },
    {
      "text": "på et sted lenger framme",
      "translation": "in a place further ahead",
      "examples": [
        "framme på gården",
        "framme på neset"
      ]
    },
    {
      "text": "om tid: senere",
      "translation": "regarding time: later",
      "examples": [
