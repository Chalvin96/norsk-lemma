  "definitions": [
    {
      "text": "særlig om norrøne forhold: som har gitt seg i tjeneste hos en konge (eller annen høvding)",
      "translation": "especially in Old Norse: having entered the service of a king (or other chieftain)",
      "examples": []
    },
    {
      "text": "som er en pålitelig og trofast tilhenger eller medarbeider",
      "translation": "being a reliable and faithful supporter or collaborator",
      "examples": [
        {
          "no": "presidentens håndgangne mann",
          "en": "the president's right-hand man"
        },
        {
          "no": "hun blir betegnet som Kremls håndgangne kvinne",
          "en": "she is described as the Kremlin's trusted woman"
        }
      ]
    }
