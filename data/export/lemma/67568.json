  "definitions": [
    {
      "text": "sette i bevegelse rundt en (tenkt) akse slik at en annen side kommer fram eller opp",
      "translation": "turn around an axis",
      "examples": []
    },
    {
      "text": "snu, dreie",
      "translation": "turn, rotate",
      "examples": [
        {
          "no": "vende høyet",
          "en": "turn the hay"
        },
        {
          "no": "vende seg langsomt rundt",
          "en": "turn slowly around"
        },
        {
          "no": "vende blikket oppover",
          "en": "turn one's gaze upward"
        },
        {
          "no": "vende ansiktet mot noen",
          "en": "turn one's face toward someone"
        }
      ]
    },
    {
      "text": "ta en ny retning",
      "translation": "take a new direction",
      "examples": [
        {
          "no": "vende kursen sørover",
          "en": "turn southward"
        },
        {
          "no": "vende og gå tilbake",
          "en": "turn and go back"
        },
        {
          "no": "det lønner seg å vende i tide",
          "en": "it pays to turn back in time"
        }
      ]
    },
    {
      "text": "peke i en viss retning",
      "translation": "point in a certain direction",
      "examples": [
        {
          "no": "rommet vender ut mot sjøen",
          "en": "the room faces the sea"
        },
        {
          "no": "vende håndflatene oppover",
          "en": "turn the palms upward"
        },
        {
          "no": "vende våpenet mot noen",
          "en": "turn the weapon on someone"
        },
        {
          "no": "stolene stod vendt mot scenen",
          "en": "the chairs were facing the stage"
        }
      ]
    },
    {
      "text": "forflytte seg",
      "translation": "move",
      "examples": []
    },
    {
      "text": "reise, dra, komme",
      "translation": "travel, go, come",
      "examples": [
        {
          "no": "nå er det vel på tide å vende hjemover?",
          "en": "isn't it about time to head home?"
        },
        {
          "no": "trekkfuglene vender sørover om høsten",
          "en": "migratory birds head south in the autumn"
        }
      ]
    },
    {
      "text": "få til å endre seg",
      "translation": "bring about change",
      "examples": []
    },
    {
      "text": "snu til det bedre",
      "translation": "turn for the better",
      "examples": [
        {
          "no": "vende en negativ utvikling",
          "en": "reverse a negative trend"
        },
        {
          "no": "vende kampen til seier",
          "en": "turn the match into victory"
        }
      ]
    },
    {
      "text": "sikte inn",
      "translation": "aim",
      "examples": [
        {
          "no": "vende oppmerksomheten mot noe",
          "en": "turn one's attention to something"
        },
        {
          "no": "han prøvde å vende tankene mot morgendagen",
          "en": "he tried to turn his thoughts to the next day"
        }
      ]
    }
