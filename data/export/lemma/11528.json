  "definitions": [
    {
      "text": "som ikke vet hvilken tid det er på døgnet",
      "translation": "not knowing what time of day it is",
      "examples": []
    },
    {
      "text": "som er trøtt og ute av den vanlige døgnrytmen, for eksempel på grunn av nattevåking eller reise mellom ulike tidssoner",
      "translation": "being tired and out of the usual daily rhythm due to staying up all night or traveling between different time zones",
      "examples": [
        {
          "no": "forsove seg så grundig at en blir døgnvill",
          "en": "oversleep so badly that you get your days and nights mixed up"
        },
        {
          "no": "jeg er fremdeles døgnvill etter den lange reisen",
          "en": "i am still jet-lagged after the long trip"
        }
      ]
    },
    {
      "text": "som har mistet regning med dagene",
      "translation": "having lost track of the days",
      "examples": []
