  "definitions": [
    {
      "text": "det som er forutbestemt for en (av en høyere makt)",
      "translation": "what is predetermined for someone (by a higher power)",
      "examples": [
        {
          "no": "finne seg i sin skjebne",
          "en": "accept one's fate"
        },
        {
          "no": "ingen kan flykte fra sin skjebne",
          "en": "no one can escape their fate"
        },
        {
          "no": "få en ublid skjebne",
          "en": "meet a grim fate"
        }
      ]
    },
    {
      "text": "noe eller noen som er eller blir avgjørende for en",
      "translation": "something or someone that is or becomes decisive for someone",
      "examples": [
        {
          "no": "kampen skulle avgjøre lagets videre skjebne",
          "en": "the match would decide the team's дальней fate"
        },
        {
          "no": "holde mange menneskers skjebne i sin hånd",
          "en": "hold many people's fate in one's hands"
        },
        {
          "no": "den mannen ble hennes skjebne",
          "en": "that man became her destiny"
        },
        {
          "no": "krigen ble hans skjebne",
          "en": "the war became his destiny"
        }
      ]
    },
    {
