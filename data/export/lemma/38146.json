  "definitions": [
    {
      "text": "målsystem der meter og kilogram er grunnenheter, og der en bruker tideling og tidobling for å lage nye enheter",
      "translation": "system of measurement where the meter and kilogram are base units, using division and multiplication by ten to create new units",
      "examples": [
        {
          "no": "konvertere målingene fra metersystemet til det engelske målsystemet med tommer og fot",
          "en": "convert the measurements from the metric system to the English system of measurement with inches and feet"
        }
      ]
    }
