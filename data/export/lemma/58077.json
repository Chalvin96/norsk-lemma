  "cross_reference": null,
  "definitions": [
    {
      "text": "føre noe inn i, i mot eller gjennom noe med stor kraft",
      "translation": "force something into, against, or through something",
      "examples": []
    },
    {
      "text": "renne, drive, kjøre",
      "translation": "run, drive, thrust",
      "examples": [
        {
          "no": "støte stokken i golvet",
          "en": "drive the log into the floor"
        },
        {
          "no": "han støter spydet i målskiva",
          "en": "he drives the spear into the target"
        }
      ]
    },
    {
      "text": "føre noe vekk fra seg med stor kraft",
      "translation": "push, shove",
      "examples": []
    },
    {
      "text": "skyve, puffe",
      "translation": "push, shove",
      "examples": [
        {
          "no": "de støtte båten fra land",
          "en": "they pushed the boat off from shore"
        },
        {
          "no": "støtte kule",
          "en": "put the shot"
        },
        {
          "no": "de støtte opp døra",
          "en": "they propped the door open"
        }
      ]
    },
    {
      "text": "knuse med noe hardt",
      "translation": "crush with something hard",
      "examples": [
        {
          "no": "støte hull på isen med en jernstang",
          "en": "break a hole in the ice with an iron bar"
        },
        {
          "no": "støte krydderet i stykker i en morter",
          "en": "crush the spice in a mortar"
        }
      ]
    },
    {
      "text": "treffe en hindring",
      "translation": "hit an obstacle",
      "examples": []
    },
    {
      "text": "renne mot noe",
      "translation": "run into something",
      "examples": [
        {
          "no": "båten støtte på grunn",
          "en": "the boat ran aground"
        },
        {
          "no": "bilene støtte sammen",
          "en": "the cars collided"
        }
      ]
    },
    {
      "text": "blåse kort og kraftig",
      "translation": "blow briefly and strongly",
      "examples": [
        {
          "no": "støte i et horn",
          "en": "blow a horn"
        },
        {
          "no": "støte i nesen",
          "en": "blow your nose"
        }
      ]
    },
    {
      "text": "gjøre noen fornærmet",
      "translation": "offend someone",
      "examples": []
    },
    {
      "text": "forulempe, krenke",
      "translation": "wrong, insult",
      "examples": [
        {
          "no": "jeg mente ikke å støte deg",
          "en": "I didn't mean to offend you"
        },
        {
          "no": "bli støtt over noe",
          "en": "be offended by something"
        },
        {
          "no": "virke støtende",
          "en": "seem offensive"
        },
        {
          "no": "en støtende bemerkning",
          "en": "an offensive remark"
        }
      ]
    }
  ]
