  "definitions": [
    {
      "text": "som ikke eller svært vanskelig lar seg gjøre eller utføre",
      "translation": "that cannot be done or performed, or is very difficult to do or perform",
      "examples": []
    },
    {
      "text": "ikke mulig, ugjørlig",
      "translation": "not possible, unachievable",
      "examples": [
        {
          "no": "få en umulig oppgave",
          "en": "be given an impossible task"
        },
        {
          "no": "det var umulig å svømme mot strømmen",
          "en": "it was impossible to swim against the current"
        },
        {
          "no": "det kan umulig være sant",
          "en": "that cannot possibly be true"
        },
        {
          "no": "veien er umulig lang",
          "en": "the road is impossibly long"
        }
      ]
    },
    {
      "text": "som ikke kan forekomme eller tenkes",
      "translation": "that cannot occur or be imagined",
      "examples": []
    },
    {
      "text": "utenkelig, usannsynlig",
      "translation": "unthinkable, unlikely",
      "examples": [
        {
          "no": "en umulig tanke",
          "en": "an impossible thought"
        },
        {
          "no": "det er ikke umulig at hun blir litt forsinket",
          "en": "it is not impossible that she will be a little delayed"
        }
      ]
    },
    {
      "text": "særlig vanskelig eller vrien",
      "translation": "particularly difficult, tricky",
      "examples": []
    },
    {
      "text": "vrang, umedgjørlig",
      "translation": "contrary, unmanageable",
      "examples": [
        {
          "no": "en umulig unge",
          "en": "an impossible child"
        },
        {
          "no": "ikke vær så umulig!",
          "en": "don't be so impossible!"
        }
      ]
    }
