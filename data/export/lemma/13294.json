  "definitions": [
    {
      "text": "ta noe eller noen som forbilde",
      "translation": "take something or someone as a model",
      "examples": []
    },
    {
      "text": "ape etter",
      "translation": "ape",
      "examples": [
        {
          "no": "etterligne sagastilen",
          "en": "imitate the saga style"
        },
        {
          "no": "han etterligner storebroren sin",
          "en": "he imitates his big brother"
        },
        {
          "no": "alle lo da hun etterlignet læreren",
          "en": "everyone laughed when she imitated the teacher"
        }
      ]
    },
    {
      "text": "fastsette skatt etter at den ordinære ligning likning er foretatt",
      "translation": "determine tax after the ordinary assessment has been made",
      "examples": [
        {
          "no": "de vil bli etterlignet for tre år",
          "en": "they will be reassessed for three years"
        }
      ]
    }
  ]
