  "definitions": [
    {
      "text": "grenselinje eller skillelinje mellom to parter i et konfliktområde, ofte fastsatt ved våpenhvile",
      "translation": "border line separating two parties in a conflict area, often established by ceasefire",
      "examples": [
        {
          "no": "en demarkasjonslinje som deler området i to",
          "en": "a demarcation line dividing the area in two"
        },
        {
          "no": "midlertidige demarkasjonslinjer",
          "en": "temporary demarcation lines"
        }
      ]
    },
    {
      "text": "skille mellom ulike ideer, meninger, grupperinger eller lignende",
      "translation": "distinction between different ideas, opinions, groupings",
      "examples": [
        {
          "no": "demarkasjonslinjene mellom stat, marked og sivilsamfunn",
          "en": "the demarcation lines between the state, the market, and civil society"
        },
        {
          "no": "en ideologisk og moralsk demarkasjonslinje mellom de to partene",
          "en": "an ideological and moral demarcation line between the two parties"
        }
      ]
    }
  ]
