  "definitions": [
    {
      "text": "i Romerriket: strafferedskap til dødsstraff som bestod av en loddrett stolpe og et tverrtre langt oppe der en hengte opp den dødsdømte",
      "translation": "in the Roman Empire: instrument of punishment for capital punishment consisting of a vertical post and a crossbeam high up on which the condemned was hung",
      "examples": [
        {
          "no": "Jesus led døden på korset",
          "en": "Jesus died on the cross"
        }
      ]
    },
    {
      "text": "symbol for kristendommen",
      "translation": "symbol of Christianity",
      "examples": [
        {
          "no": "gjøre korsets tegn",
          "en": "make the sign of the cross"
        },
        {
          "no": "stride for korset",
          "en": "fight for the cross"
        }
      ]
    },
    {
      "text": "i overført betydning: tung skjebne, prøvelse",
      "translation": "heavy fate, trial",
      "examples": [
        {
          "no": "enhver har sitt kors",
          "en": "everyone has their cross to bear"
        }
