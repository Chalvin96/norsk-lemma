  "definitions": [
    {
      "text": "si hva som skal hende i framtiden (ved hjelp av overnaturlige evner)",
      "translation": "to tell what will happen in the future (using supernatural abilities)",
      "examples": [
        {
          "no": "spå i kaffegrut",
          "en": "tell fortunes in coffee grounds"
        },
        {
          "no": "en kjerring som for rundt og spådde folk",
          "en": "an old woman who went around telling people's fortunes"
        },
        {
          "no": "tarotkortene spår et vanskelig valg for deg",
          "en": "the tarot cards predict a difficult choice for you"
        }
      ]
    },
    {
      "text": "bære bud om",
      "translation": "to herald",
      "examples": [
        {
          "no": "bli spådd en stor framtid",
          "en": "be predicted a great future"
        },
        {
          "no": "det er spådd snø til natta",
          "en": "snow is forecast for tonight"
        },
        {
          "no": "svalene spår regn, de flyr så lavt",
          "en": "the swallows foretell rain, they're flying so low"
        }
      ]
    },
    {
      "text": "anta, regne med",
      "translation": "to assume, to reckon",
      "examples": [
        {
          "no": "jeg spår at han får jobben",
          "en": "I predict that he gets the job"
        }
      ]
    }
  ]
