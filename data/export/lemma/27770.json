      "text": "eldre betegnelse for ung, ugift kvinne",
      "translation": "an older term for a young, unmarried woman",
      "examples": [
        {
          "no": "en ung, vakker jomfru",
          "en": "a young, beautiful virgin"
        }
      ]
    },
    {
      "text": "person som ikke har hatt samleie (før: særlig om kvinne)",
      "translation": "a person who has not had sexual intercourse (formerly: especially a woman)",
      "examples": [
        {
          "no": "hun var ugift, men ikke jomfru",
          "en": "she was unmarried, but not a virgin"
        },
        {
          "no": "han forteller at han er jomfru",
          "en": "he says that he is a virgin"
        }
