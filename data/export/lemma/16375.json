  "definitions": [
    {
      "text": "dom som en gjør før en kjenner en sak skikkelig eller før det er felt en rettsdom i saken",
      "translation": "judgment made before a case is properly known or before a legal judgment is passed",
      "examples": [
        {
          "no": "mediene har felt en forhåndsdom som vil følge ham resten av livet",
          "en": "the media have passed a premature judgment that will follow him for the rest of his life"
        }
      ]
    }
