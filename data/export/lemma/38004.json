  "definitions": [
    {
      "text": "sette merke på",
      "translation": "to mark",
      "examples": [
        {
          "no": "merke av på lista hvem som er til stede",
          "en": "mark on the list who is present"
        },
        {
          "no": "løypa er merket med røde bånd",
          "en": "the trail is marked with red ribbons"
        },
        {
          "no": "turlaget merker opp stier",
          "en": "the hiking association marks trails"
        },
        {
          "no": "merke sauer",
          "en": "mark sheep"
        }
      ]
    },
    {
      "text": "sette spor etter seg",
      "translation": "to leave a trace",
      "examples": [
        {
          "no": "være merket av sykdommen",
          "en": "be marked by the illness"
        }
      ]
    },
    {
      "text": "brennemerke, stemple (som uhederlig)",
      "translation": "to brand, to stamp (as dishonorable)",
      "examples": [
        {
          "no": "en merket mann",
          "en": "a marked man"
        }
      ]
    },
    {
      "text": "bli var, kjenne, erfare",
      "translation": "to notice, to feel, to experience",
      "examples": [
        {
          "no": "merket du ansiktsuttrykket hennes?",
          "en": "did you notice her facial expression?"
        },
        {
          "no": "mye har hendt siden sist, det vil du få merke",
          "en": "a lot has happened since last time, you will notice that"
        },
        {
          "no": "jeg merket at han hadde drukket",
          "en": "I noticed that he had been drinking"
        },
        {
          "no": "merke en uvanlig lukt",
          "en": "notice an unusual smell"
        }
      ]
    }
