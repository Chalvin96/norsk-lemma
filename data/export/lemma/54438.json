      "text": "berøre med tungen",
      "translation": "touch with the tongue",
      "examples": []
    },
    {
      "text": "la tungen gli over",
      "translation": "let the tongue glide over",
      "examples": [
        {
          "no": "kua slikker salt",
          "en": "the cow licks salt"
        },
