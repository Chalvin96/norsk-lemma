  "cross_reference": null,
  "definitions": [
    {
      "text": "svinge, bevege hånd eller redskap raskt mot noe og treffe",
      "translation": "to swing, to move a hand or tool rapidly against something and hit it",
      "examples": []
    },
    {
      "text": "dunke, kakke",
      "translation": "to thump, to knock",
      "examples": [
        {
          "no": "banke på døra",
          "en": "knock on the door"
        },
        {
          "no": "banke en finger mot tinningen",
          "en": "tap a finger against the temple"
        }
      ]
    },
    {
      "text": "i overført betydning: formidle et budskap gjentatte ganger",
      "translation": "to convey a message repeatedly",
      "examples": [
        {
          "no": "banke inn i arbeiderne hvor viktige de er",
          "en": "drill into the workers how important they are"
        }
      ]
    },
    {
      "text": "lage rytmiske lyder eller signaler",
      "translation": "to make rhythmic sounds or signals",
      "examples": []
    },
    {
      "text": "slå, pulsere",
      "translation": "to beat, to pulsate",
      "examples": [
        {
          "no": "motoren banker",
          "en": "the engine is knocking"
        },
        {
          "no": "hjertet banket hardt",
          "en": "the heart was pounding hard"
        }
      ]
    },
    {
      "text": "gi juling",
      "translation": "to give a beating",
      "examples": []
    },
    {
      "text": "gi bank",
      "translation": "to give a bang",
      "examples": [
        {
          "no": "bli banket opp",
          "en": "get beaten up"
        },
        {
          "no": "de dyttet ham i bakken og banket ham",
          "en": "they pushed him to the ground and beat him"
        }
      ]
    }
  ]
