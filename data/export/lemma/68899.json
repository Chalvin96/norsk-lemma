  "cross_reference": null,
  "definitions": [
    {
      "text": "bevege seg eller gynge fram og tilbake, fra side til side eller opp og ned",
      "translation": "to move or sway back and forth, from side to side, up and down",
      "examples": [
        {
          "no": "vogge med overkroppen",
          "en": "rock with the upper body"
        },
        {
          "no": "gresset vogger i vinden",
          "en": "the grass sways in the wind"
        },
        {
          "no": "måken vogger på bølgene",
          "en": "the seagull rocks on the waves"
        },
        {
          "no": "voggende valsetakt",
          "en": "swaying waltz rhythm"
        }
      ]
    },
    {
      "text": "sette i gyngende eller svaiende bevegelse",
      "translation": "to set in a rocking, swaying motion",
      "examples": [
        {
          "no": "vogge barnet i søvn",
          "en": "rock the child to sleep"
        }
      ]
    }
  ]
