  "definitions": [
    {
      "text": "ønske seg noe en annen har",
      "translation": "to wish for something another person has",
      "examples": []
    },
    {
      "text": "være bitter eller sjalu over at en annen har visse fordeler",
      "translation": "to be bitterly jealous that another has certain advantages",
      "examples": []
    },
    {
      "text": "ikke unne",
      "translation": "to not begrudge",
      "examples": [
        {
          "no": "jeg misunner deg som har råd til å reise utenlands",
          "en": "I don't envy you, having enough money to travel abroad"
        },
        {
          "no": "hun misunte dem den store hagen",
          "en": "she envied them their large garden"
        },
        {
          "no": "jeg misunner deg ikke den oppgaven",
          "en": "I don't envy you that task"
        }
      ]
    }
