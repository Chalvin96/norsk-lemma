  "definitions": [
    {
      "text": "tegne, skrive eller snakke raskt, slurvete og utydelig",
      "translation": "to draw, write or speak quickly, sloppily and indistinctly",
      "examples": [
        {
          "no": "rable ned handlelisten i en fart",
          "en": "scribble down the shopping list in a hurry"
        },
        {
          "no": "hun rablet av gårde om konspirasjoner",
          "en": "she rambled on about conspiracies"
        }
      ]
    },
    {
      "text": "brukt som adjektiv: forvirret, vettløs",
      "translation": "used as an adjective: confused, senseless",
      "examples": [
        {
          "no": "rablende vrangforestillinger",
          "en": "raving delusions"
        }
      ]
