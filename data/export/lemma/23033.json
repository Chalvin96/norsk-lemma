  "definitions": [
    {
      "text": "holde hellig, gjøre hellig",
      "translation": "keep holy, make holy",
      "examples": []
    },
    {
      "text": "velsigne",
      "translation": "bless",
      "examples": [
        {
          "no": "vår Far i himmelen! La navnet ditt helliges",
          "en": "our Father in heaven! Hallowed be your name"
        },
        {
          "no": "jeg er Herren som helliger Israel",
          "en": "I am the Lord who sanctifies Israel"
        }
      ]
    },
    {
      "text": "vie til noe eller noen",
      "translation": "dedicate to something or someone",
      "examples": [
        {
          "no": "en kirke helliget jomfru Maria",
          "en": "a church dedicated to the Virgin Mary"
        },
        {
          "no": "han helliget seg helt til sitt arbeid",
          "en": "he devoted himself entirely to his work"
        }
