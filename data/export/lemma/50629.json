  "cross_reference": null,
  "definitions": [
    {
      "text": "står til et pronomen for å framheve at det nettopp er den pronomenet betegner, det er snakk om: personlig",
      "translation": "emphasizing that it is precisely the pronoun that is meant",
      "examples": [
        {
          "no": "han sa det selv",
          "en": "he said it himself"
        },
        {
          "no": "selv stod de bare og så på",
          "en": "they themselves just stood there watching"
        },
        {
          "no": "der kan du se selv",
          "en": "there, you can see for yourself"
        },
        {
          "no": "jeg tvilte ofte på meg selv",
          "en": "I often doubted myself"
        }
      ]
    },
    {
      "text": "står til et substantiv for å framheve at det nettopp er det substantivet betegner, det er snakk om: den virkelige eller egentlige",
      "translation": "emphasizing that it is precisely the noun that is meant: the real or actual",
      "examples": []
    },
    {
      "text": "den rette",
      "translation": "the right",
      "examples": [
        {
          "no": "selve gården er dårlig, men skogen er bra",
          "en": "the farm itself is poor, but the forest is good"
        },
        {
          "no": "selve byen er ikke så stor",
          "en": "the town itself is not that big"
        },
        {
          "no": "selve grunnfjellet stikker opp",
          "en": "the bedrock itself sticks up"
        }
      ]
    },
    {
      "text": "på egen hånd",
      "translation": "on one's own",
      "examples": []
    },
    {
      "text": "uten hjelp eller påvirkning utenfra",
      "translation": "without help or outside influence",
      "examples": [
        {
          "no": "han vil gjøre alt selv",
          "en": "he wants to do everything himself"
        },
        {
          "no": "de har bygd huset helt selv",
          "en": "they built the house entirely by themselves"
        }
      ]
    },
    {
      "text": "i egen person",
      "translation": "in person",
      "examples": [
        {
          "no": "er han selv hjemme?",
          "en": "is he himself at home?"
        },
        {
          "no": "kongen selv var til stede",
          "en": "the king himself was present"
        },
        {
          "no": "jeg tror det var selve fanden",
          "en": "I think it was the devil himself"
        },
        {
          "no": "hun er ærligheten selv",
          "en": "she is honesty itself"
        }
      ]
    },
    {
      "text": "brukt som adverb: til og med",
      "translation": "used as: even",
      "examples": [
        {
          "no": "selv han ble redd",
          "en": "even he got scared"
        },
        {
          "no": "alle, selv barna, var med",
          "en": "everyone, even the children, joined in"
        },
        {
          "no": "selv for deg blir dette for mye",
          "en": "even for you this is too much"
        }
      ]
    }
  ]
