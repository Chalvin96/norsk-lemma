    },
    {
      "text": "vekke moralsk harme eller avsky",
      "translation": "to arouse moral indignation or disgust",
      "examples": [
        {
          "no": "slik framferd opprører de fleste",
          "en": "such behavior outrages most people"
        },
        {
          "no": "arbeidsforholdene var opprørende",
          "en": "the working conditions were outrageous"
        },
