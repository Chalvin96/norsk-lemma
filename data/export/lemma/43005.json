  "definitions": [
    {
      "text": "få til å protestere",
      "translation": "to cause to protest",
      "examples": [
        {
          "no": "at folk blir behandlet ulikt, opprører rettferdighetssansen min",
          "en": "the fact that people are treated differently offends my sense of justice"
