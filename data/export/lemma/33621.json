    },
    {
      "text": "gjøre ute av stand til å handle",
      "translation": "render unable to act",
      "examples": [
        {
          "no": "bli lammet av skrekk",
          "en": "be paralyzed by fear"
        }
      ]
    },
    {
      "text": "få til å stoppe opp",
      "translation": "cause to stop",
      "examples": [
        {
          "no": "snøfallet lammet trafikken",
          "en": "the snowfall brought traffic to a standstill"
        },
        {
          "no": "streiken lammet store deler av næringslivet",
          "en": "the strike brought large parts of the business sector to a standstill"
