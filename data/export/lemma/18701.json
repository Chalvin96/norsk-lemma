  "definitions": [
    {
      "text": "evne til å oppfatte inntrykk i form av fysisk påvirkning, sosiale forhold og lignende",
      "translation": "ability to perceive impressions in the form of physical influence, social conditions, and the like",
      "examples": [
        {
          "no": "økt følsomhet for radioaktiv stråling",
          "en": "increased sensitivity to radioactive radiation"
        },
        {
          "no": "barnet utvikler sin sosiale følsomhet",
          "en": "the child develops their social sensitivity"
        },
        {
          "no": "å skrive en slik tekst krever følsomhet for språk og form",
          "en": "writing such a text requires sensitivity to language and form"
        }
      ]
    },
    {
      "text": "det å (ofte) oppleve eller uttrykke sterke følelser",
      "translation": "the act of (often) experiencing or expressing strong feelings",
      "examples": [
        {
          "no": "hun satte pris på hans følsomhet og ærlighet",
          "en": "she appreciated his sensitivity and honesty"
        },
        {
          "no": "melodien er preget av følsomhet og skjørhet",
          "en": "the melody is marked by sensitivity and fragility"
