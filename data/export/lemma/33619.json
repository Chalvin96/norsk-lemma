    {
      "text": "sveise eller lime sammen tynne lag",
      "translation": "to weld or glue together thin layers",
      "examples": [
        {
          "no": "laminert glass",
          "en": "laminated glass"
        },
        {
          "no": "laminerte tekstiler",
          "en": "laminated textiles"
        }
      ]
    },
    {
      "text": "kle med tynn, gjennomsiktig plastfolie som blir til en ugjennomtrengelig hinne",
      "translation": "to cover with a thin, transparent plastic film that forms an impermeable membrane",
      "examples": [
        {
          "no": "et laminert medlemskort",
          "en": "a laminated membership card"
        }
      ]
    },
    {
      "text": "valse ut i tynne flak",
      "translation": "to roll out into thin flakes",
