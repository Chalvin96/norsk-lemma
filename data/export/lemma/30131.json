  "definitions": [
    {
      "text": "hamre ut enden på nagle eller bolt som er slått gjennom noe, så den sitter fast",
      "translation": "hammer out the end of a nail or bolt that has been driven through something, so it sits fast",
      "examples": [
        {
          "no": "klinke fast noe",
          "en": "rivet something in place"
        },
        {
          "no": "klinke sammen jernplater",
          "en": "rivet iron plates together"
        }
      ]
    },
    {
      "text": "slå, støte eller sparke hardt",
      "translation": "hit, bump, or kick hard",
      "examples": [
        {
          "no": "klinke til noen",
          "en": "clobber someone"
        },
        {
          "no": "de klinket hodene sammen så det sang",
          "en": "they banged their heads together so hard it rang"
        }
      ]
    }
