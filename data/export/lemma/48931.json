  "definitions": [
    {
      "text": "grave i eller blande sammen masse, væske eller lignende",
      "translation": "dig in, mix together mass, liquid",
      "examples": []
    },
    {
      "text": "grave, kare",
      "translation": "dig, scrabble",
      "examples": [
        {
          "no": "grisen roter i jorda",
          "en": "the pig roots in the soil"
        },
        {
          "no": "barna rotet med spader i molda",
          "en": "the children dug around in the soil with spades"
        }
      ]
    },
    {
      "text": "gjøre noe på en slik måte at det skaper rot og uorden",
      "translation": "do something in a way that creates mess and disorder",
      "examples": [
        {
          "no": "ikke rot i mine saker!",
          "en": "don't mess with my things!"
        },
        {
          "no": "rote seg opp i ubehageligheter",
          "en": "get oneself mixed up in trouble"
        }
      ]
    },
    {
      "text": "lete fram noe på en uforsiktig eller lite planlagt måte",
      "translation": "rummage for something in a careless or unplanned way",
      "examples": [
        {
          "no": "rote i veska etter noe",
          "en": "rummage in the bag for something"
        },
        {
          "no": "rote opp noen mynter fra lomma",
          "en": "scrape up some coins from your pocket"
        }
      ]
    },
    {
      "text": "gjøre noe uten en plan",
      "translation": "do something without a plan",
      "examples": []
    },
    {
      "text": "gjøre noe på måfå",
      "translation": "do something haphazardly",
      "examples": [
        {
          "no": "etter å ha rotet rundt i sentrum en time, fant vi omsider hotellet",
          "en": "after wandering around downtown for an hour, we finally found the hotel"
        }
      ]
    }
  ]
