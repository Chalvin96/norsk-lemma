  "cross_reference": null,
  "definitions": [
    {
      "text": "skryte av seg selv på en fordekt måte, forkledd som ydmykhet, selvironi eller lignende",
      "translation": "to boast about oneself in a disguised way, masked as humility or self-irony",
      "examples": [
        {
          "no": "han snikskryter når han sier at han er støl etter gårsdagens maraton",
          "en": "he's humblebragging when he says he's sore after yesterday's marathon"
        }
      ]
    }
  ]
