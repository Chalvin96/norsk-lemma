  "definitions": [
    {
      "text": "hvelvet rygg (med tilsvarende søkk) som danner seg på overflaten av vann, og som synes å bevege seg bortover",
      "translation": "arched back (with corresponding hollows) formed on the surface of water, which appears to move away",
      "examples": [
        {
          "no": "bølgene slo mot stranda",
          "en": "the waves crashed against the beach"
        },
        {
          "no": "bølgene gikk høye som hus",
          "en": "the waves rose as high as houses"
        }
      ]
    },
    {
      "text": "i overført betydning: noe som minner om en bølge",
      "translation": "something resembling a wave",
      "examples": []
    },
    {
      "text": "noe som strømmer fram eller brer seg",
      "translation": "something that flows forward or spreads",
      "examples": [
        {
          "no": "ha bølger i håret",
          "en": "have waves in one's hair"
        },
        {
          "no": "en bølge av hete slo mot oss",
          "en": "a wave of heat hit us"
        },
        {
          "no": "en bølge av arrestasjoner",
          "en": "a wave of arrests"
        },
        {
          "no": "ri på bølgen av nasjonale følelser",
          "en": "ride the wave of national sentiment"
        }
      ]
    },
    {
      "text": "i fysikk: det at en lokal tilstandsendring sprer seg i et medium",
      "translation": "in physics: the spreading of a local change in condition through a medium",
      "examples": [
        {
          "no": "elektromagnetiske bølger",
          "en": "electromagnetic waves"
        }
      ]
    }
  ]
