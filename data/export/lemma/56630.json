  "definitions": [
    {
      "text": "tale støtvis, hakkende og usikkert ofte på grunn av nervøsitet eller lignende",
      "translation": "to speak haltingly, jerkily, and uncertainly, often due to nervousness",
      "examples": [
        {
          "no": "bli nervøs og begynne å hakke og stamme",
          "en": "become nervous and start stumbling and stammering"
        }
      ]
    },
    {
      "text": "tale støtvis og gjenta stavelser på grunn av talevanske",
      "translation": "to speak haltingly and repeat syllables due to a speech impediment",
      "examples": [
        {
          "no": "barn som stammer, blir ofte ertet",
          "en": "children who stammer are often teased"
        }
      ]
    }
  ]
