  "definitions": [
    {
      "text": "ønske vel møtt eller farvel med ord eller bevegelse",
      "translation": "greet, bid farewell with words or gesture",
      "examples": [
        {
          "no": "hilse med hånden",
          "en": "greet with the hand"
        },
        {
          "no": "hilse i hånden",
          "en": "shake hands"
        },
        {
          "no": "de hilste hverandre med et kyss på kinnet",
          "en": "they greeted each other with a kiss on the cheek"
        },
        {
          "no": "den fremmede hilste ‘god kveld’ da han kom inn",
          "en": "the stranger said ‘good evening’ when he came in"
        }
      ]
    },
    {
      "text": "overbringe en hilsen",
      "translation": "convey greetings",
      "examples": [
        {
          "no": "hils alle kjente",
          "en": "give my regards to everyone you know"
        },
        {
          "no": "jeg skal hilse fra foreldrene mine",
          "en": "I am to give you regards from my parents"
        },
        {
          "no": "jeg skulle hilse og si takk for lånet",
          "en": "I was to say thanks for the loan"
        }
      ]
    },
    {
      "text": "i militæret: gjøre honnør",
      "translation": "in the military: salute",
      "examples": [
        {
          "no": "soldaten hilste med hånden til lua",
          "en": "the soldier saluted with his hand to his cap"
        },
        {
          "no": "du må stikke innom og hilse på oss en dag",
          "en": "you must drop by and visit us one day"
        },
        {
          "no": "i morgen skal jeg hilse på bestemor på sykehuset",
          "en": "tomorrow I'm going to visit Grandma in the hospital"
        },
        {
          "no": "bli hilst med sterkt bifall",
          "en": "be greeted with strong applause"
        }
      ]
    }
