  "definitions": [
    {
      "text": "tønne til å lagre krutt i",
      "translation": "barrel for storing gunpowder",
      "examples": []
    },
    {
      "text": "tønne med krutt i",
      "translation": "barrel with gunpowder in it",
      "examples": []
    },
    {
      "text": "i overført betydning: svært temperamentsfull og snarsint person",
      "translation": "very temperamental and quick-tempered person",
      "examples": [
        {
          "no": "han er en ordentlig kruttønne",
          "en": "he's a real hothead"
        }
      ]
    },
    {
      "text": "i overført betydning: situasjon eller område med sterke politiske spenninger (som kan føre til krig)",
      "translation": "situation or area with strong political tensions (that can lead to war)",
      "examples": [
        {
          "no": "området er en kruttønne",
          "en": "the area is a powder keg"
        }
      ]
