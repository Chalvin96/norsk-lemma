  "definitions": [
    {
      "text": "det å tro tru noe",
      "translation": "the act of believing something",
      "examples": []
    },
    {
      "text": "personlig mening eller tanke",
      "translation": "personal opinion or thought",
      "examples": []
    },
    {
      "text": "overbevisning, forestilling",
      "translation": "conviction, notion",
      "examples": [
        {
          "no": "det er min faste tro at det er slik",
          "en": "it is my firm belief that this is how it is"
        },
        {
          "no": "leve i den tro at alt er i orden",
          "en": "live in the belief that everything is in order"
        },
        {
          "no": "la dem bare bli i den troen",
          "en": "just let them remain in that belief"
        }
      ]
    },
    {
      "text": "sterk følelse av at noe vil gå bra eller utvikle seg positivt",
      "translation": "strong feeling that something will go well or develop positively",
      "examples": []
    },
    {
      "text": "tillit til at en person kan klare noe",
      "translation": "trust that a person can do something",
      "examples": []
    },
    {
      "text": "tiltro",
      "translation": "confidence",
      "examples": []
    },
    {
      "text": "motsatt mistro mistru",
      "translation": "distrust",
      "examples": [
        {
          "no": "ha god tro på seier",
          "en": "have great faith in victory"
        },
        {
          "no": "de mistet troen på at de ville lykkes",
          "en": "they lost faith that they would succeed"
        },
        {
          "no": "de har ikke tro på henne",
          "en": "they have no faith in her"
        }
      ]
    },
    {
      "text": "religiøs overbevisning",
