  "definitions": [
    {
      "text": "fange fisk",
      "translation": "to catch fish",
      "examples": [
        {
          "no": "dra ut for å fiske",
          "en": "go out fishing"
        },
        {
          "no": "fiske sei",
          "en": "fish for coalfish"
        }
      ]
    },
    {
      "text": "hente opp (særlig fra vann)",
      "translation": "to retrieve (especially from water)",
      "examples": [
        {
          "no": "fiske perler",
          "en": "fish for pearls"
        },
        {
          "no": "hun fisket en nøkkel opp av lomma",
          "en": "she fished a key out of her pocket"
        }
      ]
    },
    {
      "text": "prøve å oppnå noe (med å smiske eller lignende)",
      "translation": "to try to achieve something (by flattery or similar means)",
      "examples": [
        {
          "no": "fiske etter ros",
          "en": "fish for praise"
        }
      ]
    }
  ]
