  "definitions": [
    {
      "text": "lys- og energigivende stjerne som jorda og de andre planetene i solsystemet vårt kretser om, og som er forutsetningen for alt liv på jorda",
      "translation": "light and energy-giving star around which the Earth and other planets in our solar system orbit, and which is the prerequisite for all life on Earth",
      "examples": [
        {
          "no": "jorda går i bane rundt sola",
          "en": "the earth revolves around the sun"
        }
      ]
    },
    {
      "text": "i bestemt form entall: sol slik den oppleves fra jorda, med fast regelmessig gang over himmelhvelvingen",
      "translation": "sun as experienced from Earth, with a regular path across the sky",
      "examples": [
        {
          "no": "sola står opp i øst og går ned i vest",
          "en": "the sun rises in the east and sets in the west"
        },
        {
          "no": "sola stod høyt på himmelen",
          "en": "the sun stood high in the sky"
        },
        {
          "no": "sola gikk ned bak fjellet",
          "en": "the sun went down behind the mountain"
        },
        {
          "no": "vi så ikke sola i hele ferien",
          "en": "we didn't see the sun the whole vacation"
        }
      ]
    },
    {
