  "definitions": [
    {
      "text": "i nordisk folketro: overnaturlig vesen som holder til i nærheten av mennesker, særlig i uthusene på gårder, og tenkes som en liten, gråkledd mann med rød topplue og langt skjegg",
      "translation": "in folklore: a supernatural being that lives near humans, especially in the outbuildings of farms, and is thought of as a small, grey-clad man with a red cap and a long beard",
      "examples": [
        {
          "no": "sette ut grøt til nissen",
          "en": "put out porridge for the nisse"
        }
      ]
    },
    {
      "text": "nedsettende: tufs, tullebukk, fjompenisse",
      "translation": "a dope, a fool, a silly person",
      "examples": [
        {
          "no": "din nisse!",
          "en": "you idiot!"
        },
        {
          "no": "dere er noen ordentlige nisser",
          "en": "you are real idiots"
        },
        {
          "no": "nissen kom med pakker til barna",
          "en": "Santa brought presents to the children"
        }
      ]
    }
  ]
