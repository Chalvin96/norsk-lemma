    {
      "text": "om småfugler: lage korte toner",
      "translation": "of small birds: to make short sounds",
      "examples": [
        {
          "no": "fuglene kvitret og sang",
          "en": "the birds chirped and sang"
        }
      ]
    },
    {
      "text": "snakke på en måte som minner om fuglekvitter",
      "translation": "to talk in a way that resembles bird chirping",
      "examples": [
        {
          "no": "hun kvitret og lo hele tiden",
          "en": "she chirped and laughed all the time"
        },
        {
          "no": "hun må sjekke hva vennene kvitrer",
          "en": "she has to check what her friends are tweeting"
