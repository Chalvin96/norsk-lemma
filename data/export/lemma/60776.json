    {
      "text": "la krenkelse eller urett være glemt",
      "translation": "let an offense or wrong be forgotten",
      "examples": [
        {
          "no": "jeg tilgir det vonde du har gjort mot meg",
          "en": "I forgive the hurt you have done to me"
        },
        {
          "no": "de tilgav ham aldri",
          "en": "they never forgave him"
        }
      ]
    },
    {
      "text": "ikke ta ille opp",
      "translation": "do not take offense",
      "examples": []
    },
    {
      "text": "bere over med",
      "translation": "bear with",
      "examples": [
        {
          "no": "tilgi at jeg går ut et øyeblikk",
          "en": "forgive me for stepping out for a moment"
