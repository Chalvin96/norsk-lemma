  "definitions": [
    {
      "text": "svelge grådig og fort",
      "translation": "to swallow greedily and quickly",
      "examples": []
    },
    {
      "text": "svelge i store biter eller slurker",
      "translation": "to swallow in large bites or gulps",
      "examples": [
        {
          "no": "sluke maten",
          "en": "gulp down the food"
        },
        {
          "no": "sluke i seg noe",
          "en": "gulp something down"
        },
        {
          "no": "han gikk under og slukte vann",
          "en": "he went under and swallowed water"
        }
      ]
    },
    {
      "text": "uttale utydelig eller sløyfe ord eller lyder",
      "translation": "to pronounce indistinctly, slurring words or sounds",
      "examples": [
        {
          "no": "han mumler og sluker ordene",
          "en": "he mumbles and swallows his words"
        }
      ]
    },
    {
      "text": "se på eller lytte til (ukritisk og) med stor intensitet",
      "translation": "to gaze at or listen to with great intensity (uncritically)",
      "examples": [
        {
          "no": "hun sluker ham med øynene",
          "en": "she devours him with her eyes"
        },
        {
          "no": "de slukte hvert ord",
          "en": "they devoured every word"
        }
      ]
    },
    {
      "text": "legge under seg",
      "translation": "to engulf",
      "examples": []
    },
    {
      "text": "ta over",
      "translation": "to take over",
      "examples": [
        {
          "no": "de store landene sluker de små",
          "en": "the big countries swallow up the small ones"
        }
      ]
    },
    {
      "text": "la forsvinne",
      "translation": "to let disappear",
      "examples": [
        {
          "no": "mørket slukte henne",
          "en": "the darkness swallowed her"
        },
        {
          "no": "ovnen sluker en masse ved",
          "en": "the stove consumes a lot of wood"
        },
        {
          "no": "dette vil sluke en masse penger",
          "en": "this will swallow up a lot of money"
        },
        {
          "no": "arbeidet sluker all min tid",
          "en": "the work consumes all my time"
        }
      ]
    }
  ]
