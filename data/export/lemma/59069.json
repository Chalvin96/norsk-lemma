  "definitions": [
    {
      "text": "frambringe toner med stemmen, særlig slik at de blir til en melodi med ord",
      "translation": "produce tones with the voice, especially so that they become a melody with words",
      "examples": [
        {
          "no": "synge en sang",
          "en": "sing a song"
        },
        {
          "no": "de synger i et kor",
          "en": "they sing in a choir"
        },
        {
          "no": "alle sang med",
          "en": "everyone sang along"
        },
        {
          "no": "de synger falskt",
          "en": "they sing off-key"
        }
      ]
    },
    {
      "text": "lage lyder som minner om sang",
      "translation": "make sounds resembling singing",
      "examples": [
        {
          "no": "fuglene sang",
          "en": "the birds sang"
        },
        {
          "no": "gresshoppene sang langs veikanten",
          "en": "the grasshoppers sang along the roadside"
        },
        {
          "no": "jeg synes nordlendingene synger slik når de snakker",
          "en": "I think people from Northern Norway sound like they're singing when they talk"
        }
      ]
    },
    {
      "text": "klinge, gjalle",
      "translation": "ring out, resound",
      "examples": [
        {
          "no": "det sang i stålet når hammeren traff",
          "en": "the steel rang when the hammer struck"
        }
      ]
    },
    {
      "text": "suse, klukke",
      "translation": "hum, gurgle",
      "examples": [
        {
          "no": "bekken synger i sommerkvelden",
          "en": "the brook sings in the summer evening"
        },
        {
          "no": "det suste og sang for ørene",
          "en": "there was a rushing and ringing in the ears"
        },
        {
          "no": "naturen som dikteren synger om",
          "en": "the nature that the poet sings of"
        }
      ]
    }
  ]
