    {
      "text": "pengesum for felling av bestemte rovdyr eller skadedyr",
      "translation": "sum of money for the felling of certain predators or pests",
      "examples": [
        {
          "no": "innføre skuddpremie på kråker i området",
          "en": "introduce a bounty on crows in the area"
        },
        {
          "no": "i flere år var det skuddpremie på rødrev på øya",
          "en": "for several years there was a bounty on red foxes on the island"
        }
      ]
    },
    {
      "text": "brukt i overført betydning om det å uttrykke avsky for visse personer eller grupper",
      "translation": "used to express disgust for certain people or groups",
      "examples": [
        {
          "no": "det burde være skuddpremie på sånne som ham!",
          "en": "there ought to be a bounty on people like him!"
        }
