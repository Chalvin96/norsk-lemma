  "definitions": [
    {
      "text": "frambringe eller lage ved hjelp av prikker",
      "translation": "to produce or make using dots",
      "examples": [
        {
          "no": "prikke en linje",
          "en": "dot a line"
        },
        {
          "no": "prikke opp et mønster",
          "en": "dot in a pattern"
        },
        {
          "no": "prikke hull på en ballong",
          "en": "prick a hole in a balloon"
        }
      ]
    },
    {
      "text": "kjenne som stikk",
      "translation": "to feel like pricks",
      "examples": []
    },
    {
      "text": "jamfør prikkende",
      "translation": "prickling",
      "examples": [
        {
          "no": "det begynte å prikke i fingeren",
          "en": "his finger started to tingle"
        }
      ]
    },
    {
      "text": "berøre, slå lett",
      "translation": "to touch, lightly hit",
      "examples": [
        {
          "no": "prikke noen på skulderen",
          "en": "tap someone on the shoulder"
        }
      ]
    },
    {
      "text": "pirke på",
      "translation": "to pick at",
      "examples": []
    },
    {
      "text": "kritisere",
      "translation": "to criticize",
      "examples": [
        {
          "no": "du prikker på alt mulig",
          "en": "you criticize everything possible"
        }
      ]
    },
    {
      "text": "i ballspill: sparke, sende (i mål)",
      "translation": "in ball games: to kick, send (into goal)",
      "examples": [
        {
          "no": "prikke ballen i mål",
          "en": "poke the ball into the goal"
        }
      ]
    }
