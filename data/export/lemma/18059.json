    {
      "text": "merke med en viss verdi til å klistre på en postsending som betaling for frakten",
      "translation": "a mark with a certain value to be affixed to a postal item as payment for postage",
      "examples": [
        {
          "no": "sette frimerke på konvolutten",
          "en": "put a stamp on the envelope"
        },
        {
          "no": "samle på frimerker",
          "en": "collect stamps"
        }
      ]
    },
    {
      "text": "i idrett: ballspiller som hele tiden ligger nær og passer på en motspiller",
      "translation": "a ball player who constantly stays close to and guards an opponent",
      "examples": [
        {
          "no": "laget satte frimerke på kapteinen",
          "en": "the team put a marker on the captain"
        }
