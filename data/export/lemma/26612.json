    {
      "text": "ramme inn",
      "translation": "to frame",
      "examples": [
        {
          "no": "innramme bilder",
          "en": "frame pictures"
        },
        {
          "no": "ha innrammede fotografier på veggen",
          "en": "have framed photographs on the wall"
        }
      ]
    },
    {
      "text": "danne ramme omkring",
      "translation": "to form a frame around",
      "examples": [
        {
          "no": "vakre sandstrender som innrammer øya",
          "en": "beautiful sandy beaches framing the island"
        },
        {
          "no": "ansiktet var innrammet av mørkt, bølgende hår",
          "en": "the face was framed by dark, wavy hair"
        },
        {
          "no": "fortellingen i boka innrammes av de tidlige 60-årene",
