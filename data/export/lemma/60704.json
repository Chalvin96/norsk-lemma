    {
      "text": "det at noe går tilbake eller utvikler seg i ugunstig retning",
      "translation": "the act of something going backward, developing in an unfavorable direction",
      "examples": [
        {
          "no": "et tilbakeslag i økonomien",
          "en": "a setback in the economy"
        }
      ]
    },
    {
