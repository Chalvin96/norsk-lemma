  "definitions": [
    {
      "text": "berøre lett",
      "translation": "to touch lightly",
      "examples": []
    },
    {
      "text": "støte lett ved eller på",
      "translation": "to bump lightly against or on",
      "examples": [
        {
          "no": "tennisballen tøtsjet nettkanten",
          "en": "the tennis ball grazed the edge of the net"
        },
        {
          "no": "bilen tøtsjer borti gjerdet",
          "en": "the car brushes against the fence"
        }
      ]
    },
    {
      "text": "så vidt nevne eller ta for seg",
      "translation": "to mention or deal with only slightly",
      "examples": [
        {
          "no": "tøtsje innom spørsmålet",
          "en": "touch on the question"
        },
        {
          "no": "han tøtsjet bare emnet",
          "en": "he only touched on the subject"
        }
      ]
    }
  ]
