  "definitions": [
    {
      "text": "frambringe skurrende strupelyd",
      "translation": "produce a rasping guttural sound",
      "examples": [
        {
          "no": "en rype skarret oppe i lia",
          "en": "a ptarmigan rasped up on the hillside"
        }
      ]
    },
    {
      "text": "uttale ‘r’ ved at en hever den bakre delen av tunga mot drøvelen",
      "translation": "pronounce 'r' by raising the back of the tongue against the uvula",
      "examples": [
        {
          "no": "på Sørlandet og Sørvestlandet skarrer de",
          "en": "in Southern Norway and Southwestern Norway they use a uvular r"
        }
      ]
    }
