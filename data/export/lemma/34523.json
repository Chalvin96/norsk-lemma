  "cross_reference": null,
  "definitions": [
    {
      "text": "gjøre løs fra et feste",
      "translation": "to make loose from a fastening",
      "examples": [
        {
          "no": "løse en båt",
          "en": "cast off a boat"
        },
        {
          "no": "han løser hunden fra båndet",
          "en": "he unclips the dog from the leash"
        }
      ]
    },
    {
      "text": "gjøre fri fra forpliktelse, tvang eller lignende",
      "translation": "to make free from obligation or coercion",
      "examples": [
        {
          "no": "bli løst fra forpliktelsene sine",
          "en": "be released from one's obligations"
        },
        {
          "no": "løse noen ut av en vanskelig situasjon",
          "en": "get someone out of a difficult situation"
        }
      ]
    },
    {
      "text": "gjøre løsere eller romsligere",
      "translation": "to make looser or more spacious",
      "examples": []
    },
    {
      "text": "åpne, løsne",
      "translation": "to open, to loosen",
      "examples": [
        {
          "no": "løse en knute",
          "en": "untie a knot"
        },
        {
          "no": "han løste på snippen",
          "en": "he loosened his collar"
        },
        {
          "no": "hun løser grepet",
          "en": "she loosens her grip"
        }
      ]
    },
    {
      "text": "gi fritt løp",
      "translation": "to give free rein",
      "examples": []
    },
    {
      "text": "fyre av",
      "translation": "to fire (a weapon)",
      "examples": [
        {
          "no": "løse ild",
          "en": "open fire"
        },
        {
          "no": "de løste skudd",
          "en": "they fired shots"
        }
      ]
    },
    {
      "text": "blande et stoff i væske så det dannes en enhetlig blanding",
      "translation": "to mix a substance in a liquid so that a uniform mixture is formed",
      "examples": []
    },
    {
      "text": "jamfør løse opp",
      "translation": "to dissolve",
      "examples": [
        {
          "no": "løse en tablett i vann",
          "en": "dissolve a tablet in water"
        }
      ]
    },
    {
      "text": "finne svar eller forklaring på",
      "translation": "to find an answer or explanation for",
      "examples": [
        {
          "no": "løse gåter",
          "en": "solve riddles"
        },
        {
          "no": "løse kryssord",
          "en": "do crosswords"
        },
        {
          "no": "løse en ligning",
          "en": "solve an equation"
        }
      ]
    },
    {
      "text": "greie opp i",
      "translation": "to sort out",
      "examples": []
    },
    {
      "text": "ordne",
      "translation": "to arrange",
      "examples": [
        {
          "no": "løse et praktisk problem",
          "en": "solve a practical problem"
        }
      ]
    },
    {
      "text": "skaffe seg ved å betale for",
      "translation": "to obtain by paying for",
      "examples": []
    },
    {
      "text": "kjøpe",
      "translation": "to buy",
      "examples": [
        {
          "no": "løse billett",
          "en": "buy a ticket"
        },
        {
          "no": "stadig færre løser fiskekort i Oslomarka",
          "en": "fewer and fewer people buy fishing permits in the Oslo forests"
        }
      ]
    }
  ]
