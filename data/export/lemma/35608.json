  "cross_reference": null,
  "definitions": [
    {
      "text": "måle dybde i sjø eller vann med loddline eller annen dybdemåler",
      "translation": "to measure depth in the sea with a sounding line or other depth gauge",
      "examples": [
        {
          "no": "lodde havdybden",
          "en": "sound the ocean depth"
        }
      ]
    },
    {
      "text": "søke etter fisk med lodd eller ekkolodd",
      "translation": "to search for fish with a sounding lead or echo sounder",
      "examples": [
        {
          "no": "de loddet etter sild",
          "en": "they were sounding for herring"
        }
      ]
    },
    {
      "text": "i overført betydning: danne seg et inntrykk av noe en ikke kan observere direkte",
      "translation": "to form an impression of something that cannot be observed directly",
      "examples": [
        {
          "no": "lodde stemningen",
          "en": "sound out the mood"
        },
        {
          "no": "bruke folkeavstemninger for å lodde folkeviljen",
          "en": "use referendums to gauge the popular will"
        }
      ]
    },
    {
      "text": "bruke loddline, laser eller annet for å sørge for at noe blir loddrett",
      "translation": "to use a plumb line, laser, or other device to ensure something is vertical",
      "examples": [
        {
          "no": "lodde en mur",
          "en": "plumb a wall"
        }
      ]
    },
    {
      "text": "binde sammen to metallstykker med flytende metall",
      "translation": "to join two metal pieces with molten metal",
      "examples": [
        {
          "no": "lodde fast hanken til gryta",
          "en": "solder the handle onto the pot"
        },
        {
          "no": "lodde en kjele",
          "en": "solder a kettle"
        }
      ]
    }
  ]
