  "definitions": [
    {
      "text": "i kortspill: stikke med et trumfkort",
      "translation": "in card games: take with a trump",
      "examples": []
    },
    {
      "text": "bruke trumf",
      "translation": "play a trump",
      "examples": []
    },
    {
      "text": "i overført betydning: presse, tvinge",
      "translation": "in a figurative sense: to push, to force",
      "examples": [
        {
          "no": "trumfe sitt synspunkt gjennom",
          "en": "push one's point of view through"
        },
        {
          "no": "trumfe seg fram",
          "en": "push one's way through"
        },
        {
          "no": "sterke krefter trumfer seg til et nybygg",
          "en": "powerful interests push their way to a new building"
        }
      ]
    },
    {
      "text": "i overført betydning: overgå",
      "translation": "in a figurative sense: to surpass",
      "examples": [
        {
          "no": "trafikksikkerhet må trumfe alt",
          "en": "traffic safety must trump everything"
        }
