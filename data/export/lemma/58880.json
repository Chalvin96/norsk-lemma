    {
      "text": "lage, feste eller reparere med nål og tråd eller symaskin",
      "translation": "make, fasten, or repair with needle and thread or a sewing machine",
      "examples": [
        {
          "no": "han syr skjortene sine selv",
          "en": "he sews his shirts himself"
        },
        {
          "no": "hun syr helst på maskin",
          "en": "she prefers sewing by machine"
        },
        {
          "no": "jakka er ferdig når jeg har fått sydd i knappene",
          "en": "the jacket will be finished once I've sewn on the buttons"
        },
        {
          "no": "jeg må få skoen sydd hos en skomaker",
          "en": "I need to have the shoe stitched by a cobbler"
