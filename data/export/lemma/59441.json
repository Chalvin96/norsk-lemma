  "definitions": [
    {
      "text": "om eldre forhold: kristen asket eller eremitt som tilbrakte en stor del av sin tid på toppen av en søyle (ofte en rest fra et eldre tempel)",
      "translation": "in older contexts: a Christian ascetic or hermit who spent a large part of their time on top of a pillar (often a remnant from an older temple)",
      "examples": [
        {
          "no": "den mest kjente søylehelgenen er Simeon som tilbrakte 30 år på toppen av en søyle",
          "en": "the most famous stylite is Simeon, who spent 30 years on top of a pillar"
        },
        {
          "no": "flere søylehelgener dro ut i den syriske ødemarka",
          "en": "several stylites headed out into the Syrian wilderness"
        }
      ]
    }
