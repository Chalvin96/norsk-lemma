  "cross_reference": null,
  "definitions": [
    {
      "text": "presentere en idé, et prosjekt eller et produkt kortfattet til noen med tanke på samarbeid, salg eller lignende",
      "translation": "to present an idea, project, or product concisely to someone with a view to collaboration, sale",
      "examples": [
        {
          "no": "hun pitsjet prosjektet sitt til investoren",
          "en": "she pitched her project to the investor"
        },
        {
          "no": "du har to minutter på å pitsje ideen din",
          "en": "you have two minutes to pitch your idea"
        }
      ]
    }
  ]
