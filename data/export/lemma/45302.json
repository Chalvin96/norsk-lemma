  "definitions": [
    {
      "text": "brekke eller rykke løs (særlig del av plante)",
      "translation": "to break or pull off (especially a part of a plant)",
      "examples": []
    },
    {
      "text": "samle, sanke",
      "translation": "to gather, to collect",
      "examples": [
        {
          "no": "plukke blomster",
          "en": "pick flowers"
        },
        {
          "no": "de plukker blåbær",
          "en": "they pick blueberries"
        },
        {
          "no": "de plukket epler",
          "en": "they picked apples"
        },
        {
          "no": "plukke poeng",
          "en": "score points"
        }
      ]
    },
    {
      "text": "rive, nappe",
      "translation": "to tear, to pluck",
      "examples": [
        {
          "no": "plukke øyebrynene",
          "en": "pluck your eyebrows"
        },
        {
          "no": "plukke fjærene av en fugl",
          "en": "pluck the feathers off a bird"
        }
      ]
    },
    {
      "text": "fingre, pirke, pille",
      "translation": "to fiddle, to pick at",
      "examples": [
        {
          "no": "sitte og plukke på noe",
          "en": "sit picking at something"
        }
      ]
    }
