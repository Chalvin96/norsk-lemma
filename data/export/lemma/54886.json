  "definitions": [
    {
      "text": "ta seg fram på en forsiktig måte",
      "translation": "to move stealthily",
      "examples": []
    },
    {
      "text": "krype, smette",
      "translation": "to creep, to slip",
      "examples": [
        {
          "no": "hun smyger under dyna",
          "en": "she slips under the covers"
        },
        {
          "no": "en katt kommer smygende",
          "en": "a cat comes sneaking"
        }
      ]
    },
    {
      "text": "i kortspill: legge på et lavere kort enn det høyeste som er spilt ut (så en ikke får stikket)",
      "translation": "in card games: to play a lower card than the highest one played (to avoid winning a trick)",
      "examples": [
        {
          "no": "han spilte ut knekten, men jeg smøg med tieren",
          "en": "he led the jack, but I ducked with the ten"
        }
      ]
    },
    {
      "text": "innsmigre seg",
      "translation": "to insinuate oneself",
      "examples": [
        {
          "no": "jeg smyger ikke for en slik en som deg",
          "en": "I don't grovel to the likes of you"
        },
        {
          "no": "en smygende stemme",
          "en": "a wheedling voice"
        }
      ]
    },
    {
      "text": "trekke, dra, putte",
      "translation": "to pull, to draw, to put",
      "examples": [
        {
          "no": "smyge anorakken over hodet",
          "en": "pull the anorak over your head"
        },
        {
          "no": "smyge hånden ned i lomma",
          "en": "slip your hand down into your pocket"
        }
      ]
    }
  ]
