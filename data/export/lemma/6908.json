  "definitions": [
    {
      "text": "byggverk av stokker, jern- eller betongpåler langs for eksempel kanaler og elveløp for å hindre at grunnen glir ut",
      "translation": "structure of logs, iron or concrete piles along canals and riverbeds, for example, to prevent the ground from sliding out",
      "examples": [
        {
          "no": "sette opp et bolverk",
          "en": "put up a retaining structure"
        }
      ]
    },
    {
      "text": "i overført betydning: vern, beskyttelse",
      "translation": "defense, protection",
      "examples": [
        {
          "no": "et bolverk mot rasisme",
          "en": "a bulwark against racism"
        }
      ]
    }
  ]
