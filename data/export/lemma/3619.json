  "definitions": [
    {
      "text": "det å lede bort, avlede avleie",
      "translation": "the act of diverting, diverting water",
      "examples": [
        {
          "no": "avledning av vannet for å unngå flom",
          "en": "diversion of the water to avoid flooding"
        }
      ]
    },
    {
      "text": "det å lage ord av andre ord ved hjelp av forstavelse forstaving, endelse og/eller lydendring",
      "translation": "the act of forming words from other words using prefixes, suffixes, and/or sound changes",
      "examples": []
    },
    {
      "text": "jamfør avlede avleie",
      "translation": "compare derive",
      "examples": [
        {
          "no": "lage nye ord ved avledning",
          "en": "form new words by derivation"
        }
      ]
    },
    {
      "text": "avledet ord",
      "translation": "derived word",
      "examples": [
        {
          "no": "‘søknad’ er en avledning av ‘søke’",
          "en": "'søknad' is a derivation of 'søke'"
        }
