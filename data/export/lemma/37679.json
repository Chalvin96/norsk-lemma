  "definitions": [
    {
      "text": "hogge ut og bearbeide med hammer og meisel",
      "translation": "to carve out and shape with hammer and chisel",
      "examples": [
        {
          "no": "han stod som meislet i stein",
          "en": "he stood as if carved in stone"
        }
      ]
    },
    {
      "text": "brukt som adjektiv: med klare, regelmessige linjer",
      "translation": "used as: with clear, regular lines",
      "examples": [
        {
          "no": "meislede ansiktstrekk",
          "en": "chiselled features"
        }
      ]
    },
    {
      "text": "i overført betydning: feste seg i bevisstheten",
      "translation": "to be fixed in consciousness",
      "examples": [
        {
          "no": "ulykken vil for alltid stå meislet i hukommelsen hennes",
          "en": "the accident will forever be etched in her memory"
        }
      ]
