  "definitions": [
    {
      "text": "brenne med lysende flamme",
      "translation": "to burn with a bright flame",
      "examples": [
        {
          "no": "bålet flammer",
          "en": "the bonfire is blazing"
        }
      ]
    },
    {
      "text": "lyse opp (med røde og gule farger)",
      "translation": "to light up (with red and yellow colors)",
      "examples": [
        {
          "no": "nordlyset flammet over himmelen",
          "en": "the northern lights blazed across the sky"
        },
        {
          "no": "skogen flammer av heftige høstfarger",
          "en": "the forest is ablaze with vivid autumn colors"
        }
      ]
    },
    {
      "text": "vise tegn på sterk affekt",
      "translation": "to show signs of strong emotion",
      "examples": [
        {
          "no": "øynene flammet av sinne",
          "en": "his eyes blazed with anger"
        }
      ]
    },
    {
      "text": "flette (bånd) i mange farger",
      "translation": "to braid (ribbons) in many colors",
      "examples": []
    }
