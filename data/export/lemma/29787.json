  "definitions": [
    {
      "text": "skaffe seg noe mot betaling",
      "translation": "acquire something for payment",
      "examples": [
        {
          "no": "kjøpe noe dyrt",
          "en": "buy something expensive"
        },
        {
          "no": "jeg fikk kjøpt den billig på nettet",
          "en": "I managed to buy it cheaply online"
        },
        {
          "no": "du må nok kjøpe deg ny bil snart",
          "en": "you'll probably have to buy yourself a new car soon"
        },
        {
          "no": "kjøpe en bok om krigen",
          "en": "buy a book about the war"
        }
      ]
    },
    {
      "text": "oppnå ved hjelp av penger, gaver eller strev",
      "translation": "obtain through money, gifts, or effort",
      "examples": [
        {
          "no": "kjøpe seg stemmer",
          "en": "buy votes for oneself"
        },
        {
          "no": "kjøpe seg fri",
          "en": "buy oneself free"
        },
        {
          "no": "dommeren var kjøpt og betalt",
          "en": "the judge was bought and paid for"
        }
      ]
    },
    {
      "text": "tro på",
      "translation": "believe",
      "examples": [
