  "definitions": [
    {
      "text": "gi fast og varig form som ikke endrer seg over tid eller ved ytre påvirkning",
      "translation": "give a firm and lasting form that does not change over time or by external influence",
      "examples": [
        {
          "no": "pudderet fikserer kremen",
          "en": "the powder fixes the cream"
        },
        {
          "no": "fiksere cellecev for senere mikroskopiske undersøkelser",
          "en": "fix cell samples for later microscopic examination"
        }
      ]
    },
    {
      "text": "behandle fotografisk film kjemisk slik at den tåler lys",
      "translation": "chemically treat photographic film so that it is light-resistant",
      "examples": []
    },
    {
      "text": "behandle overflaten til et maleri eller lignende med fiksativ",
      "translation": "treat the surface of a painting or similar with fixative",
      "examples": []
    },
    {
      "text": "feste med fiksativ",
      "translation": "fasten with fixative",
      "examples": []
    },
    {
      "text": "slå fast",
      "translation": "establish",
      "examples": [
        {
          "no": "fiksere en pris",
          "en": "set a price"
        }
      ]
    },
    {
      "text": "konsentrere (sterkt) om",
      "translation": "concentrate (intensely) on",
      "examples": []
    },
    {
      "text": "låse fast",
      "translation": "lock in place",
      "examples": [
        {
          "no": "være fiksert på en detalj",
          "en": "be fixated on a detail"
        },
        {
          "no": "hun fikserte blikket på ham",
          "en": "she fixed her gaze on him"
        }
      ]
    }
