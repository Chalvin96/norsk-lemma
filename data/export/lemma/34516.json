  "cross_reference": null,
  "definitions": [
    {
      "text": "som ikke er bundet eller festet til noe",
      "translation": "not bound or attached to anything",
      "examples": []
    },
    {
      "text": "som har løsnet eller kan løses lett",
      "translation": "having come loose, can be easily detached",
      "examples": [
        {
          "no": "rive seg løs",
          "en": "break free"
        },
        {
          "no": "hunden er løs",
          "en": "the dog is loose"
        },
        {
          "no": "en sofa med løse puter",
          "en": "a sofa with loose cushions"
        },
        {
          "no": "sjuåringen har flere løse tenner",
          "en": "the seven-year-old has several loose teeth"
        }
      ]
    },
    {
      "text": "som ikke er samlet til et hele",
      "translation": "not gathered into a whole",
      "examples": []
    },
    {
      "text": "i enkelte deler",
      "translation": "in individual parts",
      "examples": [
        {
          "no": "løse deler",
          "en": "separate parts"
        },
        {
          "no": "notere på løse lapper",
          "en": "make notes on loose slips of paper"
        }
      ]
    },
    {
      "text": "som ikke er strammet eller kompakt, som ikke er fast oppbygd",
      "translation": "not tightened compactly, not firmly constructed",
      "examples": [
        {
          "no": "en løs knute",
          "en": "a loose knot"
        },
        {
          "no": "et løst håndtrykk",
          "en": "a limp handshake"
        },
        {
          "no": "en løs deig",
          "en": "a loose dough"
        },
        {
          "no": "løs grus",
          "en": "loose gravel"
        }
      ]
    },
    {
      "text": "som ikke er grundig",
      "translation": "not thorough",
      "examples": []
    },
    {
      "text": "upålitelig",
      "translation": "unreliable",
      "examples": [
        {
          "no": "et løst overslag",
          "en": "a rough estimate"
        },
        {
          "no": "løst snakk",
          "en": "loose talk"
        },
        {
          "no": "løse rykter",
          "en": "loose rumors"
        }
      ]
    },
    {
      "text": "uten forpliktelser",
      "translation": "without obligations",
      "examples": [
        {
          "no": "et løst forhold",
          "en": "a casual relationship"
        },
        {
          "no": "være løs og ledig",
          "en": "be unattached and free"
        },
        {
          "no": "ha en løsere tilknytning til arbeidslivet",
          "en": "have a looser connection to working life"
        }
      ]
    },
    {
      "text": "ustyrlig, uhemmet uhemma",
      "translation": "uncontrollable, unrestrained",
      "examples": [
        {
          "no": "løs ild",
          "en": "open fire"
