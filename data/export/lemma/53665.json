  "definitions": [
    {
      "text": "dreie skrue eller justere noe ved å snu eller vri på mekanisme",
      "translation": "turn a screw, adjust something by turning or twisting a mechanism",
      "examples": [
        {
          "no": "skru i en skrue",
          "en": "drive in a screw"
        },
        {
          "no": "skru av et hjul",
          "en": "take off a wheel"
        }
      ]
    },
    {
      "text": "sette i roterende bevegelse",
      "translation": "set in rotational motion",
      "examples": [
        {
          "no": "skru ballen i mål",
          "en": "curl the ball into the goal"
        }
      ]
    },
    {
      "text": "tvinge, presse, trykke",
      "translation": "force, press, push",
      "examples": [
        {
          "no": "skru utviklingen tilbake",
          "en": "turn back the course of development"
        },
        {
          "no": "skru prisene i været",
          "en": "drive prices sky-high"
        },
        {
          "no": "skuta ble skrudd ned av drivisen",
          "en": "the ship was forced down by the pack ice"
        }
      ]
    }
  ]
