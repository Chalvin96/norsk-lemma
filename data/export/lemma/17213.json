  "definitions": [
    {
      "text": "anelse eller fornemmelse på forhånd om at noe (ubehagelig) skal skje",
      "translation": "a premonition or feeling in advance that something (unpleasant) will happen",
      "examples": [
        {
          "no": "han ble grepet av en forutanelse",
          "en": "he was seized by a premonition"
        },
        {
          "no": "alle mine verste forutanelser slo til",
          "en": "all my worst premonitions came true"
        }
      ]
