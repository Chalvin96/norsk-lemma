  "definitions": [
    {
      "text": "vente på en anledning",
      "translation": "wait for an opportunity",
      "examples": []
    },
    {
      "text": "holde seg skjult og vokte på noe",
      "translation": "stay hidden and watch for something",
      "examples": [
        {
          "no": "katten lurer på fuglene",
          "en": "the cat is stalking the birds"
        },
        {
          "no": "det lurer farer hvor en går og står",
          "en": "dangers lurk wherever you go"
        },
        {
          "no": "vi visste ikke hva som lurte rundt hjørnet",
          "en": "we didn't know what was lurking around the corner"
        }
      ]
    },
    {
      "text": "spekulere eller gruble på",
      "translation": "speculate or ponder",
      "examples": [
        {
          "no": "hun lurte på hva han egentlig hadde ment med det han sa",
          "en": "she wondered what he had really meant by what he said"
        },
        {
          "no": "nå begynner jeg snart å lure på om de kommer",
          "en": "now I'm beginning to wonder whether they're coming"
        }
      ]
    },
    {
      "text": "bruke list",
      "translation": "use cunning",
      "examples": []
    },
    {
      "text": "smette, snike",
      "translation": "slip, sneak",
      "examples": [
        {
          "no": "lure seg til å gjøre noe",
          "en": "manage to do something on the sly"
        },
        {
          "no": "de lurte seg unna alt arbeidet",
          "en": "they snuck out of all the work"
        },
        {
          "no": "vi lurte oss forbi vakten",
          "en": "we sneaked past the guard"
        }
      ]
    },
    {
      "text": "narre, bedra, snyte",
      "translation": "deceive, trick, cheat",
      "examples": [
        {
          "no": "han er lett å lure",
          "en": "he is easy to fool"
        },
        {
          "no": "vi lot oss lure til å tro at det var sant",
          "en": "we let ourselves be fooled into believing that it was true"
        },
        {
          "no": "du lurer ikke meg!",
          "en": "you can't fool me!"
        }
      ]
    }
  ]
