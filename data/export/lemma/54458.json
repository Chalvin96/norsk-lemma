  "definitions": [
    {
      "text": "svinge eller slenge hit og dit",
      "translation": "swing or sway back and forth",
      "examples": [
        {
          "no": "kjelken slingret i svingene",
          "en": "the sled swerved in the bends"
        },
        {
          "no": "han slingret ut av rommet",
          "en": "he staggered out of the room"
        }
      ]
    },
    {
      "text": "om fartøy: bevege seg kraftig til siden i bølgene",
      "translation": "for a vessel: move strongly sideways in the waves",
      "examples": [
        {
          "no": "skipet slingret kraftig i den grove sjøen",
          "en": "the ship rolled heavily in the rough sea"
        }
      ]
    }
