  "definitions": [
    {
      "text": "utjevne utjamne, godtgjøre, erstatte",
      "translation": "to equalize, make up for, compensate, replace",
      "examples": [
        {
          "no": "økte utgifter må kompenseres ved høyere priser",
          "en": "increased expenses must be compensated for by higher prices"
        },
        {
          "no": "tapt arbeidsfortjeneste vil bli kompensert",
          "en": "lost earnings will be compensated"
        }
      ]
    },
    {
      "text": "i fysikk: utjevne (for eksempel feil på måleutstyr)",
      "translation": "in physics: to equalize (errors in measuring equipment)",
      "examples": []
    },
    {
      "text": "motvirke en mangel eller svakhet med å styrke andre funksjoner eller egenskaper",
      "translation": "to counteract a deficiency or weakness by strengthening other functions or characteristics",
      "examples": [
        {
          "no": "kompensere for sin indre uro med å være sykelig ryddig",
          "en": "compensate for his inner unrest by being pathologically tidy"
        }
      ]
    }
