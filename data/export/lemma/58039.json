  "definitions": [
    {
      "text": "holde oppe, oppreist eller på plass",
      "translation": "support, help",
      "examples": []
    },
    {
      "text": "støtte, hjelpe",
      "translation": "support, help",
      "examples": [
        {
          "no": "stø pasienten til senga",
          "en": "help the patient to bed"
        },
        {
          "no": "jeg stødde henne over golvetu",
          "en": "I helped her across the floor"
        },
        {
          "no": "stø seg på albuen",
          "en": "prop oneself up on one's elbow"
        }
      ]
    },
    {
      "text": "lene mot noe stabilt",
      "translation": "lean against something stable",
      "examples": [
        {
          "no": "stø seg på rekkverket",
          "en": "lean on the railing"
        },
        {
          "no": "eleven stødde hodet mot hendene",
          "en": "the student rested his head in his hands"
        },
        {
          "no": "stø ryggen mot en stein",
          "en": "rest one's back against a rock"
        },
        {
          "no": "jeg må stø meg på noe for å gå trygt",
          "en": "I have to lean on something to walk safely"
        }
      ]
    },
    {
      "text": "slutte seg til eller være enig i",
      "translation": "join or agree with",
      "examples": [
        {
          "no": "stø streiken",
          "en": "support the strike"
        },
        {
          "no": "jeg stør en god sak",
          "en": "I support a good cause"
        }
      ]
    },
    {
      "text": "bygge på eller finne støtte i",
      "translation": "be based on or find support in",
      "examples": [
        {
          "no": "stø seg på ny forskning",
          "en": "base oneself on new research"
        }
      ]
    }
  ]
