  "definitions": [
    {
      "text": "i flertall: celle selle i hjernens tinninglapp som har betydning for stedsansen og evnen til å orientere seg",
      "translation": "cell in the temporal lobe of the brain that is important for spatial sense and the ability to orient oneself",
      "examples": [
