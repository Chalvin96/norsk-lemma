  "definitions": [
    {
      "text": "redskap laget av et avlangt stykke av tre, metall eller lignende med en egg i den ene enden",
      "translation": "tool made of an oblong piece of wood, metal with an edge at one end",
      "examples": [
        {
          "no": "dele steinblokker med kiler",
          "en": "split stone blocks with wedges"
        },
        {
          "no": "feste øksa til skaftet med en kile",
          "en": "attach the axe to the handle with a wedge"
        }
      ]
    },
    {
      "text": "i overført betydning: noe som skiller",
      "translation": "in a figurative sense: something that separates",
      "examples": [
        {
          "no": "slå en kile inn i idyllen",
          "en": "drive a wedge into the idyll"
        }
      ]
    },
    {
      "text": "noe som er formet som et trekantet stykke",
      "translation": "something shaped like a triangular piece",
      "examples": [
        {
          "no": "sy inn en kile i kjolelivet",
          "en": "sew a gusset into the bodice"
        },
        {
          "no": "eiendommen dannet en kile mellom elva og veien",
          "en": "the property formed a wedge between the river and the road"
        }
      ]
    },
    {
      "text": "bolt mellom to maskindeler som kan løses opp",
      "translation": "bolt between two machine parts that can be loosened",
      "examples": []
    },
    {
      "text": "skrifttegn i kileskrift",
      "translation": "script character in cuneiform script",
