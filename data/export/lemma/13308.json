  "definitions": [
    {
      "text": "teste i ettertid for å kontrollere at noe fungerer i praksis, eller få bekreftet at noe stemmer",
      "translation": "to test afterwards to check if something works in practice, or to confirm if something is correct",
      "examples": [
        {
          "no": "de må etterprøve om produktet er sterkt nok",
          "en": "they must verify whether the product is strong enough"
        },
        {
          "no": "andre forskere må kunne etterprøve resultatet av eksperimentet",
          "en": "other researchers must be able to verify the result of the experiment"
        }
      ]
    }
  ]
