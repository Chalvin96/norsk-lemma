  "definitions": [
    {
      "text": "rive eller rispe med klør eller negler",
      "translation": "to scratch or tear with claws or nails",
      "examples": [
        {
          "no": "klore noen på kinnet",
          "en": "scratch someone on the cheek"
        },
        {
          "no": "bite og klore",
          "en": "bite and scratch"
        },
        {
          "no": "klore seg til blods",
          "en": "scratch oneself until one bleeds"
        }
      ]
    },
    {
      "text": "hogge, gripe tak med klør eller fingrer",
      "translation": "to grasp or cling with claws or fingers",
      "examples": [
        {
          "no": "klore seg fast",
          "en": "cling on"
        },
        {
          "no": "klore seg til bergveggen",
          "en": "cling to the rock face"
        }
      ]
    },
    {
      "text": "skrive eller tegne slurvete",
      "translation": "to write or draw sloppily",
      "examples": [
        {
          "no": "klore sammen et brev",
          "en": "scribble a letter"
        }
      ]
    }
  ]
