  "definitions": [
    {
      "text": "lede bort",
      "translation": "lead away",
      "examples": [
        {
          "no": "avlede varme",
          "en": "conduct heat away"
        },
        {
          "no": "avlede mistanken fra noen",
          "en": "divert suspicion away from someone"
        },
        {
          "no": "musikken avledet tankene deres",
          "en": "the music distracted them from their thoughts"
        },
        {
          "no": "avlede oppmerksomheten fra noen",
          "en": "divert attention away from someone"
        }
      ]
    },
    {
      "text": "danne som resultat (av), med utgangspunkt (i), slutte seg til (av noe annet)",
      "translation": "form as a result (of), based on (in), conclude (from something else)",
      "examples": [
        {
          "no": "avlede et nytt stoff av oljen",
          "en": "derive a new substance from the oil"
        },
        {
          "no": "av denne påstanden kan vi avlede at …",
          "en": "from this claim we can infer that ..."
        }
      ]
    },
    {
      "text": "i språkvitenskap: lage ord av andre ord ved hjelp av forstavelse forstaving, endelse og/eller lydendring",
      "translation": "create words from other words using prefixes, suffixes, and/or sound changes",
      "examples": [
        {
          "no": "‘dømme’ er avledet av ‘dom’",
          "en": "'dømme' is derived from 'dom'"
        }
      ]
    }
  ]
