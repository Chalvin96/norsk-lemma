  "definitions": [
    {
      "text": "særlig i skøyteløp: løp der to deltakere starter sammen",
      "translation": "race where two participants start together (especially in speed skating)",
      "examples": [
        {
          "no": "hun slo konkurrenten i samløpet",
          "en": "she beat her competitor in the paired race"
        }
      ]
    },
    {
      "text": "det at to eller flere elver, veier eller lignende møtes og fortsetter i ett løp",
      "translation": "the meeting of two or more rivers, roads, and continuing as one course",
      "examples": [
        {
          "no": "Glommas samløp med Vorma",
          "en": "the confluence of the Glomma and the Vorma"
        }
      ]
    }
  ]
