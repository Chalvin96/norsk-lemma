  "cross_reference": null,
  "definitions": [
    {
      "text": "sende noe eller noen gjennom lufta med hånden eller et redskap",
      "translation": "to send something or someone through the air with the hand or an implement",
      "examples": [
        {
          "no": "kaste terninger",
          "en": "roll the dice"
        },
        {
          "no": "han kastet kofferten på sofaen",
          "en": "he threw the suitcase onto the sofa"
        },
        {
          "no": "de kastet jord på kisten",
          "en": "they threw dirt on the coffin"
        }
      ]
    },
    {
      "text": "slenge eller legge fra seg",
      "translation": "to fling or lay down",
      "examples": [
        {
          "no": "kaste alt en har i hendene",
          "en": "throw down everything one has in one's hands"
        },
        {
          "no": "de kaster løvet i en haug",
          "en": "they throw the leaves into a pile"
        },
        {
          "no": "han kastet genseren på stolen",
          "en": "he threw the sweater onto the chair"
        },
        {
          "no": "de kastet fram et forslag",
          "en": "they put forward a proposal"
        }
      ]
    },
    {
      "text": "bevege brått",
      "translation": "to move suddenly",
      "examples": [
        {
          "no": "kaste børsa til kinnet",
          "en": "raise the rifle to one's cheek"
        },
        {
          "no": "de kaster seg ned",
          "en": "they throw themselves down"
        },
        {
          "no": "hun kastet bilen til side",
          "en": "she swerved the car aside"
        },
        {
          "no": "du kaster bort tiden",
          "en": "you're wasting time"
        }
      ]
    },
    {
      "text": "sette not eller line i sjøen",
      "translation": "to set net or line in the sea",
      "examples": [
        {
          "no": "kaste etter sild",
          "en": "cast for herring"
        }
      ]
    },
    {
      "text": "sende",
      "translation": "to send",
      "examples": []
    },
    {
      "text": "lage",
      "translation": "to make",
      "examples": [
        {
          "no": "kaste skygge",
          "en": "cast a shadow"
        },
        {
          "no": "lyden ble kastet tilbake",
          "en": "the sound was thrown back"
        }
      ]
    },
    {
      "text": "i overført betydning: sende, overføre, skape",
      "translation": "to send, transfer, create",
      "examples": [
        {
          "no": "han prøver å kaste mistanken over på søsteren",
          "en": "he tries to cast suspicion on his sister"
        },
        {
          "no": "de kastet frifinnelsen i tvil",
          "en": "they cast doubt on the acquittal"
        }
      ]
    },
    {
      "text": "flytte med makt",
      "translation": "to move by force",
      "examples": []
    },
    {
      "text": "jage ut, fordrive",
      "translation": "to drive out, expel",
      "examples": [
        {
          "no": "de kastet ham i fengsel",
          "en": "they threw him in prison"
        }
      ]
    },
    {
      "text": "om dyr: føde for tidlig",
      "translation": "of animals: to give birth prematurely",
      "examples": [
        {
          "no": "kua kastet kalven",
          "en": "the cow miscarried the calf"
        }
      ]
    },
    {
      "text": "sy over stoffkant med kastesting",
      "translation": "to sew over the edge of fabric with a catch stitch",
      "examples": []
    }
