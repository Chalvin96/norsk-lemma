  "cross_reference": null,
  "definitions": [
    {
      "text": "med samme farge som nyfallen snø (et fargeinntrykk som kommer fram når nesten alt lyset blir kastet tilbake)",
      "translation": "having the same color as freshly fallen snow (a color impression that arises when almost all light is reflected)",
      "examples": [
        {
          "no": "hvit skjorte",
          "en": "white shirt"
        },
        {
          "no": "blendende hvitt tøy",
          "en": "blindingly white cloth"
        },
        {
          "no": "det hvite papiret",
          "en": "the white paper"
        },
        {
          "no": "smile med hvite tenner",
          "en": "smile with white teeth"
        }
      ]
    },
    {
      "text": "om person eller folkegruppe: som har medfødt lys hudfarge",
      "translation": "of a person or ethnic group: having congenital light skin color",
      "examples": []
    },
    {
      "text": "jamfør brun og svart",
      "translation": "brown and black",
      "examples": [
        {
          "no": "hvite kvinner fra Europa",
          "en": "white women from Europe"
        },
        {
          "no": "den hvite befolkningen i Sør-Afrika",
          "en": "the white population in South Africa"
        },
        {
          "no": "det økonomiske gapet mellom hvite og svarte i USA",
          "en": "the economic gap between whites and blacks in the USA"
        }
      ]
    },
    {
      "text": "om person: med unormalt lys hudfarge, for eksempel på grunn av sinnsbevegelse eller anstrengelse",
      "translation": "of a person: with abnormally light skin color, for example due to emotional distress or exertion",
      "examples": [
        {
          "no": "være hvit i ansiktet av sinne",
          "en": "be white in the face with anger"
        },
        {
          "no": "holde så hardt at knokene blir hvite",
          "en": "grip so hard that the knuckles turn white"
        }
      ]
    },
    {
      "text": "om penger: tjent på lovlig vis",
      "translation": "of money: earned legally",
      "examples": []
    },
    {
      "text": "til forskjell fra svart",
      "translation": "black",
      "examples": [
        {
          "no": "hvitt arbeid",
          "en": "legal work"
        },
        {
          "no": "svarte og hvite penger",
          "en": "black and white money"
        },
        {
          "no": "legge til rette for hvit betaling",
          "en": "facilitate legal payment"
        },
        {
          "no": "betale hvitt",
          "en": "pay legally"
        }
      ]
    },
    {
      "text": "brukt som substantiv: sjakkspiller med hvite brikker",
      "translation": "used as a noun: chess player with white pieces",
      "examples": [
        {
          "no": "hvit flytter kongen",
          "en": "White moves the king"
        },
        {
          "no": "hvits første trekk",
          "en": "White's first move"
        }
      ]
    },
    {
      "text": "om eldre forhold, brukt som substantiv: antirevolusjonær, antikommunistisk (etter den hvite liljen på våpenskjoldet til den franske fyrstefamilien Bourbon)",
      "translation": "of older circumstances, used as a noun: anti-revolutionary, anti-communist (after the white lily on the coat of arms of the French royal family Bourbon)",
      "examples": [
        {
          "no": "kampen mellom de røde og de hvite",
          "en": "the struggle between the Reds and the Whites"
