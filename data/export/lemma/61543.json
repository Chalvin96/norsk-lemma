  "cross_reference": null,
  "definitions": [
    {
      "text": "ha mot til",
      "translation": "to have the courage to",
      "examples": [
        {
          "no": "jeg tør ikke tenke på hva som kunne ha hendt",
          "en": "I dare not think about what could have happened"
        },
        {
          "no": "hun torde ikke å svare",
          "en": "she did not dare to answer"
        },
        {
          "no": "bare gjør det om du tør",
          "en": "just do it if you dare"
        },
        {
          "no": "de torde ikke forstyrre henne",
          "en": "they did not dare disturb her"
        }
      ]
    },
    {
      "text": "være mulig, sannsynlig eller rimelig",
      "translation": "to be possible, probable, or reasonable",
      "examples": []
    },
    {
      "text": "kunne kanskje",
      "translation": "to possibly",
      "examples": [
        {
          "no": "det torde være flere som kommer",
          "en": "there may well be more people coming"
        },
        {
          "no": "jeg tør minne på at alle må registrere seg før de kommer",
          "en": "I dare remind you that everyone must register before they arrive"
        },
        {
          "no": "dette tør være det viktigste",
          "en": "this may well be the most important thing"
        }
      ]
    }
  ]
