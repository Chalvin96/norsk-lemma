  "definitions": [
    {
      "text": "lage bilde av eller gjengi ved hjelp av streker",
      "translation": "to create a picture of or represent using lines",
      "examples": [
        {
          "no": "lære å tegne",
          "en": "learn to draw"
        },
        {
          "no": "tegne etter naturen",
          "en": "draw from nature"
        },
        {
          "no": "han tegner en blomst",
          "en": "he is drawing a flower"
        }
      ]
    },
    {
      "text": "framstille skisse, plan eller lignende med streker",
      "translation": "to produce a sketch, plan, or similar using lines",
      "examples": [
        {
          "no": "tegne et hus",
          "en": "draw a house"
        },
        {
          "no": "tegne nye møbelmodeller",
          "en": "design new furniture models"
        }
      ]
    },
    {
      "text": "skrive, notere",
      "translation": "to write, to note down",
      "examples": [
        {
          "no": "tegne ned noen ord",
          "en": "write down a few words"
        }
      ]
    },
    {
      "text": "gi en forpliktende underskrift på brev, kontrakter eller lignende",
      "translation": "to sign, to obtain a share in, to become the owner of",
      "examples": [
        {
          "no": "tegne nye medlemmer",
          "en": "sign up new members"
        },
        {
          "no": "tegne seg på talerlista",
          "en": "put one's name on the speakers' list"
        }
      ]
    },
    {
      "text": "sikre seg, få del i, bli eier av",
      "translation": "to secure, to get a share of, to become the owner of",
      "examples": [
        {
          "no": "tegne forsikring",
          "en": "take out insurance"
        },
        {
          "no": "hun tegnet seg for 1000 kr på gavelista",
          "en": "she pledged NOK 1,000 on the gift list"
        }
      ]
    },
    {
      "text": "vise tegn til",
      "translation": "to show signs of",
      "examples": []
    },
    {
      "text": "peke i retning av",
      "translation": "to point in the direction of",
      "examples": [
        {
          "no": "begynnelsen tegnet bra",
          "en": "the beginning looked promising"
        }
      ]
    },
    {
      "text": "skildre i ord",
      "translation": "to depict in words",
      "examples": [
        {
          "no": "tegne et dystert bilde av framtiden",
          "en": "paint a bleak picture of the future"
        }
      ]
    }
