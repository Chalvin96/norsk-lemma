        }
      ]
    },
    {
      "text": "drive fram grøde",
      "translation": "to grow produce",
      "examples": [
        {
          "no": "dyrke korn",
          "en": "grow grain"
        },
        {
          "no": "de dyrker gulrøtter bak huset",
