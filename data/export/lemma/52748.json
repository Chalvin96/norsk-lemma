  "definitions": [
    {
      "text": "fjerne eller føre fra hverandre",
      "translation": "to remove or move apart",
      "examples": [
        {
          "no": "skille barken fra veden",
          "en": "separate the bark from the wood"
        },
        {
          "no": "skille to som slåss",
          "en": "separate two people who are fighting"
        },
        {
          "no": "skille gutter og jenter",
          "en": "separate boys and girls"
        }
      ]
    },
    {
      "text": "danne grense",
      "translation": "to form a border",
      "examples": []
    },
    {
      "text": "dele",
      "translation": "to divide",
      "examples": [
        {
          "no": "høye fjell skiller Østlandet og Vestlandet",
          "en": "high mountains separate eastern and western Norway"
        }
      ]
    },
    {
      "text": "danne forskjell eller motsetning",
      "translation": "to form a difference or contrast",
      "examples": [
        {
          "no": "det er mye som skiller dem",
          "en": "there is a lot that sets them apart"
        },
        {
          "no": "det skilte bare tre sekunder mellom første- og andremann",
          "en": "only three seconds separated first and second place"
        }
      ]
    },
    {
      "text": "vedkomme, rake, skjelle",
      "translation": "to concern, relate to, be relevant to",
      "examples": [
        {
          "no": "hva skiller det deg?",
          "en": "what is it to you?"
        }
      ]
    },
    {
      "text": "holde fra hverandre",
      "translation": "to keep apart",
      "examples": [
        {
          "no": "hun kunne ikke skille dem fra hverandre",
          "en": "she could not tell them apart"
        }
      ]
    }
  ]
