  "definitions": [
    {
      "text": "merke med julemotiv til å sette på postsendinger ved juletider",
      "translation": "stamp with a Christmas motif to be put on mail during the Christmas season",
      "examples": []
    },
    {
      "text": "om eldre forhold: merke som på hver av de tolv juledagene (25. desember–5. januar) ble satt i vegg eller takbjelke for å vise været disse dagene, og som gav varsel om været de tilsvarende tolv månedene i året",
      "translation": "mark that on each of the twelve days of Christmas (December 25th–January 5th) was placed in the wall or ceiling beam to show the weather on those days, and which gave a forecast of the weather for the corresponding twelve months of the year",
      "examples": []
    },
    {
      "text": "jamfør solemerke solmerke",
      "translation": "sun mark",
      "examples": []
    }
