  "cross_reference": null,
  "definitions": [
    {
      "text": "passe og stelle et sykt eller svakt menneske eller dyr",
      "translation": "to care for and tend to a sick or weak person or animal",
      "examples": [
        {
          "no": "pleie den syke",
          "en": "care for the sick person"
        },
        {
          "no": "han pleide den gamle moren sin",
          "en": "he cared for his old mother"
        }
      ]
    },
    {
      "text": "stelle (en del av) kroppen så den holdes ren og sunn",
      "translation": "to groom (a part of) the body so it is kept clean and healthy",
      "examples": [
        {
          "no": "pleie kroppen sin",
          "en": "take care of one's body"
        },
        {
          "no": "hun pleier neglene regelmessig",
          "en": "she takes care of her nails regularly"
        }
      ]
    },
    {
      "text": "holde noe i god stand",
      "translation": "to keep something in good condition",
      "examples": [
        {
          "no": "hun pleide bilen med voks",
          "en": "she treated the car with wax"
        },
        {
          "no": "pleie kulturlandskapet",
          "en": "maintain the cultural landscape"
        }
      ]
    },
    {
      "text": "holde ved like",
      "translation": "to maintain",
      "examples": [
        {
          "no": "de pleier kontakt med venner",
          "en": "they keep in touch with friends"
        },
        {
          "no": "ha tid til å pleie sine interesser",
          "en": "have time to cultivate one's interests"
        }
      ]
    }
