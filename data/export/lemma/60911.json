  "definitions": [
    {
      "text": "langsom, jevn vannstrøm til brønn, tjern, bekk eller lignende",
      "translation": "slow, steady flow of water to a well, pond, or stream",
      "examples": [
        {
          "no": "det er alltid vann i brønnen på grunn av tilsig fra tjernet",
          "en": "there is always water in the well because of inflow from the pond"
        }
      ]
    },
    {
      "text": "i overført betydning: gradvis økning eller tilstrømming",
      "translation": "gradual increase or influx",
      "examples": [
        {
          "no": "tilsig av folk",
          "en": "an influx of people"
        },
        {
          "no": "klubben har fått et jevnt tilsig av nye medlemmer",
          "en": "the club has had a steady influx of new members"
        }
      ]
    }
