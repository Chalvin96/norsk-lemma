  "definitions": [
    {
      "text": "styre skip, fly eller annet fartøy",
      "translation": "steer a ship, aircraft, or other vessel",
      "examples": [
        {
          "no": "navigere i ukjent farvann",
          "en": "navigate in unfamiliar waters"
        }
      ]
    },
    {
      "text": "bestemme posisjon og kurs",
      "translation": "determine position and course",
      "examples": [
        {
          "no": "ha stjerner å navigere etter",
          "en": "have stars to navigate by"
        }
      ]
    },
    {
      "text": "flytte seg i en digital struktur",
      "translation": "move within a digital structure",
      "examples": [
        {
          "no": "navigere på nettet",
          "en": "navigate online"
        },
        {
          "no": "bruke mus for å navigere",
          "en": "use a mouse to navigate"
        }
      ]
    },
    {
      "text": "handle slik at en oppnår det en ønsker",
      "translation": "act in such a way as to achieve what one desires",
      "examples": [
        {
          "no": "navigere klokt mellom fag og politikk",
          "en": "navigate wisely between academia and politics"
        }
      ]
    },
    {
      "text": "finne fram, orientere seg",
      "translation": "find one's way, orient oneself",
      "examples": [
        {
          "no": "navigere i jungelen av kosttilskudd",
          "en": "navigate the jungle of dietary supplements"
        }
      ]
    }
