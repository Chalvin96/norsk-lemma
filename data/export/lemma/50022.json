  "definitions": [
    {
      "text": "det at flere (musikere, skuespillere, idrettsfolk eller lignende) spiller sammen på en bestemt måte",
      "translation": "the way several (musicians, actors, athletes) play together in a specific manner",
      "examples": [
        {
          "no": "samspillet mellom skuespillerne var godt",
          "en": "the interplay between the actors was good"
        }
      ]
    },
    {
      "text": "det at flere faktorer virker sammen",
      "translation": "the way several factors work together",
      "examples": [
        {
          "no": "samspillet i naturen må ikke forstyrres",
          "en": "the interplay in nature must not be disturbed"
        }
      ]
    }
  ]
