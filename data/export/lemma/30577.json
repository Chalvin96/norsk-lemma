    {
      "text": "blande elementer fra skriftspråk, et annet språk eller andre dialekter inn i eget talemål",
      "translation": "to mix elements from written language, another language or other dialects into one's own speech",
      "examples": [
        {
          "no": "knote på engelsk",
          "en": "speak broken English"
        },
        {
          "no": "stadig flere unge knoter",
          "en": "more and more young people mix dialects"
        }
      ]
    },
