  "cross_reference": null,
  "definitions": [
    {
      "text": "kroppsdel ytterst på arm, med fingre som blant annet kan gripe og holde",
      "translation": "body part at the end of the arm, with fingers that can grasp and hold",
      "examples": [
        {
          "no": "ha små hender",
          "en": "have small hands"
        },
        {
          "no": "vaske hendene",
          "en": "wash one's hands"
        },
        {
          "no": "gripe noe med hånden",
          "en": "grasp something with one's hand"
        },
        {
          "no": "ha hendene på ryggen",
          "en": "have one's hands behind one's back"
        }
      ]
    },
    {
      "text": "brukt i uttrykk for hilsen, overenskomst eller lignende",
      "translation": "used in expressions for greeting, agreement",
      "examples": [
        {
          "no": "takke i hånden",
          "en": "thank someone with a handshake"
        },
        {
          "no": "ta noen i hånden",
          "en": "take someone by the hand"
        }
      ]
    },
    {
      "text": "brukt i uttrykk for arbeid, virksomhet, medvirkning eller lignende",
      "translation": "used for work, activity, participation",
      "examples": [
        {
          "no": "ikke løfte en hånd for å hjelpe",
          "en": "not lift a hand to help"
        },
        {
          "no": "ikke ta sin hånd i noen ting",
          "en": "not have a hand in anything"
        },
        {
          "no": "vi kan vente flere bøker fra hans hånd",
          "en": "we can expect more books from his hand"
        },
        {
          "no": "skaffe arbeid til alle ledige hender",
          "en": "find work for all idle hands"
        }
      ]
    },
    {
      "text": "brukt i uttrykk for eiendom, forvaring, makt, vern eller lignende",
      "translation": "used for property, custody, power, protection",
      "examples": [
        {
          "no": "ha mange penger mellom hendene",
          "en": "have a lot of money passing through one's hands"
        },
        {
          "no": "samle makten på få hender",
          "en": "concentrate power in few hands"
        },
        {
          "no": "være i trygge hender",
          "en": "be in safe hands"
        },
        {
          "no": "det står i Guds hånd",
          "en": "it is in God's hands"
        }
      ]
    },
    {
      "text": "side, kant, plassering i forhold til en person",
      "translation": "side, edge, position relative to a person",
      "examples": [
        {
          "no": "det tredje huset på venstre hånd",
          "en": "the third house on the left-hand side"
        },
        {
          "no": "sitte ved Guds høyre hånd",
          "en": "sit at God's right hand"
        }
      ]
    },
    {
      "text": "samling av kort som en spiller får utdelt i kortspill",
      "translation": "collection of cards dealt to a player in a card game",
      "examples": [
        {
          "no": "sitte med en god hånd",
          "en": "sit with a good hand"
        },
        {
          "no": "ha en leselig hånd",
          "en": "have legible handwriting"
        }
      ]
    }
