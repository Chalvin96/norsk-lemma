  "definitions": [
    {
      "text": "væte ut eller skitne til noe med noe vått og skittent, for eksempel vann, gjørme eller lignende",
      "translation": "to wet or soil something with something wet and dirty, water, mud",
      "examples": []
    },
    {
      "text": "grise, skitne",
      "translation": "to mess, to soil",
      "examples": [
        {
          "no": "nå må du ikke søle så fælt!",
          "en": "now don't make such a mess!"
        },
        {
          "no": "hun søler til klærne sine",
          "en": "she gets her clothes dirty"
        },
        {
          "no": "de sølte med malingen",
          "en": "they made a mess with the paint"
        }
      ]
    },
    {
      "text": "kaste bort",
      "translation": "to waste",
      "examples": []
    },
    {
      "text": "rote, somle, tulle",
      "translation": "to mess around, to dawdle, to fool around",
      "examples": [
        {
          "no": "han søler bort tiden sin",
          "en": "he wastes his time"
