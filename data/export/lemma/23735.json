  "definitions": [
    {
      "text": "språk som brukes mellom folk fra ulike språksamfunn, særlig et som ikke er morsmål for noen av partene",
      "translation": "language used between people from different language communities, especially one that is not the native language of any of the parties",
      "examples": [
        {
          "no": "engelsk fungerer som hjelpespråk i store deler av verden",
          "en": "English functions as a lingua franca in large parts of the world"
        }
      ]
    },
    {
      "text": "hjelpespråk som ikke er nasjonalspråk",
      "translation": "auxiliary language that is not a national language",
      "examples": [
        {
          "no": "av internasjonale hjelpespråk er esperanto det mest suksessrike",
          "en": "of international auxiliary languages, Esperanto is the most successful"
