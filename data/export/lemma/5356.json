  "definitions": [
    {
      "text": "føre eller hjelpe til et trygt sted fra et sted der det er fare for skade eller ødeleggelse",
      "translation": "to bring to a safe place from a place of danger or destruction",
      "examples": []
    },
    {
      "text": "redde, frelse",
      "translation": "rescue, save",
      "examples": [
        {
          "no": "mannskapet på den forliste båten ble berget",
          "en": "the crew of the wrecked boat were rescued"
        },
        {
          "no": "de berget livet ved å hoppe ut gjennom vinduet",
          "en": "they saved their lives by jumping out through the window"
        }
      ]
    },
    {
      "text": "bringe i hus, sikkerhet",
      "translation": "bring in, to safety",
      "examples": [
        {
          "no": "berge avlingen",
          "en": "save the harvest"
        }
      ]
    },
    {
      "text": "i idrett, i overført betydning: unngå tap, nedrykk",
      "translation": "avoid loss, relegation",
      "examples": [
        {
          "no": "berge seieren",
          "en": "save the victory"
        }
      ]
    }
