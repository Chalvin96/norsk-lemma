  "definitions": [
    {
      "text": "lem, liten dør til å stenge en åpning med",
      "translation": "hatch, small door to close an opening",
      "examples": []
    },
    {
      "text": "lem til å dekke lasterom med",
      "translation": "hatch to cover a cargo hold",
      "examples": [
        {
          "no": "mannskapet tok av lukene",
          "en": "the crew took off the hatches"
        }
      ]
    },
    {
      "text": "åpning, glugge i en vegg, et skipsdekk eller lignende",
      "translation": "opening, hatch in a wall, a ship's deck",
      "examples": [
        {
          "no": "sitte i luka på postkontoret",
          "en": "sit at the post office window"
        },
        {
          "no": "skalke lukene",
          "en": "batten down the hatches"
        }
      ]
    },
    {
      "text": "lasterom på skip",
      "translation": "cargo hold on a ship",
      "examples": [
        {
          "no": "skipet har fem luker, to akterut og tre forut",
          "en": "the ship has five holds, two aft and three forward"
        }
      ]
    },
    {
      "text": "lomme, mellomrom, tomrom, for eksempel mellom spillere på en fotballbane",
      "translation": "gap, space, void between players on a football field",
      "examples": [
        {
          "no": "parkere i en luke",
          "en": "park in a space"
        },
        {
          "no": "det oppstod farlige luker i forsvaret",
          "en": "dangerous gaps opened up in the defense"
        },
        {
          "no": "det ble en luke på ti meter mellom teten og hovedfeltet",
          "en": "a gap of ten meters opened up between the leaders and the main field"
        }
      ]
    }
