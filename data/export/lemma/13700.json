  "definitions": [
    {
      "text": "innretning med en stor duk som folder seg ut som en paraply, og som reduserer farten ved fall fra store høyder, særlig fra fly",
      "translation": "device with a large fabric that unfolds like an umbrella, reducing speed during falls from great heights, especially from aircraft",
      "examples": [
        {
          "no": "hoppe ut i fallskjerm",
          "en": "jump out with a parachute"
        },
        {
          "no": "fallskjermen foldet seg ikke ut",
          "en": "the parachute did not open"
        },
        {
          "no": "droppe forsyninger med fallskjerm",
          "en": "drop supplies by parachute"
        }
      ]
    },
    {
      "text": "i overført betydning: godtgjørelse godtgjøring som personer i lederstillinger kan få om de må slutte før kontrakttiden er ute",
      "translation": "severance pay for executives who must leave before their contract term is up",
      "examples": [
        {
          "no": "han fikk en gyllen fallskjerm",
          "en": "he got a golden parachute"
        }
      ]
