  "definitions": [
    {
      "text": "gjøre opp ild og la brenne",
      "translation": "make a fire and let it burn",
      "examples": []
    },
    {
      "text": "tilintetgjøre eller ødelegge med ild",
      "translation": "destroy or damage with fire",
      "examples": [
        {
          "no": "brenne bål",
          "en": "light a bonfire"
        },
        {
          "no": "brenne søppel",
          "en": "burn trash"
        },
        {
          "no": "hun brente gamle aviser",
          "en": "she burned old newspapers"
        },
        {
          "no": "han har brent alle brevene",
          "en": "he has burned all the letters"
        }
      ]
    },
    {
      "text": "lage merke eller hull med ild eller varme",
      "translation": "make a mark or hole with fire or heat",
      "examples": [
        {
          "no": "gloa brente hull i teppet",
          "en": "the ember burned a hole in the carpet"
        }
      ]
    },
    {
      "text": "lage eller behandle noe med ild, varme, laser eller lignende",
      "translation": "make or process something with fire, heat, laser",
      "examples": [
        {
          "no": "brenne kaffe",
          "en": "roast coffee"
        },
        {
          "no": "brenne brennevin",
          "en": "distill liquor"
        },
        {
          "no": "brenne tjære",
          "en": "burn tar"
        },
        {
          "no": "brenne cd-er",
          "en": "burn CDs"
        }
      ]
    },
    {
      "text": "skade eller bli skadd ved bruk av ild, varme eller sviende stoff",
      "translation": "injure or be injured by fire, heat, or corrosive substance",
      "examples": [
        {
          "no": "de brente fangen med sigaretter",
          "en": "they burned the prisoner with cigarettes"
        },
        {
          "no": "brente pølser",
          "en": "burnt sausages"
        }
      ]
    },
    {
      "text": "varme sterkt",
      "translation": "heat strongly",
      "examples": [
        {
          "no": "sola brente",
          "en": "the sun was scorching"
        },
        {
          "no": "lyset brente",
          "en": "the light was glaring"
        },
        {
          "no": "trene hardt for å brenne fett",
          "en": "train hard to burn fat"
        }
      ]
    },
    {
      "text": "i ballspill: ødelegge en sjanse til å skåre mål, få poeng eller lignende",
      "translation": "in ball games: ruin a chance to score a goal or points",
      "examples": [
        {
          "no": "brenne et straffespark",
          "en": "miss a penalty kick"
        },
        {
          "no": "de brente sjanse på sjanse",
          "en": "they missed chance after chance"
        }
      ]
