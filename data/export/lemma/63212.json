  "cross_reference": null,
  "definitions": [
    {
      "text": "få større masse",
      "translation": "gain greater mass",
      "examples": []
    },
    {
      "text": "bli tykk tjukk",
      "translation": "become thick",
      "examples": [
        {
          "no": "isen tykner i kulda",
          "en": "the ice thickens in the cold"
        }
      ]
    },
    {
      "text": "bli tett",
      "translation": "become dense",
      "examples": []
    },
    {
      "text": "jamfør tykk tjukk",
      "translation": "thick",
      "examples": [
        {
          "no": "skogen tyknet rundt dem",
          "en": "the forest thickened around them"
        }
      ]
    },
    {
      "text": "om væske: bli mer tyktflytende tjuktflytende",
      "translation": "of liquid: become more viscous",
      "examples": [
        {
          "no": "sausen tykner når den blir kald",
          "en": "the sauce thickens when it gets cold"
        }
      ]
    },
    {
      "text": "om røyk, luft eller vær: bli tett",
      "translation": "of smoke, air or weather: become dense",
      "examples": []
    },
    {
      "text": "bli overskyet",
      "translation": "become overcast",
      "examples": [
        {
          "no": "været tyknet til",
          "en": "the weather turned overcast"
        },
        {
          "no": "skodden tyknet nærmere kvelden",
          "en": "the fog thickened toward evening"
        }
      ]
    }
  ]
