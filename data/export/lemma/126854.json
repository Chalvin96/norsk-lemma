  "definitions": [
    {
      "text": "det å kontrollere om noe er trygt å bruke",
      "translation": "the act of checking if something is safe to use",
      "examples": [
        {
          "no": "sikkerhetskontroll av bremsene",
          "en": "safety check of the brakes"
        }
      ]
    },
    {
      "text": "kontroll av besøkende eller flypassasjerer for å sikre at de ikke har med seg farlige eller ulovlige gjenstander inn i en bygning eller om bord i et fly",
      "translation": "control of visitors or air passengers to ensure they are not carrying dangerous or illegal items into a building or on board an aircraft",
      "examples": [
        {
          "no": "skjerpe sikkerhetskontrollen ved flyplassen",
          "en": "tighten security at the airport"
        }
      ]
    },
    {
      "text": "sted der besøkende eller flypassasjerer blir kontrollert for å sikre at de ikke har med seg farlige eller ulovlige gjenstander inn i en bygning eller om bord i et fly",
      "translation": "place where visitors or air passengers are checked to ensure they are not carrying dangerous or illegal items into a building or on board an aircraft",
      "examples": [
        {
          "no": "de stod lenge i sikkerhetskontrollen på flyplassen",
          "en": "they stood in the security check at the airport for a long time"
        }
      ]
