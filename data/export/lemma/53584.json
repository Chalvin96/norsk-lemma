  "cross_reference": null,
  "definitions": [
    {
      "text": "gå langsomt og verdig",
      "translation": "to walk slowly and with dignity",
      "examples": [
        {
          "no": "prosesjonen skred forbi",
          "en": "the procession passed by in stately fashion"
        }
      ]
    },
    {
      "text": "flytte seg nærmest friksjonsløst på et underlag",
      "translation": "to move almost frictionlessly on a surface",
      "examples": []
    },
    {
      "text": "gli glide, rase",
      "translation": "to slide, slip, rush",
      "examples": [
        {
          "no": "jordbunnen skred ut",
          "en": "the ground slid away"
        }
      ]
    },
    {
      "text": "forløpe, li",
      "translation": "to proceed, to pass (time)",
      "examples": [
        {
          "no": "vinteren lakket og skred",
          "en": "the winter wore on and passed"
        }
      ]
    }
  ]
