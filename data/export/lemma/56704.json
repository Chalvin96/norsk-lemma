  "cross_reference": null,
  "definitions": [
    {
      "text": "pakke hardt sammen og fylle eller tette noe",
      "translation": "to pack tightly together and fill or seal something",
      "examples": [
        {
          "no": "de stappet mose i veggsprekkene",
          "en": "they stuffed moss into the cracks in the wall"
        },
        {
          "no": "stappe klærne i ryggsekken",
          "en": "stuff the clothes into the backpack"
        }
      ]
    },
    {
      "text": "fylle med noe en pakker hardt sammen",
      "translation": "to fill with something that is packed tightly together",
      "examples": [
        {
          "no": "stappe pipa",
          "en": "stuff the pipe"
        }
      ]
    },
    {
      "text": "putte eller stikke gjennom en åpning",
      "translation": "to put or stick through an opening",
      "examples": [
        {
          "no": "han stapper hendene i lomma",
          "en": "he stuffs his hands into his pockets"
        }
      ]
    },
    {
      "text": "røre sammen",
      "translation": "to mash together",
      "examples": []
    },
    {
      "text": "knuse, mose",
      "translation": "to crush, to mash",
      "examples": [
        {
          "no": "stappe potetene i sausen",
          "en": "mash the potatoes into the sauce"
        }
      ]
    }
  ]
