  "definitions": [
    {
      "text": "det at et skip synker eller blir ødelagt",
      "translation": "the sinking or destruction of a ship",
      "examples": [
        {
          "no": "lide skipbrudd",
          "en": "be shipwrecked"
        },
        {
          "no": "hun led skipbrudd like utenfor Kappstaden",
          "en": "she was shipwrecked just off Cape Town"
        },
        {
          "no": "han var i flere skipbrudd under krigen",
          "en": "he was in several shipwrecks during the war"
        }
      ]
    },
    {
      "text": "i overført betydning: det at noe eller noen mislykkes",
      "translation": "the failure of something or someone",
      "examples": [
        {
          "no": "valget var et totalt skipbrudd for politikeren",
          "en": "the election was a total disaster for the politician"
        },
        {
          "no": "prosjektet led skipbrudd allerede før start",
          "en": "the project foundered before it even started"
