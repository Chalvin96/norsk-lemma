    {
      "text": "begynne, sette i gang",
      "translation": "begin, set in motion",
      "examples": [
        {
          "no": "innlede en diskusjon",
          "en": "begin a discussion"
        },
        {
          "no": "bedriftene har innledet et nært samarbeid",
          "en": "the companies have begun a close collaboration"
        },
        {
          "no": "innlede et nytt bekjentskap",
          "en": "strike up a new acquaintance"
        },
        {
          "no": "skisesongen ble innledet i går",
          "en": "the ski season began yesterday"
        }
      ]
    },
    {
      "text": "holde første innlegg eller foredrag (som del av et arrangement)",
      "translation": "give the first presentation or lecture (as part of an event)",
      "examples": [
        {
          "no": "hun skal innlede om tilstanden i norsk litteratur",
          "en": "she will give the opening presentation on the state of Norwegian literature"
