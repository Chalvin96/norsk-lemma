  "definitions": [
    {
      "text": "spare for noe hardt, ubehagelig eller en påkjenning",
      "translation": "to spare from something hard, unpleasant, or a strain",
      "examples": [
        {
          "no": "skåne barna fra dårlig litteratur",
          "en": "shield the children from bad literature"
        },
        {
          "no": "jeg har vært skånt for sykdom",
          "en": "I have been spared illness"
        }
      ]
    },
    {
      "text": "bevare mot skade",
      "translation": "to preserve from damage",
      "examples": [
        {
          "no": "skåne klærne sine",
          "en": "spare one's clothes"
        }
      ]
    }
  ]
