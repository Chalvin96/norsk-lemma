  "definitions": [
    {
      "text": "prate, samtale",
      "translation": "to chat, converse",
      "examples": []
    },
    {
      "text": "jamfør snakkes",
      "translation": "to talk together",
      "examples": [
        {
          "no": "snakke med hverandre",
          "en": "talk to each other"
        },
        {
          "no": "vi snakket sammen på telefon",
          "en": "we spoke on the phone"
        },
        {
          "no": "jeg snakker på vegne av flere",
          "en": "I speak on behalf of several people"
        },
        {
          "no": "snakke om andre ting",
          "en": "talk about other things"
        }
      ]
    },
    {
      "text": "skravle",
      "translation": "to chatter",
      "examples": [
        {
          "no": "snakke i ett kjør",
          "en": "talk nonstop"
        },
        {
          "no": "snakke seg fra noe",
          "en": "talk one's way out of something"
        },
        {
          "no": "han snakker i vei om hobbyen sin",
          "en": "he goes on talking about his hobby"
        }
      ]
    },
    {
      "text": "bruke sin taleevne",
      "translation": "to use one's ability to speak",
      "examples": [
        {
          "no": "barnet kunne ikke snakke ennå",
          "en": "the child could not speak yet"
        },
        {
          "no": "snakke rent",
          "en": "speak clearly"
        },
        {
          "no": "snakke russisk",
          "en": "speak Russian"
        },
        {
          "no": "snakk høyere!",
          "en": "speak louder!"
        }
      ]
    },
    {
      "text": "drøfte",
      "translation": "to discuss",
      "examples": [
        {
          "no": "snakke forretninger",
          "en": "talk business"
        }
      ]
    },
    {
      "text": "sladre",
      "translation": "to gossip",
      "examples": [
        {
          "no": "de snakket om henne over hele byen",
          "en": "they talked about her all over town"
        }
      ]
    },
    {
      "text": "brukt i utrop om noe storartet",
      "translation": "used in an exclamation about something great",
      "examples": [
        {
          "no": "snakk om flaks!",
          "en": "talk about luck!"
        },
        {
          "no": "du snakker om flott forestilling!",
          "en": "now that's what I call a splendid performance!"
