  "definitions": [
    {
      "text": "bevege seg opp og ned eller fram og tilbake (med lett og rask bevegelse)",
      "translation": "move up and down or back and forth (with a light and quick movement)",
      "examples": [
        {
          "no": "linerla vippet med stjerten",
          "en": "the wagtail bobbed its tail"
        },
        {
          "no": "sitte og vippe på stolen",
          "en": "sit rocking on the chair"
        }
      ]
    },
    {
      "text": "i overført betydning: bevege seg fram og tilbake mellom to tilstander",
      "translation": "move back and forth between two states",
      "examples": []
    },
    {
      "text": "vakle",
      "translation": "swing",
      "examples": [
        {
          "no": "det vipper mellom borgerlig og sosialistisk flertall",
          "en": "it teeters between a bourgeois and a socialist majority"
        }
      ]
    },
    {
      "text": "flytte seg brått fra én posisjon til en annen (rundt et midtpunkt eller tyngdepunkt)",
      "translation": "move abruptly from one position to another (around a central point or center of gravity)",
      "examples": [
        {
          "no": "bilen vippet rundt i svingen",
          "en": "the car tipped over in the bend"
        }
      ]
    },
    {
      "text": "få til å miste balansen og falle",
      "translation": "cause to lose balance and fall",
      "examples": []
    },
    {
      "text": "bevege noe opp og ned",
      "translation": "move something up and down",
      "examples": [
        {
          "no": "vippe noen over ende",
          "en": "tip someone over"
        }
      ]
    },
    {
      "text": "sende noe av gårde med én rask bevegelse",
      "translation": "send something off with one quick movement",
      "examples": [
        {
          "no": "vippe ballen over målmannen og i mål",
          "en": "chip the ball over the goalkeeper and into the net"
        }
      ]
    }
  ]
