  "definitions": [
    {
      "text": "la tære eller oppløse",
      "translation": "to corrode or dissolve",
      "examples": [
        {
          "no": "etse bort kobberet med syre",
          "en": "etch away the copper with acid"
        }
      ]
    },
    {
      "text": "tære, oppløse oppløyse",
      "translation": "to corrode, dissolve",
      "examples": [
        {
          "no": "væsken etset bort belegget",
          "en": "the liquid etched away the coating"
        },
        {
          "no": "syren etset seg ned i platen",
          "en": "the acid etched its way down into the plate"
        },
        {
          "no": "etsende væske",
          "en": "corrosive liquid"
        }
      ]
    },
    {
      "text": "få fram innskrift eller motiv på overflate ved hjelp av syre",
      "translation": "to create an inscription or motif on a surface using acid",
      "examples": [
        {
          "no": "etse navnet sitt inn i en kopperplate",
          "en": "etch one's name into a copper plate"
        }
      ]
    },
    {
      "text": "i overført betydning: gjøre sterkt inntrykk eller feste seg permanent",
      "translation": "to make a strong impression or become permanently fixed",
      "examples": [
        {
          "no": "ordene etset seg inn i henne",
          "en": "the words were etched into her memory"
        },
        {
          "no": "episoden etset seg fast",
          "en": "the episode became etched in memory"
        }
      ]
    }
  ]
