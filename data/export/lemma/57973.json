  "definitions": [
    {
      "text": "mest i flertall: stang med fottrinn et stykke oppå, som en setter foten på og gå med, hevet over bakken",
      "translation": "mostly plural: pole with a footrest partway up that one stands on to walk above the ground",
      "examples": [
        {
          "no": "gå på stylter",
          "en": "walk on stilts"
        },
        {
          "no": "klovnene gikk rundt på stylter",
          "en": "the clowns walked around on stilts"
        }
      ]
    },
    {
      "text": "påle som bygning over vann står på",
      "translation": "pile supporting a building over water",
      "examples": [
        {
          "no": "hyttene er plassert på stylter over vannet",
          "en": "the cabins are built on stilts over the water"
        }
      ]
    }
