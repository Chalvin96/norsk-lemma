  "definitions": [
    {
      "text": "i bestemt form entall: gammel tid, eldre tid",
      "translation": "in definite singular: old times, earlier times",
      "examples": [
        {
          "no": "i gamletiden",
          "en": "in the old days"
        }
      ]
    },
    {
      "text": "eldre betegnelse for eldste historiske tid (i Norge ofte regnet fram til begynnelsen av vikingtiden)",
      "translation": "older term for the earliest historical period (in Norway often counted up to the beginning of the Viking Age)",
      "examples": []
    },
    {
      "text": "eldre geologisk betegnelse for tidsalder i jordhistorien (fra kambrium til perm) som en har de første viktige fossile funnene fra",
      "translation": "older geological term for an era in Earth's history (from Cambrian to Permian) from which the first important fossil finds originate",
      "examples": []
    }
  ]
