  "definitions": [
    {
      "text": "halvsirkel- eller trekantformet håndredskap, som en kan folde ut eller slå sammen, brukt til å vifte seg med når det er varmt",
      "translation": "semicircular, triangular hand-held tool, which can be folded out or together, used for fanning oneself when it is hot",
      "examples": [
        {
          "no": "ha med seg vifte på spasertur i varmen",
          "en": "bring a fan along on a walk in the heat"
        }
      ]
    },
    {
      "text": "noe som ligner en vifte",
      "translation": "something that resembles a fan",
      "examples": [
        {
          "no": "ordne kortene i en vifte",
          "en": "arrange the cards in a fan"
        },
        {
          "no": "sette opp serviettene i vifter",
          "en": "set up the napkins in fans"
        },
        {
          "no": "fuglen brer stjerten ut til en vifte",
          "en": "the bird spreads its tail into a fan"
        }
      ]
    },
    {
      "text": "maskin eller apparat med roterende propell som driver fram eller skifter ut luft",
      "translation": "machine or apparatus with a rotating propeller that drives or displaces air",
      "examples": [
        {
          "no": "elektrisk vifte",
          "en": "electric fan"
        },
        {
          "no": "viften i en høytørke",
          "en": "the fan in a hay dryer"
        }
      ]
    }
  ]
