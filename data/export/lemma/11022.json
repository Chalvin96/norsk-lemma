  "definitions": [
    {
      "text": "falle tett i små partikler og spres utover",
      "translation": "fall densely in small particles and spread out",
      "examples": [
        {
          "no": "snøen drysset ned",
          "en": "the snow drifted down"
        },
        {
          "no": "støvet drysser ned fra taket",
          "en": "dust is drifting down from the ceiling"
        }
      ]
    },
    {
      "text": "spre utover i et tynt lag",
      "translation": "spread out in a thin layer",
      "examples": [
        {
          "no": "drysse melis på kaka",
          "en": "sprinkle powdered sugar on the cake"
        }
      ]
    }
