  "definitions": [
    {
      "text": "banke eller slå (slik at det høres)",
      "translation": "to knock or strike (so as to make a sound)",
      "examples": []
    },
    {
      "text": "pikke, hamre",
      "translation": "to peck, to hammer",
      "examples": [
        {
          "no": "hun kakket på døra",
          "en": "she knocked on the door"
        },
        {
          "no": "kakke noen i hodet med noe hardt",
          "en": "knock someone on the head with something hard"
        },
        {
          "no": "kakke hull på isen",
          "en": "knock a hole in the ice"
        },
        {
          "no": "kakke hull på et egg",
          "en": "crack an egg"
        }
      ]
    },
    {
      "text": "få til å drysse",
      "translation": "to cause to crumble",
      "examples": [
        {
          "no": "kakke sund",
          "en": "break up"
        }
