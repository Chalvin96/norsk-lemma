  "definitions": [
    {
      "text": "på eller ved utsiden av hus, bygning eller lignende",
      "translation": "on the outside of a house, building",
      "examples": []
    },
    {
      "text": "bortenfor eller på andre siden av et avgrenset område",
      "translation": "beyond or on the other side of a defined area",
      "examples": []
    },
    {
      "text": "ikke innenfor",
      "translation": "not inside",
      "examples": [
        {
          "no": "de ventet utenfor huset",
          "en": "they waited outside the house"
        },
        {
          "no": "være utenfor rekkevidde",
          "en": "be out of reach"
        },
        {
          "no": "stå utenfor porten",
          "en": "stand outside the gate"
        },
        {
          "no": "arbeide utenfor kommunen",
          "en": "work outside the municipality"
        }
      ]
    },
    {
      "text": "i overført betydning: bortenfor eller på andre siden av et område, felt, tema og lignende",
      "translation": "beyond or on the other side of an area, field, topic",
      "examples": [
        {
          "no": "utenfor fare",
          "en": "out of danger"
        },
        {
          "no": "hun talte fullstendig utenfor manus",
          "en": "she spoke entirely off script"
