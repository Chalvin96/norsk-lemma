  "definitions": [
    {
      "text": "halvfast, gjennomsiktig og skjelvende masse av innkokt og avkjølt kraft eller særlig av bær- og fruktsaft brukt til dessert eller lignende",
      "translation": "semi-solid, transparent, and trembling mass of reduced and cooled stock or especially of boiled-down berry and fruit juice used as a dessert or the like",
      "examples": [
        {
          "no": "tunfisk i gelé",
          "en": "tuna in aspic"
        },
        {
          "no": "ha gelé med vaniljesaus til dessert",
          "en": "have jelly with vanilla sauce for dessert"
        }
      ]
    },
    {
      "text": "kosmetisk middel som ligner gelé gele",
      "translation": "cosmetic product resembling jelly",
      "examples": []
    },
    {
      "text": "brukt i overført betydning for å betegne svakhet",
      "translation": "used figuratively to denote weakness",
      "examples": [
        {
          "no": "bli gelé i knærne",
          "en": "go weak at the knees"
        }
      ]
    }
