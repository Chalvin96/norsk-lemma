  "definitions": [
    {
      "text": "gå etter og bringe med seg tilbake",
      "translation": "go after and bring back",
      "examples": [
        {
          "no": "hente posten",
          "en": "pick up the mail"
        },
        {
          "no": "hente ved",
          "en": "fetch firewood"
        },
        {
          "no": "vil du hente en kniv til meg?",
          "en": "will you get me a knife?"
        },
        {
          "no": "jeg henter deg på stasjonen",
          "en": "I'll pick you up at the station"
        }
      ]
    },
    {
      "text": "skaffe seg, få, vinne",
      "translation": "obtain, get, win",
      "examples": [
