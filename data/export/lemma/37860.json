  "definitions": [
    {
      "text": "ha i tankene",
      "translation": "have in mind",
      "examples": []
    },
    {
      "text": "tenke på",
      "translation": "think of",
      "examples": []
    },
    {
      "text": "sikte til",
      "translation": "refer to",
      "examples": [
        {
          "no": "det mener du ikke!",
          "en": "you don't mean that!"
        },
        {
          "no": "si det en mener",
          "en": "say what one means"
        },
        {
          "no": "jeg skjønner ikke hva du mener",
          "en": "I don't understand what you mean"
        }
      ]
    },
    {
      "text": "ha til hensikt",
      "translation": "intend",
      "examples": [
        {
          "no": "hun mente ikke å gjøre noe galt",
          "en": "she didn't mean to do anything wrong"
        },
        {
          "no": "det var ikke så galt ment som det var sagt",
          "en": "it was not meant as badly as it was said"
        },
        {
          "no": "mene alvor",
          "en": "be serious"
        },
        {
          "no": "han mente det godt",
          "en": "he meant it well"
        }
      ]
    },
    {
      "text": "tro, synes",
      "translation": "believe, think",
      "examples": [
        {
          "no": "jeg mener at jeg så det i avisen i går",
          "en": "I think I saw it in the newspaper yesterday"
        },
        {
          "no": "han visste ikke hva han skulle mene om den saken",
          "en": "he didn't know what to think about that matter"
        }
      ]
    },
    {
      "text": "brukt for å framheve noe som et faktum",
      "translation": "used to emphasize something as a fact",
      "examples": [
        {
          "no": "ja, det skulle jeg mene!",
          "en": "yes, I should say so!"
        }
      ]
    }
  ]
