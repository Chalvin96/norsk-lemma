    {
      "text": "midlertidig isolering av (mulige) smittebærer",
      "translation": "temporary isolation of (possible) carriers of infection",
      "examples": [
        {
          "no": "hele familien måtte i karantene på grunn av smittefaren",
          "en": "the whole family had to go into quarantine because of the risk of infection"
        }
      ]
    },
    {
      "text": "midlertidig utestengelse utestenging utestengning fra en gitt virksomhet",
      "translation": "temporary exclusion from a given activity",
      "examples": [
        {
          "no": "han ble ilagt karantene i to år av skifteretten",
          "en": "he was given a two-year quarantine by the probate court"
        },
        {
