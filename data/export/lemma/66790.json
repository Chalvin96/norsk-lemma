  "definitions": [
    {
      "text": "informere om fare, lovbrudd eller lignende",
      "translation": "inform about danger, a crime, or similar",
      "examples": [
        {
          "no": "varsle politiet",
          "en": "notify the police"
        },
        {
          "no": "de varsler med lyssignal",
          "en": "they signal with light signals"
        },
        {
          "no": "hun varslet om mobbing",
          "en": "she reported bullying"
        },
        {
          "no": "det ble varslet om glatte veier",
          "en": "there was a warning about slippery roads"
        }
      ]
    },
    {
      "text": "gi beskjed om noe som skal skje",
      "translation": "give notice of something that will happen",
      "examples": [
        {
          "no": "varsle streik",
          "en": "announce a strike"
        },
        {
          "no": "butikken varsler at de skal stenge",
          "en": "the store announces that it will close"
        },
        {
          "no": "det er varslet kuling",
          "en": "gale-force winds have been forecast"
        }
      ]
    },
    {
      "text": "være tegn på",
      "translation": "be a sign of",
      "examples": [
