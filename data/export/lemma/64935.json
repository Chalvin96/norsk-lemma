    },
    {
      "text": "som ikke er tilstrekkelig beskyttet mot ulovlig bruk, tyveri eller innbrudd",
      "translation": "not adequately protected against unlawful use, theft, or break-in",
      "examples": [
        {
          "no": "et usikret nettverk",
          "en": "an unsecured network"
        }
      ]
    },
    {
      "text": "som ikke har sikkerhet i pant",
      "translation": "without collateral",
      "examples": [
