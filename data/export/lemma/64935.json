          "en": "the weapon was off safety"
        },
        {
          "no": "en usikret håndgranat",
          "en": "an unsecured hand grenade"
        }
      ]
    },
    {
      "text": "som ikke er tilstrekkelig sperret av eller inngjerdet",
      "translation": "not adequately cordoned off or fenced",
