    },
    {
      "text": "slippe spytt ut av munnviken",
      "translation": "to let saliva drip from the corner of the mouth",
      "examples": [
        {
          "no": "han sikler i skjegget",
          "en": "he drools into his beard"
        }
      ]
    },
    {
      "text": "i overført betydning: ha lyst på",
      "translation": "to covet",
      "examples": [
        {
          "no": "sikle på noe",
          "en": "drool over something"
        },
        {
          "no": "de siklet etter den største hyttetomten",
          "en": "they were drooling over the biggest cabin plot"
