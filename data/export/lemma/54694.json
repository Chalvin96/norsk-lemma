  "definitions": [
    {
      "text": "egenskap ved et stoff som gir et karakteristisk sanseinntrykk når noe, særlig mat eller drikke, kommer i berøring med sanseorganene i munnen",
      "translation": "property of a substance that gives a characteristic sensory impression when something, especially food or drink, comes into contact with the sensory organs in the mouth",
      "examples": [
        {
          "no": "vinen hadde en fyldig smak",
          "en": "the wine had a full-bodied taste"
        },
        {
          "no": "krydder med bitter smak",
          "en": "spices with a bitter taste"
        },
        {
          "no": "det var vond smak på vannet",
          "en": "the water had a bad taste"
        }
      ]
    },
    {
      "text": "evne til å fornemme søtt, salt, surt, bittert og umami",
      "translation": "ability to perceive sweet, salty, sour, bitter, and umami",
      "examples": [
        {
          "no": "våre fem sanser er syn, hørsel, lukt, smak og følelse",
          "en": "our five senses are sight, hearing, smell, taste, and touch"
        }
      ]
    },
    {
      "text": "liten bit",
      "translation": "small piece",
      "examples": [
        {
          "no": "få en smak av noe",
          "en": "get a taste of something"
        }
      ]
    },
    {
      "text": "tilbøyelighet til å foretrekke noe framfor noe annet",
      "translation": "inclination to prefer something over something else",
