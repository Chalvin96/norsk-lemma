  "definitions": [
    {
      "text": "strekke eller folde ut (for å dekke noe)",
      "translation": "to stretch or fold out (to cover something)",
      "examples": [
        {
          "no": "hun bredte ut armene",
          "en": "she spread out her arms"
        },
        {
          "no": "høna bredte vingene over kyllingene",
          "en": "the hen spread her wings over the chicks"
        },
        {
          "no": "bre over seg dyna",
          "en": "pull the duvet over yourself"
        }
      ]
    },
    {
      "text": "legge utover",
      "translation": "to lay out",
      "examples": [
        {
          "no": "rake og bre høy",
          "en": "rake and spread hay"
        }
      ]
    }
