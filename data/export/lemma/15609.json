      ]
    },
    {
      "text": "strømme, renne",
      "translation": "flow, run",
      "examples": [
        {
          "no": "flyte over",
          "en": "overflow"
        },
        {
          "no": "flyte med blod",
          "en": "flow with blood"
        }
      ]
    },
    {
      "text": "gli lett",
      "translation": "glide easily",
