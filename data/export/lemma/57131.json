  "cross_reference": null,
  "definitions": [
    {
      "text": "føre et spisst redskap inn i noe eller noen",
      "translation": "to insert a pointed tool into something or someone",
      "examples": [
        {
          "no": "stikke kniven i noen",
          "en": "stab someone with a knife"
        },
        {
          "no": "stikke noen ned",
          "en": "stab someone to death"
        },
        {
          "no": "stikke hull på noe",
          "en": "pierce something"
        },
        {
          "no": "stikke spaden i jorda",
          "en": "stick the spade into the ground"
        }
      ]
    },
    {
      "text": "gi en følelse av å bli berørt av noe spisst",
      "translation": "to cause a sensation of being touched by something sharp",
      "examples": [
        {
          "no": "sola stakk",
          "en": "the sun stung"
        },
        {
          "no": "mørke, stikkende øyne",
          "en": "dark, piercing eyes"
        }
      ]
    },
    {
      "text": "få en plutselig innskytelse",
      "translation": "to have a sudden impulse",
      "examples": [
        {
          "no": "hva var det som stakk henne?",
          "en": "what got into her all of a sudden?"
        }
      ]
    },
    {
      "text": "føle en plutselig smerte",
      "translation": "to feel a sudden pain",
      "examples": [
        {
          "no": "det stakk i tanna",
          "en": "there was a sharp pain in the tooth"
        }
      ]
    },
    {
      "text": "bevege, føre",
      "translation": "to move, to guide",
      "examples": [
        {
          "no": "stikke hånden borti noe",
          "en": "let a hand brush against something"
        },
        {
          "no": "stikke noe til side",
          "en": "move something aside"
        },
        {
          "no": "stikke nesen ut av vinduet",
          "en": "stick one's nose out the window"
        },
        {
          "no": "hun stikker papirene ned i veska",
          "en": "she sticks the papers down into her bag"
        }
      ]
    },
    {
      "text": "gå raskt, smette",
      "translation": "to move quickly, to dart",
      "examples": []
    },
    {
      "text": "dra, fare",
      "translation": "to go, to travel",
      "examples": [
        {
          "no": "stikke bort i butikken etter noe",
          "en": "run over to the shop for something"
        },
        {
          "no": "komme stikkende",
          "en": "come hurrying along"
        },
        {
          "no": "røyskatten stakk inn i muren",
          "en": "the weasel darted into the wall"
        }
      ]
    },
    {
      "text": "være synlig eller framstående i en viss retning fra en skjult posisjon",
      "translation": "to be visibly prominent in a certain direction from a hidden position",
      "examples": [
        {
          "no": "høye fjell stakk ende til værs",
          "en": "high mountains jutted straight up into the air"
        },
        {
          "no": "gresstuster stikker opp av snøen",
          "en": "tufts of grass stick up through the snow"
        },
        {
          "no": "mobilen stakk opp av lomma",
          "en": "the mobile phone stuck up out of the pocket"
        },
        {
          "no": "hodet stikker ut av vinduet",
          "en": "the head sticks out of the window"
        }
      ]
    },
    {
      "text": "i ballspill: treffe med ball",
      "translation": "in ball games: to hit with the ball",
      "examples": [
        {
          "no": "hun var flink til å stikke motspillerne",
          "en": "she was good at hitting the opposing players with the ball"
        }
      ]
    },
    {
      "text": "i kortspill: legge på høyere kort enn dem eller det som ligger der før",
      "translation": "in card games: to play a higher card than those already played or on the table",
      "examples": [
        {
          "no": "stikke tieren med kongen",
          "en": "beat the ten with the king"
        }
      ]
    }
  ]
