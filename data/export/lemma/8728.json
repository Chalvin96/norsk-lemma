  "cross_reference": null,
  "definitions": [
    {
      "text": "diakritisk tegn i form av en liten hake under bokstaven c (ç) for å vise at den skal uttales s (og ikke k) selv om den står foran a, o eller u",
      "translation": "diacritical mark in the form of a small hook under the letter c (ç) to indicate it should be pronounced 's' (and not 'k') even when followed by a, o, or u",
      "examples": [
        {
          "no": "c-en i ‘provençalsk’ skal skrives med cédille",
          "en": "the c in ‘provençal’ should be written with a cedilla"
        }
      ]
    }
  ]
