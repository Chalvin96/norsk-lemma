  "definitions": [
    {
      "text": "stor i høyere grad enn noe eller noen det sammenlignes med",
      "translation": "larger to a higher degree than something or someone it is compared with",
      "examples": [
        {
          "no": "hun er større enn sin mor",
          "en": "she is taller than her mother"
        },
        {
          "no": "lik pris gir større rettferdighet",
          "en": "equal prices provide greater fairness"
        },
        {
          "no": "i de større kommunene",
          "en": "in the larger municipalities"
        }
      ]
    },
    {
      "text": "uten klar sammenlikning: nokså drøy, stor eller mye",
      "translation": "without clear comparison: quite considerable, large or much",
      "examples": [
        {
          "no": "en større lekkasje",
          "en": "a fairly major leak"
        },
        {
          "no": "det var ikke større med snø",
          "en": "there wasn't much snow"
        }
      ]
    }
