  "definitions": [
    {
      "text": "skade ved å lage sår",
      "translation": "to injure by making a wound",
      "examples": []
    },
    {
      "text": "lage sår på",
      "translation": "to make a wound on",
      "examples": [
        {
          "no": "han bare såret elgen med skuddet",
          "en": "he only wounded the moose with the shot"
        },
        {
          "no": "bli såret i foten",
          "en": "be wounded in the foot"
        }
      ]
    },
    {
      "text": "si eller gjøre noe slik at noen blir lei seg",
      "translation": "to say or do something that makes someone sad",
      "examples": []
    },
    {
      "text": "krenke, fornærme",
      "translation": "to offend, insult",
      "examples": [
        {
          "no": "om forlatelse, jeg mente ikke å såre deg",
          "en": "forgive me, I didn't mean to hurt you"
