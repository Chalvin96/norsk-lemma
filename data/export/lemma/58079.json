  "definitions": [
    {
      "text": "myk pute som demper sammenstøt",
      "translation": "soft pad that cushions collisions",
      "examples": [
        {
          "no": "montere på en støtpute på sykkelsetet",
          "en": "mount a shock absorber on the bicycle seat"
        }
      ]
    },
    {
      "text": "i overført betydning: noe eller noen som skal redusere effekten av uønsket eller negativ påvirkning",
      "translation": "figurative: something or someone meant to lessen the effect of unwanted or negative influence",
      "examples": [
        {
          "no": "være en støtpute mot svingninger i aksjemarkedet",
          "en": "serve as a buffer against fluctuations in the stock market"
        }
      ]
    }
  ]
