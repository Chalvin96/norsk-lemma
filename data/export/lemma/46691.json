  "definitions": [
    {
      "text": "forskjell mellom det en forlanger, og det en egentlig kan tenke seg å gå med på, særlig brukt om priser",
      "translation": "the difference between what is asked for and what one is actually willing to accept, especially regarding prices",
      "examples": [
        {
          "no": "det er prutingsmonn på alle priser",
          "en": "there is room for bargaining in all prices"
        },
        {
          "no": "sannheten har ikke prutingsmonn",
          "en": "the truth is not negotiable"
        }
      ]
    }
  ]
