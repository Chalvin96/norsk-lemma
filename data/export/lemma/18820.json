  "definitions": [
    {
      "text": "motta, bli gitt, skaffe seg, komme til å ha",
      "translation": "receive, be given, acquire, come to have",
      "examples": [
        {
          "no": "få brev",
          "en": "receive letters"
        },
        {
          "no": "han får svar i morgen",
          "en": "he'll get an answer tomorrow"
        },
        {
          "no": "hun fikk besøk",
          "en": "she had a visitor"
        },
        {
          "no": "de har fått mye fisk",
          "en": "they have caught a lot of fish"
        }
      ]
    },
    {
      "text": "pådra seg, utsettes for",
      "translation": "contract, be subjected to",
      "examples": [
        {
          "no": "få lungebetennelse",
          "en": "get pneumonia"
        },
        {
