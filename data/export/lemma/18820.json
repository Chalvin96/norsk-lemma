          "en": "get the ball in your head"
        },
        {
          "no": "få straff",
          "en": "be punished"
        }
      ]
    },
    {
      "text": "oppnå mulighet eller tillatelse til",
      "translation": "obtain opportunity, permission to",
      "examples": []
    },
    {
      "text": "være forunt",
      "translation": "be destined to",
      "examples": [
        {
          "no": "får jeg komme?",
          "en": "may I come?"
        },
        {
          "no": "få se!",
          "en": "let me see!"
        },
        {
