  "definitions": [
    {
      "text": "hos mennesker og høyerestående dyr: rød kroppsvæske som hjertet pumper gjennom kroppen, og som fører oksygen og andre næringsstoffer til kroppscellene og avfallsstoffer bort fra dem",
      "translation": "red bodily fluid pumped by the heart through the body, carrying oxygen and nutrients to cells and waste products away",
      "examples": [
        {
          "no": "gi blod",
          "en": "give blood"
        },
        {
          "no": "skjære seg til blods",
          "en": "cut oneself until one bleeds"
        },
        {
          "no": "slåss så blodet renner",
          "en": "fight until the blood flows"
        },
        {
          "no": "våge liv og blod",
          "en": "risk life and limb"
        }
      ]
    },
    {
      "text": "i overført betydning: livskraft, temperament",
      "translation": "in a figurative sense: vitality, temperament",
      "examples": [
        {
          "no": "ha hett blod i årene",
          "en": "have hot blood in one's veins"
        }
      ]
    },
    {
      "text": "blod som symbol for slektsegenskaper",
      "translation": "blood as a symbol of hereditary traits",
      "examples": [
        {
          "no": "det flyter noen dråper russisk blod i årene hennes",
          "en": "a few drops of Russian blood run in her veins"
        },
        {
          "no": "han har arvet farens urolige blod",
          "en": "he has inherited his father's restless blood"
        },
        {
          "no": "være prins av blodet",
          "en": "be a prince of the blood"
        }
      ]
    }
