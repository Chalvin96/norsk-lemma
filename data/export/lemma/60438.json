  "definitions": [
    {
      "text": "juridisk prinsipp som går ut på at alle (innenlandske eller utenlandske) gjenstander og personer innenfor området til en stat er underkastet lovene i denne staten",
      "translation": "legal principle that all (domestic and foreign) objects and persons within the territory of a state are subject to the laws of that state",
      "examples": []
    },
    {
      "text": "i enkelte land: regel som går ut på at statsborgerskap blir tildelt på grunnlag av hvor en person er født",
      "translation": "in some countries: rule that citizenship is granted based on where a person was born",
      "examples": []
    }
  ]
