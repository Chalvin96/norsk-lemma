  "definitions": [
    {
      "text": "gi straff, refse eller tukte for en misgjerning",
      "translation": "to punish, to reprimand or chastise for a misdeed",
      "examples": [
        {
          "no": "faren straffet barna strengt når de var ulydige",
          "en": "the father punished the children severely when they were disobedient"
        }
      ]
    },
    {
      "text": "dømme for lovbrudd",
      "translation": "to convict for an offense",
      "examples": [
        {
          "no": "tiltalte er ikke tidligere straffet",
          "en": "the defendant has not previously been convicted"
        }
      ]
    },
    {
      "text": "i idrett: overgå eller forbedre",
      "translation": "to surpass or improve",
      "examples": [
        {
          "no": "hun straffet den tidligere rekorden med 2 tidels sekund",
          "en": "she beat the previous record by two tenths of a second"
        },
        {
          "no": "utlendingene straffer oss på lengdene",
          "en": "the foreigners beat us in the distance events"
        },
        {
          "no": "ingen kunne straffe henne i kretsmesterskapet",
          "en": "no one could beat her in the district championship"
        }
      ]
    }
  ]
