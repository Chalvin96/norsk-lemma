  "definitions": [
    {
      "text": "det at to eller flere ting eller forhold har ulike egenskaper",
      "translation": "the fact that two or more things or circumstances have different properties",
      "examples": [
        {
          "no": "en viktig forskjell",
          "en": "an important difference"
        },
        {
          "no": "det er stor forskjell på å tenke noe og å si noe",
          "en": "there is a big difference between thinking something and saying something"
        },
        {
          "no": "vite forskjell på ditt og mitt",
          "en": "know the difference between yours and mine"
        },
        {
          "no": "det er forskjell på folk",
          "en": "there's a difference between people"
        }
      ]
    },
    {
      "text": "det som skiller to eller flere ting fra hverandre",
      "translation": "that which distinguishes two or more things from each other",
      "examples": [
        {
          "no": "forskjellen på lagene var evnen til å skåre mål",
          "en": "the difference between the teams was the ability to score goals"
        },
        {
          "no": "frisyren er den eneste forskjellen mellom tvillingene",
          "en": "the hairstyle is the only difference between the twins"
        }
      ]
    },
    {
      "text": "økonomisk ulikhet",
      "translation": "economic inequality",
      "examples": [
        {
          "no": "økende forskjeller mellom fattige og rike",
          "en": "growing inequalities between rich and poor"
        },
        {
          "no": "et land preget av store forskjeller",
          "en": "a country marked by great inequality"
        }
      ]
    }
