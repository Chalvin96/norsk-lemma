  "definitions": [
    {
      "text": "suffiks brukt til å lage substantiv av adjektiv som ender på -laus eller -løs med betydning skort, mangel, i ord som",
      "translation": "used to form nouns from adjectives ending in -laus -løs with lack, deficiency, in words like",
