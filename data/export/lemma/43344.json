  "definitions": [
    {
      "text": "ha krefter til",
      "translation": "have the strength to",
      "examples": []
    },
    {
      "text": "greie, makte",
      "translation": "manage, be able to",
      "examples": [
        {
          "no": "han orket ikke å reise seg",
          "en": "he couldn't manage to get up"
        },
        {
          "no": "orker dere et smørbrød til?",
          "en": "can you manage one more sandwich?"
        }
      ]
    },
    {
      "text": "være villig til",
      "translation": "be willing to",
      "examples": [
        {
          "no": "vi orker ikke å vaske opp for hånd",
          "en": "we can't be bothered washing up by hand"
        }
      ]
    },
    {
      "text": "tåle, utstå",
      "translation": "tolerate, endure",
      "examples": [
        {
          "no": "jeg orker ikke mer mas",
          "en": "I can't take any more nagging"
        },
        {
          "no": "jeg orket ikke den fyren",
          "en": "I couldn't stand that guy"
        }
      ]
    },
    {
      "text": "ha hjerte til",
      "translation": "have the heart to",
      "examples": [
        {
          "no": "han orket ikke å drepe så mye som en flue",
          "en": "he couldn't bring himself to kill as much as a fly"
