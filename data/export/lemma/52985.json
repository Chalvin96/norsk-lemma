  "definitions": [
    {
      "text": "ikke kunne se i samme retning med begge øynene på grunn av synsfeil",
      "translation": "unable to see in the same direction with both eyes due to a vision defect",
      "examples": [
        {
          "no": "han skjelte på begge øynene",
          "en": "he was cross-eyed in both eyes"
        }
      ]
    },
    {
      "text": "se til siden eller på skrå, uten å snu hodet",
      "translation": "to look to the side or obliquely, without turning the head",
      "examples": [
        {
          "no": "skjele til siden",
          "en": "look sideways"
        },
        {
          "no": "han skjeler ned på svarene mine",
          "en": "he looks down at my answers from the corner of his eye"
        }
      ]
    }
