  "cross_reference": null,
  "definitions": [
    {
      "text": "i kjemi: (om stoff) som har tatt opp i seg størst mulig mengde av et annet stoff",
      "translation": "(of a substance) that has absorbed the largest possible amount of another substance",
      "examples": [
        {
          "no": "mettet vanndamp",
          "en": "saturated water vapor"
        },
        {
          "no": "mettede fettsyrer",
          "en": "saturated fatty acids"
        },
        {
          "no": "en mettet løsning",
          "en": "a saturated solution"
        },
        {
          "no": "i mettet tilstand",
          "en": "in a saturated state"
        }
      ]
    },
    {
      "text": "som er fylt opp helt eller fylt opp av noe annet",
      "translation": "completely filled with something else",
      "examples": [
        {
          "no": "et mettet marked gjorde det vanskelig å tjene penger på mobilsalg",
          "en": "a saturated market made it difficult to make money selling mobile phones"
        }
      ]
    },
    {
      "text": "intens eller konsentrert",
      "translation": "intense or concentrated",
      "examples": [
        {
          "no": "få en mettet gjengivelse av fargen med god fargedybde",
          "en": "get a saturated rendering of the color with good color depth"
        }
      ]
    }
  ]
