  "definitions": [
    {
      "text": "måte et dyr, særlig hest, går eller løper på",
      "translation": "the way an animal, especially a horse, walks or runs",
      "examples": [
        {
          "no": "en islandshest har fem gangarter: skritt, trav, galopp, tølt og pass",
          "en": "an Icelandic horse has five gaits: walk, trot, gallop, tölt and pace"
        },
        {
          "no": "holde seg til rett gangart",
          "en": "keep to the correct gait"
        }
      ]
    },
    {
      "text": "måte et menneske går på",
      "translation": "the way a person walks",
      "examples": [
        {
          "no": "ha en gyngende gangart",
          "en": "have a swaying gait"
        }
      ]
    }
