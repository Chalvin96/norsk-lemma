  "definitions": [
    {
      "text": "sette tråd i",
      "translation": "to thread",
      "examples": [
        {
          "no": "træ en nål",
          "en": "thread a needle"
        },
        {
          "no": "jeg har trædd veven",
          "en": "I have threaded the loom"
        }
      ]
    },
    {
      "text": "føre noe inn i eller tvers gjennom noe",
      "translation": "to pass something into or through something else",
      "examples": [
        {
          "no": "træ i skolissene",
          "en": "thread in the shoelaces"
        },
        {
          "no": "træ perler på en snor",
          "en": "thread beads onto a string"
        },
        {
          "no": "de trædde  jordbær på et strå",
          "en": "they threaded strawberries onto a straw"
        },
        {
          "no": "han trær i strikken",
          "en": "he threads the elastic through"
        }
      ]
    },
    {
      "text": "kle på seg",
      "translation": "to put on clothes",
      "examples": []
    },
    {
      "text": "trekke på seg",
      "translation": "to pull on",
      "examples": [
        {
          "no": "træ på seg hanskene",
          "en": "pull on the gloves"
        },
        {
          "no": "hun trædde genseren over hodet",
          "en": "she pulled the sweater over her head"
        }
      ]
    }
  ]
