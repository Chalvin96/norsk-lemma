  "definitions": [
    {
      "text": "sterk lyst til å gjøre noe som en kanskje vil angre på",
      "translation": "a strong desire to do something one might regret",
      "examples": [
        {
          "no": "falle for fristelsen til å kjøpe nye gardiner",
          "en": "give in to the temptation to buy new curtains"
        },
        {
          "no": "han motstod fristelsen",
          "en": "he resisted the temptation"
        },
        {
          "no": "fristelsen ble for stor",
          "en": "the temptation became too great"
        }
      ]
    },
    {
      "text": "noe som lokker til synd eller annen amoralsk atferd",
      "translation": "something that lures to sin or other immoral behavior",
      "examples": [
        {
          "no": "det er mange fristelser",
          "en": "there are many temptations"
        },
        {
          "no": "led oss ikke inn i fristelse",
          "en": "lead us not into temptation"
        },
        {
          "no": "storbyens fristelser",
          "en": "the temptations of the big city"
        }
      ]
    },
    {
      "text": "ting eller vare som virker tillokkende",
      "translation": "an item or product that appears attractive",
      "examples": [
        {
          "no": "finne mange fristelser i butikken",
          "en": "find many temptations in the shop"
        }
      ]
    }
  ]
