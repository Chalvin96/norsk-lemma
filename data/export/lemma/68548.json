  "definitions": [
    {
      "text": "bruke vinkel for å bringe noe i (rett) vinkel",
      "translation": "use a set square to bring something into (a right) angle",
      "examples": []
    },
    {
      "text": "merke av vinkel",
      "translation": "mark out an angle",
      "examples": [
        {
          "no": "vinkle opp noe",
          "en": "square something up"
        },
        {
          "no": "måle og vinkle",
          "en": "measure and square up"
        }
      ]
    },
    {
      "text": "presentere noe fra en viss synsvinkel, for eksempel ved å gi nyhetsreportasjer en bestemt form (etter interesser, formål, politiske synspunkter og annet)",
      "translation": "present something from a certain point of view, for example by giving news reports a specific form (according to interests, purpose, political viewpoints)",
      "examples": [
        {
          "no": "et tidsskrift som vinkler stoffet kritisk",
          "en": "a journal that presents the material from a critical angle"
        }
      ]
    }
