          "en": "first you, then me"
        }
      ]
    },
    {
      "text": "så eller så lang tid fra noe skjedde",
      "translation": "so long ago from when something happened",
      "examples": [
        {
          "no": "det er lenge siden",
          "en": "it's been a long time"
        },
        {
          "no": "for to år siden",
          "en": "two years ago"
        }
      ]
    },
    {
      "text": "brukt som preposisjon: fra (et gitt tidspunkt)",
      "translation": "used as: from (a specified point in time)",
      "examples": [
