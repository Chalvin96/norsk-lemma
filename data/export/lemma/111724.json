  "cross_reference": null,
  "definitions": [
    {
      "text": "kaste eller sparke hardt og målrettet",
      "translation": "to throw or kick hard and purposefully",
      "examples": [
        {
          "no": "dryle ballen i mål",
          "en": "slam the ball into the goal"
        },
        {
          "no": "dryle frisbeen av gårde",
          "en": "send the frisbee flying"
        }
      ]
    },
    {
      "text": "føre hardt mot eller ned i",
      "translation": "to move hard towards or down into",
      "examples": [
        {
          "no": "de drylte løs på hverandre",
          "en": "they laid into each other"
        },
        {
          "no": "få hodet drylt ned i asfalten",
          "en": "get your head slammed down into the asphalt"
        },
        {
          "no": "dryle toalettveska ned i den fulle kofferten",
          "en": "cram the toiletry bag down into the full suitcase"
        }
      ]
    },
    {
      "text": "bevege seg raskt",
      "translation": "to move quickly",
      "examples": [
        {
          "no": "de drylte av gårde på hver sin sykkel",
          "en": "they sped off on their bicycles"
        }
      ]
    }
  ]
