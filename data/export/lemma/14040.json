  "definitions": [
    {
      "text": "gripe, klamre seg til",
      "translation": "to grasp, to cling to",
      "examples": [
        {
          "no": "fatte om noe",
          "en": "grasp onto something"
        }
      ]
    },
    {
      "text": "skjønne, forstå, erkjenne",
      "translation": "to comprehend, to understand, to realize",
      "examples": [
        {
          "no": "jeg kan ikke fatte at han er død",
          "en": "I can't grasp that he is dead"
        },
        {
          "no": "jeg fatter ikke hvordan du kunne gjøre det",
          "en": "I can't understand how you could do that"
        }
      ]
    },
    {
      "text": "få",
      "translation": "to get",
      "examples": []
    },
    {
      "text": "ta",
      "translation": "to make",
      "examples": [
        {
          "no": "fatte en beslutning",
          "en": "make a decision"
        },
        {
          "no": "fatte håp",
          "en": "conceive hope"
