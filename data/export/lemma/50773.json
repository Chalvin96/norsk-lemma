  "cross_reference": null,
  "definitions": [
    {
      "text": "som tenker og handler uten å rette seg etter andre",
      "translation": "thinking and acting without regard to others",
      "examples": []
    },
    {
      "text": "som selv bestemmer",
      "translation": "that decides for oneself",
      "examples": []
    },
    {
      "text": "fri, uavhengig, ubundet",
      "translation": "free, independent, unbound",
      "examples": [
        {
          "no": "en selvstendig stat",
          "en": "an independent state"
        },
        {
          "no": "jeg er blitt en mer selvstendig person",
          "en": "I have become a more independent person"
        },
        {
          "no": "tenke selvstendig",
          "en": "think independently"
        },
        {
          "no": "han stod fram som en selvstendig forfatter",
          "en": "he emerged as an independent writer"
        }
      ]
    },
    {
      "text": "som driver på egen hånd eller for egen regning",
      "translation": "that operates on one's own or for one's own account",
      "examples": [
        {
          "no": "hun er selvstendig næringsdrivende",
          "en": "she is self-employed"
        }
