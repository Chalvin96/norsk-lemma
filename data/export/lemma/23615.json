  "definitions": [
    {
      "text": "være i veien for",
      "translation": "to be in the way of",
      "examples": []
    },
    {
      "text": "stenge",
      "translation": "to block",
      "examples": [
        {
          "no": "gjerdet hindret dyra i å dra til skogs",
          "en": "the fence kept the animals from going into the woods"
        },
        {
          "no": "høye boligblokker hindrer utsikten",
          "en": "tall apartment blocks block the view"
        }
      ]
    },
    {
      "text": "hefte, sinke",
      "translation": "to hinder, to slow down",
      "examples": [
        {
          "no": "uvær og snøfall hindret arbeidet",
          "en": "bad weather and snowfall held up the work"
        },
        {
          "no": "jeg kunne ikke hindre henne fra å gå",
          "en": "I couldn't stop her from leaving"
        }
      ]
    },
    {
      "text": "avverge, forhindre",
      "translation": "to avert, to prevent",
      "examples": [
        {
          "no": "vi må hindre en ny krig",
          "en": "we must prevent a new war"
        },
        {
          "no": "han greide å hindre at skuta gikk på grunn",
          "en": "he managed to keep the ship from running aground"
        }
      ]
    }
  ]
