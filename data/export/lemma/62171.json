  "definitions": [
    {
      "text": "tom for krefter og energi",
      "translation": "empty of strength and energy",
      "examples": []
    },
    {
      "text": "matt, slapp, sliten",
      "translation": "dull, listless, tired",
      "examples": [
        {
          "no": "bli trøtt og sliten av arbeidet",
          "en": "become tired and worn out from the work"
        },
        {
          "no": "være trøtt i beina etter den lange gåturen",
          "en": "have tired legs after the long walk"
        }
      ]
    },
    {
      "text": "som kjenner trang til å sove",
      "translation": "feeling the need to sleep",
      "examples": [
        {
          "no": "bli trøtt av medisinene",
          "en": "become sleepy from the medication"
        },
        {
          "no": "et trøtt smil",
          "en": "a tired smile"
        },
        {
          "no": "ha trøtte øyne",
          "en": "have tired eyes"
        },
        {
          "no": "filmen gjorde ham så trøtt at han sovnet",
          "en": "the movie made him so sleepy that he fell asleep"
        }
      ]
    },
    {
      "text": "som har gått lei noe",
      "translation": "having had enough of something",
      "examples": [
        {
          "no": "være trøtt av skolen",
          "en": "be tired of school"
        },
        {
          "no": "hun er trøtt av det ensformige livet sitt",
          "en": "she is tired of her monotonous life"
        }
      ]
    },
    {
      "text": "som gjør en trøtt trett",
      "translation": "that makes one tired",
