  "definitions": [
    {
      "text": "jordsmonn dannet av mose, gress, løv og lignende som har blitt liggende i vann og bare delvis råtner",
      "translation": "soil formed from moss, grass, leaves lying in water and only partially decaying",
      "examples": [
        {
          "no": "torva ble dannet etter siste istid",
          "en": "the peat was formed after the last ice age"
        },
        {
          "no": "skjære torv til brenning",
          "en": "cut peat for burning"
        },
        {
          "no": "torva er den viktigste delen av en myr",
          "en": "peat is the most important part of a bog"
        }
      ]
    },
    {
      "text": "skåret, tørket og presset stykke av torv til å brenne",
      "translation": "cut, dried, and pressed piece of peat for burning",
      "examples": [
        {
          "no": "fyre med torv",
          "en": "burn peat"
        }
      ]
    },
    {
      "text": "øverste del av matjord som er gjennomvevd av røtter",
      "translation": "top layer of topsoil interwoven with roots",
      "examples": [
        {
          "no": "huset har torv på taket",
          "en": "the house has a turf roof"
        }
      ]
    }
