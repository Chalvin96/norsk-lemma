    {
      "text": "punkt hvor en tangent berører en kurve eller et tangentplan berører en krum flate",
      "translation": "point where a tangent touches a curve or a tangent plane touches a curved surface",
      "examples": [
        {
          "no": "berøringspunktet mellom to kurver",
          "en": "the point of contact between two curves"
        }
