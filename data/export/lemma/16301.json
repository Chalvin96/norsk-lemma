    },
    {
      "text": "plass framfor bygning",
      "translation": "space in front of a building",
      "examples": [
        {
          "no": "huset har en fin forgård med plass til bord og stoler",
          "en": "the house has a nice front yard with room for tables and chairs"
        }
      ]
    },
    {
      "text": "i overført betydning: sted, rom eller tilstand ved inngangen til eller starten av noe",
      "translation": "in a figurative sense: place, room, or state at the entrance or the start of something",
      "examples": [
