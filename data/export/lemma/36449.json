  "definitions": [
    {
      "text": "i bestemt form entall: fellesbetegnelse for hovedform i offisiell rettskrivning (for bokmål 1959–2005 og nynorsk 1959–2012), som godkjente lærebøker og statsansatte var pliktige til å bruke",
      "translation": "common term for the main form in official orthography (for Bokmål 1959–2005 and Nynorsk 1959–2012), which approved textbooks and state employees were obliged to use",
      "examples": [
        {
          "no": "bruke læreboknormalen av 1959",
          "en": "use the 1959 textbook norm"
        }
      ]
    }
