  "cross_reference": null,
  "definitions": [
    {
      "text": "renne, dryppe, sive ut gjennom mindre åpning",
      "translation": "to run out, drip, seep out through a small opening",
      "examples": [
        {
          "no": "lufta lekket ut av ballongen",
          "en": "the air leaked out of the balloon"
        },
        {
          "no": "det lekker gass fra røret",
          "en": "gas is leaking from the pipe"
        }
      ]
    },
    {
      "text": "i overført betydning: bli kjent",
      "translation": "to become known (figurative)",
      "examples": [
        {
          "no": "hemmeligheten lekket ut",
          "en": "the secret leaked out"
        }
      ]
    },
    {
      "text": "være utett, ha sprekker eller hull",
      "translation": "to be leaky, have cracks or holes",
      "examples": [
        {
          "no": "taket lekker",
          "en": "the roof leaks"
        },
        {
          "no": "spannet lekker",
          "en": "the bucket leaks"
        },
        {
          "no": "lekke som en sil",
          "en": "leak like a sieve"
        }
      ]
    },
    {
      "text": "i overført betydning: røpe noe for noen",
      "translation": "to reveal something to someone",
      "examples": [
        {
          "no": "enkeltpersoner og bedrifter har lekket strategisk kunnskap og utstyr til Øst-Europa",
          "en": "individuals and companies have leaked strategic knowledge and equipment to Eastern Europe"
        }
      ]
    }
  ]
