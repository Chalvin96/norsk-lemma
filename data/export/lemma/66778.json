      "text": "klokke som varsler",
      "translation": "bell that warns",
      "examples": [
        {
          "no": "bommene er nede, det blinker rødt og varselklokkene kimer",
          "en": "the barriers are down, red lights are flashing, and the warning bells are ringing"
