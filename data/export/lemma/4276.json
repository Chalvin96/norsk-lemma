  "definitions": [
    {
      "text": "klemme noe (sammen) i en ball",
      "translation": "to squeeze something (together) into a ball",
      "examples": [
        {
          "no": "balle klærne sammen",
          "en": "bale the clothes together"
        }
      ]
    },
    {
      "text": "pakke noe rundt noe annet",
      "translation": "to pack something around something else",
      "examples": []
    },
    {
      "text": "tulle (inn)",
      "translation": "to wrap (up)",
      "examples": [
        {
          "no": "balle ullteppet godt omkring seg",
          "en": "wrap the wool blanket tightly around oneself"
        },
        {
          "no": "balle varen inn i et papir",
          "en": "wrap the item in paper"
        }
      ]
    },
    {
      "text": "klusse, plundre",
      "translation": "to mess up, to botch",
      "examples": [
        {
          "no": "så er det noen som baller det til likevel",
          "en": "then someone goes and messes it up anyway"
        }
      ]
    }
  ]
