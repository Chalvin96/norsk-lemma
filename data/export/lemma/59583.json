  "definitions": [
    {
      "text": "følelse av plikt og velvilje overfor noen som har gjort en en tjeneste eller vist velvilje",
      "translation": "feeling of obligation and goodwill towards someone who has done a service or shown kindness",
      "examples": [
        {
          "no": "være full av takk",
          "en": "be full of gratitude"
        }
      ]
    },
    {
      "text": "ytring eller handling som uttrykker takknemlighet",
      "translation": "utterance or action expressing gratitude",
      "examples": [
        {
          "no": "få en gave til takk",
          "en": "receive a gift in thanks"
        },
        {
          "no": "få blomster som takk for innsatsen",
          "en": "receive flowers as thanks for the effort"
        },
        {
          "no": "du skal ha takk for at du sa ifra",
          "en": "thank you for speaking up"
        },
        {
          "no": "være noen takk skyldig",
          "en": "owe someone thanks"
        }
      ]
    },
    {
      "text": "brukt i utrop for å gi uttrykk for takknemlighet",
      "translation": "used in exclamations to express gratitude",
      "examples": []
    },
    {
      "text": "brukt i høflig samtykke eller avslag",
      "translation": "used in polite agreement or refusal",
      "examples": [
        {
          "no": "takk for maten",
          "en": "thanks for the meal"
        },
        {
          "no": "takk for hjelpen",
          "en": "thanks for the help"
        },
        {
          "no": "takk for sist",
          "en": "thanks for last time"
        },
        {
          "no": "takk for nå",
          "en": "thanks for now"
        }
      ]
    },
    {
      "text": "brukt ironisk om gjengjeld som viser manglende takknemlighet",
      "translation": "used ironically for a return that shows a lack of gratitude",
      "examples": [
        {
          "no": "er dette takken etter alt vi har gjort for deg?",
          "en": "is this the thanks we get after all we have done for you?"
        }
      ]
    }
