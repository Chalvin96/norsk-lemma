  "cross_reference": null,
  "definitions": [
    {
      "text": "gli i lufta",
      "translation": "to glide in the air",
      "examples": [
        {
          "no": "en hauk svever høyt oppe",
          "en": "a hawk soars high up"
        },
        {
          "no": "hopperen svevde nedover bakken",
          "en": "the jumper floated down the slope"
        }
      ]
    },
    {
      "text": "befinne seg oppe i lufta",
      "translation": "to be in the air",
      "examples": [
        {
          "no": "sveve fritt i rommet",
          "en": "float freely in space"
        },
        {
          "no": "ute i horisonten svevde lette sommerskyer",
          "en": "light summer clouds floated on the horizon"
        }
      ]
    },
    {
      "text": "bevege seg lett",
      "translation": "to move lightly",
      "examples": [
        {
          "no": "de dansende svever forbi",
          "en": "the dancers glide by"
        }
      ]
    },
    {
      "text": "befinne seg i en usikker eller ustabil tilstand",
      "translation": "to be in an uncertain or unstable state",
      "examples": []
    },
    {
      "text": "jamfør svevende",
      "translation": "hovering",
      "examples": [
        {
          "no": "sveve mellom liv og død",
          "en": "hover between life and death"
        },
        {
          "no": "sveve i en villfarelse",
          "en": "be under a delusion"
        },
        {
          "no": "han svever i livsfare",
          "en": "he is in mortal danger"
        }
      ]
    }
  ]
