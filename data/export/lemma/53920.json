          "en": "the sea splashed over the rail"
        }
      ]
    },
    {
      "text": "plutselig sette seg i bevegelse",
      "translation": "to suddenly start moving",
      "examples": []
    },
    {
      "text": "fare av sted",
      "translation": "to dash off",
      "examples": [
        {
          "no": "skvette til side",
          "en": "dart aside"
        },
        {
          "no": "skvette opp av senga",
          "en": "jump out of bed"
        }
      ]
    },
    {
      "text": "støkke, kveppe",
      "translation": "to startle, to jump",
