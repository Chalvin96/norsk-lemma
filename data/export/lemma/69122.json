  "definitions": [
    {
      "text": "vri eller lee på noe gjentatte ganger",
      "translation": "to twist or move something repeatedly",
      "examples": [
        {
          "no": "vrikke løs en stein med et spett",
          "en": "pry a stone loose with a crowbar"
        },
        {
          "no": "danserne vrikker på hoftene",
          "en": "the dancers wiggle their hips"
        },
        {
          "no": "vrikke ankelen",
          "en": "sprain your ankle"
        }
      ]
    },
    {
      "text": "drive robåt fram ved å vrikke en åre fram og tilbake som en pendel bak båten",
      "translation": "to propel a rowboat by twisting an oar back and forth behind the boat",
      "examples": []
    }
  ]
