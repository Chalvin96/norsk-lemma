  "definitions": [
    {
      "text": "tid som følger nåtiden, kommende tid",
      "translation": "time that follows the present, coming time",
      "examples": [
        {
          "no": "fortid, nåtid og framtid",
          "en": "past, present and future"
        },
        {
          "no": "framtiden ligger åpen foran deg",
          "en": "the future lies open before you"
        },
        {
          "no": "framtiden vil vise",
          "en": "time will tell"
        }
      ]
    },
    {
      "text": "(utsikter til) framgang og gode kår i tiden som kommer",
      "translation": "(prospects of) progress and good conditions in the time to come",
      "examples": [
        {
          "no": "det er ingen framtid i det",
          "en": "there is no future in that"
        },
        {
          "no": "det er ingen framtid for ham der",
          "en": "there is no future for him there"
        },
        {
          "no": "gå en dyster framtid i møte",
          "en": "face a bleak future"
        },
        {
          "no": "gå en lys framtid i møte",
          "en": "face a bright future"
        }
      ]
    },
    {
      "text": "foreldet term i språkvitenskap for futurum",
      "translation": "obsolete term for future",
      "examples": []
    }
