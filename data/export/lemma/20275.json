  "definitions": [
    {
      "text": "det å glippe gleppe (med ski)",
      "translation": "the act of slipping or losing grip (with skis)",
      "examples": [
        {
          "no": "jeg hadde litt glipp i skiene",
          "en": "my skis were slipping a little"
        }
      ]
    },
    {
      "text": "feil som skyldes dårlig kontroll eller manglende konsentrasjon",
      "translation": "an error due to poor control or lack of concentration",
      "examples": [
        {
          "no": "en teknisk glipp",
          "en": "a technical slip-up"
        },
        {
          "no": "navnene ble offentliggjort ved en glipp",
          "en": "the names were made public by mistake"
        },
        {
          "no": "det har skjedd en liten glipp",
