  "definitions": [
    {
      "text": "gutt eller mann i forhold til den eller dem som han har felles foreldre med",
      "translation": "a male sibling, a boy or man in relation to the one(s) he shares parents with",
      "examples": [
        {
          "no": "den eldste broren min skal gifte seg",
          "en": "my oldest brother is getting married"
        },
        {
          "no": "hun lekte med brødrene sine",
          "en": "she played with her brothers"
        }
      ]
    },
    {
