  "definitions": [
    {
      "text": "være i støtvis, hoppende bevegelse, særlig på grunn av ujevnt underlag",
      "translation": "to move with jerky, bouncing motion, especially due to uneven ground",
      "examples": [
        {
          "no": "bilen humpet og ristet på den dårlige veien",
          "en": "the car jolted and shook on the bad road"
        }
      ]
    },
    {
      "text": "gå haltende",
      "translation": "to walk with a limp",
      "examples": [
        {
          "no": "humpe av gårde på krykker",
          "en": "limp along on crutches"
        }
      ]
    }
  ]
