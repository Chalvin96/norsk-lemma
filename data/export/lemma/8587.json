  "definitions": [
    {
      "text": "snøre, snor, tau, reip rep",
      "translation": "lace, cord, rope",
      "examples": [
        {
          "no": "sette hunden i bånd",
          "en": "put the dog on a leash"
        },
        {
          "no": "røde og hvite bånd blafret i vinden",
          "en": "red and white ribbons fluttered in the wind"
        }
      ]
    },
    {
      "text": "i overført betydning: noe som forener eller samler",
      "translation": "something that unites or collects",
      "examples": []
    },
    {
      "text": "tilknytning tilknytting, forbindelse",
      "translation": "connection, bond",
      "examples": [
        {
          "no": "styrke båndet til nabolandet",
          "en": "strengthen the ties to the neighboring country"
        },
        {
          "no": "det er tette bånd mellom søstrene",
          "en": "there are close ties between the sisters"
        }
      ]
    },
    {
      "text": "smal strimmel av tøy eller lignende",
      "translation": "narrow strip of fabric",
      "examples": [
        {
          "no": "duken var kantet med bånd",
          "en": "the cloth was edged with ribbon"
        },
        {
          "no": "knytte et bånd rundt såret",
          "en": "tie a bandage around the wound"
        }
      ]
    },
    {
      "text": "ring som omslutter noe, holder noe på plass",
      "translation": "ring that encloses something, holds something in place",
      "examples": [
        {
          "no": "sette bånd på en tønne",
          "en": "put bands on a barrel"
        }
      ]
    },
    {
      "text": "endeløs reim rem i tekstil eller gummi som går rundt",
      "translation": "endless belt or strap in textile or rubber that goes around",
      "examples": [
        {
          "no": "transportere varene på båndet",
          "en": "transport the goods on the conveyor belt"
        },
        {
          "no": "stå ved båndet og vente på at bagasjen kommer",
          "en": "stand by the belt waiting for the luggage to arrive"
        }
      ]
    },
    {
      "text": "remse i polyester med finfordelt magnetisk materiale til å ta opp bilde på og/eller lyd med",
      "translation": "strip of polyester with finely divided magnetic material for recording image and/or sound",
      "examples": [
