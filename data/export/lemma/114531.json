  "definitions": [
    {
      "text": "forhold mellom det aktuelle vanninnholdet i et reguleringsmagasin og vanninnholdet ved fullt magasin, målt i prosent av fullt magasin",
      "translation": "ratio between the current water content in a reservoir and the water content when the reservoir is full, measured in percent of a full reservoir",
      "examples": [
        {
          "no": "fyllingsgraden i vannmagasinet er på 77 prosent",
          "en": "the fill level in the reservoir is 77 percent"
        }
      ]
    },
    {
      "text": "forhold mellom antall passasjerer på et kommunikasjonsmiddel og det tillatte antall",
      "translation": "ratio between the number of passengers on a means of transport and the permitted number",
      "examples": [
        {
          "no": "fyllingsgraden på toget gjennom jula var høy",
          "en": "the occupancy on the train over Christmas was high"
        }
      ]
    }
