  "definitions": [
    {
      "text": "bestemme retning til noe ved hjelp av kompass, radiosignal eller lignende, for å fastslå en posisjon",
      "translation": "determine direction to something using compass, radio signal, to establish a position",
      "examples": [
        {
          "no": "de gjorde flere forsøk på å peile ulven",
          "en": "they made several attempts to track the wolf"
        }
      ]
    },
    {
      "text": "måle dybde eller høyde på (væske i beholder)",
      "translation": "measure depth or height of (liquid in a container)",
      "examples": [
        {
          "no": "peile motoroljen",
          "en": "check the engine oil"
        }
      ]
    }
