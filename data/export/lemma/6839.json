  "definitions": [
    {
      "text": "slå med nevene etter visse regler for å bekjempe en jevntung motstander",
      "translation": "to fight an evenly matched opponent with fists according to certain rules",
      "examples": [
        {
          "no": "bokse en 15 runders kamp",
          "en": "box a 15-round fight"
        }
      ]
    },
    {
      "text": "slå med neven",
      "translation": "to hit with a fist",
      "examples": [
        {
          "no": "bokse noen i magen",
          "en": "punch someone in the stomach"
        },
        {
          "no": "målmannen bokset ballen ut",
          "en": "the goalkeeper punched the ball away"
        }
      ]
    }
