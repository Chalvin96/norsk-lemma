  "definitions": [
    {
      "text": "om person: som ikke lar seg påvirke eller forandre",
      "translation": "about a person: one who cannot be influenced or changed",
      "examples": []
    },
    {
      "text": "som ikke viker fra sine holdninger eller prinsipper",
      "translation": "one who does not deviate from their attitudes or principles",
      "examples": [
        {
          "no": "en hardnakket tilhenger av presidenten",
          "en": "a staunch supporter of the president"
        },
        {
          "no": "nekte hardnakket",
          "en": "stubbornly refuse"
        }
      ]
    },
    {
      "text": "om kamp eller forsvar: utholdende, seig, standhaftig",
      "translation": "about a fight or defense: persistent, tenacious, steadfast",
      "examples": [
        {
          "no": "gjøre hardnakket motstand",
          "en": "put up stubborn resistance"
        },
        {
          "no": "kjempe hardnakket",
          "en": "fight tenaciously"
        }
      ]
    },
    {
      "text": "om noe leit eller ubehagelig: som ikke vil gi seg",
      "translation": "about something unpleasant or uncomfortable: that does not go away",
      "examples": [
        {
          "no": "en hardnakket forkjølelse",
          "en": "a stubborn cold"
        },
        {
          "no": "hardnakkede rykter",
          "en": "persistent rumors"
