    {
      "text": "mer eller mindre gjennomsiktig stoff til å dekke hele eller deler av hodet med, brukt som pynt, symbol eller beskyttelse",
      "translation": "more or less transparent fabric to cover all or part of the head, used as decoration, symbol or protection",
      "examples": [
        {
          "no": "en hatt med slør",
          "en": "a hat with a veil"
        },
        {
          "no": "bære svart slør i begravelsen",
          "en": "wear a black veil at the funeral"
        },
        {
          "no": "burka og andre heldekkende slør",
          "en": "burqa and other full-covering veils"
        },
        {
          "no": "bruke rødt slør mot sola",
          "en": "use a red veil against the sun"
        }
      ]
    },
    {
