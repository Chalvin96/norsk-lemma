  "definitions": [
    {
      "text": "si nei til",
      "translation": "to say no to",
      "examples": []
    },
    {
      "text": "avslå, avvise",
      "translation": "to decline, to reject",
      "examples": [
        {
          "no": "nekte militærtjeneste",
          "en": "refuse military service"
        },
        {
          "no": "jeg nekter å bli med",
          "en": "I refuse to come along"
        },
        {
          "no": "de var så beruset at de ble nektet servering",
          "en": "they were so intoxicated that they were refused service"
        }
      ]
    },
    {
      "text": "bestride riktigheten av",
      "translation": "to dispute the correctness of",
      "examples": []
    },
    {
      "text": "tvile på",
      "translation": "to doubt",
      "examples": [
        {
          "no": "nekte for Guds eksistens",
          "en": "deny God's existence"
        },
        {
          "no": "det kan du ikke nekte for",
          "en": "you can't deny that"
        },
        {
          "no": "den anklagede nektet seg skyldig",
          "en": "the accused pleaded not guilty"
        },
        {
          "no": "det står ikke til å nekte for at kvaliteten er dårlig",
          "en": "there is no denying that the quality is poor"
        }
      ]
    },
    {
      "text": "i grammatikk: uttrykke et negativt forhold eller en nekting",
      "translation": "to express a negative relationship or a refusal",
      "examples": [
        {
          "no": "en nektende setning",
          "en": "a negative sentence"
        }
      ]
    }
