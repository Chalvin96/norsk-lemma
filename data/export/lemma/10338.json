  "definitions": [
    {
      "text": "klinge sammen slik at det gir dissonans",
      "translation": "to sound together in a way that creates dissonance",
      "examples": [
        {
          "no": "bassen i denne låten dissonerer med akkordene",
          "en": "the bass in this song clashes with the chords"
        },
        {
          "no": "dissonerende overtoner",
          "en": "dissonant overtones"
        }
      ]
    },
    {
      "text": "i overført betydning: klinge uharmonisk og falskt",
      "translation": "in a figurative sense: to sound disharmonious and false",
      "examples": [
        {
          "no": "hva som dissonerer, er et skjønnsspørsmål",
          "en": "what clashes is a matter of judgment"
        }
      ]
    }
  ]
