  "cross_reference": null,
  "definitions": [
    {
      "text": "gå tassende, subbe",
      "translation": "walk shufflingly, shuffle",
      "examples": [
        {
          "no": "det tuslet ute i bislaget",
          "en": "there was shuffling about outside in the entryway"
        },
        {
          "no": "det tuslet og taslet i krokene",
          "en": "there was shuffling and rustling in the corners"
        }
      ]
    },
    {
      "text": "komme eller gå på en beskjeden måte",
      "translation": "come walking in a modest way",
      "examples": [
        {
          "no": "tusle av gårde",
          "en": "shuffle off"
        },
        {
          "no": "tusle seg inn igjen",
          "en": "shuffle back in"
        }
      ]
    },
    {
      "text": "bevege seg stillferdig, pusle",
      "translation": "move quietly, potter about",
      "examples": [
        {
          "no": "gå og tusle for seg selv",
          "en": "go around pottering by oneself"
        }
      ]
    }
  ]
