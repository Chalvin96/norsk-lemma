  "definitions": [
    {
      "text": "bli eller gjøre mør",
      "translation": "become or make tender",
      "examples": [
        {
          "no": "la kjøttet henge så det mørner",
          "en": "let the meat hang so it tenderizes"
        }
      ]
    },
    {
      "text": "bli eller gjøre mer medgjørlig",
      "translation": "become or make more compliant",
      "examples": [
        {
          "no": "de lot den mistenkte mørne en stund på glattcella",
          "en": "they let the suspect soften up for a while in the drunk tank"
        }
      ]
    },
    {
      "text": "bli eller gjøre lemster og sliten",
      "translation": "become or make crippled and tired",
      "examples": [
        {
          "no": "hun prøvde å mørne konkurrentene i bakkene",
          "en": "she tried to wear down the competitors on the slopes"
        }
      ]
    }
