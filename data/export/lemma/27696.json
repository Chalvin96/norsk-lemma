  "definitions": [
    {
      "text": "uten humper og søkk",
      "translation": "without bumps and hollows",
      "examples": []
    },
    {
      "text": "slett, flat, plan",
      "translation": "smooth, flat, level",
      "examples": [
        {
          "no": "en jevn overflate",
          "en": "an even surface"
        },
        {
          "no": "en jevn kant",
          "en": "an even edge"
        },
        {
          "no": "veien er jevn og fin",
          "en": "the road is smooth and nice"
        }
      ]
    },
    {
      "text": "likt fordelt eller like tykk overalt",
      "translation": "evenly distributed or equally thick everywhere",
      "examples": [
        {
          "no": "legge på et jevnt lag med sand",
          "en": "apply an even layer of sand"
        },
        {
          "no": "en jevn strek",
          "en": "an even line"
        },
        {
          "no": "fordele noe jevnt utover",
          "en": "distribute something evenly over"
        }
      ]
    },
    {
      "text": "med ensartet konsistens eller struktur",
      "translation": "with uniform consistency or structure",
      "examples": [
        {
          "no": "visp sammen til en jevn saus",
          "en": "whisk together into a smooth sauce"
        }
      ]
    },
    {
      "text": "uten avbrudd og uten merkbar endring i intensitet",
      "translation": "without interruption and without noticeable change in intensity",
      "examples": []
    },
    {
      "text": "vedvarende, uavbrutt",
      "translation": "persistent, uninterrupted",
      "examples": []
    },
    {
      "text": "regelmessig",
      "translation": "regular",
      "examples": [
        {
          "no": "holde jevn fart",
          "en": "maintain a steady speed"
        },
        {
          "no": "en jevn utvikling",
          "en": "steady development"
        },
        {
          "no": "det regnet jevnt og smått",
          "en": "it rained steadily and lightly"
        },
        {
          "no": "motoren surret jevnt og fint",
          "en": "the engine purred steadily and nicely"
        }
      ]
    },
    {
      "text": "like ens",
      "translation": "equally",
      "examples": []
    },
    {
      "text": "like god, stor, sterk eller lignende",
      "translation": "equally good, large, strong",
      "examples": [
        {
          "no": "de to konkurrentene var helt jevne",
          "en": "the two competitors were completely evenly matched"
        },
        {
          "no": "det er jevnere i eliteserien i år",
          "en": "it's more even in the premier division this year"
        }
      ]
    },
    {
      "text": "allmenn, vanlig",
      "translation": "general, common",
      "examples": []
    },
    {
      "text": "middels",
      "translation": "medium",
      "examples": [
        {
          "no": "de var jevne folk",
          "en": "they were ordinary people"
        },
        {
          "no": "leve i jevne kår",
          "en": "live in modest circumstances"
        }
      ]
    },
    {
      "text": "brukt som adverb: akkurat",
      "translation": "used as: exactly",
      "examples": [
