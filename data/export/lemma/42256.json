  "definitions": [
    {
      "text": "vei som ikke fører rett til målet",
      "translation": "a path that does not lead directly to the destination",
      "examples": [
        {
          "no": "ta en omvei rundt fjellet",
          "en": "take a detour around the mountain"
        }
      ]
    },
    {
      "text": "omstendelig, indirekte framgangsmåte",
      "translation": "circuitous, indirect procedure",
      "examples": [
        {
          "no": "komme fram til et resultat ad omveier",
          "en": "arrive at a result by indirect means"
        }
      ]
    }
  ]
