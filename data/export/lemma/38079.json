        {
          "no": "hvem fikk mest fisk?",
          "en": "who got the most fish?"
        },
        {
          "no": "det meste av tiden",
          "en": "most of the time"
        }
      ]
    },
    {
      "text": "brukt som adverb: i høyest grad, i størst monn, framfor alt",
      "translation": "used as: to the highest degree, in the greatest amount, above all",
      "examples": [
        {
          "no": "mest av alt har jeg lyst til å snu",
          "en": "more than anything else I want to turn around"
        },
        {
          "no": "få mest mulig ut av noe",
          "en": "get as much as possible out of something"
        },
        {
          "no": "være mest lik faren sin",
          "en": "be most like his father"
        }
      ]
    },
    {
      "text": "oftest, som regel, vesentlig",
      "translation": "most often, as a rule, essentially",
      "examples": [
        {
          "no": "holde seg mest hjemme",
          "en": "mostly stay at home"
        }
      ]
    },
    {
