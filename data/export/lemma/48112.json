  "definitions": [
    {
      "text": "om væske eller masse: strømme, flyte, sige",
      "translation": "of liquid or mass: to flow, stream, pour",
      "examples": [
        {
          "no": "tårene renner",
          "en": "the tears are running"
        },
        {
          "no": "elva rant stri",
          "en": "the river ran swift"
        },
        {
          "no": "en strøm av gjørme har rent ned fra vulkanen",
          "en": "a stream of mud has run down from the volcano"
        },
        {
          "no": "smeltevannet renner ut i havet",
          "en": "the meltwater runs out into the sea"
        }
      ]
    },
    {
      "text": "gi fra seg eller bli fylt av væske",
      "translation": "to give off or be filled with liquid",
      "examples": [
        {
          "no": "vannkranen rant",
          "en": "the tap was running"
        },
        {
          "no": "nedbørsmåleren rant full",
          "en": "the rain gauge ran full"
        },
        {
          "no": "rennende nese",
          "en": "runny nose"
        },
        {
          "no": "ha rennende øyne",
          "en": "have watery eyes"
        }
      ]
    },
    {
      "text": "fare av sted",
      "translation": "to rush along",
      "examples": []
    },
    {
      "text": "gli",
      "translation": "to slide",
      "examples": [
        {
          "no": "steinblokkene renner ned fjellsiden",
          "en": "the boulders slide down the mountainside"
        },
        {
          "no": "sinnet rant bort",
          "en": "the anger ran off"
        }
      ]
    },
    {
      "text": "komme opp, stige opp",
      "translation": "to come up, to rise up",
      "examples": []
    },
    {
      "text": "jamfør solrenning",
      "translation": "sunrise",
      "examples": [
        {
          "no": "nå fjelltoppen idet sola renner",
          "en": "reach the mountain peak just as the sun rises"
        },
        {
          "no": "det var ikke lenge til dagen rant",
          "en": "it was not long until day broke"
        }
      ]
    },
    {
      "text": "spire, gro",
      "translation": "to sprout, to grow",
      "examples": [
        {
          "no": "åkeren vil snart renne",
          "en": "the field will soon sprout"
        }
      ]
