  "definitions": [
    {
      "text": "oppvarming av jordoverflaten som skyldes at drivhusgass i atmosfære reflekterer deler av varmestrålingen fra jorda tilbake til overflaten",
      "translation": "warming of the Earth's surface caused by greenhouse gases in the atmosphere reflecting part of the heat radiation from the Earth back to the surface",
      "examples": [
        {
          "no": "utslipp av klimagasser fører til økt drivhuseffekt",
          "en": "emissions of greenhouse gases lead to an increased greenhouse effect"
        }
      ]
    },
    {
      "text": "oppvarming av rom eller bygning som følge av at det slippes inn mer stråling fra sola enn det som slipper ut gjennom glassflatene i rommet eller bygningen",
      "translation": "warming of a room or building as a result of more radiation from the sun entering than escaping through the glass surfaces of the room or building",
      "examples": [
        {
          "no": "de store vinduene gir drivhuseffekt om våren og høsten",
          "en": "the large windows create a greenhouse effect in spring and autumn"
        }
      ]
    }
  ]
