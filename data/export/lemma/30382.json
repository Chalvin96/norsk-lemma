  "definitions": [
    {
      "text": "dele i to med øks, kile eller lignende",
      "translation": "to split in two with an axe, wedge",
      "examples": [
        {
          "no": "kløyve ved",
          "en": "split firewood"
        },
        {
          "no": "kløyve en kubbe til småflis",
          "en": "split a log into kindling"
        }
      ]
    },
    {
      "text": "stykke opp i flere deler",
      "translation": "to cut up into several parts",
      "examples": []
    },
    {
      "text": "skille, dele",
      "translation": "to separate, divide",
      "examples": [
        {
          "no": "landet var kløyvd av fjorder",
          "en": "the country was split by fjords"
        },
        {
          "no": "øya ligger midt i elva og kløyver den",
          "en": "the island lies in the middle of the river and splits it"
        },
        {
          "no": "kløyvd tunge",
          "en": "split tongue"
        }
      ]
    },
    {
      "text": "i overført betydning: skape splittelse",
      "translation": "in a figurative sense: to create division",
      "examples": [
        {
          "no": "saken kløyver bygdesamfunnet",
          "en": "the issue is splitting the village community"
        }
      ]
    }
  ]
