  "cross_reference": null,
  "definitions": [
    {
      "text": "avlive og dele opp (hus)dyr som skal brukes til mat",
      "translation": "to slaughter and butcher (domestic) animals for food",
      "examples": [
        {
          "no": "slakte grisen til jul",
          "en": "slaughter the pig for Christmas"
        },
        {
          "no": "laksen ble slaktet rett på båten",
          "en": "the salmon was slaughtered right on the boat"
        }
      ]
    },
    {
      "text": "drepe eller myrde brutalt og hensynsløst",
      "translation": "to kill or murder brutally and ruthlessly",
      "examples": [
        {
          "no": "hele landsbyen ble slaktet av opprørerne",
          "en": "the whole village was slaughtered by the rebels"
        }
      ]
    },
    {
      "text": "kritisere svært hardt",
      "translation": "to criticize severely",
      "examples": [
        {
          "no": "forestillingen ble slaktet av kritikerne",
          "en": "the production was slaughtered by the critics"
        },
        {
          "no": "opposisjonen slakter regjeringens forslag",
          "en": "the opposition is slaughtering the government's proposal"
        }
      ]
    },
    {
      "text": "hogge opp eller dele opp noe og selge det som er av verdi",
      "translation": "to chop up or dismantle something and sell its valuable parts",
      "examples": [
        {
          "no": "banden stjal biler og slaktet dem",
          "en": "the gang stole cars and stripped them"
        },
        {
          "no": "utlendingene kjøpte opp bedriften bare for å slakte den",
          "en": "the foreigners bought up the company just to strip it"
        }
      ]
    }
  ]
