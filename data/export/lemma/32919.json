  "cross_reference": null,
  "definitions": [
    {
      "text": "skjære eller hogge raskt",
      "translation": "to cut or chop quickly",
      "examples": [
        {
          "no": "kutte tauet",
          "en": "cut the rope"
        },
        {
          "no": "kutte seg i fingeren",
          "en": "cut one's finger"
        }
      ]
    },
    {
      "text": "bryte av, stanse",
      "translation": "to break off, to stop",
      "examples": [
        {
          "no": "kutte strømmen",
          "en": "cut off the power"
        },
        {
          "no": "kutte av midt i talen",
          "en": "cut off in the middle of the speech"
        }
      ]
    },
    {
      "text": "skjære ned, redusere",
      "translation": "to cut down, reduce",
      "examples": [
        {
          "no": "butikken kuttet prisene",
          "en": "the shop cut prices"
        },
        {
          "no": "vi må kutte utslippene av klimagasser",
          "en": "we have to cut greenhouse gas emissions"
        },
        {
          "no": "de måtte kutte i bevilgningene",
          "en": "they had to cut the appropriations"
        }
      ]
    }
  ]
