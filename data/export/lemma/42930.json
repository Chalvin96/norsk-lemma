  "definitions": [
    {
      "text": "landområde som er omgitt av vann på alle kanter (og er større enn en holme og mindre enn et kontinent)",
      "translation": "land area surrounded by water on all sides (larger than a islet and smaller than a continent)",
      "examples": [
        {
          "no": "de bor på en øy langt ute i havet",
          "en": "they live on an island far out at sea"
        },
        {
          "no": "de greske øyene",
          "en": "the Greek islands"
        }
      ]
    },
    {
      "text": "i overført betydning: noe som minner om en øy fordi det er isolert eller omgitt av noe annet",
      "translation": "something resembling an island because it is isolated or surrounded by something else",
      "examples": [
        {
          "no": "landet er en liten øy av velstand og stabilitet",
          "en": "the country is a small island of prosperity and stability"
        }
      ]
    }
