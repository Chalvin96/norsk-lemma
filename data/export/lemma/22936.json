  "definitions": [
    {
      "text": "feste sammen med hekte",
      "translation": "fasten together with a hook",
      "examples": [
        {
          "no": "hekte en kofte",
          "en": "fasten a cardigan"
        },
        {
          "no": "hekte kroken på døra",
          "en": "hook the latch onto the door"
        },
        {
          "no": "hekte sammen noe",
          "en": "hook something together"
        }
      ]
    },
    {
      "text": "henge seg opp eller bli sittende fast i noe",
      "translation": "get stuck or caught on something",
      "examples": [
        {
          "no": "gasspedalen hektet seg opp",
          "en": "the gas pedal got stuck"
        },
        {
          "no": "hun hektet foten fast i en rot",
          "en": "she caught her foot on a root"
        },
        {
          "no": "alpinisten hektet i den nest siste porten",
          "en": "the skier caught the second-to-last gate"
        },
        {
          "no": "hekte seg opp i detaljer",
          "en": "get hung up on details"
        }
      ]
    },
    {
      "text": "i fotball: stoppe ulovlig",
      "translation": "in football: stop illegally",
      "examples": [
        {
          "no": "spilleren ble hektet innenfor 16-meteren",
          "en": "the player was tripped inside the penalty area"
        }
      ]
    }
  ]
