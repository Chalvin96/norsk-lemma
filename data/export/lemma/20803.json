  "definitions": [
    {
      "text": "legge en avdød i graven",
      "translation": "to lay a deceased person in the grave",
      "examples": [
        {
          "no": "bli gravlagt",
          "en": "be buried"
        },
        {
          "no": "han skal gravlegges på onsdag",
          "en": "he is to be buried on Wednesday"
        }
      ]
    },
    {
      "text": "i overført betydning: skrinlegge, glemme",
      "translation": "in a figurative sense: to shelve, to forget",
      "examples": [
        {
          "no": "hele saken er gravlagt",
          "en": "the whole matter is buried"
        },
        {
          "no": "gravlegge en plan",
          "en": "bury a plan"
        }
      ]
    }
