  "definitions": [
    {
      "text": "tall som ganget med seg selv n ganger blir et annet gitt tall",
      "translation": "the number that when multiplied by itself n times becomes another given number",
      "examples": [
        {
          "no": "om tallet er 9 og n er lik 2, er n-te-rota 3",
          "en": "if the number is 9 and n equals 2, the nth root is 3"
        }
      ]
    }
