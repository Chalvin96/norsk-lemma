  "definitions": [
    {
      "text": "ha som navn",
      "translation": "to have as a name",
      "examples": [
        {
          "no": "jeg heter Leah, hva heter du?",
          "en": "my name is Leah, what's your name?"
        },
        {
          "no": "han heter Christian etter bestefaren",
          "en": "his name is Christian after his grandfather"
        },
        {
          "no": "hva het firmaet du arbeidet for?",
          "en": "what was the name of the company you worked for?"
        },
        {
          "no": "hovedstaden i Norge heter Oslo",
          "en": "the capital of Norway is called Oslo"
        }
      ]
    },
    {
      "text": "ha som (korrekt) språklig betegnelse",
      "translation": "to have as a (correct) linguistic designation",
      "examples": [
        {
          "no": "hva heter det på norsk?",
          "en": "what is it called in Norwegian?"
        },
        {
          "no": "det heter ‘nitid’, ikke ‘nitidig’",
          "en": "it's called 'nitid', not 'nitidig'"
        }
