  "definitions": [
    {
      "text": "skyve på hjul",
      "translation": "to push on wheels",
      "examples": []
    },
    {
      "text": "skyve rundt, la rulle",
      "translation": "to push around, to let roll",
      "examples": [
        {
          "no": "trille ballen i mål",
          "en": "roll the ball into the goal"
        },
        {
          "no": "trille en tønne",
          "en": "roll a barrel"
        },
        {
          "no": "trille sykkelen",
          "en": "wheel the bike"
        }
      ]
    },
    {
      "text": "komme rullende med jevn bevegelse",
      "translation": "to come rolling with steady movement",
      "examples": [
        {
          "no": "ballen triller",
          "en": "the ball is rolling"
        },
        {
          "no": "steinene trillet ned skråningen",
          "en": "the stones rolled down the slope"
        },
        {
          "no": "sykkelen triller fort ned bakken",
          "en": "the bike rolls fast downhill"
        },
        {
          "no": "tårene triller nedover kinnene hans",
          "en": "the tears roll down his cheeks"
        }
      ]
    },
    {
      "text": "falle, dette",
      "translation": "to fall, to tumble",
      "examples": [
        {
          "no": "spedbarnet trillet ut av vogna",
          "en": "the infant fell out of the stroller"
        }
      ]
    },
    {
      "text": "frakte med trillebår",
      "translation": "to transport with a wheelbarrow",
      "examples": [
        {
          "no": "en trillebår til å trille stein i",
          "en": "a wheelbarrow for moving stones in"
        }
      ]
    }
  ]
