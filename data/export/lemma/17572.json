  "definitions": [
    {
      "text": "føre fram",
      "translation": "to bring forward",
      "examples": [
        {
          "no": "framstille for retten",
          "en": "present in court"
        }
      ]
    },
    {
      "text": "gjengi kunstnerisk, gi et bilde av, skildre, illustrere",
      "translation": "to render artistically, to give a picture of, to depict, to illustrate",
      "examples": [
        {
          "no": "maleriet framstiller et norsk vinterlandskap",
          "en": "the painting depicts a Norwegian winter landscape"
        },
        {
          "no": "romanen framstiller livet i en drabantby",
          "en": "the novel portrays life in a suburban housing development"
        },
        {
          "no": "framstille objektivt",
          "en": "portray objectively"
        },
        {
          "no": "jeg har hørt det framstilt på en annen måte",
          "en": "I have heard it presented in a different way"
        }
      ]
    },
    {
      "text": "produsere, fabrikkere",
      "translation": "to produce, to manufacture",
      "examples": [
        {
          "no": "framstille gass",
          "en": "produce gas"
        },
        {
          "no": "papir framstilles av tremasse",
          "en": "paper is made from wood pulp"
        }
      ]
    }
  ]
