  "definitions": [
    {
      "text": "gjøre kjent noe som til nå har vært ukjent eller hemmelig",
      "translation": "make known something that has until now been unknown or secret",
      "examples": [
        {
          "no": "røpe en hemmelighet",
          "en": "reveal a secret"
        },
        {
          "no": "blikket hans røpte hva han egentlig mente",
          "en": "his look revealed what he really meant"
        }
      ]
    },
    {
      "text": "vitne om",
      "translation": "testify to",
      "examples": []
    },
    {
      "text": "vise",
      "translation": "show",
      "examples": [
        {
          "no": "språket røper at han var utlending",
          "en": "his language gave away that he was a foreigner"
        },
        {
          "no": "musikken røpte et stort talent",
          "en": "the music revealed a great talent"
