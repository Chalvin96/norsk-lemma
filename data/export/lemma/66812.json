  "definitions": [
    {
      "text": "gjøre ren med vann eller annen væske (og såpe)",
      "translation": "to make clean with water, another liquid (and soap)",
      "examples": [
        {
          "no": "vaske klær",
          "en": "wash clothes"
        },
        {
          "no": "hun vasker  hendene",
          "en": "she washes her hands"
        },
        {
          "no": "han vasket seg i ansiktet",
          "en": "he washed his face"
        },
        {
          "no": "jeg har vasket over golvet",
          "en": "I have washed the floor over"
        }
      ]
    },
    {
      "text": "utvinne metall av løse jordarter ved hjelp av rennende vann",
      "translation": "to extract metal from loose earth using running water",
      "examples": [
        {
          "no": "vaske ut gull av elvesanden",
          "en": "wash gold out of the river sand"
        }
      ]
    },
    {
      "text": "skylle, strømme, fosse (over)",
      "translation": "to rinse, flow, surge (over)",
      "examples": [
        {
          "no": "bølgene vasket oppover svaberget",
          "en": "the waves washed up over the skerry"
        },
        {
          "no": "brottsjøen vasket flere mennesker over bord",
          "en": "the breaker washed several people overboard"
        },
        {
          "no": "mye rart var vasket i land",
          "en": "a lot of strange things had washed ashore"
        },
        {
          "no": "bølgene har vasket ut en hule i fjellet",
          "en": "the waves have washed out a cave in the rock"
        }
      ]
    },
    {
      "text": "fjerne eller rette på noe",
      "translation": "to remove or correct something",
      "examples": []
    },
    {
      "text": "jamfør språkvaske",
      "translation": "to proofread",
      "examples": []
    },
    {
      "text": "endre noe til å bli tilsynelatende lovlig eller bedre",
      "translation": "to alter something to appear legal or better",
      "examples": []
    },
    {
      "text": "jamfør grønnvaske og hvitvaske kvitvaske",
      "translation": "to launder money",
      "examples": [
        {
          "no": "vaske svarte penger",
          "en": "launder black money"
        }
      ]
    }
