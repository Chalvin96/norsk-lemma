  "cross_reference": null,
  "definitions": [
    {
      "text": "sette foten mot et underlag",
      "translation": "place one's foot on a surface",
      "examples": []
    },
    {
      "text": "gå og trå trø (på samme sted)",
      "translation": "walk and tread (in the same place)",
      "examples": [
        {
          "no": "gå og tråkke i de samme lokalene hver dag",
          "en": "walk around in the same premises every day"
        }
      ]
    },
    {
      "text": "bevege seg til fots",
      "translation": "move on foot",
      "examples": []
    },
    {
      "text": "stadig være i bevegelse fram og tilbake",
      "translation": "constantly move back and forth",
      "examples": [
        {
          "no": "tråkke omkring i byen",
          "en": "pace around the city"
        }
      ]
    },
    {
      "text": "stampe eller jevne med føttene",
      "translation": "stomp evenly with the feet",
      "examples": [
        {
          "no": "tråkke høylasset",
          "en": "trample the hayload"
        },
        {
          "no": "tråkke ned gresset",
          "en": "trample down the grass"
        },
        {
          "no": "tråkke vei gjennom snødrivene",
          "en": "trample a path through the snowdrifts"
        },
        {
          "no": "de tråkket unnarennet i bakken",
          "en": "they packed down the ski jump run on the slope"
        }
      ]
    },
    {
      "text": "sette foten på eller i noe",
      "translation": "place one's foot on or in something",
      "examples": [
        {
          "no": "tråkke på pedalene",
          "en": "step on the pedals"
        },
        {
          "no": "han tråkket på gassen",
          "en": "he stepped on the gas"
        },
        {
          "no": "barna tråkker i sølepyttene",
          "en": "the children are stepping in the puddles"
        }
      ]
    }
  ]
