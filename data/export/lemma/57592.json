  "cross_reference": null,
  "definitions": [
    {
      "text": "gå til felles arbeidsnedleggelse, særlig for å få gjennomført krav som gjelder lønn, arbeidsforhold og lignende",
      "translation": "to go on a collective work stoppage, especially to achieve demands concerning wages or working conditions",
      "examples": []
    },
    {
      "text": "delta i streik",
      "translation": "to participate in a strike",
      "examples": []
    },
    {
      "text": "gå til streik",
      "translation": "to go on strike",
      "examples": [
        {
          "no": "streike for høyere lønn",
          "en": "strike for higher pay"
        }
      ]
    },
    {
      "text": "nekte å utføre noe, som protest",
      "translation": "to refuse to do something as a protest",
      "examples": [
        {
          "no": "tenåringen streiker",
          "en": "the teenager is on strike"
        }
      ]
    },
    {
      "text": "slutte å fungere",
      "translation": "to stop functioning",
      "examples": [
        {
          "no": "motoren streiket",
          "en": "the engine broke down"
        }
      ]
    }
  ]
