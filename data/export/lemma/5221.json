  "definitions": [
    {
      "text": "ense, legge merke til",
      "translation": "to notice, to observe",
      "examples": [
        {
          "no": "ingen bemerket fraværet hans",
          "en": "no one noticed his absence"
        },
        {
          "no": "gjøre seg bemerket",
          "en": "make oneself noticed"
        }
      ]
    },
    {
      "text": "uttale seg om",
      "translation": "to comment on",
      "examples": []
    },
    {
      "text": "komme med innvendinger imot, tilføye",
      "translation": "to object to, to add",
      "examples": [
        {
          "no": "tillat meg å bemerke at …",
          "en": "allow me to note that ..."
        },
        {
          "no": "som ovenfor bemerket",
          "en": "as noted above"
        },
        {
          "no": "i parentes bemerket",
          "en": "parenthetically speaking"
        },
        {
          "no": "ingen hadde noe å bemerke til lovforslaget",
          "en": "no one had anything to object to in the bill"
        }
      ]
    }
