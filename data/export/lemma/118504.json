  "definitions": [
    {
      "text": "samfunn, særlig by eller bygd, som har vokst opp rundt en eller flere industrielle virksomheter",
      "translation": "society, especially a town or village, that has grown up around one or more industrial enterprises",
      "examples": [
        {
          "no": "de små industrisamfunnene innerst i fjordene på Vestlandet",
          "en": "the small industrial communities deep in the fjords of Western Norway"
        }
      ]
    },
    {
      "text": "samfunn som har industri som viktigste næringsvei",
      "translation": "society where industry is the main source of livelihood",
      "examples": [
        {
          "no": "overgangen fra jordbrukssamfunn til industrisamfunn",
          "en": "the transition from an agricultural society to an industrial society"
        }
      ]
    }
