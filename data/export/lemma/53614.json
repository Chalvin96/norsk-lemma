        {
          "no": "stormen skrek rundt huset",
          "en": "the storm shrieked around the house"
        }
      ]
    },
    {
      "text": "i overført betydning: komme kraftig til uttrykk",
      "translation": "be strongly expressed",
      "examples": []
    },
