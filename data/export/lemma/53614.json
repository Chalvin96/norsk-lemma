    {
      "text": "gråte høyt",
      "translation": "cry loudly",
      "examples": [
        {
          "no": "småbarn skriker når de er sultne",
          "en": "small children scream when they are hungry"
        }
      ]
    },
    {
      "text": "bruke sterk stemme, særlig for å bli hørt eller uttrykke sterk følelse",
      "translation": "use a strong voice, especially to be heard or express strong emotion",
      "examples": [
        {
          "no": "skrike om hjelp",
          "en": "scream for help"
        },
        {
          "no": "skrike i munnen på hverandre",
          "en": "scream at each other"
        }
      ]
    },
    {
      "text": "gi fra seg en høy og skjærende eller pipende lyd",
      "translation": "emit a loud and shrill or squeaking sound",
      "examples": []
    },
    {
      "text": "knirke, hvine kvine",
      "translation": "creak, squeak",
      "examples": [
        {
          "no": "porten skrek på hengslene",
          "en": "the gate squealed on its hinges"
