  "definitions": [
    {
      "text": "sperre, hindre",
      "translation": "to block, to obstruct",
      "examples": [
        {
          "no": "veien er blokkert av ras",
          "en": "the road is blocked by a landslide"
        },
        {
          "no": "blokkere oppkjørselen til huset",
          "en": "block the driveway to the house"
        },
        {
          "no": "få luftveiene blokkert",
          "en": "have the airways blocked"
        },
        {
          "no": "høyhus som blokkerer utsikten",
          "en": "high-rises that block the view"
        }
      ]
    },
    {
      "text": "gjennomføre blokade",
      "translation": "to carry out a blockade",
      "examples": [
        {
          "no": "blokkere en havn",
          "en": "block a harbor"
        },
        {
          "no": "blokkere kysten med krigsskip",
          "en": "block the coast with warships"
        }
      ]
    },
    {
      "text": "gjennomføre blokade for å hindre en arbeidsgiver i å få arbeidskraft",
      "translation": "to carry out a blockade to prevent an employer from obtaining labor",
      "examples": [
        {
          "no": "blokkere en arbeidsgiver",
          "en": "block an employer"
        },
        {
          "no": "fagorganisasjonen blokkerte stillingen",
          "en": "the union blocked the position"
        }
      ]
    }
  ]
