  "definitions": [
    {
      "text": "det å hindre noen i å komme inn et sted",
      "translation": "the act of preventing someone from entering a place",
      "examples": [
        {
          "no": "utestengelse fra eiendommen",
          "en": "exclusion from the property"
        }
      ]
    },
    {
      "text": "det å hindre deltakelse",
      "translation": "the act of preventing participation",
      "examples": [
        {
          "no": "fusk fører til utestengelse fra studiene",
          "en": "cheating leads to exclusion from the studies"
        },
        {
          "no": "spilleren klaget på utestengelsen fra klubben",
          "en": "the player complained about the exclusion from the club"
        }
      ]
    }
