  "definitions": [
    {
      "text": "levere gjenstand, ofte flasker, en kan få utbetalt pant for",
      "translation": "to deliver an item, often bottles, for which one can receive a deposit",
      "examples": [
        {
          "no": "flaskene kan du pante",
          "en": "you can return the bottles for a deposit refund"
        }
      ]
    },
    {
      "text": "levere noe til en pantelåner for å få penger",
      "translation": "to deliver something to a pawnbroker for money",
      "examples": []
    },
    {
      "text": "stille noe som garanti for et lån eller lignende",
      "translation": "to pledge something as security for a loan",
      "examples": [
        {
          "no": "han pantet alle verdisakene sine",
          "en": "he pawned all his valuables"
        }
      ]
    },
    {
      "text": "kreve pant",
      "translation": "to demand a pledge",
      "examples": []
    }
