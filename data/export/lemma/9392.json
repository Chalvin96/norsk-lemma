  "definitions": [
    {
      "text": "kjøre slik at en motors yteevne reduseres over tid",
      "translation": "to drive in such a way that an engine's performance is reduced over time",
      "examples": [
        {
          "no": "daukjøre bilen",
          "en": "wreck the car's engine"
        },
        {
          "no": "en daukjørt motor",
          "en": "a worn-out engine"
        }
      ]
    },
    {
      "text": "i overført betydning: slite ut, overanstrenge",
      "translation": "in a figurative sense: to wear out, overexert",
      "examples": [
        {
          "no": "føle seg daukjørt etter skirennet",
          "en": "feel worn out after the ski race"
        }
      ]
    }
