  "cross_reference": null,
  "definitions": [
    {
      "text": "straffe eller prøve med ulykke, motgang eller lignende",
      "translation": "to punish or test with misfortune, adversity",
      "examples": [
        {
          "no": "fedrenes synder hjemsøkes på barna",
          "en": "the sins of the fathers are visited on the children"
        }
      ]
    },
    {
      "text": "om ulykke, plage, motgang: ramme, plage",
      "translation": "concerning misfortune, plague, adversity: to strike, to plague",
      "examples": [
        {
          "no": "landet ble hjemsøkt av uår og sult",
          "en": "the country was plagued by crop failure and hunger"
        },
        {
          "no": "indre stridigheter hjemsøker partiet",
          "en": "internal strife plagues the party"
        },
        {
          "no": "de vonde minnene hjemsøkte ham resten av livet",
          "en": "the painful memories haunted him for the rest of his life"
        }
      ]
    },
    {
      "text": "om spøkelse, ånd eller lignende: oppsøke en person eller et sted, særlig for å plage eller hevne seg",
      "translation": "concerning ghosts, spirits: to visit a person or place, especially to plague or take revenge",
      "examples": [
        {
          "no": "familien ble hjemsøkt av onde ånder",
          "en": "the family was haunted by evil spirits"
        },
        {
          "no": "han ble hjemsøkt av sin døde fars gjenferd",
          "en": "he was haunted by the ghost of his dead father"
        },
        {
          "no": "et hjemsøkt hus",
          "en": "a haunted house"
        }
      ]
    }
  ]
