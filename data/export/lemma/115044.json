  "definitions": [
    {
      "text": "innleder en leddsetning som uttrykker at noe skjer etter et tidspunkt",
      "translation": "introduces a subordinate clause expressing that something happens after a point in time",
      "examples": []
    },
    {
      "text": "i tiden etter at",
      "translation": "in the time after that",
      "examples": [
        {
          "no": "jeg har kjent henne siden vi var fem år gamle",
          "en": "I have known her since we were five years old"
        },
        {
          "no": "siden han giftet seg, har jeg ikke sett ham",
          "en": "since he got married, I haven't seen him"
        }
      ]
    },
    {
      "text": "innleder en leddsetning som uttrykker årsak",
      "translation": "introduces a subordinate clause expressing cause",
      "examples": []
    },
    {
      "text": "fordi for di, på grunn av at",
      "translation": "because, due to the fact that",
      "examples": [
        {
          "no": "siden vi ikke har penger, blir vi hjemme i sommer",
          "en": "since we don't have any money, we're staying home this summer"
        },
        {
          "no": "siden det var så godt vær, spiste vi ute",
          "en": "since the weather was so good, we ate outside"
        }
      ]
    }
  ]
