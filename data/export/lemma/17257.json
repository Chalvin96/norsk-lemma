  "definitions": [
    {
      "text": "vente, regne med, håpe",
      "translation": "wait for, count on, hope for",
      "examples": [
        {
          "no": "de forventet mye av ham",
          "en": "they expected a lot of him"
        },
        {
          "no": "jeg hadde ikke forventet noe annet av deg",
          "en": "I hadn't expected anything else from you"
        },
        {
          "no": "kritikerne kan ikke forvente seg så mye",
          "en": "the critics can't expect that much"
        },
        {
          "no": "budsjettene øker mer enn den forventede prisveksten",
          "en": "the budgets are increasing more than the expected rise in prices"
