    {
      "text": "sette inn",
      "translation": "to deposit (money)",
      "examples": [
        {
          "no": "pengene er innsatt i banken",
          "en": "the money has been deposited in the bank"
        }
      ]
    },
    {
      "text": "la noen overta embete eller verv",
      "translation": "to inaugurate someone into office or a position",
      "examples": [
        {
          "no": "den nye presidenten ble innsatt i embetet",
          "en": "the new president was installed in office"
        }
      ]
    },
    {
      "text": "sette inn med bevarende stoff",
      "translation": "to treat with a preserving substance",
      "examples": [
        {
