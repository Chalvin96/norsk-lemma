  "definitions": [
    {
      "text": "bli lettere av vekt",
      "translation": "to become lighter in weight",
      "examples": [
        {
          "no": "grønnsakene letner under lagring",
          "en": "the vegetables become lighter during storage"
        }
      ]
    },
    {
      "text": "om været: klarne opp",
      "translation": "regarding weather: to clear up",
      "examples": []
    },
    {
      "text": "bli opphold",
      "translation": "to stop raining",
      "examples": [
        {
          "no": "været letnet på ettermiddagen",
          "en": "the weather cleared up in the afternoon"
        },
        {
          "no": "det ser ut til at det letner nå",
          "en": "it looks like it's clearing up now"
        }
      ]
    },
    {
      "text": "løse seg opp",
      "translation": "to dissipate",
      "examples": [
        {
          "no": "tåka letnet",
          "en": "the fog lifted"
        }
      ]
    },
    {
      "text": "bli gladere",
      "translation": "to become happier",
      "examples": []
    },
    {
      "text": "bli mindre nedstemt eller trykkende",
      "translation": "to become less somber or oppressive",
      "examples": [
        {
          "no": "stemningen letnet",
          "en": "the mood lightened"
        },
        {
          "no": "jeg letnet flere kilo da jeg hørte at alt var i orden med dem",
          "en": "I felt several kilos lighter when I heard that everything was all right with them"
        }
