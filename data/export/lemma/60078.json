  "definitions": [
    {
      "text": "strimmel eller bånd med lim på",
      "translation": "strip or band with adhesive on it",
      "examples": [
        {
          "no": "henge opp plakaten med teip",
          "en": "put up the poster with tape"
        },
        {
          "no": "fingrene henger seg fast i teipen",
          "en": "the fingers stick to the tape"
        }
      ]
    },
    {
      "text": "om eldre forhold: magnetbånd magnetband til å ta opp og lagre lyd eller bilde på",
      "translation": "in older contexts: magnetic tape for recording and storing sound or image",
      "examples": []
    },
    {
      "text": "jamfør lydbånd lydband",
      "translation": "audio tape",
