  "definitions": [
    {
      "text": "prakt og skjønnhet (som vitner om noe guddommelig)",
      "translation": "splendor and beauty (that testifies to something divine)",
      "examples": [
        {
          "no": "og Herrens herlighet lyste om dem",
          "en": "and the glory of the Lord shone around them"
        },
        {
          "no": "kong Salomo i all sin herlighet",
          "en": "King Solomon in all his glory"
        }
      ]
    },
    {
      "text": "det at noe er herlig",
      "translation": "the fact that something is wonderful",
      "examples": []
    },
    {
      "text": "overdådighet, rikdom",
      "translation": "opulence, richness",
      "examples": [
        {
          "no": "leve i herlighet og glede",
          "en": "live in splendor and joy"
        },
        {
          "no": "all jordens herlighet",
          "en": "all the glory of the earth"
        }
      ]
    },
    {
      "text": "noe som er herlig",
      "translation": "something that is wonderful",
      "examples": [
        {
          "no": "skiføret var ypperlig da vi startet, men herligheten varte ikke lenge",
          "en": "the skiing was excellent when we started, but the glory didn't last long"
        }
      ]
    },
    {
      "text": "utnyttbar verdi eller rettighet (som hører til en eiendom)",
      "translation": "usable value or right belonging to a property",
      "examples": [
        {
          "no": "kjøpe gården med tilliggende herligheter",
          "en": "buy the farm with its appurtenant rights"
        }
      ]
    },
    {
      "text": "brukt som interjeksjon for å uttrykke glede, overraskelse, ergrelse eller annen sinnsstemning",
      "translation": "used as an interjection to express joy, surprise, annoyance, or other emotions",
      "examples": [
        {
          "no": "herlighet for en forestilling!",
          "en": "good heavens, what a performance!"
        },
        {
          "no": "herlighet så barnslige dere er!",
          "en": "good heavens, how childish you are!"
        }
      ]
    }
  ]
