  "cross_reference": null,
  "definitions": [
    {
      "text": "stå i en viss pris, komme på",
      "translation": "to have a certain price, to cost",
      "examples": [
        {
          "no": "dressen koster 900 kr",
          "en": "the suit costs 900 kroner"
        }
      ]
    },
    {
      "text": "føre med seg utgifter",
      "translation": "to entail expenses",
      "examples": [
        {
          "no": "å holde bil koster mange tusen for året",
          "en": "keeping a car costs many thousands a year"
        },
        {
          "no": "koste mer enn det smaker",
          "en": "cost more than it's worth"
        }
      ]
    },
    {
      "text": "kreve, føre med seg",
      "translation": "to require, to entail",
      "examples": [
        {
          "no": "det vil koste kamp",
          "en": "it will cost a fight"
        },
        {
          "no": "det kostet mye arbeid",
          "en": "it cost a lot of work"
        },
        {
          "no": "dette kan koste deg jobben",
          "en": "this could cost you your job"
        }
      ]
    },
    {
      "text": "bruke penger på",
      "translation": "to spend money on",
      "examples": [
        {
          "no": "koste på seg en ny dress",
          "en": "treat yourself to a new suit"
        },
        {
          "no": "koste på huset",
          "en": "spend money on the house"
        }
      ]
    },
    {
      "text": "skaffe penger til",
      "translation": "to provide money for",
      "examples": [
        {
          "no": "han kostet selv oppholdet",
          "en": "he paid for the stay himself"
        },
        {
          "no": "koste utdanning på barna",
          "en": "pay for the children's education"
        }
      ]
    }
  ]
