  "definitions": [
    {
      "text": "gi noe større eller mindre betydning enn noe annet",
      "translation": "to give something more or less weight than something else",
      "examples": []
    },
    {
      "text": "legge vekt på",
      "translation": "to attach importance to",
      "examples": []
    },
    {
      "text": "betone, vektlegge",
      "translation": "to emphasize",
      "examples": [
        {
          "no": "svarene på spørsmålene vektes ulikt",
          "en": "the answers to the questions are weighted differently"
        },
        {
          "no": "hensynene må vektes mot hverandre",
          "en": "the considerations must be weighed against each other"
        }
      ]
    },
    {
      "text": "gi vekttall",
      "translation": "assign credit points",
      "examples": [
