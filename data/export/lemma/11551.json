  "definitions": [
    {
      "text": "oppta i den kristne kirke ved å øse vann på eller dukke i vann",
      "translation": "admit into the Christian church by pouring water on or immersing in water",
      "examples": [
        {
          "no": "jeg døper deg til Faderens og Sønnens og Den hellige ånds navn",
          "en": "I baptize you in the name of the Father and of the Son and of the Holy Spirit"
        },
        {
          "no": "la seg døpe",
          "en": "be baptized"
        },
        {
          "no": "være døpt og konfirmert i kirken",
          "en": "be baptized and confirmed in the church"
        }
      ]
    },
    {
      "text": "innvie ved en seremoni",
      "translation": "consecrate by a ceremony",
      "examples": [
        {
          "no": "døpe båten i sjampanje",
          "en": "christen the boat with champagne"
        },
        {
          "no": "de nye studentene ble døpt",
          "en": "the new students were initiated"
        }
      ]
    },
    {
      "text": "gi navn",
      "translation": "give a name",
      "examples": [
        {
          "no": "hun ble døpt Lisa",
          "en": "she was named Lisa"
        },
        {
          "no": "veien ble døpt Dødsveien etter alle ulykkene",
          "en": "the road was dubbed Death Road after all the accidents"
        },
        {
          "no": "døpe noen i snø",
          "en": "baptize someone in snow"
        }
      ]
    }
  ]
