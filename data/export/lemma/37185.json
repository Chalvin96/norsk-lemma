  "definitions": [
    {
      "text": "gå ordnet i flokk",
      "translation": "walk in an orderly group",
      "examples": [
        {
          "no": "marsjere i takt",
          "en": "march in step"
        },
        {
          "no": "elevene marsjerer inn i klasserommet",
          "en": "the students march into the classroom"
        }
      ]
    },
    {
      "text": "gå eller flytte seg under militær kommando",
      "translation": "walk or move under military command",
      "examples": [
        {
          "no": "prøysserne var gode til å marsjere",
          "en": "the Prussians were good at marching"
        },
        {
          "no": "den tyske hæren marsjerte inn i Frankrike",
          "en": "the German army marched into France"
        }
      ]
    },
    {
      "text": "gå fort og energisk for å markere et standpunkt",
      "translation": "walk or move energetically to mark a position",
      "examples": [
        {
          "no": "mindretallet marsjerte ut av møtelokalet etter valget",
          "en": "the minority marched out of the meeting room after the vote"
        }
      ]
    },
    {
      "text": "lede en militær avdeling i sluttet orden",
      "translation": "lead a military unit in close order",
      "examples": [
        {
          "no": "marsjere en avdeling",
          "en": "march a unit"
        }
      ]
    }
  ]
