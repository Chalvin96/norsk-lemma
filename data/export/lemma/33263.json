  "definitions": [
    {
      "text": "hogge eller skjære vekk kvister og grener",
      "translation": "to chop or cut off twigs and branches",
      "examples": [
        {
          "no": "trærne må felles, kvistes og kappes",
          "en": "the trees must be felled, limbed, and cut to length"
        }
      ]
    },
    {
      "text": "merke opp vintervei eller skiløype med kvister",
      "translation": "to mark out a winter road or ski trail with twigs",
      "examples": [
        {
          "no": "mange ruter i fjellet er kvistet i påsken",
          "en": "many routes in the mountains are marked with twigs at Easter"
        }
      ]
    }
