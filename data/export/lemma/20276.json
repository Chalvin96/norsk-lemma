  "cross_reference": null,
  "definitions": [
    {
      "text": "gli glide (ut av et feste), løsne",
      "translation": "slide (out of a fastening), loosen",
      "examples": []
    },
    {
      "text": "ikke sitte fast, ikke holde",
      "translation": "not be fixed, not hold",
      "examples": [
        {
          "no": "skiene glipper",
          "en": "the skis are slipping"
        },
        {
          "no": "glippe taket",
          "en": "lose one's grip"
        },
        {
          "no": "fisken glapp ut av hendene mine",
          "en": "the fish slipped out of my hands"
        },
        {
          "no": "ordene glapp ut av henne",
          "en": "the words slipped out of her"
        }
      ]
    },
    {
      "text": "mislykkes, slå feil, svikte",
      "translation": "fail, go wrong, falter",
      "examples": [
        {
          "no": "forsøket glapp",
          "en": "the attempt failed"
        },
        {
          "no": "det glapp for henne",
          "en": "she blew it"
        }
      ]
    }
  ]
