  "definitions": [
    {
      "text": "sjakktrekk som skal avverge virkningen av et farlig trekk fra motspilleren",
      "translation": "chess move intended to avert the effect of a dangerous move by the opponent",
      "examples": [
        {
          "no": "et overraskende mottrekk",
          "en": "a surprising countermove"
        }
      ]
    },
    {
      "text": "handling som skal tilintetgjøre eller svekke virkningen av noe",
      "translation": "action intended to nullify or weaken the effect of something",
      "examples": [
        {
          "no": "arbeidsgiverne vedtok lockout som et mottrekk mot streiken",
          "en": "the employers adopted a lockout as a countermove against the strike"
        }
      ]
    }
  ]
