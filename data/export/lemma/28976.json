  "definitions": [
    {
      "text": "stoff som har evne til å forandre hastigheten i en kjemisk reaksjon uten selv å bli varig kjemisk forandret",
      "translation": "substance that has the ability to change the speed of a chemical reaction without itself being permanently chemically changed",
      "examples": []
    },
    {
      "text": "jamfør inhibitor",
      "translation": "inhibitor",
      "examples": []
    },
    {
      "text": "i overført betydning: utløsende faktor, drivkraft",
      "translation": "triggering factor, driving force",
      "examples": [
        {
          "no": "krisen virket som en katalysator for nye krefter",
          "en": "the crisis acted as a catalyst for new forces"
        }
      ]
    },
    {
      "text": "i motor: system som renser avgassene i bilmotorer og lignende ved katalyse",
      "translation": "in an engine: system that cleans exhaust gases in car engines through catalysis",
      "examples": [
        {
          "no": "katalysatorer på bil har vært påbudt siden 1989",
          "en": "catalytic converters in cars have been mandatory since 1989"
        }
      ]
    }
