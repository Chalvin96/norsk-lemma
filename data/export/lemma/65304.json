  "definitions": [
    {
      "text": "oppfordre sterkt til handling",
      "translation": "to urge strongly to action",
      "examples": []
    },
    {
      "text": "egge, hisse",
      "translation": "to egg on, incite",
      "examples": [
        {
          "no": "utfordre noen til duell",
          "en": "challenge someone to a duel"
        },
        {
          "no": "han utfordret alle mosjonistene til å delta i løpet",
          "en": "he challenged all the recreational runners to take part in the race"
        }
      ]
    },
    {
      "text": "være eller opptre kritisk overfor noen (slik at de reagerer)",
      "translation": "to be or act critically towards someone (so that they react)",
      "examples": [
        {
          "no": "utfordre de etablerte sannhetene",
          "en": "challenge the established truths"
        }
      ]
    },
    {
      "text": "stille krav til",
      "translation": "to demand of",
      "examples": [
        {
          "no": "bli utfordret intellektuelt",
          "en": "be intellectually challenged"
        },
        {
          "no": "utviklingen utfordrer samfunnet",
          "en": "developments challenge society"
