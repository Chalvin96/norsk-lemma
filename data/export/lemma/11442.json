  "definitions": [
    {
      "text": "tette en sprekk eller et hull med et mykt stoff",
      "translation": "to plug a crack or hole with a soft material",
      "examples": [
        {
          "no": "dytte igjen sprekken i muren med mose",
          "en": "plug the crack in the wall with moss"
        }
      ]
    },
    {
      "text": "pakke eller stappe med noe mykt",
      "translation": "to pack or stuff with something soft",
      "examples": [
        {
          "no": "dytte dyna rundt barnet",
          "en": "tuck the quilt around the child"
        },
        {
          "no": "de dytter så mye høy som mulig ned i sekkene",
          "en": "they stuff as much hay as possible into the sacks"
        }
      ]
    }
