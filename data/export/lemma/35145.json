  "definitions": [
    {
      "text": "i samme grad, like mye",
      "translation": "to the same degree, as much",
      "examples": [
        {
          "no": "de er like gamle",
          "en": "they are the same age"
        },
        {
          "no": "like mye",
          "en": "just as much"
        },
        {
          "no": "jeg er like glad i vinteren som i sommeren",
          "en": "I like winter as much as summer"
        },
        {
          "no": "det var like godt at det gikk som det gikk",
          "en": "it was just as well that it turned out the way it did"
        }
      ]
    },
    {
      "text": "tett, rett, nær",
      "translation": "close, straight, near",
      "examples": [
        {
          "no": "det var like før det startet",
          "en": "it was just before it started"
        },
        {
          "no": "like etter dro de",
          "en": "right after that they left"
        },
        {
          "no": "like ved grensen",
          "en": "right by the border"
        },
        {
          "no": "de satt like overfor oss",
          "en": "they were sitting directly opposite us"
        }
      ]
    },
    {
      "text": "fullt ut, fullstendig, aldeles",
      "translation": "fully, completely, entirely",
      "examples": [
        {
          "no": "sove like til klokka tolv",
          "en": "sleep right until twelve o'clock"
        },
        {
          "no": "dra like til byen",
          "en": "go all the way into town"
        },
        {
          "no": "fra 80-tallet og like fram til i dag",
          "en": "from the eighties right up to today"
        },
        {
          "no": "gå like hjem",
          "en": "go straight home"
        }
      ]
    }
