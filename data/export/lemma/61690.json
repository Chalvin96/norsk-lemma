    },
    {
      "text": "jamfør folklore",
      "translation": "folklore",
      "examples": [
        {
          "no": "ifølge tradisjonen er haugen en jernaldergrav",
          "en": "according to tradition, the mound is an Iron Age grave"
        },
        {
          "no": "julemarkedet har lange tradisjoner",
          "en": "the Christmas market has a long tradition"
        }
      ]
    },
    {
      "text": "sed og skikk",
      "translation": "custom and practice",
