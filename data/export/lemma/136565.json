  "definitions": [
    {
      "text": "gjøre en øks, ljå eller lignende ukvass ved at redskapet treffer mot en stein",
      "translation": "",
      "examples": [
        {
          "no": "steinhogge øksa",
          "en": "nick the axe on a stone"
        },
        {
          "no": "slåttekaren bannet stygt da han steinhogde ljåen",
          "en": "the haymaker cursed loudly when he nicked the scythe on a stone"
        }
      ]
    },
    {
      "text": "i overført betydning: gjøre en feilvurdering",
      "translation": "",
      "examples": []
    },
    {
      "text": "mislykkes",
      "translation": "fail",
      "examples": [
        {
          "no": "han steinhogde grovt i forsøket sitt",
          "en": "he failed badly in his attempt"
        }
      ]
    }
  ]
