  "definitions": [
    {
      "text": "gi fra seg gurglende lyder",
      "translation": "to make gurgling sounds",
      "examples": [
        {
          "no": "hønene klukket",
          "en": "the hens clucked"
        }
      ]
    },
    {
      "text": "le med halvkvalte utbrudd",
      "translation": "to laugh with half-suppressed outbursts",
      "examples": [
        {
          "no": "le så en klukker",
          "en": "laugh so that you chuckle"
        },
        {
          "no": "klukke og le",
          "en": "chuckle and laugh"
        }
      ]
    },
    {
      "text": "om væske: skvulpe med surklende lyder",
      "translation": "of liquid: to gurgle with lapping sounds",
      "examples": [
        {
          "no": "bølgene klukket mot bryggestolpene",
          "en": "the waves gurgled against the pier posts"
        }
      ]
    }
  ]
