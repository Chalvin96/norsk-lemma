  "definitions": [
    {
      "text": "begynne å vokse fra frø, frukt eller knoll",
      "translation": "begin to grow from seed, fruit, tuber",
      "examples": [
        {
          "no": "frøet gror",
          "en": "the seed sprouts"
        }
      ]
    },
    {
      "text": "vokse fram, utvikle seg",
      "translation": "grow forth, develop",
      "examples": []
    },
    {
      "text": "finnes på et sted",
      "translation": "exist in a place",
      "examples": [
        {
          "no": "gresset gror",
          "en": "the grass grows"
        },
        {
          "no": "skjegget gror godt",
          "en": "the beard grows well"
        },
        {
          "no": "muggen gror fram på vegger og i vinduskarmer",
          "en": "mold grows on walls and in window frames"
        }
      ]
    },
    {
      "text": "i overført betydning: vokse fram, utvikle seg, finnes",
      "translation": "in a figurative sense: grow forth, develop, exist",
      "examples": [
        {
          "no": "nye miljøbevegelser gror fram",
          "en": "new environmental movements are springing up"
        },
        {
          "no": "i byen har det grodd opp et rikt litterært miljø de siste årene",
          "en": "in the city, a rich literary community has sprung up in recent years"
        }
      ]
    },
    {
      "text": "om sår: leges, heles, bli bra",
      "translation": "about wounds: heal, mend, get better",
      "examples": []
    },
    {
      "text": "fylles med nytt kroppsvev",
      "translation": "be filled with new body tissue",
      "examples": [
        {
          "no": "såret har ikke begynt å gro enda",
          "en": "the wound has not started to heal yet"
        },
        {
          "no": "kuttet gror fint",
          "en": "the cut is healing nicely"
        }
      ]
    },
    {
      "text": "få til å vokse",
      "translation": "cause to grow",
      "examples": []
    },
    {
      "text": "la vokse",
      "translation": "let grow",
      "examples": [
        {
          "no": "gro skjegg",
          "en": "grow a beard"
        }
      ]
    }
  ]
