    {
      "text": "det som oppfattes av sansene, i motsetning til ‘tingen i seg selv’, foreteelse",
      "translation": "that which is perceived by the senses, as opposed to 'the thing in itself', phenomenon",
      "examples": [
        {
          "no": "som fenomen betraktet",
          "en": "regarded as a phenomenon"
        },
        {
          "no": "et universelt fenomen",
          "en": "a universal phenomenon"
        },
        {
          "no": "nordlys er et vanlig fenomen i Nord-Norge",
          "en": "the northern lights are a common phenomenon in Northern Norway"
        },
        {
          "no": "fenomenenes verden",
          "en": "the world of phenomena"
        }
      ]
    },
    {
      "text": "noe merkelig og ualminnelig",
      "translation": "something strange and unusual",
      "examples": [
