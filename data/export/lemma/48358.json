  "definitions": [
    {
      "text": "gjøre rett eller bein",
      "translation": "to make straight or even",
      "examples": []
    },
    {
      "text": "strekke ut",
      "translation": "to stretch out",
      "examples": [
        {
          "no": "rette ryggen",
          "en": "straighten one's back"
        },
        {
          "no": "de har rettet ut gulvet",
          "en": "they have leveled the floor"
        },
        {
          "no": "vegvesenet retter ut ujevnhetene i veien",
          "en": "the road authorities are smoothing out the unevenness in the road"
        },
        {
          "no": "rett deg opp!",
          "en": "straighten up!"
        }
      ]
    },
    {
      "text": "strekke fram, opp eller ut",
      "translation": "to stretch forward, up, or out",
      "examples": []
    },
    {
      "text": "rekke, peke",
      "translation": "to reach, point",
      "examples": [
        {
          "no": "rette fram hånden",
          "en": "hold out one's hand"
        },
        {
          "no": "han rettet en revolver mot henne",
          "en": "he pointed a revolver at her"
        }
      ]
    },
    {
      "text": "vende mot noen eller noe",
      "translation": "to turn towards someone or something",
      "examples": []
    },
    {
      "text": "henvende, adressere, mynte på",
      "translation": "to address, to mean for",
      "examples": [
        {
          "no": "rette en takk til noen",
          "en": "extend thanks to someone"
        },
        {
          "no": "de rettet oppmerksomheten mot scenen",
          "en": "they turned their attention to the stage"
        },
        {
          "no": "publikum rettet spørsmål til panelet",
          "en": "the audience put questions to the panel"
        },
        {
          "no": "rette kritikk mot en",
          "en": "direct criticism at someone"
        }
      ]
    },
    {
      "text": "ordne eller sette på plass",
      "translation": "to adjust or put in place",
      "examples": [
        {
          "no": "rette på slipset",
          "en": "adjust one's tie"
        }
      ]
    },
    {
      "text": "avhjelpe",
      "translation": "to make amends for",
      "examples": [
        {
          "no": "rette på et misforhold",
          "en": "correct an imbalance"
        }
      ]
    },
    {
      "text": "fjerne eller påpeke feil og mangler",
      "translation": "to remove or point out errors and deficiencies",
      "examples": []
    },
    {
      "text": "korrigere",
      "translation": "to correct",
      "examples": [
        {
          "no": "rette opp feilene",
          "en": "correct the errors"
        },
        {
          "no": "rette trykkfeil",
          "en": "correct misprints"
        },
        {
          "no": "læreren rettet stiler",
          "en": "the teacher corrected essays"
        },
        {
          "no": "rette på noens uttale",
          "en": "correct someone's pronunciation"
        }
      ]
    },
    {
      "text": "komme seg, bli bra",
      "translation": "to recover, to get better",
      "examples": [
        {
          "no": "det retter seg vel",
          "en": "it'll sort itself out"
        }
      ]
