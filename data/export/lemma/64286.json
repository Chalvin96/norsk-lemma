  "definitions": [
    {
      "text": "oppfatte eller forutsette noe som ikke er direkte uttrykt, men som framgår av sammenhengen",
      "translation": "to perceive or assume something not directly expressed but implied by the context",
      "examples": [
        {
          "no": "det var underforstått at vi skulle hjelpe til",
          "en": "it was understood that we were supposed to help out"
        },
        {
          "no": "det ligger et underforstått premiss i argumentet hennes",
          "en": "there is an implicit premise in her argument"
        }
      ]
    }
  ]
