  "definitions": [
    {
      "text": "si noe som en vet ikke er sant",
      "translation": "say something one knows is not true",
      "examples": [
        {
          "no": "nå lyver du!",
          "en": "now you're lying!"
        },
        {
          "no": "være god til å lyve",
          "en": "be good at lying"
        },
        {
          "no": "jeg lyver ikke",
          "en": "I'm not lying"
        },
        {
          "no": "han løy om alderen",
          "en": "he lied about his age"
        }
      ]
    },
    {
      "text": "gi et falskt bilde av virkeligheten",
      "translation": "give a false impression of reality",
      "examples": [
        {
          "no": "speilet lyver ikke",
          "en": "the mirror doesn't lie"
        },
        {
          "no": "statistikken lyver litt",
          "en": "the statistics lie a little"
        }
      ]
    }
