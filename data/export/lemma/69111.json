  "cross_reference": null,
  "definitions": [
    {
      "text": "snu eller dreie på noe så det skifter stilling, kommer av lage eller mister formen sin",
      "translation": "turn or twist something so that its position changes, it comes loose, or loses its shape",
      "examples": [
        {
          "no": "vri om nøkkelen",
          "en": "turn the key"
        },
        {
          "no": "vri på hodet",
          "en": "turn one's head"
        },
        {
          "no": "barnet vred armen ut av ledd",
          "en": "the child twisted its arm out of joint"
        },
        {
          "no": "hun vrir hendene i fortvilelse",
          "en": "she wrings her hands in despair"
        }
      ]
    },
    {
      "text": "føre noe i en ny retning",
      "translation": "shift something in a new direction",
      "examples": [
        {
          "no": "vri innsatsen fra justis- til helsesektoren",
          "en": "shift the effort from the justice sector to the health sector"
        }
      ]
    },
    {
      "text": "gi en forvridd framstilling av noe",
      "translation": "give a distorted representation of something",
      "examples": [
        {
          "no": "vri det til slik at en annen får skylden",
          "en": "twist it so that someone else gets the blame"
        },
        {
          "no": "vri og vrenge på alt som blir sagt",
          "en": "twist and distort everything that is said"
        }
      ]
    },
    {
      "text": "i kortspill: skifte farge (etter visse regler)",
      "translation": "in card games: change suit (according to certain rules)",
      "examples": []
    },
    {
      "text": "jamfør vriåtter",
      "translation": "twist (in whist)",
      "examples": [
        {
          "no": "vri med åtteren",
          "en": "do a figure eight with a twist"
        }
      ]
    }
  ]
