  "definitions": [
    {
      "text": "brukt for å angi utgangspunkt ved sted eller rom",
      "translation": "used to indicate the starting point in space",
      "examples": []
    },
    {
      "text": "med utgangspunkt i",
      "translation": "from",
      "examples": [
        {
          "no": "reise fra Bergen",
          "en": "travel from Bergen"
        },
        {
          "no": "komme fra jobb",
          "en": "come from work"
        },
        {
          "no": "trafikken fra fjellet",
          "en": "the traffic from the mountains"
        },
        {
          "no": "komme fra alle kanter",
          "en": "come from all directions"
        }
      ]
    },
    {
      "text": "ved (måling av) utgangspunktet for strekning, område, størrelse, intervall",
      "translation": "at (measurement of) the starting point for a distance, area, size, interval",
      "examples": [
        {
          "no": "fra Lindesnes til Nordkapp",
          "en": "from Lindesnes to Nordkapp"
        },
        {
          "no": "fra ende til annen",
          "en": "from one end to the other"
        },
        {
          "no": "fra topp til tå",
          "en": "from head to toe"
        },
        {
          "no": "fra hånd til munn",
          "en": "from hand to mouth"
        }
      ]
    },
    {
      "text": "ved utgangspunktet for tid",
      "translation": "at the starting point for time",
      "examples": [
        {
          "no": "fra gammelt av",
          "en": "from of old"
        },
        {
          "no": "fra morgen til kveld",
          "en": "from morning to evening"
        },
        {
          "no": "fra da av reiste jeg heller alene",
          "en": "from then on I preferred to travel alone"
        },
        {
          "no": "fra mars til oktober",
          "en": "from March to October"
        }
      ]
    },
    {
      "text": "ved utvikling, endring",
      "translation": "in development, change",
      "examples": [
        {
          "no": "vokse fra gutt til mann",
          "en": "grow from boy to man"
        },
        {
          "no": "fra larve til sommerfugl",
          "en": "from larva to butterfly"
        },
        {
          "no": "avansere fra fenrik til løytnant",
          "en": "advance from second lieutenant to lieutenant"
        }
      ]
    },
    {
      "text": "med opphav, opprinnelse, årsak, grunnlag, kilde",
      "translation": "with origin, source, cause, basis, root",
      "examples": [
        {
          "no": "være fra Skien",
          "en": "be from Skien"
        },
        {
          "no": "stamme fra apene",
          "en": "descend from the apes"
        },
        {
          "no": "snøen fra i fjor",
          "en": "the snow from last year"
        },
        {
          "no": "funn fra oldtiden",
          "en": "finds from antiquity"
        }
      ]
    },
    {
      "text": "ved fjerning, atskillelse eller avstand i forhold til",
      "translation": "with removal, separation, distance in relation to",
      "examples": [
        {
          "no": "du må ikke forsvinne fra meg",
          "en": "you mustn't disappear from me"
        },
        {
          "no": "hun reiste seg fra stolen",
          "en": "she rose from the chair"
        },
        {
          "no": "flykte fra landet",
          "en": "flee the country"
        },
        {
          "no": "rømme fra hele situasjonen",
          "en": "escape the whole situation"
        }
      ]
    }
