  "definitions": [
    {
      "text": "legge et sted eller et område i mørke",
      "translation": "to plunge a place or an area into darkness",
      "examples": []
    },
    {
      "text": "dekke til alt lys for å hindre flyangrep",
      "translation": "to cover all light to prevent air raids",
      "examples": [
        {
          "no": "hele distriktet ble mørklagt på grunn av strømbrudd",
          "en": "the whole district was blacked out because of a power outage"
        },
        {
          "no": "en mørklagt by",
          "en": "a blacked-out city"
        }
      ]
    },
    {
      "text": "ikke gi opplysninger om",
      "translation": "not to provide information about",
      "examples": []
    },
    {
      "text": "holde hemmelig",
      "translation": "to keep secret",
      "examples": [
        {
          "no": "forhandlingene er mørklagt",
          "en": "the negotiations are being kept secret"
        }
      ]
    }
  ]
