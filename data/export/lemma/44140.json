  "definitions": [
    {
      "text": "i matematikk: flytte eller forskyve en linje, figur eller lignende slik at alle linjer hele tiden er parallell med de opprinnelige",
      "translation": "to move or shift a line, figure so that all lines remain parallel to the original ones",
      "examples": []
    },
    {
      "text": "overføre et mønster, en hending eller et fenomen til nye omgivelser",
      "translation": "to transfer a pattern, event, or phenomenon to new surroundings",
      "examples": [
        {
          "no": "hele det politiske spektrumet er parallellforskjøvet",
          "en": "the entire political spectrum has been shifted in parallel"
        }
      ]
