  "definitions": [
    {
      "text": "slå med vingene",
      "translation": "to beat wings",
      "examples": [
        {
          "no": "fuglene flakser og flyr",
          "en": "the birds flap and fly"
        }
      ]
    },
    {
      "text": "flagre, vifte",
      "translation": "to flutter, to wave",
      "examples": [
        {
          "no": "håret flakset vilt",
          "en": "her hair flapped wildly"
        }
      ]
    },
    {
      "text": "fare urolig hit og dit",
      "translation": "to move restlessly back and forth",
      "examples": [
        {
          "no": "flakse fra det ene til det andre",
          "en": "flit from one thing to another"
        },
        {
          "no": "flakse omkring som en forvirret høne",
          "en": "flit about like a confused hen"
        }
