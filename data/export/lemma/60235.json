  "cross_reference": null,
  "definitions": [
    {
      "text": "slå fast hvor mange enheter det er av noe i en mengde (ved å peke eller nevne)",
      "translation": "determine how many units of something are in a quantity (by pointing or naming)",
      "examples": [
        {
          "no": "telle bøkene i hylla",
          "en": "count the books on the shelf"
        },
        {
          "no": "hun talte hvor mange kopper hun hadde",
          "en": "she counted how many cups she had"
        },
        {
          "no": "han teller åtte lastebiler på kaia",
          "en": "he counts eight trucks on the quay"
        }
      ]
    },
    {
      "text": "nevne tall etter hverandre i den rekkefølgen de står i tallrekken",
      "translation": "name numbers in sequence as they appear in the number series",
      "examples": [
        {
          "no": "telle til tolv",
          "en": "count to twelve"
        },
        {
          "no": "telle takten",
          "en": "count the beat"
        }
      ]
    },
    {
      "text": "holde regning med",
      "translation": "keep account of",
      "examples": []
    },
    {
      "text": "holde tall på",
      "translation": "keep track of",
      "examples": [
        {
          "no": "telle dagene til jul",
          "en": "count the days until Christmas"
        },
        {
          "no": "telle trafikken i hovedgata",
          "en": "count the traffic on the main street"
        }
      ]
    },
    {
      "text": "være av betydning eller verdi",
      "translation": "be of significance or value",
      "examples": []
    },
    {
      "text": "være viktig",
      "translation": "be important",
      "examples": []
    },
    {
      "text": "gjelde",
      "translation": "count",
      "examples": [
        {
          "no": "gjøre en innsats som teller",
          "en": "make an effort that counts"
        },
        {
          "no": "det er bare standpunktkarakterene som teller",
          "en": "it's only the final grades that count"
        }
      ]
    },
    {
      "text": "være på",
      "translation": "comprise",
      "examples": [
