  "definitions": [
    {
      "text": "sete for rytter på ryggen av et ridedyr",
      "translation": "seat for a rider on the back of a riding animal",
      "examples": [
        {
          "no": "legge sal på hesten",
          "en": "put a saddle on the horse"
        },
        {
          "no": "svinge seg i salen",
          "en": "swing oneself into the saddle"
        }
      ]
    },
    {
      "text": "underlag til å legge under bør på ryggen på pakkdyr",
      "translation": "underlay to be placed under a pack on the back of a pack animal",
      "examples": []
    },
    {
      "text": "særlig på storfe: flekk med avstikkende farge over ryggen",
      "translation": "especially on cattle: a patch of contrasting color over the back",
      "examples": []
    },
    {
      "text": "ryggstykke på slakt",
      "translation": "back piece of meat",
      "examples": []
    },
    {
      "text": "på strengeinstrument: liten tverrpinne som strengene hviler mot øverst på gripebrettet",
      "translation": "on string instruments: a small transverse pin over which the strings rest at the top of the fingerboard",
      "examples": []
    }
