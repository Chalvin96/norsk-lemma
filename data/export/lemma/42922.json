    {
      "text": "det å øve eller øve opp",
      "translation": "the act of practicing or training",
      "examples": [
        {
          "no": "øving er viktig",
          "en": "practicing is important"
        }
      ]
    },
    {
      "text": "det å beherske en kunst, et fag eller en ferdighet (fordi en har øvd opp evnen og holdt den ved like)",
      "translation": "the act of mastering an art, a trade, or a skill (by having trained the ability and maintained it)",
      "examples": [
        {
          "no": "ha øving i å sykle",
          "en": "have practice in cycling"
        }
      ]
    },
    {
      "text": "handling, prøve, omgang eller forsøk (i en sammenhengende rekke) utført for å oppnå større dyktighet",
      "translation": "action, test, round, or attempt (in a continuous series) performed to achieve greater skill",
      "examples": [
        {
          "no": "skriftlige øvinger på skolen",
          "en": "written exercises at school"
        }
      ]
    },
    {
      "text": "organisert virksomhet der mannskap eller personale øver for å få rutine i å samarbeide om en større operasjon",
      "translation": "organized activity where crew or personnel practice to gain routine in cooperating on a larger operation",
      "examples": [
        {
          "no": "personell som deltar i øvingen",
          "en": "personnel taking part in the exercise"
        }
