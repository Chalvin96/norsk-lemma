    {
      "text": "del av en stat som er skilt fra denne og helt omgitt av fremmed territorium",
      "translation": "part of a state that is separated from it and completely surrounded by foreign territory",
      "examples": [
        {
          "no": "en spansk enklave i Nord-Afrika",
          "en": "a Spanish enclave in North Africa"
        },
        {
          "no": "Vest-Berlin lå som en enklave i Øst-Tyskland",
          "en": "West Berlin lay like an enclave in East Germany"
        }
      ]
    },
