  "definitions": [
    {
      "text": "surre en tråd eller et tøystykke rundt noe (eller av noe)",
      "translation": "",
      "examples": [
        {
          "no": "vikle et lommetørkle rundt dørhåndtaket",
          "en": "wrap a handkerchief around the doorknob"
        },
        {
          "no": "vikle tråden på snella",
          "en": "wind the thread onto the bobbin"
        },
        {
          "no": "vikle tauet rundt et tre",
          "en": "wrap the rope around a tree"
        },
        {
          "no": "ha et skjerf viklet rundt hodet",
          "en": "have a scarf wrapped around your head"
        }
      ]
    },
    {
      "text": "feste ved at noe blir filtret eller flettet sammen",
      "translation": "",
      "examples": [
        {
          "no": "trådene viklet seg sammen",
          "en": "the threads got tangled together"
        },
        {
          "no": "han vikler fingrene inn i håret sitt",
          "en": "he winds his fingers into his hair"
        },
        {
          "no": "vikle beina rundt en stolpe",
          "en": "wrap your legs around a pole"
        },
        {
          "no": "vikle hendene inn i hverandre",
          "en": "interlace your hands"
        }
      ]
    },
    {
      "text": "pakke inn eller ut noe",
      "translation": "",
      "examples": [
        {
          "no": "vikle noen inn i et teppe",
          "en": "wrap someone in a blanket"
        }
      ]
    }
  ]
