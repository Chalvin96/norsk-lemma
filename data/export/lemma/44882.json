  "definitions": [
    {
      "text": "skyve seg fram med stav(er) med pigg",
      "translation": "to push oneself forward with poles with spikes",
      "examples": [
        {
          "no": "skiløperne pigget over mål",
          "en": "the skiers poled their way across the finish line"
        },
        {
          "no": "det er vel snart på tide å pigge hjem",
          "en": "I suppose it's about time to head home"
        }
      ]
    },
    {
      "text": "sette pigger i noe",
      "translation": "to put spikes in something",
      "examples": [
        {
          "no": "pigge opp igjen vinterdekk",
          "en": "restud winter tires"
        }
      ]
    },
    {
      "text": "bryte stein, asfalt eller lignende ved hjelp av et spisst redskap",
      "translation": "to break stone, asphalt using a pointed tool",
      "examples": []
    }
  ]
