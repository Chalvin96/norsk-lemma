  "cross_reference": null,
  "definitions": [
    {
      "text": "arbeid som utføres med håndkraft, ikke med maskin",
      "translation": "work performed by hand, not by machine",
      "examples": [
        {
          "no": "pølseproduksjon er fortsatt mye håndarbeid",
          "en": "sausage production is still largely handwork"
        }
      ]
    },
    {
      "text": "fellesbetegnelse for tekstilarbeid som søm, brodering, strikking, hekling og lignende",
      "translation": "general term for textile work such as sewing, embroidery, knitting, crochet",
      "examples": [
        {
          "no": "tradisjonsrikt håndarbeid",
          "en": "traditional handicrafts"
        },
        {
          "no": "hygge seg med håndarbeid",
          "en": "enjoy doing needlework"
        }
      ]
    },
    {
      "text": "hekletøy, strikketøy, broderi eller lignende som er under arbeid",
      "translation": "crocheted item, knitted item, embroidery that is in progress",
      "examples": [
        {
          "no": "ha et håndarbeid å sysle med",
          "en": "have some needlework to occupy oneself with"
        }
      ]
    },
    {
      "text": "sydd, strikket, heklet eller brodert arbeid",
      "translation": "sewn, knitted, crocheted, embroidered work",
      "examples": [
        {
          "no": "duken er et antikt håndarbeid",
          "en": "the tablecloth is an antique piece of needlework"
        }
      ]
    },
    {
      "text": "om eldre forhold: håndarbeid handarbeid som skolefag",
      "translation": "referring to older conditions: handicraft as a school subject",
      "examples": [
        {
          "no": "være lærer i håndarbeid",
          "en": "be a teacher of needlework"
        }
      ]
    }
  ]
