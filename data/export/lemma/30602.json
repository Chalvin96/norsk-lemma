  "definitions": [
    {
      "text": "særlig om dyr: gi fra seg murrende lyd (i sinne)",
      "translation": "especially of animals: to make a rumbling sound (in anger)",
      "examples": [
        {
          "no": "hunden knurret og viste tenner",
          "en": "the dog growled and bared its teeth"
        }
      ]
    },
    {
      "text": "brukt som adjektiv:",
      "translation": "used as an adjective: a growling sound",
      "examples": [
        {
          "no": "en knurrende lyd",
          "en": "a growling sound"
        }
      ]
    },
    {
      "text": "i overført betydning: gi uttrykk for at en er misfornøyd",
      "translation": "in a figurative sense: to express dissatisfaction",
      "examples": []
    },
    {
      "text": "murre, protestere",
      "translation": "to grumble, to protest",
      "examples": [
        {
          "no": "arbeiderne knurret over arbeidsforholdene",
          "en": "the workers grumbled about the working conditions"
        }
      ]
    }
  ]
