  "definitions": [
    {
      "text": "le høyt og støyende",
      "translation": "to laugh loudly and noisily",
      "examples": []
    },
    {
      "text": "gaple, skogre",
      "translation": "to guffaw, to roar with laughter",
      "examples": [
        {
          "no": "de skrattet og lo",
          "en": "they cackled and laughed"
        }
      ]
    },
    {
      "text": "om fugl: skrike ensformig",
      "translation": "of a bird: to cry monotonously",
      "examples": []
    },
    {
      "text": "kakle, skvatre",
      "translation": "to cackle, to chatter",
      "examples": [
        {
          "no": "en rype skrattet oppe i lia",
          "en": "a ptarmigan cackled up on the hillside"
        }
      ]
    },
    {
      "text": "gi en høy, skjærende lyd",
      "translation": "to make a high, piercing sound",
      "examples": [
        {
          "no": "grammofonen skrattet",
          "en": "the gramophone crackled"
        }
      ]
