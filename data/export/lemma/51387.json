    {
      "text": "skrive under",
      "translation": "to sign",
      "examples": []
    },
    {
      "text": "sette navnetrekket sitt på",
      "translation": "to put one's signature on",
      "examples": [
        {
          "no": "brevet var signert av styreformannen",
          "en": "the letter was signed by the chairman of the board"
        },
        {
          "no": "forfatteren vil være til stede og signere boka si",
          "en": "the author will be present to sign her book"
        }
      ]
    },
    {
      "text": "stadfeste opphav, særlig med signatur, initialer eller lignende",
      "translation": "to confirm origin, especially with signature, initials",
      "examples": [
        {
          "no": "maleriet var signert Edvard Munch",
          "en": "the painting was signed Edvard Munch"
        }
      ]
    },
    {
      "text": "skrive kontrakt eller avtale med",
      "translation": "to sign a contract or agreement",
      "examples": [
        {
          "no": "fotballklubben signerte en ny spiss",
          "en": "the football club signed a new striker"
        }
      ]
