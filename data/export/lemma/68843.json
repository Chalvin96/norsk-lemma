  "definitions": [
    {
      "text": "person har sett noe skje og som senere kan fortelle om det",
      "translation": "person who has seen something happen and can later tell about it",
      "examples": []
    },
    {
      "text": "jamfør tidsvitne og øyevitne øyenvitne",
      "translation": "witness to history and eyewitness",
      "examples": [
        {
          "no": "være vitne til en trafikkulykke",
          "en": "witness a traffic accident"
        }
      ]
    },
    {
      "text": "i jus: person som gir utsagn i retten om hva han eller hun i et visst tilfelle har sett, hørt, kjent, ment eller sagt",
      "translation": "in law: person who gives testimony in court about what they have seen, heard, known, or said in a specific case",
      "examples": []
    },
    {
      "text": "jamfør rettsvitne",
      "translation": "legal witness",
      "examples": [
        {
          "no": "sakkyndig vitne",
          "en": "expert witness"
        },
        {
          "no": "møte som vitne i en rettssak",
          "en": "appear as a witness in a court case"
        }
      ]
    },
    {
      "text": "person som er til stede for å bekrefte at en handling har foregått på lovlig måte, for eksempel ved skriving av testament",
      "translation": "person present to confirm that an action has taken place legally, for example when writing a will",
      "examples": []
    },
    {
      "text": "jamfør testamentvitne testamentsvitne",
      "translation": "testamentary witness",
      "examples": []
    },
    {
      "text": "i religiøst språk: person som har sett eller hørt Kristus, eller som kjenner seg kalt til å forkynne Guds ord",
      "translation": "person who has seen or heard Christ, who feels called to proclaim God's word",
      "examples": []
    }
  ]
