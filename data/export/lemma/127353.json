  "definitions": [
    {
      "text": "som ikke gir fra seg røyk røk",
      "translation": "not emitting smoke",
      "examples": [
        {
          "no": "en ovn som gir røykfri forbrenning",
          "en": "a stove that provides smokeless combustion"
        }
      ]
    },
    {
      "text": "som har forbud mot røyking",
      "translation": "prohibiting smoking",
      "examples": [
        {
          "no": "skolen skal være røykfritt område",
          "en": "the school is to be a smoke-free area"
        }
      ]
    },
    {
      "text": "som ikke røyker, særlig brukt om noen som har røykt tidligere",
      "translation": "not smoking, especially used of someone who used to smoke",
      "examples": [
        {
          "no": "hun har vært røykfri i tre måneder",
          "en": "she has been smoke-free for three months"
        }
      ]
    }
  ]
