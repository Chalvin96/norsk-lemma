  "cross_reference": null,
  "definitions": [
    {
      "text": "falle i dråpe",
      "translation": "to fall in drops",
      "examples": [
        {
          "no": "det drypper fra taket",
          "en": "it's dripping from the roof"
        },
        {
          "no": "det regner ikke så mye, men det drypper litt",
          "en": "it's not raining that much, but it's dripping a little"
        },
        {
          "no": "svetten drypper fra pannen",
          "en": "sweat is dripping from his forehead"
        }
      ]
    },
    {
      "text": "gi fra seg dråpe",
      "translation": "to give off drops",
      "examples": [
        {
          "no": "krana drypper",
          "en": "the tap is dripping"
        },
        {
          "no": "klærne er så våte at de drypper",
          "en": "the clothes are so wet they are dripping"
        }
      ]
    },
    {
      "text": "la falle dråpevis",
      "translation": "to let fall drop by drop",
      "examples": []
    },
    {
      "text": "påføre væske i dråpe",
      "translation": "to apply liquid in drops",
      "examples": []
    },
    {
      "text": "væte med dråper",
      "translation": "to wet with drops",
      "examples": [
        {
          "no": "pasienten må dryppe øynene hver dag",
          "en": "the patient must put drops in their eyes every day"
        },
        {
          "no": "dryppe en stek",
          "en": "baste a roast"
        },
        {
          "no": "dryppe nesen",
          "en": "put drops in the nose"
        }
      ]
    },
    {
      "text": "komme i små mengder eller litt etter litt",
      "translation": "to come in small quantities or little by little",
      "examples": [
        {
          "no": "etter hvert begynte det å dryppe inn litt penger fra salget",
          "en": "after a while, a little money from the sales started to trickle in"
        }
      ]
    },
    {
      "text": "oppstå fordeler som en konsekvens av en større hendelse eller lignende",
      "translation": "to arise as benefits as a consequence of a larger event or similar",
      "examples": [
        {
          "no": "i forbindelse med det nye anlegget kan det dryppe et oppdrag og to på de lokale bedriftene",
          "en": "in connection with the new facility, a job or two may come the way of the local businesses"
        }
      ]
    }
  ]
