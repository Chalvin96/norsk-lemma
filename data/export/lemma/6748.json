    {
      "text": "om væske: være i bevegelse på grunn av luft eller annen gass som stiger opp",
      "translation": "of liquid: to be in motion due to air or other gas rising",
      "examples": []
    },
    {
      "text": "lage bobler",
      "translation": "to bubble",
      "examples": [
        {
          "no": "grøten bobler i gryta",
          "en": "the porridge is bubbling in the pot"
        }
      ]
    },
    {
      "text": "i overført betydning: være livlig og full av påfunn",
      "translation": "to be lively and full of ideas",
      "examples": [
        {
          "no": "boble over av gode ideer",
          "en": "bubble over with good ideas"
