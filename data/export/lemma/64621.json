  "cross_reference": null,
  "definitions": [
    {
      "text": "komme seg unna",
      "translation": "get away",
      "examples": [
        {
          "no": "hun unnslapp forfølgeren",
          "en": "she escaped the pursuer"
        },
        {
          "no": "de hoppet i sjøen for å unnslippe flammene",
          "en": "they jumped into the sea to escape the flames"
        }
      ]
    },
    {
      "text": "slippe unna oppmerksomhet",
      "translation": "escape attention",
      "examples": [
        {
          "no": "ikke ett ord av foredraget har unnsluppet meg",
          "en": "not a single word of the lecture has escaped me"
        }
      ]
    },
    {
      "text": "om utrop eller lignende: glippe ut av",
      "translation": "of an exclamation: slip out",
      "examples": [
        {
          "no": "en ufrivillig latter unnslapp meg",
          "en": "an involuntary laugh escaped me"
        }
      ]
    }
  ]
