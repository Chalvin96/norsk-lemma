  "definitions": [
    {
      "text": "føre opp som kredit for noen eller noe",
      "translation": "enter as a credit for someone or something",
      "examples": [
        {
          "no": "beløpet skal godskrives konto",
          "en": "the amount is to be credited to the account"
        }
      ]
    },
    {
      "text": "regne som en fordel for noen",
      "translation": "consider as an advantage for someone",
      "examples": [
        {
          "no": "lang praksis må godskrives søkeren",
          "en": "long experience must be credited to the applicant"
        }
      ]
    },
    {
      "text": "la noen ha æren eller fortjenesten for noe",
      "translation": "let someone have the honor or merit for something",
      "examples": [
        {
          "no": "han må godskrives seieren",
          "en": "he must be credited with the victory"
        }
