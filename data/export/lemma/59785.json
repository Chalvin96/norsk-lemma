  "definitions": [
    {
      "text": "komme nær eller berøre i ett punkt",
      "translation": "to come close to, touch at one point",
      "examples": [
        {
          "no": "linjen tangerer kurven",
          "en": "the line is tangent to the curve"
        },
        {
          "no": "veien tangerer eiendommen",
          "en": "the road borders the property"
        }
      ]
    },
    {
      "text": "komme inn på",
      "translation": "to touch upon",
      "examples": [
        {
          "no": "spørsmålet ble tangert flere ganger i løpet av ordskiftet",
          "en": "the question was touched on several times during the debate"
        }
      ]
    },
    {
      "text": "komme likt med",
      "translation": "to reach the same level as",
      "examples": []
    },
    {
      "text": "oppnå samme resultat som",
      "translation": "to achieve the same result as",
      "examples": [
        {
          "no": "tangere banerekorden",
          "en": "equal the track record"
        },
        {
          "no": "tangere salgstallene fra i fjor",
          "en": "match last year's sales figures"
        }
      ]
    }
