  "definitions": [
    {
      "text": "buldre og brake av torden",
      "translation": "to rumble and roar like thunder",
      "examples": [
        {
          "no": "lyne og tordne",
          "en": "lightning and thunder"
        },
        {
          "no": "det tordnet hele dagen",
          "en": "it thundered all day"
        },
        {
          "no": "han ble alltid redd når det tordnet",
          "en": "he was always scared when it thundered"
        }
      ]
    },
    {
      "text": "lage høy, buldrende lyd som av torden",
      "translation": "to make a loud, rumbling sound like thunder",
      "examples": [
        {
          "no": "fossen tordnet utfor",
          "en": "the waterfall thundered down"
        },
        {
          "no": "flyene tordner over oss",
          "en": "the planes thunder over us"
        }
      ]
    },
    {
      "text": "i overført betydning: tale høyt og rasende",
      "translation": "to speak loudly and furiously",
      "examples": []
    },
    {
      "text": "agitere sterkt, refse",
      "translation": "to agitate strongly, to reprimand",
      "examples": []
    },
    {
      "text": "jamfør tordentale",
      "translation": "to thunder a speech",
      "examples": [
        {
          "no": "hun tordnet mot politikerne",
          "en": "she thundered against the politicians"
        }
      ]
    }
  ]
