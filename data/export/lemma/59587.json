  "definitions": [
    {
      "text": "uttrykke takknemlighet",
      "translation": "express gratitude",
      "examples": []
    },
    {
      "text": "si ‘takk’",
      "translation": "say 'thank you'",
      "examples": [
        {
          "no": "takke for hjelpen",
          "en": "thank someone for the help"
        },
        {
          "no": "han takket henne for gaven",
          "en": "he thanked her for the gift"
        },
        {
          "no": "barna takker for maten",
          "en": "the children thank for the meal"
        }
      ]
    },
    {
      "text": "gi noe eller noen æren eller ansvaret for",
      "translation": "give credit or responsibility to something or someone",
      "examples": [
        {
          "no": "vi har bare oss selv å takke for at vi tapte kampen",
          "en": "we have only ourselves to thank for losing the match"
        }
      ]
    }
