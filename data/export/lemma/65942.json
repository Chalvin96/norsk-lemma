  "definitions": [
    {
      "text": "som har fått trukket ut salt eller annet stoff ved å ligge i vann",
      "translation": "desalted (fish, etc.)",
      "examples": [
        {
          "no": "utvannet fisk",
          "en": "desalted fish"
        }
      ]
    },
    {
      "text": "i overført betydning: uten opprinnelig verdi eller innhold",
      "translation": "diluted, watered down (in a figurative sense)",
      "examples": [
        {
          "no": "et utvannet prinsipp",
          "en": "a watered-down principle"
        }
      ]
    }
