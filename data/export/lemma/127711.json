  "definitions": [
    {
      "text": "(hvit) metallskive brukt til å bestemme vannets siktedyp",
      "translation": "(white) metal disc used to determine water clarity depth",
      "examples": [
        {
          "no": "måle sikten i vannet med en sikteskive",
          "en": "measure the water clarity with a Secchi disk"
        }
      ]
    },
    {
      "text": "(stor) skive med siktelinje, satt opp på utsiktspunkt",
      "translation": "(large) disc with a sight line, set up at a viewpoint",
      "examples": [
        {
          "no": "sikteskiven i tårnet oppgir avstanden til åser og fjelltopper",
          "en": "the sighting disc in the tower states the distance to hills and mountain peaks"
        }
      ]
    }
