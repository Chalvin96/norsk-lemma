  "definitions": [
    {
      "text": "ha håp eller forventning om noe",
      "translation": "to have hope or expectation of something",
      "examples": [
        {
          "no": "håpe på godt vær",
          "en": "hope for good weather"
        },
        {
          "no": "håpe på bedre tider",
          "en": "hope for better times"
        },
        {
          "no": "de håper at behandlingen vil fungere",
          "en": "they hope that the treatment will work"
        },
        {
          "no": "jeg håpte at han ville svare på meldingen",
          "en": "I hoped that he would reply to the message"
        }
      ]
    }
