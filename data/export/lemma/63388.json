  "definitions": [
    {
      "text": "sylinderformet beholder med utbuede vegger",
      "translation": "cylindrical container with bulging walls",
      "examples": [
        {
          "no": "en tønne med sild",
          "en": "a barrel of herring"
        }
      ]
    },
    {
      "text": "om eldre forhold: mål for mengde som går i en tønne (mellom 115,8 og 139,4 liter, etter vareslag)",
      "translation": "in older conditions: measure of quantity that fits in a barrel (between 115.8 and 139.4 liters, depending on the commodity)",
      "examples": [
        {
          "no": "en tønne poteter",
          "en": "a barrel of potatoes"
        }
      ]
    },
    {
      "text": "om eldre forhold: flatemål som egentlig svarer til det arealet som kan bli tilsådd med én tønne såkorn, i Norge = 3,937 dekar",
      "translation": "in older conditions: area measure corresponding to the area that can be sown with one barrel of seed, in Norway = 3.937 decares",
      "examples": []
    }
