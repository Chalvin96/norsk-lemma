  "cross_reference": null,
  "definitions": [
    {
      "text": "behandle overflaten på keramikk, porselen og lignende så den får et nett av fine sprekker",
      "translation": "to treat the surface of ceramics, porcelain so that it gets a network of fine cracks",
      "examples": [
        {
          "no": "krakelert porselen",
          "en": "crazed porcelain"
        }
      ]
    },
    {
      "text": "danne tynne sprekker",
      "translation": "to form thin cracks",
      "examples": [
        {
          "no": "malingen flasser av og himlingen er krakelert",
          "en": "the paint is peeling off and the ceiling is crazed"
        },
        {
          "no": "asfalten er krakelert og ujevn",
          "en": "the asphalt is cracked and uneven"
        }
      ]
    }
  ]
