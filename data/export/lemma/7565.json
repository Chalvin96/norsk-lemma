  "definitions": [
    {
      "text": "slites over",
      "translation": "wear through",
      "examples": []
    },
    {
      "text": "sprekke, revne",
      "translation": "burst, tear",
      "examples": [
        {
          "no": "isen brast under dem",
          "en": "the ice cracked beneath them"
        },
        {
          "no": "tauet brast",
          "en": "the rope snapped"
        }
      ]
    },
    {
      "text": "sprenges av noe som vokser fram",
      "translation": "burst from something growing forth",
      "examples": [
        {
          "no": "knoppene brister",
          "en": "the buds are bursting"
        },
        {
          "no": "hans hjerte var nær ved å briste",
          "en": "his heart was close to bursting"
        }
      ]
    },
    {
      "text": "slå feil",
      "translation": "fail",
      "examples": []
    },
    {
      "text": "svikte",
      "translation": "fail",
      "examples": [
        {
          "no": "håpet brast",
          "en": "hope failed"
        },
        {
          "no": "resonnementet bygger på bristende forutsetninger",
          "en": "the reasoning is based on failing assumptions"
        }
      ]
    },
    {
      "text": "brått og uoverveid slippe løs følelse, reaksjon eller lignende",
      "translation": "suddenly and rashly release emotion, reaction",
      "examples": [
        {
          "no": "han brister i gråt",
          "en": "he bursts into tears"
        },
        {
          "no": "de brast i latter",
          "en": "they burst out laughing"
        }
      ]
    },
    {
      "text": "bli så stort følelsesmessig trykk at en mister kontroll",
      "translation": "become so emotionally pressured that one loses control",
      "examples": [
        {
          "no": "det brast for henne",
          "en": "she snapped"
        }
      ]
    },
    {
      "text": "om øye: brått miste glansen når døden inntreffer",
      "translation": "of an eye: suddenly lose its gleam when death occurs",
      "examples": [
        {
          "no": "øynene brast",
          "en": "the eyes lost their luster"
        }
      ]
    },
    {
      "text": "om stemme: plutselig svikte",
      "translation": "of a voice: suddenly fail",
      "examples": []
    },
    {
      "text": "bli uklar og skurrende",
      "translation": "become unclear and hoarse",
      "examples": [
        {
          "no": "stemmen brast",
          "en": "the voice broke"
        }
      ]
    },
    {
      "text": "om ytring: komme brått, heftig og uoverveid",
      "translation": "of an utterance: come suddenly, intensely, and rashly",
      "examples": [
        {
          "no": "«Drittsekk!» brast det ut av henne",
          "en": "\"Asshole!\" burst out of her"
