  "definitions": [
    {
      "text": "renne med fin, sped lyd",
      "translation": "to flow with a fine, gentle sound",
      "examples": [
        {
          "no": "høre bekken sildre",
          "en": "hear the brook trickle"
        },
        {
          "no": "det sildret og rant vann alle steder",
          "en": "water trickled and ran everywhere"
        }
      ]
    },
    {
      "text": "i overført betydning: sive, strømme",
      "translation": "to seep, to stream",
      "examples": [
        {
          "no": "musikken sildrer ut av høytalerne",
          "en": "the music trickles out of the speakers"
        },
        {
          "no": "tynne gardiner lar lyset sildre inn",
          "en": "thin curtains let the light trickle in"
        },
        {
          "no": "la tiden sildre sakte forbi",
          "en": "let time trickle slowly by"
        },
        {
          "no": "pengene fra oljeindustrien sildret inn i norsk økonomi",
          "en": "the money from the oil industry trickled into the Norwegian economy"
        }
      ]
    }
  ]
