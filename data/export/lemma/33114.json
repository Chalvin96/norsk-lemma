  "definitions": [
    {
      "text": "særlig om frosk eller and: gi fra seg en serie enstonige lyder",
      "translation": "especially of frogs or ducks: to emit a series of monotonous sounds",
      "examples": [
        {
          "no": "froskene kvekker nede ved tjernet",
          "en": "the frogs are croaking down by the pond"
        }
      ]
    },
    {
      "text": "om person: snakke med støtvis og enstonig stemme",
      "translation": "of a person: to speak with a jerky and monotonous voice",
      "examples": [
        {
          "no": "jo da, kvekket bestefaren",
          "en": "oh yes, croaked grandfather"
        }
      ]
    }
