    {
      "text": "skremme opp",
      "translation": "scare up",
      "examples": []
    },
    {
      "text": "forferde, sjokkere",
      "translation": "dismay, shock",
      "examples": [
        {
          "no": "nyheten rystet dem i grunnvollene",
          "en": "the news shook them to their core"
        },
        {
          "no": "hendelsen rystet hele bygda",
          "en": "the incident shook the whole village"
        },
        {
          "no": "de ønsker bare å ryste og provosere",
          "en": "they only want to shock and provoke"
        },
        {
          "no": "han var dypt rystet",
          "en": "he was deeply shaken"
        }
      ]
    },
    {
      "text": "skjelve, skake",
      "translation": "tremble, shake",
      "examples": [
        {
          "no": "jordskjelvet rystet hele regionen",
          "en": "the earthquake shook the entire region"
        }
      ]
    },
    {
      "text": "bevege fort fram og tilbake eller opp og ned",
      "translation": "move rapidly back and forth or up and down",
      "examples": [
        {
          "no": "hun rystet på hodet",
          "en": "she shook her head"
        }
      ]
