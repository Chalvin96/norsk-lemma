  "definitions": [
    {
      "text": "ta på klær",
      "translation": "to put on clothes",
      "examples": [
        {
          "no": "kle seg naken",
          "en": "dress naked"
        },
        {
          "no": "kle seg pent",
          "en": "dress nicely"
        },
        {
          "no": "være godt kledd",
          "en": "be well dressed"
        },
        {
          "no": "kle av og på seg",
          "en": "take one's clothes off and put them on"
        }
      ]
    },
    {
      "text": "sørge for klær til",
      "translation": "to provide clothes for",
      "examples": [
        {
          "no": "fø og kle en stor ungeflokk",
          "en": "feed and clothe a large brood of children"
        },
        {
          "no": "toppen var kledd med skog",
          "en": "the summit was clad in forest"
        },
        {
          "no": "kle en vegg med sponplater",
          "en": "cover a wall with chipboard"
        }
      ]
    },
    {
      "text": "om klær, framferd: passe (til)",
      "translation": "concerning clothes, behavior: to suit",
      "examples": [
        {
          "no": "det kler deg ikke å være sint",
          "en": "it does not become you to be angry"
        },
        {
          "no": "den kjolen kler deg godt",
          "en": "that dress suits you well"
        }
      ]
    }
  ]
