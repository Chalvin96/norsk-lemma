  "definitions": [
    {
      "text": "ikke huske",
      "translation": "not remember",
      "examples": []
    },
    {
      "text": "tape av minne",
      "translation": "lose from memory",
      "examples": [
        {
          "no": "jeg har glemt hva han heter",
          "en": "I have forgotten what his name is"
        },
        {
          "no": "glemme tid og sted",
          "en": "forget time and place"
        },
        {
          "no": "glemme morsmålet sitt",
          "en": "forget one's mother tongue"
        },
        {
          "no": "jeg glemmer det aldri",
          "en": "I will never forget it"
        }
      ]
    },
    {
      "text": "legge igjen ved et uhell",
      "translation": "leave behind by accident",
      "examples": [
        {
          "no": "glemme boka hjemme",
          "en": "leave the book at home"
        },
        {
          "no": "jeg glemte lommeboka på butikken",
          "en": "I left my wallet at the store"
        }
      ]
    },
    {
      "text": "ikke gjøre",
      "translation": "not do",
      "examples": []
    },
    {
      "text": "forsømme, unnlate",
      "translation": "neglect, fail to",
      "examples": [
        {
          "no": "glemme pliktene sine",
          "en": "neglect one's duties"
        },
        {
          "no": "glemme å slokke lyset",
          "en": "forget to turn off the light"
        }
      ]
    },
    {
      "text": "ikke bry seg om eller ta hensyn til",
      "translation": "not care about or consider",
      "examples": []
    },
    {
      "text": "ikke tenke på",
      "translation": "not think about",
      "examples": [
        {
          "no": "glemme gammel urett",
          "en": "forget old wrongs"
        },
        {
          "no": "glem det!",
          "en": "forget it!"
        },
        {
          "no": "det kan du bare glemme",
          "en": "you can just forget it"
        },
        {
          "no": "du glemmer hvem du snakker med",
          "en": "you're forgetting who you're talking to"
        }
      ]
    }
  ]
