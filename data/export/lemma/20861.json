  "definitions": [
    {
      "text": "skillelinje mellom geografiske områder, for eksempel mellom stater, fylker, eiendommer",
      "translation": "dividing line between geographical areas, for example between states, counties, properties",
      "examples": [
        {
          "no": "grensen mellom Norge og Sverige",
          "en": "the border between Norway and Sweden"
        },
        {
          "no": "grensen er stengt",
          "en": "the border is closed"
        },
        {
          "no": "bo like ved grensen",
          "en": "live right by the border"
        },
        {
          "no": "rømme over grensen",
          "en": "flee across the border"
        }
      ]
    },
    {
      "text": "tenkt linje mellom to tilstander",
      "translation": "imaginary line between two states",
      "examples": [
        {
          "no": "grensen mellom parodi og satire er hårfin",
          "en": "the line between parody and satire is razor-thin"
        }
      ]
    },
    {
      "text": "punkt som ikke kan eller bør overskrides",
      "translation": "point that cannot or should not be exceeded",
      "examples": [
        {
          "no": "dette er på grensen av det en kan tåle",
          "en": "this is on the edge of what one can endure"
        },
        {
          "no": "det er grenser for hva et menneske skal måtte finne seg i",
          "en": "there are limits to what a person should have to put up with"
        },
        {
          "no": "få dekket utgiftene sine innenfor rimelighetens grenser",
          "en": "have one's expenses covered within reasonable limits"
        },
        {
          "no": "det får være grenser for tull",
          "en": "there must be limits to nonsense"
