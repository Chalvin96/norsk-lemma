  "definitions": [
    {
      "text": "det at en lengde, en flate eller et volum trekker seg sammen på grunn av påvirkning",
      "translation": "the act of a length, surface, or volume contracting due to influence",
      "examples": [
        {
          "no": "et legemes kontraksjon ved temperaturfall",
          "en": "a body's contraction when the temperature falls"
        }
      ]
    },
    {
      "text": "sammentrekning (av muskel)",
      "translation": "contraction (of a muscle)",
      "examples": []
    },
    {
      "text": "i språkvitenskap: sammenfall av lyder, særlig av to vokaler til én",
      "translation": "coalescence of sounds, especially of two vowels into one",
      "examples": [
        {
          "no": "‘fjøs’ er en kontraksjon av ‘fe-hus’",
          "en": "'fjøs' is a contraction of 'fe-hus'"
        }
      ]
