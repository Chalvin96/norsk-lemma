  "definitions": [
    {
      "text": "det å bryte eller bli brutt",
      "translation": "the act of breaking, being broken",
      "examples": []
    },
    {
      "text": "det å være brutt",
      "translation": "the state of being broken",
      "examples": [
        {
          "no": "få et stygt brudd i foten",
          "en": "get a bad fracture in the foot"
        },
        {
          "no": "bruddet er leget",
          "en": "the fracture has healed"
        },
        {
          "no": "reparere flere brudd på kabelen",
          "en": "repair several breaks in the cable"
        }
      ]
    },
    {
      "text": "i overført betydning: det at et forhold eller vilkår er eller blir brutt",
      "translation": "the act of a relationship or condition being broken",
      "examples": [
        {
          "no": "brudd i forhandlingene",
          "en": "a breakdown in the negotiations"
        },
        {
          "no": "det kom til et brudd mellom dem",
          "en": "there was a break between them"
        },
        {
          "no": "grove brudd på menneskerettighetene",
          "en": "serious violations of human rights"
        }
      ]
    },
    {
      "text": "sted der noe blir laget ved bryting",
      "translation": "place where something is made by breaking",
      "examples": []
    },
    {
      "text": "i sykkelritt eller løp: det å bryte ut fra hovedfelt",
      "translation": "in cycling races or running: the act of breaking away from the main group",
      "examples": [
        {
          "no": "han forsøker å ligge i et brudd med to andre syklister",
          "en": "he tries to stay in a breakaway with two other cyclists"
