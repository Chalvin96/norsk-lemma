  "definitions": [
    {
      "text": "leddyr ledd-dyr av ordenen Araneae, med hode som er sammenvokst med brystet, og med bakkropp som er skilt fra forkroppen med en dyp innsnevring",
      "translation": "arthropod of the order Araneae, with a head fused to the thorax, and a abdomen separated from the cephalothorax by a deep constriction",
      "examples": [
        {
          "no": "en giftig edderkopp",
          "en": "a venomous spider"
        },
        {
          "no": "edderkopper som fanger fluer i spindelvevet",
          "en": "spiders that catch flies in the web"
        },
        {
          "no": "han var livredd for edderkopper",
          "en": "he was terrified of spiders"
        }
      ]
    },
    {
      "text": "i overført betydning: noen som i det skjulte styrer et nettverk av andre mennesker",
      "translation": "in a figurative sense: someone who secretly controls a network of other people",
      "examples": [
        {
          "no": "den anonyme edderkoppen i norsk næringsliv",
          "en": "the anonymous mastermind of Norwegian business life"
        },
        {
          "no": "han var edderkoppen i terrornettverket",
          "en": "he was the mastermind in the terrorist network"
        }
      ]
    }
