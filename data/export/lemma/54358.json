  "definitions": [
    {
      "text": "person som en er i slekt med, særlig brukt om personer som ikke tilhører den aller nærmeste familien",
      "translation": "a person one is related to, especially one not in the immediate family",
      "examples": [
        {
          "no": "de er nære slektninger av oss",
          "en": "they are close relatives of ours"
        }
      ]
    },
    {
      "text": "hver av flere dyr eller planter som har visse felles trekk",
      "translation": "each of several animals or plants that share certain characteristics",
      "examples": []
    },
    {
      "text": "i overført betydning: noe som har nær forbindelse eller fellestrekk med noe annet",
      "translation": "something that has a close connection or shared characteristics with something else",
      "examples": [
        {
          "no": "rent kunstnerisk er maleren en nær slektning av Munch",
          "en": "artistically speaking, the painter is a close relative of Munch"
        }
      ]
    }
  ]
