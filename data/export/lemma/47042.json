    {
      "text": "helle, øse, tømme (ut)",
      "translation": "to pour, to ladle, to empty (out)",
      "examples": [
        {
          "no": "pøse på vann",
          "en": "pour on water"
        },
        {
          "no": "regnet pøser ned",
          "en": "the rain is pouring down"
        }
      ]
    },
    {
      "text": "i overført betydning: tilføre eller la strømme i store mengder",
      "translation": "in a figurative sense: to supply or let flow in large quantities",
      "examples": [
        {
          "no": "pøse millioner av kroner inn i selskapet",
          "en": "pour millions of kroner into the company"
        }
