  "definitions": [
    {
      "text": "holde for sant eller sannsynlig",
      "translation": "hold as true or probable",
      "examples": []
    },
    {
      "text": "anta",
      "translation": "assume",
      "examples": [
        {
          "no": "jeg tror det blir regn",
          "en": "I think it's going to rain"
        },
        {
          "no": "du skal vite, ikke tro",
          "en": "you must know, not think"
        },
        {
          "no": "det er bare noe du tror",
          "en": "that's just something you think"
        },
        {
          "no": "det gikk raskere enn jeg trodde",
          "en": "it went faster than I thought"
        }
      ]
    },
    {
      "text": "forestille seg",
      "translation": "imagine",
      "examples": []
    },
    {
      "text": "tenke seg",
      "translation": "think",
      "examples": []
    },
    {
      "text": "mene",
      "translation": "mean",
      "examples": [
        {
          "no": "jeg skulle tro det ville hjelpe litt",
          "en": "I should think it would help a little"
        },
        {
          "no": "du kan tro det smakte godt",
          "en": "you bet it tasted good"
        },
        {
          "no": "det hadde jeg ikke trodd om deg",
          "en": "I wouldn't have thought that of you"
        },
        {
          "no": "tro godt om noen",
          "en": "think well of someone"
        }
      ]
    },
    {
      "text": "ha tiltro til",
      "translation": "have faith in",
      "examples": []
    },
    {
      "text": "stole på",
      "translation": "trust",
      "examples": [
        {
          "no": "en skal ikke tro alt en hører",
          "en": "you shouldn't believe everything you hear"
        },
        {
          "no": "jeg trodde ikke mine egne øyne",
          "en": "I didn't believe my own eyes"
        },
        {
          "no": "tro på det gode i menneskene",
          "en": "believe in the good in people"
        },
        {
          "no": "tro det den som vil",
          "en": "believe that if you want to"
        }
      ]
    },
    {
      "text": "være sikker på at noe guddommelig eksisterer",
      "translation": "be sure that something divine exists",
      "examples": []
    },
    {
      "text": "være kristen",
      "translation": "be Christian",
      "examples": []
    },
    {
      "text": "jamfør troende",
      "translation": "believer",
      "examples": [
        {
          "no": "tro på Gud",
          "en": "believe in God"
