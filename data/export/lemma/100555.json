  "definitions": [
    {
      "text": "person som hører til en folkegruppe som i stor grad har levd som omreisende og med norsk romani som nedarvet språk",
      "translation": "person belonging to an ethnic group that has largely lived as travelers and has Norwegian Romani as an inherited language",
      "examples": []
    },
    {
      "text": "jamfør romanifolk",
      "translation": "Romani people",
      "examples": []
    },
    {
      "text": "til forskjell fra rom",
      "translation": "Romani people",
      "examples": [
        {
          "no": "taterne/romanifolket har status som én av de fem nasjonale minoritetene i Norge",
          "en": "the Tatars/the Romani people have the status of one of the five national minorities in Norway"
        },
        {
          "no": "musikk og sang har alltid vært en viktig del av identiteten til taterne",
          "en": "music and singing have always been an important part of the identity of the Tatars"
        }
      ]
    },
    {
      "text": "nedsettende, om eldre forhold: person som levde i utkanten av samfunnet og livnærte seg med håndverk, småhandel og til dels tigging",
      "translation": "derogatory, in older contexts: person who lived on the fringes of society and made a living from handicrafts, small trade, and partly begging",
