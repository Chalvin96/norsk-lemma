  "definitions": [
    {
      "text": "i grammatikk: partikkel eller subjunksjon som (på norsk og flere andre språk) i visse tilfeller settes foran en infinitiv og innleder en infinitivkonstruksjon",
      "translation": "particle or subjunction that (in Norwegian and several other languages) in certain cases is placed before an infinitive and introduces an infinitive construction",
      "examples": [
        {
          "no": "infinitivmerket er ‘å’ på norsk",
          "en": "the infinitive marker is ‘å’ in Norwegian"
        }
      ]
    }
