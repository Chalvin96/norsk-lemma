  "cross_reference": null,
  "definitions": [
    {
      "text": "skjøte eller flette sammen to tauender",
      "translation": "join or splice together two rope ends",
      "examples": [
        {
          "no": "elevene lærte å spleise tau",
          "en": "the students learned to splice ropes"
        }
      ]
    },
    {
      "text": "i overført betydning: føre sammen personer så de blir et par eller en gruppe",
      "translation": "bring people together so they become a couple or a group",
      "examples": [
        {
          "no": "han ble spleiset med en utenlandsk kvinne",
          "en": "he was paired up with a foreign woman"
        },
        {
          "no": "spleise elevene enda bedre sammen",
          "en": "bring the students together even better"
        }
      ]
    },
    {
      "text": "legge sammen penger for å betale for noe",
      "translation": "pool money to pay for something",
      "examples": [
        {
          "no": "de spleiset på en gave til kollegaen",
          "en": "they chipped in on a gift for their colleague"
        }
      ]
    }
  ]
