  "cross_reference": null,
  "definitions": [
    {
      "text": "trekke eller føre fra et sted til et annet, slite, rykke",
      "translation": "to pull or move from one place to another, to strain, to tug",
      "examples": [
        {
          "no": "hal i og dra!",
          "en": "heave-ho!"
        },
        {
          "no": "dra fisk",
          "en": "pull in fish"
        },
        {
          "no": "dra opp fisk",
          "en": "pull up fish"
        },
        {
          "no": "dra nota",
          "en": "pull the seine"
        }
      ]
    },
    {
      "text": "hale, slepe (noe tungt)",
      "translation": "to haul, to drag (something heavy)",
      "examples": [
        {
          "no": "dra på en tung koffert",
          "en": "drag a heavy suitcase"
        }
      ]
    },
    {
      "text": "ta fram våpen (av hylster og true med det)",
      "translation": "to draw a weapon (from its holster and threaten with it)",
      "examples": [
        {
          "no": "dra sverdet",
          "en": "draw the sword"
        }
      ]
    },
    {
      "text": "risse, markere",
      "translation": "to score, to mark",
      "examples": [
        {
          "no": "dra opp retningslinjer",
          "en": "draw up guidelines"
        }
      ]
    },
    {
      "text": "røre på muskel for å uttrykke følelse",
      "translation": "to move a muscle to express a feeling",
      "examples": [
        {
          "no": "dra på skuldrene",
          "en": "shrug"
        },
        {
          "no": "dra på smilebåndet",
          "en": "smile"
        }
      ]
    },
    {
      "text": "i overført betydning: virke tillokkende",
      "translation": "to be appealing",
      "examples": [
        {
          "no": "byen drar",
          "en": "the city has appeal"
        }
      ]
    },
    {
      "text": "gjøre haltende bevegelse",
      "translation": "to move with a limping gait",
      "examples": [
        {
          "no": "dra på det ene beinet",
          "en": "drag one leg"
        }
      ]
    },
    {
      "text": "i idrett: ligge fremst (og dermed bestemme farten)",
      "translation": "to be in front (and thus determine the speed)",
      "examples": [
        {
          "no": "ligge foran og dra",
          "en": "be out in front and set the pace"
        }
      ]
    },
    {
      "text": "gi drivkraft til",
      "translation": "to provide motive power to",
      "examples": [
        {
          "no": "dra slipesteinen",
          "en": "turn the grindstone"
        },
        {
          "no": "motoren drar saga",
          "en": "the motor drives the saw"
        }
      ]
    },
    {
      "text": "samle, vinne",
      "translation": "to gather, to gain",
      "examples": [
        {
          "no": "dra lærdom av noe",
          "en": "learn from something"
        },
        {
          "no": "dra nytte av noe",
          "en": "benefit from something"
        }
      ]
    },
    {
      "text": "i overført betydning: tenke seg til, slutte logisk",
      "translation": "to infer, to conclude logically",
      "examples": [
        {
          "no": "dra noe i tvil",
          "en": "cast doubt on something"
        },
        {
          "no": "det ene drar det andre med seg",
          "en": "one thing leads to another"
        },
        {
          "no": "dra kjensel på noen",
          "en": "recognize someone"
        }
      ]
    },
    {
      "text": "suge, trekke til seg",
      "translation": "to inhale, to draw in",
      "examples": [
        {
          "no": "dra pusten",
          "en": "draw breath"
        }
      ]
    },
    {
      "text": "reise, fare",
      "translation": "to travel, to go",
      "examples": [
        {
          "no": "dra sin vei",
          "en": "go away"
        },
        {
          "no": "hun har dratt til utlandet",
          "en": "she has gone abroad"
        },
        {
          "no": "dra på tur",
          "en": "go on a trip"
        },
        {
          "no": "dra til fjells",
          "en": "go to the mountains"
        }
      ]
    },
    {
      "text": "om vær: bevege seg over et område",
      "translation": "about weather: to move across an area",
      "examples": [
        {
          "no": "uværet dro forbi",
          "en": "the storm passed by"
        }
      ]
    }
  ]
}
