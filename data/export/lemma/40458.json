  "definitions": [
    {
      "text": "det å bygge på tidligere ubebygde områder",
      "translation": "the act of building on previously undeveloped areas",
      "examples": [
        {
          "no": "nedbyggingen av dyrket jord må stoppes",
          "en": "the building over of cultivated land must be stopped"
        }
      ]
    },
    {
      "text": "det å redusere eller avvikle gradvis",
      "translation": "the act of gradually reducing or phasing out",
      "examples": [
        {
          "no": "vi må hindre nedbygging av velferdsstaten",
          "en": "we must prevent the dismantling of the welfare state"
        },
        {
          "no": "nedbygging av en virksomhet",
          "en": "the winding down of a business"
        }
      ]
    }
