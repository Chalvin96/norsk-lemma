  "definitions": [
    {
      "text": "med stor utstrekning på tvers av lengden eller høyden",
      "translation": "with great extent across the width or height",
      "examples": []
    },
    {
      "text": "motsatt smal, til forskjell fra lang og høy høg",
      "translation": "narrow, long and high high",
      "examples": [
        {
          "no": "en bred gate",
          "en": "a wide street"
        },
        {
          "no": "være bred over skuldrene",
          "en": "be broad across the shoulders"
        },
        {
          "no": "et bredt smil",
          "en": "a broad smile"
        },
        {
          "no": "et rikt område med brede bygder",
          "en": "a rich area with wide rural districts"
        }
      ]
    },
    {
      "text": "med en nærmere angitt utstrekning, målt på tvers av lengden eller høyden",
      "translation": "with a specified extent, measured across the width or height",
      "examples": [
        {
          "no": "huset er ti meter langt og fem meter bredt",
          "en": "the house is ten meters long and five meters wide"
        }
      ]
    },
    {
      "text": "som omfatter mye eller mange",
      "translation": "encompassing much or many",
      "examples": []
    },
    {
      "text": "vidstrakt",
      "translation": "extensive",
      "examples": [
        {
          "no": "et bredt utvalg av matvarer",
          "en": "a wide selection of groceries"
        },
        {
          "no": "bred enighet",
          "en": "broad agreement"
        },
        {
          "no": "de brede lag av folket",
          "en": "the broad masses of the people"
