  "definitions": [
    {
      "text": "salte og tørke (og ofte røyke) kjøtt, flesk eller fisk",
      "translation": "to salt and dry (and often smoke) meat, bacon, fish",
      "examples": [
        {
          "no": "speke kjøttet så det kan spises ukokt",
          "en": "cure the meat so it can be eaten uncooked"
        },
        {
          "no": "flesk passer godt til å speke",
          "en": "pork is well suited for curing"
        }
      ]
    },
    {
      "text": "la sild ligge i saltlake til den kan spises ukokt",
      "translation": "to let herring lie in brine until it can be eaten uncooked",
      "examples": [
        {
          "no": "silda er speket etter 4–6 uker",
          "en": "the herring is cured after 4–6 weeks"
        }
      ]
    }
