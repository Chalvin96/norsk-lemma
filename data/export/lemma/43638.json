  "definitions": [
    {
      "text": "kjøre over",
      "translation": "to drive over",
      "examples": [
        {
          "no": "bli overkjørt av en bil",
          "en": "be run over by a car"
        }
      ]
    },
    {
      "text": "i overført betydning: ikke ta hensyn til noen eller noe",
      "translation": "in a figurative sense: to disregard someone or something",
      "examples": [
        {
          "no": "vi føler oss overkjørt av myndighetene i denne saken",
          "en": "we feel steamrolled by the authorities in this matter"
        }
      ]
    },
    {
      "text": "få overtak på",
      "translation": "to gain the upper hand over",
      "examples": []
    },
    {
      "text": "seire over",
      "translation": "to triumph over",
      "examples": [
        {
          "no": "hun overkjørte motparten fullstendig i debatten",
          "en": "she completely steamrolled the opposition in the debate"
        }
      ]
    }
  ]
