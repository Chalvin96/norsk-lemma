  "definitions": [
    {
      "text": "komme fram (til)",
      "translation": "to arrive (at)",
      "examples": [
        {
          "no": "etter ruten skal skipet ankomme i morgen",
          "en": "according to the schedule, the ship is due to arrive tomorrow"
        },
        {
          "no": "han er nettopp ankommet fra Paris",
          "en": "he has just arrived from Paris"
        },
        {
          "no": "vi ankom Bergen to timer forsinket",
          "en": "we arrived in Bergen two hours late"
        },
        {
          "no": "den sist ankomne",
          "en": "the most recent arrival"
        }
      ]
    },
    {
      "text": "troppe opp",
      "translation": "to show up",
      "examples": [
        {
          "no": "hun ankom i shorts",
          "en": "she showed up in shorts"
