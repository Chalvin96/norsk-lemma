  "cross_reference": null,
  "definitions": [
    {
      "text": "rase, strømme eller falle nedover uten styring",
      "translation": "rush, stream, or fall downward without control",
      "examples": [
        {
          "no": "elva styrtet utfor stupet",
          "en": "the river plunged over the cliff"
        },
        {
          "no": "skiløperne styrtet utfor en skrent",
          "en": "the skiers plunged over an embankment"
        },
        {
          "no": "passasjerfly styrtet",
          "en": "the passenger plane crashed"
        },
        {
          "no": "tårnet styrtet sammen",
          "en": "the tower collapsed"
        }
      ]
    },
    {
      "text": "få noe eller noen til å falle sammen eller falle ned",
      "translation": "cause something or someone to collapse or fall down",
      "examples": []
    },
    {
      "text": "støte, tømme, kaste ned",
      "translation": "dump, pour, throw down",
      "examples": [
        {
          "no": "styrte noe i avgrunnen",
          "en": "plunge something into the abyss"
        },
        {
          "no": "styrte lasset i fyllinga",
          "en": "dump the load on the fill"
        }
      ]
    },
    {
      "text": "drikke noe raskt",
      "translation": "drink something quickly",
      "examples": [
        {
          "no": "styrte ned et glass vann",
          "en": "gulp down a glass of water"
        },
        {
          "no": "hun styrtet en øl på åtte sekunder",
          "en": "she chugged a beer in eight seconds"
        }
      ]
    },
    {
      "text": "bevege seg i høy fart",
      "translation": "rush, storm",
      "examples": []
    },
    {
      "text": "fare, storme",
      "translation": "rush, storm",
      "examples": [
        {
          "no": "styrte på dør",
          "en": "rush to the door"
        }
      ]
    },
    {
      "text": "i overført betydning: begynne å gjøre noe uten planlegging",
      "translation": "figurative: begin doing something without planning",
      "examples": [
        {
          "no": "styrte seg ut i dristige spekulasjoner",
          "en": "throw oneself into bold speculations"
        }
      ]
    },
    {
      "text": "i overført betydning: få noen ut av balanse, ut av posisjon eller i vanry",
      "translation": "figurative: throw someone off balance, out of position, or into disgrace",
      "examples": [
        {
          "no": "styrte regjeringen",
          "en": "overthrow the government"
        },
        {
          "no": "svindleren styrtet dem alle i ulykken",
          "en": "the swindler brought them all to ruin"
        }
      ]
    },
    {
      "text": "kollapse eller dø",
      "translation": "collapse or die",
      "examples": [
        {
          "no": "kua styrtet på båsen",
          "en": "the cow collapsed in the stall"
        }
      ]
    }
  ]
