        {
          "no": "han springer fra de andre",
          "en": "he outruns the others"
        }
      ]
    },
    {
      "text": "endre eller flytte seg raskt",
      "translation": "change or move quickly",
      "examples": []
    },
    {
      "text": "hoppe, sprette, fyke",
