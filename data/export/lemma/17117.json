  "definitions": [
    {
      "text": "trenge sammen, gjøre tettere",
      "translation": "to crowd together, make denser",
      "examples": [
        {
          "no": "vi må fortette bebyggelsen",
          "en": "we need to build more densely"
        },
        {
          "no": "hun lar fargene fortette seg",
          "en": "she lets the colors intensify"
        },
        {
          "no": "en fortettet stemning",
          "en": "a concentrated atmosphere"
        }
      ]
    },
    {
      "text": "få gass til å gå over i fast form eller væskeform",
      "translation": "to cause gas to turn into solid or liquid form",
      "examples": [
        {
          "no": "gassen blir fortettet til væske",
          "en": "the gas is condensed into liquid"
