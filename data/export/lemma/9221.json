  "definitions": [
    {
      "text": "gi fra seg damp eller røyk",
      "translation": "give off steam or smoke",
      "examples": [
        {
          "no": "hestene dampet av svette",
          "en": "the horses steamed with sweat"
        },
        {
          "no": "det damper av varm mat, våte klær",
          "en": "steam rises from hot food, wet clothes"
        }
      ]
    },
    {
      "text": "la tørke ved fordamping fordampning",
      "translation": "let dry by evaporation",
      "examples": [
        {
          "no": "koke til vannet damper bort",
          "en": "boil until the water evaporates"
        },
        {
          "no": "oljen dampet opp",
          "en": "the oil evaporated"
        }
      ]
    },
    {
      "text": "tilsette damp",
      "translation": "add steam",
      "examples": []
    },
    {
      "text": "behandle med, utsette for damp",
      "translation": "treat with, expose to steam",
      "examples": [
        {
          "no": "dampe ei skjorte",
          "en": "steam a shirt"
        },
        {
          "no": "dampe opp et brev",
          "en": "steam open a letter"
        },
        {
          "no": "grønnsakene skal dampes",
          "en": "the vegetables should be steamed"
        },
        {
          "no": "la laksen bli dampet i 20 minutter",
          "en": "let the salmon be steamed for 20 minutes"
        }
      ]
    },
    {
      "text": "bevege seg med bruk av dampkraft",
      "translation": "move using steam power",
      "examples": [
        {
          "no": "toget dampet av sted",
          "en": "the train steamed away"
        },
        {
          "no": "en liten båt damper sakte forbi",
          "en": "a small boat steams slowly past"
        }
      ]
    },
    {
      "text": "patte på en sigarett, pipe eller lignende",
      "translation": "puff on a cigarette, pipe, or similar",
      "examples": [
        {
          "no": "dampe på sigaretter",
          "en": "puff on cigarettes"
        },
        {
          "no": "de satt og dampet på pipene sine",
          "en": "they sat puffing on their pipes"
        }
      ]
    },
    {
      "text": "i overført betydning: være kjennetegnet av noe",
      "translation": "in a figurative sense: be characterized by something",
      "examples": []
    },
    {
      "text": "ha et tydelig preg av noe",
      "translation": "have a clear trace of something",
      "examples": [
        {
          "no": "filmen dampet av erotikk",
          "en": "the film steamed with eroticism"
        },
        {
          "no": "boka damper av melankoli",
          "en": "the book steams with melancholy"
        }
      ]
    }
