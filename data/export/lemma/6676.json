    {
      "text": "gjøre bløt blaut ved å legge i vann eller annen væske",
      "translation": "make soft or wet by placing in water or other liquid",
      "examples": []
    },
    {
      "text": "væte",
      "translation": "wet",
      "examples": [
        {
          "no": "hun bløtte vaskekluten i såpevannet",
          "en": "she soaked the washcloth in the soapy water"
        }
      ]
    },
    {
      "text": "mykne, gjøre bløt blaut ved å legge i vann eller annen væske",
