  "definitions": [
    {
      "text": "forklare, presisere betydningen av et ord eller innholdet av et begrep",
      "translation": "to explain, to clarify the meaning of a word or the content of a concept",
      "examples": []
    },
    {
      "text": "avgrense, presisere",
      "translation": "to delimit, to clarify",
      "examples": [
        {
          "no": "'dusør' er definert som 'finnerlønn'",
          "en": "'reward' is defined as 'finder's fee'"
        },
        {
          "no": "hvordan vil du definere begrepet ‘demokrati’?",
          "en": "how would you define the term ‘democracy’?"
        }
      ]
    },
    {
      "text": "fastsette statusen, innholdet eller identiteten til noe",
      "translation": "to establish the status, content, or identity of something",
      "examples": [
        {
          "no": "dette er definert som en forbrytelse",
          "en": "this is defined as a crime"
        },
        {
