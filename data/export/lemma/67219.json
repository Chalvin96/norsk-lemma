  "cross_reference": null,
  "definitions": [
    {
      "text": "fastsette, bestemme vekten",
      "translation": "determine, ascertain the weight",
      "examples": [
        {
          "no": "veie og måle skolebarna",
          "en": "weigh and measure the schoolchildren"
        },
        {
          "no": "veie en pakke, et brev",
          "en": "weigh a package, a letter"
        },
        {
          "no": "veie seg hver morgen",
          "en": "weigh oneself every morning"
        },
        {
          "no": "veie opp 5 kg poteter",
          "en": "weigh out 5 kg of potatoes"
        }
      ]
    },
    {
      "text": "ha en viss vekt",
      "translation": "have a certain weight",
      "examples": [
        {
          "no": "pakka veier 2 kg",
          "en": "the package weighs 2 kg"
        },
        {
          "no": "veie over 70 kg",
          "en": "weigh over 70 kg"
        },
        {
          "no": "hennes mening veier tungt",
          "en": "her opinion carries weight"
        },
        {
          "no": "alle fordelene veier opp ulempen",
          "en": "all the advantages outweigh the disadvantage"
        }
      ]
    }
  ]
