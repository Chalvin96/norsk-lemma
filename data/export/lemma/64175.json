  "definitions": [
    {
      "text": "i folketro: fugl som varsler eller bringer ulykke",
      "translation": "in folklore: bird that signals or brings bad luck",
      "examples": [
        {
          "no": "hun ser på ravnen som en ulykkesfugl",
          "en": "she regards the raven as a bird of ill omen"
        }
      ]
    },
    {
      "text": "person som ufrivillig bringer med seg ulykke for andre",
      "translation": "person who involuntarily brings misfortune to others",
      "examples": [
        {
          "no": "hold deg unna den ulykkesfuglen",
          "en": "keep away from that jinx"
        }
      ]
    },
    {
      "text": "person som ofte rammes av uhell eller ulykker",
      "translation": "person who is often struck by accidents",
      "examples": [
        {
          "no": "en stakkars ulykkesfugl",
          "en": "a poor unlucky soul"
        },
        {
          "no": "som den ulykkesfuglen hun var, fikk hun en istapp i hodet",
          "en": "being the unlucky soul she was, she got an icicle in the head"
        }
      ]
    }
  ]
