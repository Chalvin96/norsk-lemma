  "definitions": [
    {
      "text": "ta makten i et land ved kupp",
      "translation": "to seize power in a country by a coup",
      "examples": [
        {
          "no": "militæret kuppet landet",
          "en": "the military seized the country in a coup"
        }
      ]
    },
    {
      "text": "overta kontrollen eller styringen av noe",
      "translation": "to take over control or management of something",
      "examples": [
        {
          "no": "hun kuppet hele showet",
          "en": "she hijacked the whole show"
        },
        {
          "no": "han prøvde å kuppe avstemningen",
          "en": "he tried to hijack the vote"
        }
      ]
    }
