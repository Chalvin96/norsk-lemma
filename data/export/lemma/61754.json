  "definitions": [
    {
      "text": "kjegleformet hul redskap med tut nederst, særlig til å helle væske over på flasker eller lignende med smal hals",
      "translation": "cone-shaped hollow tool with a spout at the bottom, especially for pouring liquid into bottles or similar narrow-necked containers",
      "examples": [
        {
          "no": "helle saften gjennom en trakt og ned i flaska",
          "en": "pour the juice through a funnel and into the bottle"
        }
      ]
    },
    {
      "text": "hul gang eller passasje som minner om en trakt",
      "translation": "hollow passage or corridor resembling a funnel",
      "examples": [
        {
          "no": "vinden blåser gjennom trakten mellom fjellveggene",
          "en": "the wind blows through the funnel between the mountain walls"
        }
      ]
    }
  ]
