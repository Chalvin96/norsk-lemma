  "definitions": [
    {
      "text": "stille sammen for 친 finne innbyrdes likhet og ulikhet",
      "translation": "to place together to find mutual similarity and difference",
      "examples": [
        {
          "no": "sammenligne norske forhold med utenlandske",
          "en": "compare Norwegian conditions with foreign ones"
        },
        {
          "no": "han er liten sammenlignet med broren sin",
          "en": "he is small compared with his brother"
        },
        {
          "no": "sammenligne avskriften med originalen",
          "en": "compare the copy with the original"
        },
        {
          "no": "dette prosjektet kunne ikke sammenlignes med andre bruprosjekter",
          "en": "this project could not be compared with other bridge projects"
        }
      ]
    },
    {
      "text": "brukt som adjektiv: som tar utgangspunkt i sammenligninger for 친 unders칮ke hvordan ulike fenomener henger sammen",
      "translation": "used as an adjective: based on comparisons to examine how different phenomena relate to each other",
      "examples": [
        {
          "no": "sammenlignende metoder",
          "en": "comparative methods"
