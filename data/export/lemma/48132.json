  "definitions": [
    {
      "text": "gjøre ren",
      "translation": "to make clean",
      "examples": []
    },
    {
      "text": "fjerne skitt, avfall eller uønskte parikler med å vaske, pusse, bruke kjemiske midler eller lignende",
      "translation": "to remove dirt, waste, or unwanted particles by washing, scrubbing, or using chemical agents",
      "examples": [
        {
          "no": "rense motoren",
          "en": "clean the engine"
        },
        {
          "no": "rense dressen",
          "en": "clean the suit"
        },
        {
          "no": "hun renset såret og la på et plaster",
          "en": "she cleaned the wound and put on a bandage"
        }
      ]
    },
    {
      "text": "fjerne eller skjære bort uønskte deler",
      "translation": "to remove or cut away unwanted parts",
      "examples": [
        {
          "no": "rense fisk",
          "en": "clean fish"
        },
        {
          "no": "kan du rense grønnsakene til middag?",
          "en": "can you clean the vegetables for dinner?"
        }
      ]
    },
    {
      "text": "gjøre fri for mistanke, vanære, onde tanker, synd eller lignende",
      "translation": "to free from suspicion, dishonor, evil thoughts, sin",
      "examples": [
        {
          "no": "rense for synder og laster",
          "en": "cleanse of sins and vices"
        },
        {
          "no": "rense sjelen",
          "en": "cleanse the soul"
        }
      ]
    }
  ]
