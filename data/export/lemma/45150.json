  "cross_reference": null,
  "definitions": [
    {
      "text": "sette en plante med røttene i jord",
      "translation": "to set a plant with its roots in soil",
      "examples": [
        {
          "no": "plante et epletre",
          "en": "plant an apple tree"
        },
        {
          "no": "de planter roser i bedet",
          "en": "they plant roses in the flower bed"
        }
      ]
    },
    {
      "text": "bygge opp et område ved å sette en stor mengde planter i jorda",
      "translation": "to build up an area by setting a large number of plants in the ground",
      "examples": [
        {
          "no": "plante skog",
          "en": "plant a forest"
        },
        {
          "no": "de plantet en vingård",
          "en": "they planted a vineyard"
        }
      ]
    },
    {
      "text": "plassere noe fast og stødig",
      "translation": "to place something firmly and steadily",
      "examples": [
        {
          "no": "plante neven i bordet",
          "en": "plant one's fist on the table"
        },
        {
          "no": "hun planter begge beina i gulvet",
          "en": "she plants both feet on the floor"
        }
      ]
    },
    {
      "text": "i hemmelighet plassere noe eller noen et sted for å skade eller avsløre",
      "translation": "to secretly place something or someone somewhere to harm or expose",
      "examples": [
        {
          "no": "plante en spion i fiendens leir",
          "en": "plant a spy in the enemy camp"
        },
        {
          "no": "noen hadde plantet narkotika i leiligheten hennes",
          "en": "someone had planted drugs in her apartment"
        }
      ]
    }
  ]
