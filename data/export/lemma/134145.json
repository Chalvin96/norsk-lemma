  "cross_reference": null,
  "definitions": [
    {
      "text": "som er brukt til å bygge hus, hytte eller andre bygg på",
      "translation": "built up with houses, cabins, or other buildings",
      "examples": [
        {
          "no": "et utbygd boligfelt",
          "en": "a developed residential area"
        }
      ]
    },
    {
      "text": "om foss eller elv: som er knyttet til et anlegg som bruker kraften til å produsere elektristet",
      "translation": "for a waterfall or river: connected to a facility that uses its power to produce electricity",
      "examples": [
        {
          "no": "fossen er ikke utbygd",
          "en": "the waterfall is not developed"
        },
        {
          "no": "utbygde vassdrag",
          "en": "developed waterways"
        }
      ]
    },
    {
      "text": "om anlegg, infrastruktur, institusjon og lignende: som er laget for å dekke et behov",
      "translation": "for facilities, infrastructure, institutions: designed to meet a need",
      "examples": [
        {
          "no": "et godt utbygd helsetilbud",
          "en": "a well-developed healthcare service"
        },
        {
          "no": "veinettet er dårlig utbygd",
          "en": "the road network is poorly developed"
        }
      ]
    },
    {
      "text": "utformet eller utviklet i detalj",
      "translation": "designed or developed in detail",
      "examples": [
        {
          "no": "et godt utbygd argument",
          "en": "a well-developed argument"
        }
      ]
    }
  ]
