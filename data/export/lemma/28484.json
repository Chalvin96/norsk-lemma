  "definitions": [
    {
      "text": "gjøre vanskelig å oppdage eller kjenne igjen",
      "translation": "make difficult to discover or recognize",
      "examples": []
    },
    {
      "text": "jamfør kamuflasje",
      "translation": "camouflage",
      "examples": [
        {
          "no": "tanksene er kamuflert med busker og greiner",
          "en": "the tanks are camouflaged with bushes and branches"
        }
      ]
    },
    {
      "text": "i overført betydning: gjemme, skjule",
      "translation": "in a figurative sense: hide, conceal",
      "examples": [
        {
          "no": "han vil kamuflere at han har kjøpt en kostbar bil",
          "en": "he wants to conceal that he has bought an expensive car"
        },
        {
          "no": "et kamuflert forsøk på å dekke over dårlig økonomi",
          "en": "a disguised attempt to cover up poor finances"
        }
      ]
    }
  ]
