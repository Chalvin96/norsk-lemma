  "definitions": [
    {
      "text": "gjøre fersk eller frisk igjen",
      "translation": "to make fresh or new again",
      "examples": []
    },
    {
      "text": "fornye, friske",
      "translation": "renew, freshen up",
      "examples": [
        {
          "no": "ferske opp sminken",
          "en": "freshen up the makeup"
        }
      ]
    },
    {
      "text": "raffinere ved oksidasjon, særlig for å lage om råjern til smijern og stål",
      "translation": "refine by oxidation, especially to convert pig iron to wrought iron and steel",
      "examples": []
    },
    {
      "text": "overraske noen på fersk gjerning",
      "translation": "to catch someone in the act",
      "examples": [
        {
          "no": "bli fersket med tyvegodset i hendene",
          "en": "be caught with the stolen goods in your hands"
        }
      ]
    }
