  "definitions": [
    {
      "text": "i språkvitenskap: forbindelse mellom to eller flere (setnings)ledd der ingen av leddene alene kan ha samme funksjon som hele forbindelsen",
      "translation": "connection between two or more (sentence) elements where none of the elements alone can have the same function as the entire connection",
      "examples": []
    },
    {
      "text": "jamfør hypotagme, paratagme og syntagme",
      "translation": "cataclasis",
      "examples": [
        {
          "no": "'de reiste' er et eksempel på et katatagme fordi meningen går tapt om et av de to ordene fjernes",
          "en": "'they left' is an example of a catatagm because the meaning is lost if one of the two words is removed"
        }
      ]
    }
