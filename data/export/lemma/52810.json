  "definitions": [
    {
      "text": "hver av to smale, profilerte gjenstander av metall som ligger parallelt og tjener som kjørebane for tog og trikk",
      "translation": "one of two narrow, profiled metal objects that lie parallel and serve as a track for trains and trams",
      "examples": [
        {
          "no": "de la ned skinner til trikken",
          "en": "they laid tracks for the tram"
        }
      ]
    },
    {
      "text": "smal, avlang gjenstand av metall, plast eller lignende som noe kan gli eller kjøre på",
      "translation": "narrow, elongated object of metal, plastic on which something can slide or run",
      "examples": [
        {
          "no": "gardinene glir på en skinne",
          "en": "the curtains slide on a rail"
        }
      ]
    },
    {
      "text": "langt, smalt stykke av fast materiale brukt til å holde en skadd legemsdel i ro",
      "translation": "long, narrow piece of solid material used to keep an injured body part still",
      "examples": [
        {
          "no": "han har en skinne på foten for å holde kneet i ro",
          "en": "he has a brace on his foot to keep his knee still"
        }
      ]
    }
  ]
