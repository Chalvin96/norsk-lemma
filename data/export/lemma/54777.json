  "definitions": [
    {
      "text": "få til å bli flytende",
      "translation": "to cause to become liquid",
      "examples": [
        {
          "no": "smelte snø",
          "en": "melt snow"
        }
      ]
    },
    {
      "text": "bli flytende",
      "translation": "to become liquid",
      "examples": [
        {
          "no": "smøret smeltet i sola",
          "en": "the butter melted in the sun"
        },
        {
          "no": "isen smelter bort",
          "en": "the ice is melting away"
        }
      ]
    },
    {
      "text": "bli bløtgjort",
      "translation": "to become softened",
      "examples": [
        {
          "no": "hun smeltet helt da hun så hvor ulykkelig han var",
          "en": "she completely melted when she saw how unhappy he was"
