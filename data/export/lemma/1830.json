  "definitions": [
    {
      "text": "gå til angrep på",
      "translation": "to go on the attack",
      "examples": [
        {
          "no": "fiendtlige styrker har angrepet hovedstaden",
          "en": "enemy forces have attacked the capital"
        },
        {
          "no": "bærplukkeren ble angrepet av en bjørn",
          "en": "the berry picker was attacked by a bear"
        }
      ]
    },
    {
      "text": "i lagidett: forsøke å få mål",
      "translation": "in team sports: to try to score",
      "examples": [
        {
          "no": "laget angrep gjennom hele kampen",
          "en": "the team attacked throughout the match"
        }
      ]
    },
    {
      "text": "kritisere, polemisere mot",
      "translation": "to criticize, to polemicize against",
      "examples": [
        {
          "no": "regjeringens politikk ble sterkt angrepet",
          "en": "the government's policy was strongly attacked"
        }
      ]
    },
    {
      "text": "tære på, bryte ned, ødelegge øydelegge",
      "translation": "to wear down, break down, destroy",
      "examples": [
        {
          "no": "bli angrepet av en sykdom",
          "en": "be attacked by a disease"
        },
        {
          "no": "huset var angrepet av sopp og råte",
          "en": "the house was affected by fungus and rot"
        }
      ]
    },
    {
      "text": "ordne opp i",
      "translation": "to deal with",
      "examples": []
    },
    {
      "text": "løse løyse, takle",
      "translation": "to solve, tackle",
      "examples": [
        {
          "no": "angripe saken fra gal side",
          "en": "approach the matter from the wrong side"
        },
        {
          "no": "hvordan skal dette angripes?",
          "en": "how should this be tackled?"
        }
      ]
    }
