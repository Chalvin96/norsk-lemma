  "definitions": [
    {
      "text": "fangstnett av fine tråder som edderkopper skiller ut som sekret, og som størkner i luft",
      "translation": "catching net made of fine threads secreted by spiders, which solidify in the air",
      "examples": []
    },
    {
      "text": "edderkoppspinn, spindelvev",
      "translation": "spider's web, cobweb",
      "examples": [
        {
          "no": "en flue som surret hjelpeløst i et edderkoppnett",
          "en": "a fly that buzzed helplessly in a spiderweb"
        }
      ]
    },
    {
      "text": "i overført betydning: forgrenet system som fanger eller kontrollerer og er umulig å slippe unna",
      "translation": "branched system that traps or controls and is impossible to escape",
      "examples": [
        {
          "no": "et edderkoppnett av intriger",
          "en": "a spiderweb of intrigue"
        },
        {
          "no": "et edderkoppnett av informanter som drev med avlytting og spionasje",
          "en": "a spiderweb of informants engaged in wiretapping and espionage"
        }
      ]
    }
