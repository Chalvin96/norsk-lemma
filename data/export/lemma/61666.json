  "definitions": [
    {
      "text": "behandle ull eller andre materialer slik at det filtrer seg sammen og blir tettere og tykkere",
      "translation": "to treat wool or other materials so that they felt together and become denser and thicker",
      "examples": [
        {
          "no": "tove votter i vaskemaskinen",
          "en": "felt mittens in the washing machine"
        },
