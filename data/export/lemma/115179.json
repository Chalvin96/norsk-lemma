  "definitions": [
    {
      "text": "prinsipp eller tanke om at det er bedre å være forsiktig eller forberede seg godt på forhånd enn å bøte på noe etterpå",
      "translation": "principle or idea that it is better to be careful or well-prepared in advance than to remedy something afterwards",
      "examples": [
        {
          "no": "anbefalingen gis ut fra et føre-var-prinsipp",
          "en": "the recommendation is given on the basis of the precautionary principle"
        }
      ]
