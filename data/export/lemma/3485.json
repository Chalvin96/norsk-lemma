  "cross_reference": null,
  "definitions": [
    {
      "text": "gjøre slutt på, løse en strid eller et tvilsspørsmål",
      "translation": "to put an end to, resolve a dispute or a question",
      "examples": [
        {
          "no": "avgjøre hvem som er sterkest",
          "en": "determine who is strongest"
        },
        {
          "no": "det avgjør saken",
          "en": "that settles the matter"
        }
      ]
    },
    {
      "text": "bestemme, beslutte",
      "translation": "to decide, to resolve",
      "examples": [
        {
          "no": "det kan vi avgjøre senere",
          "en": "we can decide that later"
        },
        {
          "no": "det må du selv avgjøre",
          "en": "you have to decide that yourself"
        },
        {
          "no": "det skal hun avgjøre",
          "en": "she will decide that"
        }
      ]
    },
    {
      "text": "gjøre endelig vedtak i en sak",
      "translation": "to make a final decision in a case",
      "examples": [
        {
          "no": "saken blir avgjort i statsråd",
          "en": "the matter is decided in the Council of State"
        }
      ]
    },
    {
      "text": "gjøre utslaget",
      "translation": "to be decisive",
      "examples": [
        {
          "no": "kondisjonen avgjorde kampen",
          "en": "fitness decided the match"
        }
      ]
    }
  ]
