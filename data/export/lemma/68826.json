    {
      "text": "ha kjennskap til",
      "translation": "to have knowledge of",
      "examples": []
    },
    {
      "text": "ha greie på",
      "translation": "to be aware of",
      "examples": [
        {
          "no": "la noen få vite hva en mener",
          "en": "let someone know what one means"
        },
        {
          "no": "jeg visste ikke at de hadde flyttet",
