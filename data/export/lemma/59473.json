  "definitions": [
    {
      "text": "boble av såpeskum, som en kan lage ved å dyppe en ring i såpevann og blåse på den tynne hinnen som danner seg",
      "translation": "bubble of soapy foam, made by dipping a ring in soapy water and blowing on the thin film that forms",
      "examples": [
        {
          "no": "blåse såpebobler",
          "en": "blow soap bubbles"
        }
      ]
    },
    {
      "text": "i overført betydning: noe som lett går i stykker eller mislykkes",
      "translation": "something that easily breaks or fails",
      "examples": [
        {
          "no": "planen sprakk som en såpeboble",
          "en": "the plan burst like a soap bubble"
        },
        {
          "no": "prosjektet er ingen såpeboble",
          "en": "the project is no soap bubble"
        }
      ]
