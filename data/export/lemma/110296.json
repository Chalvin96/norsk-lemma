  "definitions": [
    {
      "text": "utspent presenning som folk kan hoppe ned i fra hus som står i brann",
      "translation": "stretched tarpaulin that people can jump into from houses on fire",
      "examples": [
        {
          "no": "spenne ut et brannseil",
          "en": "stretch out a fire rescue sheet"
        },
        {
          "no": "hun kastet seg ut og landet i brannseilet",
          "en": "she threw herself out and landed in the fire rescue sheet"
        }
      ]
    },
    {
      "text": "våt presenning som beskytter hus mot gnister og varme fra en brann",
      "translation": "wet tarpaulin that protects a house from sparks and heat from a fire",
      "examples": []
    }
