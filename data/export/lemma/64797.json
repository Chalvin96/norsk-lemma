  "cross_reference": null,
  "definitions": [
    {
      "text": "det å være uren",
      "translation": "the state of being unclean",
      "examples": [
        {
          "no": "sykdom og pest ble oppfattet som urenhet og smitte",
          "en": "disease and plague were perceived as uncleanness and contagion"
        }
      ]
    },
    {
      "text": "noe som er urent, oppblandet eller skittent",
      "translation": "something that is unclean, mixed, or dirty",
      "examples": [
        {
          "no": "det var urenheter i drikkevannet",
          "en": "there were impurities in the drinking water"
        },
        {
          "no": "urenheter i huden",
          "en": "skin impurities"
        }
      ]
    },
    {
      "text": "umoral, usedelighet",
      "translation": "immorality, worthlessness",
      "examples": [
        {
          "no": "alt som hadde med lettsindighet og urenhet å gjøre ble bannlyst fra kirken",
          "en": "everything that had to do with frivolity and impurity was banned from the church"
        }
      ]
    }
  ]
