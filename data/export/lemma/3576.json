  "definitions": [
    {
      "text": "kjøle av, gjøre kaldere",
      "translation": "cool down, make colder",
      "examples": [
        {
          "no": "jeg trenger noe å avkjøle meg på",
          "en": "I need something to cool myself down with"
        },
        {
          "no": "vannet fra breelvene avkjøler fjordene",
          "en": "the water from the glacial rivers cools the fjords"
        }
      ]
    },
    {
      "text": "i overført betydning: døyve, for eksempel lyst eller sinne",
      "translation": "dampen, desire or anger",
      "examples": [
        {
          "no": "få avkjølt raseriet sitt",
          "en": "get his rage cooled down"
