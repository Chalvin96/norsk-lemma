  "definitions": [
    {
      "text": "ha flagg heist eller hengt ut",
      "translation": "to have a flag hoisted or displayed",
      "examples": [
        {
          "no": "flagge for noen",
          "en": "fly the flag for someone"
        },
        {
          "no": "hele byen flagger i dag",
          "en": "the whole town is flying flags today"
        }
      ]
    },
    {
      "text": "gi tegn med flagg",
      "translation": "to signal with flags",
      "examples": [
        {
          "no": "bli flagget inn som vinner av billøpet",
          "en": "be flagged in as the winner of the car race"
        }
      ]
    },
    {
      "text": "gjøre kjent, vise fram",
      "translation": "to make known, to show off",
      "examples": []
    },
    {
      "text": "briske seg",
      "translation": "to boast",
      "examples": [
        {
          "no": "flagge sin misnøye",
          "en": "show one's dissatisfaction"
        },
        {
          "no": "partiet har flagget sitt standpunkt i saken",
          "en": "the party has made its position on the matter clear"
        },
        {
          "no": "ikke ha så mye å flagge med",
          "en": "not have much to show for oneself"
        }
      ]
    }
  ]
