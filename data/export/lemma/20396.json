  "definitions": [
    {
      "text": "gni, skure",
      "translation": "to rub, to scrape",
      "examples": [
        {
          "no": "kvistene gnisser mot vinduet",
          "en": "the twigs scrape against the window"
        }
      ]
    },
    {
      "text": "gi en fint skjærende eller knirkende lyd",
      "translation": "to make or emit a fine, grating, or creaking sound",
      "examples": [
        {
          "no": "gresshoppene gnisser",
          "en": "the grasshoppers chirr"
        }
      ]
    },
    {
      "text": "lage eller være utsatt for gnisning",
      "translation": "to cause or be subject to friction",
      "examples": [
        {
          "no": "ekteskapet gnisset",
          "en": "the marriage was strained"
        }
      ]
