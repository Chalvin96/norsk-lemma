    {
      "text": "stein som en lett kan snuble i",
      "translation": "stone that one can easily trip over",
      "examples": []
    },
    {
      "text": "i overført betydning: hindring som fort kan gjøre en plan mer komplisert",
      "translation": "figurative: obstacle that can quickly make a plan more complicated",
      "examples": []
    },
    {
      "text": "triks, knep",
      "translation": "trick, ruse",
      "examples": [
        {
          "no": "dette ble nok en snublestein i forhandlingene",
          "en": "this was probably another stumbling block in the negotiations"
        }
      ]
    },
    {
      "text": "minnesmerke utformet som gatestein foran hjemmet til offer for nazisme under andre verdenskrig",
      "translation": "memorial stone placed in the street outside the home of a victim of Nazism during World War II",
      "examples": [
        {
          "no": "en finner snublesteiner over hele Europa",
          "en": "you can find stumbling stones all over Europe"
