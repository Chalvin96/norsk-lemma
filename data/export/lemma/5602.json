  "definitions": [
    {
      "text": "ilagt forbud mot å motta besøk i fengselet, ofte med brevforbud i tillegg",
      "translation": "prohibition imposed on receiving visitors in prison, often with a ban on mail as well",
      "examples": [
        {
          "no": "de siktede ble fengslet for åtte uker med brev- og besøksforbud",
          "en": "the accused were remanded in custody for eight weeks with a ban on letters and visits"
        }
      ]
    },
    {
      "text": "ilagt forbud mot å oppsøke en eller flere personer, ofte for å forhindre vold",
      "translation": "prohibition imposed on approaching one or more persons, often to prevent violence",
      "examples": [
        {
          "no": "bli dømt for brudd på besøksforbudet",
          "en": "be convicted of violating the restraining order"
        }
      ]
    }
