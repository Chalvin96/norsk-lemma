  "definitions": [
    {
      "text": "skape eller forme et (fysisk eller immaterielt) produkt",
      "translation": "create or shape a (physical or intangible) product",
      "examples": [
        {
          "no": "lage en kake",
          "en": "make a cake"
        },
        {
          "no": "snekkeren lagde et bord av gamle materialer",
          "en": "the carpenter made a table from old materials"
        },
        {
          "no": "det er han som har laget musikken til filmen",
          "en": "he's the one who composed the music for the film"
        },
        {
          "no": "båten lagde ringer i vannet",
          "en": "the boat made ripples in the water"
        }
      ]
    },
    {
      "text": "brukt som adjektiv: tilgjort, unaturlig",
      "translation": "used as an adjective: artificial, unnatural",
      "examples": [
        {
          "no": "problemstillingen virker så laget",
          "en": "the issue seems so contrived"
        }
      ]
    },
    {
      "text": "få en bestemt tilstand eller situasjon til å oppstå",
      "translation": "cause a certain state or situation to arise",
      "examples": []
    },
    {
      "text": "stelle i stand",
      "translation": "cause to happen",
      "examples": [
        {
          "no": "lage en flekk på duken",
          "en": "make a stain on the tablecloth"
        },
        {
          "no": "de laget bråk og uro i klasserommet",
          "en": "they made noise and caused unrest in the classroom"
        },
        {
          "no": "hun laget det slik at alle ble tilfredse",
          "en": "she arranged it so that everyone was satisfied"
        }
