  "definitions": [
    {
      "text": "det å ta livet av seg selv",
      "translation": "the act of taking one's own life",
      "examples": [
        {
          "no": "begå selvmord",
          "en": "commit suicide"
        },
        {
          "no": "de mistet onkelen i selvmord",
          "en": "they lost their uncle to suicide"
        },
        {
          "no": "det er selvmord å sette til havs i slikt vær",
          "en": "it is suicide to put to sea in such weather"
        }
      ]
    },
    {
      "text": "i overført betydning: det å ødelegge for seg selv og sin egen framtid",
      "translation": "the act of ruining oneself and one's own future",
      "examples": [
        {
          "no": "å fronte den upopulære saken vil være politisk selvmord",
          "en": "to champion the unpopular cause would be political suicide"
        }
      ]
    }
