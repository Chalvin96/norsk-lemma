  "cross_reference": null,
  "definitions": [
    {
      "text": "oppheve forbindelsen mellom, skille",
      "translation": "to break the connection between, to separate",
      "examples": [
        {
          "no": "atskille foreldre og barn",
          "en": "separate parents and children"
        }
      ]
    },
    {
      "text": "danne skille mellom",
      "translation": "to form a separation between",
      "examples": [
        {
          "no": "en hekk atskiller eiendommene",
          "en": "a hedge separates the properties"
        },
        {
          "no": "Kanalen atskiller England og Frankrike",
          "en": "The Channel separates England and France"
        }
      ]
    },
    {
      "text": "skjelne, skille mellom",
      "translation": "to distinguish, to differentiate between",
      "examples": [
        {
          "no": "de to typene lar seg ikke atskille",
          "en": "the two types cannot be distinguished"
        }
      ]
    },
    {
      "text": "avvike fra",
      "translation": "to deviate from",
      "examples": [
        {
          "no": "fuglene atskiller seg fra pattedyra ved at de legger egg",
          "en": "birds differ from mammals in that they lay eggs"
        },
        {
          "no": "rådhuset atskiller seg fra de andre husene i strøket",
          "en": "the town hall stands out from the other houses in the neighborhood"
        }
      ]
    }
  ]
