  "cross_reference": null,
  "definitions": [
    {
      "text": "som har en lavere stilling (uten særlig beslutningsmyndighet)",
      "translation": "having a lower position (without much decision-making authority)",
      "examples": [
        {
          "no": "ha en underordnet stilling",
          "en": "hold a subordinate position"
        }
      ]
    },
    {
      "text": "som rangerer eller sorterer under (noe annet)",
      "translation": "ranking or sorting below (something else)",
      "examples": [
        {
          "no": "være underordnet loven",
          "en": "be subordinate to the law"
        }
      ]
    },
    {
      "text": "i språkvitenskap: som inngår som avhengig ledd i en større helhet",
      "translation": "forming a dependent part of a larger whole",
      "examples": [
        {
          "no": "leddsetninger er underordnede setninger",
          "en": "subordinate clauses are subordinate sentences"
        }
      ]
    },
    {
      "text": "mindre viktig",
      "translation": "less important",
      "examples": [
        {
          "no": "spørsmålet er av underordnet interesse",
          "en": "the question is of subordinate interest"
        }
      ]
    }
  ]
