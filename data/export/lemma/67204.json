  "definitions": [
    {
      "text": "(bearbeidet) smal strekning i terrenget for ferdsel",
      "translation": " (prepared) narrow strip of terrain for travel",
      "examples": [
        {
          "no": "utbedre veien",
          "en": "improve the road"
        },
        {
          "no": "stikke ut, anlegge ny vei",
          "en": "stake out, build a new road"
        },
        {
          "no": "veien mellom Fagernes og Lærdal",
          "en": "the road between Fagernes and Lærdal"
        },
        {
          "no": "trafikkert vei",
          "en": "busy road"
        }
      ]
    },
    {
      "text": "ofte i overført betydning: bevegelse, gang (mot et mål)",
      "translation": "often: movement, progress (towards a goal)",
      "examples": [
        {
          "no": "ha bare tida og veien",
          "en": "have nothing but time"
        },
        {
          "no": "hun er tre måneder på vei",
          "en": "she is three months pregnant"
        },
        {
          "no": "være på vei inn i, ut av politikken",
          "en": "be on the way into, out of politics"
        },
        {
          "no": "være langt på vei enige",
          "en": "be largely in agreement"
        }
      ]
    },
    {
      "text": "retning, lei",
      "translation": "direction, course",
      "examples": [
        {
          "no": "prøve nye veier i undervisningen",
          "en": "try new approaches in teaching"
        },
        {
          "no": "gå veien om departementet med en sak",
          "en": "go through the ministry with a matter"
        },
        {
          "no": "finne veien til fred",
          "en": "find the way to peace"
        },
        {
          "no": "en gate med trafikk begge veier, bare én vei",
          "en": "a street with traffic in both directions, one-way only"
        }
