  "definitions": [
    {
      "text": "lete igjennom og undersøke (sted eller person) for å finne noe som er stjålet, forbudt eller lignende",
      "translation": "to search through and examine (a place or person) to find something stolen or forbidden",
      "examples": []
    },
    {
      "text": "jamfør kroppsvisitere",
      "translation": "to body search",
      "examples": [
        {
          "no": "ransake et hus",
          "en": "search a house"
        },
        {
          "no": "han ble stoppet på gata og ransaket",
          "en": "he was stopped in the street and searched"
        }
      ]
    },
    {
      "text": "i overført betydning: granske nøye",
      "translation": "to examine closely",
      "examples": [
