  "definitions": [
    {
      "text": "nedsette synsevnen ved sterk lyspåvirkning",
      "translation": "impair vision by strong light",
      "examples": [
        {
          "no": "sollyset blendet henne",
          "en": "the sunlight blinded her"
        }
      ]
    },
    {
      "text": "i overført betydning: imponere, bløffe",
      "translation": "impress, bluff",
      "examples": [
        {
          "no": "la seg blende av ytre glans",
          "en": "be dazzled by outward splendor"
        }
      ]
    },
    {
      "text": "avskjerme eller dempe en lyskilde",
      "translation": "shield, dim a light source",
      "examples": [
        {
          "no": "når bilister møter hverandre i mørket, skal de blende",
          "en": "when motorists meet each other in the dark, they must dip their headlights"
        },
        {
          "no": "vinduene ble blendet på grunn av faren for flyangrep",
          "en": "the windows were blacked out because of the danger of air raids"
        }
      ]
    },
    {
      "text": "farge hårspissene på pelsverk",
      "translation": "color the tips of fur",
      "examples": []
    }
  ]
