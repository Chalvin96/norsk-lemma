  "definitions": [
    {
      "text": "trekke pusten dypt inn og slippe den hørbart ut igjen",
      "translation": "to inhale deeply and exhale audibly",
      "examples": [
        {
          "no": "sukke tungt",
          "en": "sigh heavily"
        },
        {
          "no": "sukke og stønne",
          "en": "sigh and groan"
        },
        {
          "no": "sukke lettet",
          "en": "sigh with relief"
        },
        {
          "no": "sukke under åket",
          "en": "sigh under the yoke"
        }
      ]
    },
    {
      "text": "blåse, suse",
      "translation": "to blow, to rustle",
      "examples": [
        {
          "no": "vinden sukket i trekronene",
          "en": "the wind sighed in the treetops"
        }
      ]
    },
    {
      "text": "skvulpe, klukke",
      "translation": "to lap, to gurgle",
      "examples": [
        {
          "no": "det sukket og skvulpet rundt båten",
          "en": "it sighed and splashed around the boat"
        }
      ]
    }
  ]
