  "cross_reference": null,
  "definitions": [
    {
      "text": "bli løs eller fri",
      "translation": "to become loose or free",
      "examples": []
    },
    {
      "text": "få bevege seg fritt",
      "translation": "to be allowed to move freely",
      "examples": [
        {
          "no": "hun slapp ut av karantenen",
          "en": "she got out of quarantine"
        },
        {
          "no": "de slapp fra forfølgeren",
          "en": "they got away from the pursuer"
        },
        {
          "no": "jeg slipper ikke fra hjemme i dag",
          "en": "I can't get away from home today"
        },
        {
          "no": "han prøvde å slippe unna politiet",
          "en": "he tried to get away from the police"
        }
      ]
    },
    {
      "text": "bli fritatt eller spart for",
      "translation": "to be exempted or spared from",
      "examples": []
    },
    {
      "text": "bli kvitt",
      "translation": "to get rid of",
      "examples": [
        {
          "no": "de slapp lett fra ulykken",
          "en": "they got off lightly in the accident"
        },
        {
          "no": "vi slipper å rydde i dag",
          "en": "we don't have to tidy up today"
        },
        {
          "no": "jeg slapp heldigvis å betale full pris",
          "en": "fortunately I didn't have to pay full price"
        },
        {
          "no": "de håper å slippe millitærtjenesten",
          "en": "they hope to avoid military service"
        }
      ]
    },
    {
      "text": "miste eller løsne taket i noe",
      "translation": "to lose grip on something",
      "examples": []
    },
    {
      "text": "la noe eller noen bevege seg fritt",
      "translation": "to let something or someone move freely",
      "examples": [
        {
          "no": "hun slapp koppen i gulvet",
          "en": "she dropped the cup on the floor"
        },
        {
          "no": "han slipper hunden løs",
          "en": "he lets the dog loose"
        },
        {
          "no": "selja slipper barken",
          "en": "the willow is shedding its bark"
        },
        {
          "no": "slipp meg!",
          "en": "let me go!"
        }
      ]
    },
    {
      "text": "la seg gli",
      "translation": "to slide",
      "examples": []
    },
    {
      "text": "falle",
      "translation": "to fall",
      "examples": [
        {
          "no": "slippe seg ned fra en gren",
          "en": "drop down from a branch"
        }
      ]
    },
    {
      "text": "slutte å interessere",
      "translation": "to stop being interesting",
      "examples": []
    },
    {
      "text": "slutte å holde fast ved",
      "translation": "to stop holding onto",
      "examples": [
        {
          "no": "ideen ville ikke slippe meg",
          "en": "the idea would not let go of me"
        },
        {
          "no": "de ville ikke slippe samtaleemnet",
          "en": "they would not let go of the topic of conversation"
        }
      ]
    },
    {
      "text": "bryte av",
      "translation": "to break off",
      "examples": []
    },
    {
      "text": "stanse",
      "translation": "to stop",
      "examples": [
        {
          "no": "vi begynner igjen der vi slapp",
          "en": "we'll start again where we left off"
        }
      ]
    }
  ]
