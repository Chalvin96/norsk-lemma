  "definitions": [
    {
      "text": "yte hjelp, berge, redde",
      "translation": "provide help, save, rescue",
      "examples": [
        {
          "no": "de hjelper hverandre",
          "en": "they help each other"
        },
        {
          "no": "hjelpe til med gårdsarbeidet",
          "en": "help with the farm work"
        },
        {
          "no": "hjelpe folk i havsnød",
          "en": "help people in distress at sea"
        },
        {
          "no": "hovmesteren hjalp gjestene å finne et passende bord",
          "en": "the headwaiter helped the guests find a suitable table"
        }
      ]
    },
    {
      "text": "brukt i utrop",
      "translation": "used in exclamations",
      "examples": [
        {
          "no": "hjelpe og trøste oss!",
          "en": "help and comfort us!"
        },
        {
          "no": "jeg er hjelpe meg helt blakk",
          "en": "help me, I'm completely broke"
        }
      ]
    },
    {
      "text": "ha virkning, nytte, gagne, forslå",
      "translation": "be effective, useful, benefit, serve a purpose",
      "examples": [
        {
          "no": "det hjelper ikke hva du sier",
          "en": "it doesn't help what you say"
        },
        {
          "no": "hva hjelper det med lønnspålegg når prisene går opp tilsvarende?",
          "en": "what good is a pay raise when prices go up correspondingly?"
        },
