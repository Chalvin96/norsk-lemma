  "definitions": [
    {
      "text": "lage krølle",
      "translation": "to make curls",
      "examples": [
        {
          "no": "krølle håret",
          "en": "curl one's hair"
        }
      ]
    },
    {
      "text": "vokse eller falle i krøller",
      "translation": "to grow or fall in curls",
      "examples": [
        {
          "no": "håret krøller seg så fint i nakken",
          "en": "the hair curls so nicely at the nape of the neck"
        }
      ]
    },
    {
      "text": "slå krøll på seg",
      "translation": "to tie oneself in a knot",
      "examples": []
    },
    {
      "text": "bøye i ring eller bue",
      "translation": "to bend into a ring or arc",
      "examples": []
    },
    {
      "text": "krype sammen",
      "translation": "to curl up",
      "examples": [
        {
          "no": "katten krøllet seg sammen ved ovnen",
          "en": "the cat curled up by the stove"
        },
        {
          "no": "krølle kjolen sin",
          "en": "crumple up one's dress"
        },
        {
          "no": "jakka hadde krøllet seg",
          "en": "the jacket had become wrinkled"
        },
        {
          "no": "krølle sammen et papir",
          "en": "crumple up a piece of paper"
        }
      ]
    }
  ]
