  "cross_reference": null,
  "definitions": [
    {
      "text": "mørkt område på den siden av noe som vender bort fra lyskilden",
      "translation": "dark area on the side of something facing away from the light source",
      "examples": [
        {
          "no": "sette seg i skyggen",
          "en": "sit in the shade"
        },
        {
          "no": "stå i skyggen av huset",
          "en": "stand in the shadow of the house"
        },
        {
          "no": "det er 20 °C i skyggen",
          "en": "it is 20 °C in the shade"
        },
        {
          "no": "trærne kastet lange skygger",
          "en": "the trees cast long shadows"
        }
      ]
    },
    {
      "text": "mørkere farget eller skravert parti på maleri eller tegning",
      "translation": "darker colored shaded area in a painting or drawing",
      "examples": [
        {
          "no": "legge skygge på en tegning",
          "en": "add shading to a drawing"
        },
        {
          "no": "fordele lys og skygge",
          "en": "distribute light and shadow"
        }
      ]
    },
    {
      "text": "mørk flekk",
      "translation": "dark spot",
      "examples": [
        {
          "no": "ha blå skygger under øynene",
          "en": "have dark shadows under the eyes"
        }
      ]
    },
    {
      "text": "skjerm på hodeplagg",
      "translation": "brim on a head covering",
      "examples": [
        {
          "no": "en lue med skygge",
          "en": "a cap with a visor"
        }
      ]
    },
    {
      "text": "i overført betydning: antydning, snev",
      "translation": "in a figurative sense: hint, trace",
      "examples": [
        {
          "no": "ikke en skygge av tvil",
          "en": "not a shadow of a doubt"
        },
        {
          "no": "en skygge av et smil",
          "en": "a shadow of a smile"
        }
      ]
    },
    {
      "text": "i overført betydning: alvorlig mine",
      "translation": "in a figurative sense: serious expression",
      "examples": [
        {
          "no": "det la seg en skygge over ansiktet hans",
          "en": "a shadow fell over his face"
        }
      ]
    }
  ]
