  "cross_reference": null,
  "definitions": [
    {
      "text": "det at fugler seiler i lufta uten å bevege vingene, eller at fly flyr uten å bruke motor",
      "translation": "the act of birds soaring in the air without moving their wings, or of planes flying without using their engines",
      "examples": [
        {
          "no": "se en ørn i glideflukt",
          "en": "see an eagle gliding"
        }
      ]
    },
    {
      "text": "i overført betydning: det å stille og ubemerket endre synspunkt eller ståsted",
      "translation": "in a figurative sense: the act of calmly and unnoticedly changing one's viewpoint or stance",
      "examples": [
        {
          "no": "partiet er inne i en glideflukt mot høyre",
          "en": "the party is drifting to the right"
        },
        {
          "no": "presidenten gjør glideflukt i stadig flere saker",
          "en": "the president is shifting position on more and more issues"
        }
      ]
    }
  ]
