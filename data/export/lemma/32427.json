  "cross_reference": null,
  "definitions": [
    {
      "text": "om dyr: bevege seg ved å dra seg fram med kroppen mot underlaget",
      "translation": "for animals: to move by dragging the body along the ground",
      "examples": [
        {
          "no": "ormen krøp tvers over veien",
          "en": "the snake crawled straight across the road"
        }
      ]
    },
    {
      "text": "om menneske: flytte seg på en måte som minner om å krype",
      "translation": "for humans: to move in a way that resembles crawling",
      "examples": []
    },
    {
      "text": "bevege seg på alle fire",
      "translation": "to move on all fours",
      "examples": []
    },
    {
      "text": "krabbe, kravle",
      "translation": "to crawl, to creep",
      "examples": [
        {
          "no": "krype på hender og knær",
          "en": "crawl on hands and knees"
        },
        {
          "no": "krype gjennom vinduet",
          "en": "crawl through the window"
        },
        {
          "no": "jeg krøp tidlig til køys i går",
          "en": "I crawled into bed early yesterday"
        }
      ]
    },
    {
      "text": "bevege seg tungt og sent",
      "translation": "to move slowly and heavily",
      "examples": [
        {
          "no": "lastebilen krøp oppover stigningen",
          "en": "the truck crawled up the incline"
        },
        {
          "no": "temperaturen har krøpet oppover de siste dagene",
          "en": "the temperature has crept upward in recent days"
        }
      ]
    },
    {
      "text": "om plante: vokse langsetter bakken og samtidig slå rot",
      "translation": "for plants: to grow along the ground and simultaneously take root",
      "examples": []
    },
    {
      "text": "trekke seg sammen",
      "translation": "to contract",
      "examples": [
        {
          "no": "sokkene har krøpet i vask",
          "en": "the socks have shrunk in the wash"
        },
        {
          "no": "krype sammen av skrekk",
          "en": "crumple up in fear"
        }
      ]
    },
    {
      "text": "oppføre seg ydmykt",
      "translation": "to behave humbly",
      "examples": [
        {
          "no": "krype for sjefen",
          "en": "crawl to the boss"
        }
      ]
    },
    {
      "text": "ha en ekkel følelse",
      "translation": "to have an unpleasant feeling",
      "examples": [
        {
          "no": "kjenne hvordan det kryper oppover ryggen",
          "en": "feel it creeping up your spine"
        }
      ]
    }
  ]
