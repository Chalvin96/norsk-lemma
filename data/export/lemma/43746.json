  "definitions": [
    {
      "text": "verdi eller pengesum som blir igjen når en trekker alle utgiftene fra inntektene",
      "translation": "value or sum of money remaining when all expenses are deducted from income",
      "examples": [
        {
          "no": "forretningen går med overskudd",
          "en": "the business is running at a profit"
        }
      ]
    },
    {
      "text": "rest når noe er trukket fra eller brukt opp",
      "translation": "remainder when something has been deducted or used up",
      "examples": []
    },
    {
      "text": "forskjell mellom tilgang og avgang",
      "translation": "difference between inflow and outflow",
      "examples": [
        {
          "no": "det var overskudd av menn på festen",
          "en": "there was a surplus of men at the party"
        },
        {
          "no": "overskudd på energi",
          "en": "surplus energy"
        }
      ]
    },
    {
      "text": "krefter, tiltakslyst",
      "translation": "strength, willingness to act",
      "examples": [
