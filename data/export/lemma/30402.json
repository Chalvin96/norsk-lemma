  "definitions": [
    {
      "text": "gi brakende eller knasende lyd",
      "translation": "make a cracking or creaking sound",
      "examples": [
        {
          "no": "isen knaker under henne",
          "en": "the ice creaks under her"
        },
        {
          "no": "trappa knaket under tyngden",
          "en": "the stairs creaked under the weight"
        },
        {
          "no": "det knaket i stive ledd",
          "en": "it creaked in stiff joints"
        }
      ]
    },
    {
      "text": "i overført betydning: vise tegn på at noe kan ta slutt eller bli ødelagt",
      "translation": "in a figurative sense: show signs of ending or being destroyed",
      "examples": [
        {
          "no": "forholdet til ektemannen knaker",
          "en": "the relationship with her husband is creaking"
        }
      ]
    },
    {
      "text": "i overført betydning: vise styrke og framgang",
      "translation": "in a figurative sense: show strength and progress",
      "examples": [
        {
          "no": "bedriften vokser så det knaker",
          "en": "the company is growing like crazy"
        }
      ]
    }
