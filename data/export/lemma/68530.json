  "definitions": [
    {
      "text": "gjøre viftende bevegelser med hånden eller armen, som hilsen eller signal til noen (som er litt lengre vekk)",
      "translation": "make waving movements with the hand or arm, as a greeting or signal to someone (who is a little further away)",
      "examples": [
        {
          "no": "de vinker farvel",
          "en": "they wave goodbye"
        },
        {
          "no": "jeg vinket på en taxi",
          "en": "I waved down a taxi"
        },
        {
          "no": "vinke til noen",
          "en": "wave to someone"
        },
        {
          "no": "vinke noen vekk",
          "en": "wave someone away"
        }
      ]
    },
    {
      "text": "virke dragende",
      "translation": "seem attractive",
      "examples": [
        {
          "no": "ære og vinning vinker i det fjerne",
          "en": "honor and gain beckon in the distance"
        }
      ]
    }
