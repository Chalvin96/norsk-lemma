  "cross_reference": null,
  "definitions": [
    {
      "text": "bøye eller huke seg ned",
      "translation": "to bend down, crouch",
      "examples": [
        {
          "no": "dukke for et slag",
          "en": "duck a blow"
        },
        {
          "no": "dukke seg inn gjennom døren",
          "en": "duck through the door"
        }
      ]
    },
    {
      "text": "duppe ned i eller under vann",
      "translation": "to dip down underwater",
      "examples": [
        {
          "no": "dukke noen under",
          "en": "duck someone under"
        },
        {
          "no": "dukke seg ned i isvannet",
          "en": "duck down into the icy water"
        }
      ]
    },
    {
      "text": "sette grundig på plass, ydmyke",
      "translation": "to put someone firmly in their place, to humiliate",
      "examples": [
        {
          "no": "han ble kraftig dukket",
          "en": "he was soundly put in his place"
        }
      ]
    },
    {
      "text": "gå under vann",
      "translation": "to go underwater",
      "examples": [
        {
          "no": "ubåten dukket",
          "en": "the submarine dived"
        },
        {
          "no": "dukke etter noe",
          "en": "dive for something"
        }
      ]
    }
  ]
