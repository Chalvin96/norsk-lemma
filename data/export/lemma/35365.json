  "cross_reference": null,
  "definitions": [
    {
      "text": "lee forsiktig på noe som sitter fast eller er vanskelig å få på plass",
      "translation": "to gently move something that is stuck or difficult to move",
      "examples": [
        {
          "no": "lirke seg løs",
          "en": "ease oneself free"
        },
        {
          "no": "lirke nøkkelen inn i låsen",
          "en": "ease the key into the lock"
        },
        {
          "no": "hun lirket av seg skoene",
          "en": "she eased off her shoes"
        }
      ]
    },
    {
      "text": "i overført betydning: få fram med list og lempe",
      "translation": "in a figurative sense: to elicit with cunning and persuasion",
      "examples": [
        {
          "no": "lirke og lure",
          "en": "wheedle and cajole"
        },
        {
          "no": "de fikk lirket hemmeligheten ut av ham",
          "en": "they managed to coax the secret out of him"
        }
      ]
    }
  ]
