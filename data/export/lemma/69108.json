  "definitions": [
    {
      "text": "snu innsiden ut",
      "translation": "turn inside out",
      "examples": []
    },
    {
      "text": "vri slik at vrangsiden vender ut",
      "translation": "twist so that the wrong side faces out",
      "examples": [
        {
          "no": "vrenge genseren",
          "en": "turn the sweater inside out"
        },
        {
          "no": "vrenge lommene",
          "en": "turn the pockets inside out"
        },
        {
          "no": "vinden vrengte paraplyen",
          "en": "the wind turned the umbrella inside out"
        },
        {
          "no": "jeg vrenger av meg de våte klærne",
          "en": "I peel off my wet clothes"
        }
      ]
    },
    {
      "text": "vri eller tvinge ut av stilling eller retning",
      "translation": "twist or force out of position or direction",
      "examples": []
    },
    {
      "text": "gjøre om",
      "translation": "change",
      "examples": [
        {
          "no": "han vrengte munnen til et spydig smil",
          "en": "he twisted his mouth into a sarcastic smile"
        },
        {
          "no": "hun vrenger på stemmen",
          "en": "she distorts her voice"
        },
        {
          "no": "sjåføren vrengte bilen inn på gårdsplassen",
          "en": "the driver swung the car into the yard"
        },
        {
          "no": "vrenge gitaren",
          "en": "distort the guitar sound"
        }
      ]
    },
    {
      "text": "(under press) la skjulte deler av (følelses)livet bli synlig for andre",
      "translation": "(under pressure) let hidden parts of (emotional) life become visible to others",
      "examples": [
        {
          "no": "vrenge sjelen sin",
          "en": "lay one's soul bare"
        },
        {
          "no": "artisten fikk hele privatlivet sitt vrengt ut i offentligheten",
          "en": "the artist had his entire private life laid bare in public"
        }
      ]
    },
    {
      "text": "gi en gal tolkning eller et vrengebilde av noe",
      "translation": "give a wrong interpretation or distortion of something",
      "examples": [
        {
          "no": "vri og vrenge på alt som blir sagt",
          "en": "twist and distort everything that is said"
        },
        {
          "no": "vrenge på ordene",
          "en": "twist the words"
        },
        {
          "no": "de vrenger på sannheten",
          "en": "they distort the truth"
        }
      ]
    }
  ]
