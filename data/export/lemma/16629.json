  "definitions": [
    {
      "text": "gjøre mørkere",
      "translation": "to make darker",
      "examples": [
        {
          "no": "skyer formørket himmelen",
          "en": "clouds darkened the sky"
        }
      ]
    },
    {
      "text": "stenge utsikten til en lyskilde",
      "translation": "to block the view of a light source",
      "examples": []
    },
    {
      "text": "skygge for",
      "translation": "to cast a shadow over",
      "examples": [
        {
          "no": "månen formørker sola",
          "en": "the moon darkens the sun"
        }
      ]
    },
    {
      "text": "i overført betydning: gjøre dyster og trist",
      "translation": "in a figurative sense: to make gloomy and sad",
      "examples": [
        {
          "no": "formørke tilværelsen",
          "en": "darken existence"
        },
        {
          "no": "tiden ble formørket av krig",
          "en": "the time was darkened by war"
        },
        {
          "no": "du må ikke la dette formørke livet ditt",
          "en": "you must not let this darken your life"
        }
      ]
