  "definitions": [
    {
      "text": "gå i rute som kommunikasjonsmiddel",
      "translation": "to run a route as a means of communication",
      "examples": [
        {
          "no": "båtene trafikkerer strekningen Oslo–København",
          "en": "the boats operate on the Oslo-Copenhagen route"
        }
      ]
    },
    {
      "text": "drive en rute med kommunikasjonsmidler",
      "translation": "to operate a route with means of communication",
      "examples": [
        {
          "no": "busselskapet trafikkerer veien over fjellet",
          "en": "the bus company operates the road across the mountains"
        }
      ]
    },
    {
      "text": "gå, ferdes eller kjøre i eller på",
      "translation": "to go, travel, or drive on",
      "examples": [
        {
          "no": "lystfartøyer som trafikkerer fjorden",
          "en": "pleasure craft that ply the fjord"
        },
        {
          "no": "sterkt trafikkerte veier",
          "en": "heavily traveled roads"
        }
      ]
    }
