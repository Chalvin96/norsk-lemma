  "definitions": [
    {
      "text": "holde seg i ro",
      "translation": "to remain still",
      "examples": []
    },
    {
      "text": "bie, drøye dryge",
      "translation": "to wait, to linger",
      "examples": [
        {
          "no": "stå og vente",
          "en": "stand and wait"
        },
        {
          "no": "vent og se!",
          "en": "wait and see!"
        },
        {
          "no": "vent litt!",
          "en": "wait a moment!"
        },
        {
          "no": "bare vent – jeg skal nok greie det!",
          "en": "just wait - I'll manage it!"
        }
      ]
    },
    {
      "text": "være klar eller ferdig",
      "translation": "to be ready or finished",
      "examples": [
        {
          "no": "middagen venter",
          "en": "dinner is waiting"
        },
        {
          "no": "hoppe inn i en ventende bil",
          "en": "jump into a waiting car"
        }
      ]
    },
    {
      "text": "regne med (som sannsynlig)",
      "translation": "to expect (as probable)",
      "examples": [
        {
          "no": "vente gjester",
          "en": "expect guests"
        },
        {
          "no": "vente barn",
          "en": "be expecting a child"
        },
        {
          "no": "du kan vente meg klokka sju",
          "en": "you can expect me at seven o'clock"
        },
        {
          "no": "det var ikke annet å vente",
          "en": "it was only to be expected"
        }
      ]
    }
