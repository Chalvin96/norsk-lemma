  "cross_reference": null,
  "definitions": [
    {
      "text": "bevege seg fram og tilbake på samme sted",
      "translation": "to move back and forth in the same place",
      "examples": []
    },
    {
      "text": "sette i gyngende bevegelse",
      "translation": "to set in a rocking motion",
      "examples": []
    },
    {
      "text": "gynge, vogge vugge",
      "translation": "to rock, to sway",
      "examples": [
        {
          "no": "båten rugget",
          "en": "the boat rocked"
        },
        {
          "no": "sitte og rugge i stolen",
          "en": "sit rocking in the chair"
        },
        {
          "no": "han har rugget barnet i søvn",
          "en": "he rocked the child to sleep"
        }
      ]
    },
    {
      "text": "få til å flytte seg",
      "translation": "to cause to move",
      "examples": []
    },
    {
      "text": "rikke, rokke",
      "translation": "to budge, to shift",
      "examples": [
        {
          "no": "rugge en stein",
          "en": "rock a stone"
        }
      ]
    },
    {
      "text": "gå med voggende gange",
      "translation": "to walk with a rolling gait",
      "examples": [
        {
          "no": "han rugget oppover bakken",
          "en": "he lumbered up the hill"
        },
        {
          "no": "hun kom ruggende",
          "en": "she came waddling"
        }
      ]
    }
  ]
