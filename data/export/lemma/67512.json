  "definitions": [
    {
      "text": "ønske velsignelse over",
      "translation": "to wish blessing upon",
      "examples": [
        {
          "no": "paven velsigner folket på Petersplassen første påskedag",
          "en": "the Pope blesses the crowd in St. Peter's Square on Easter Sunday"
        }
      ]
    },
    {
      "text": "takke, prise",
      "translation": "to thank, to praise",
      "examples": [
        {
          "no": "jeg kan ikke nok få velsignet deg for hjelpen",
          "en": "I can't bless you enough for the help"
        },
        {
          "no": "bøndene velsigner regnet",
          "en": "the farmers bless the rain"
        }
      ]
    },
    {
      "text": "la få (som gave)",
      "translation": "",
      "examples": []
    },
    {
      "text": "gi, forære",
      "translation": "",
      "examples": [
        {
          "no": "være velsignet med rike naturressurser",
          "en": "be blessed with rich natural resources"
        },
        {
          "no": "forrige uke velsignet oss med regn og storm",
          "en": "last week blessed us with rain and storm"
        }
      ]
    },
    {
      "text": "brukt som adjektiv: herlig, vidunderlig",
      "translation": "",
      "examples": [
        {
          "no": "ha en velsignet stund",
          "en": "have a blessed moment"
        },
        {
          "no": "et velsignet vær",
          "en": "blessed weather"
        },
        {
          "no": "være velsignet fri for nykker",
          "en": "be blessedly free of whims"
        }
      ]
    }
