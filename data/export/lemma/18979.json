      ]
    },
    {
      "text": "tradisjonell, vanlig, velkjent",
      "translation": "traditional, usual, well-known",
      "examples": [
        {
          "no": "gamle fraser",
          "en": "old phrases"
        },
        {
          "no": "gamle takter",
          "en": "the same old tricks"
        },
        {
