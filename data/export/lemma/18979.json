    },
    {
      "text": "om ting: som har vært til eller vært i bruk lenge",
      "translation": "about things: which has existed or been in use for a long time",
      "examples": []
    },
    {
      "text": "dårlig på grunn av elde",
      "translation": "bad due to age",
      "examples": [
