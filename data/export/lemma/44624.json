  "definitions": [
    {
      "text": "drysse pepper på",
      "translation": "to sprinkle pepper on",
      "examples": []
    },
    {
      "text": "krydre med pepper",
      "translation": "to season with pepper",
      "examples": [
        {
          "no": "salte og pepre maten",
          "en": "salt and pepper the food"
        }
      ]
    },
    {
      "text": "i overført betydning: sette en spiss på",
      "translation": "to add a point to",
      "examples": [
        {
          "no": "han peprer historien med fortellinger fra kongehuset",
          "en": "he peppers the story with tales from the royal family"
        }
      ]
    },
    {
      "text": "skyte mange kuler i en serie",
      "translation": "to shoot many bullets in a series",
      "examples": []
    },
    {
      "text": "sende en skur av noe mot noe eller noen",
      "translation": "to send a shower of something towards something or someone",
      "examples": [
        {
          "no": "flyskroget ble pepret med kuler",
          "en": "the fuselage was peppered with bullets"
        },
        {
          "no": "bli pepret med stein",
          "en": "be peppered with stones"
        },
        {
          "no": "pepre inn mål",
          "en": "pepper in goals"
        }
      ]
    },
    {
      "text": "i overført betydning: sende av gårde en mengde kommentarer, spørsmål eller lignende",
      "translation": "to send off a multitude of comments, questions",
      "examples": [
        {
          "no": "pepre læreren med spørsmål",
          "en": "pepper the teacher with questions"
        },
        {
          "no": "de pepret oss med informasjon",
          "en": "they peppered us with information"
        }
      ]
    }
  ]
