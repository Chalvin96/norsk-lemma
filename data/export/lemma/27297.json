  "definitions": [
    {
      "text": "stenge ute fra omverdenen",
      "translation": "to shut off from the outside world",
      "examples": [
        {
          "no": "den syke måtte isoleres",
          "en": "the sick person had to be isolated"
        },
        {
          "no": "folkene på fjellgarden var isolert hele vinterhalvåret",
          "en": "the people on the mountain farm were isolated all winter"
        }
      ]
    },
    {
      "text": "unngå sosialt samkvem",
      "translation": "to avoid social contact",
      "examples": [
        {
          "no": "innflytterne isolerte seg helt fra de andre i bygda",
          "en": "the newcomers isolated themselves completely from the others in the village"
        }
      ]
    },
    {
      "text": "skille ut og plassere for seg selv",
      "translation": "to separate and place by itself",
      "examples": [
        {
          "no": "isolere smittestoff",
          "en": "isolate infectious agents"
        },
        {
          "no": "et isolert tilfelle",
          "en": "an isolated case"
        }
      ]
    },
    {
      "text": "forsyne med isolasjon",
      "translation": "to supply with insulation",
      "examples": [
        {
          "no": "det gamle huset var dårlig isolert",
          "en": "the old house was poorly insulated"
        },
        {
          "no": "elektriske kabler må isoleres godt",
          "en": "electrical cables must be well insulated"
        }
      ]
    }
