  "cross_reference": null,
  "definitions": [
    {
      "text": "som har stor masse",
      "translation": "having great mass",
      "examples": []
    },
    {
      "text": "fet feit, omfangsrik",
      "translation": "fat, plump, voluminous",
      "examples": [
        {
          "no": "en tykk unge",
          "en": "a fat kid"
        },
        {
          "no": "ha tykke fingre",
          "en": "have thick fingers"
        },
        {
          "no": "magen har blitt tykkere i det siste",
          "en": "my stomach has gotten bigger lately"
        },
        {
          "no": "jeg er blitt litt for tykk, syns jeg",
          "en": "I've gotten a little too fat, I think"
        }
      ]
    },
    {
      "text": "med stor tykkelse tjukkelse",
      "translation": "with great thickness",
      "examples": []
    },
    {
      "text": "med stort tverrmål",
      "translation": "with large cross-section",
      "examples": [
        {
          "no": "isen er mange meter tykk",
          "en": "the ice is many meters thick"
        },
        {
          "no": "huset har tykke vegger",
          "en": "the house has thick walls"
        },
        {
          "no": "støvet lå i tykke lag",
          "en": "the dust lay in thick layers"
        },
        {
          "no": "lese en tykk bok",
          "en": "read a thick book"
        }
      ]
    },
    {
      "text": "som er dekket av enkeltdeler som står nær hverandre",
      "translation": "covered by closely spaced individual parts",
      "examples": [
        {
          "no": "tykt hår",
          "en": "thick hair"
        },
        {
          "no": "gå inn i tykkeste skogen",
          "en": "go into the thickest part of the forest"
        },
        {
          "no": "bo midt i tykke byen",
          "en": "live right in the thick of the city"
        }
      ]
    },
    {
      "text": "som er framstilt av grove og varme materialer",
      "translation": "made of coarse and warm materials",
      "examples": [
        {
          "no": "ta på seg en tykk genser",
          "en": "put on a thick sweater"
        },
        {
          "no": "pakke med seg tykke sokker",
          "en": "pack thick socks"
        }
      ]
    },
    {
      "text": "om væske: som renner sakte",
      "translation": "for liquids: flowing slowly",
      "examples": [
        {
          "no": "tykk olje",
          "en": "thick oil"
        },
        {
          "no": "gjøre sausen tykkere",
          "en": "make the sauce thicker"
        }
      ]
    },
    {
      "text": "om gass eller luft: som er vanskelig å se gjennom",
      "translation": "for gas or air: difficult to see through",
      "examples": [
        {
          "no": "tykk luft",
          "en": "thick air"
        },
        {
          "no": "tykk røyk",
          "en": "thick smoke"
        },
        {
          "no": "tåka var tykk som grøt",
          "en": "the fog was thick as porridge"
        }
      ]
    },
    {
      "text": "om stemme: som skurrer eller låter urent",
      "translation": "for voice: hoarse or impure sounding",
      "examples": [
        {
          "no": "være tykk i målet",
          "en": "be thick-tongued"
        },
        {
          "no": "stemmen hans var tykk av gråt",
          "en": "his voice was thick with tears"
        }
      ]
    },
    {
      "text": "om talemål: utpreget utprega, folkelig",
      "translation": "for speech: pronounced, colloquial",
      "examples": [
        {
          "no": "prate en tykk dialekt",
          "en": "speak a thick dialect"
        },
        {
          "no": "ha en tykk aksent",
          "en": "have a thick accent"
        }
      ]
    },
    {
      "text": "om påstand, historie, unnskyldning eller lignende: som en må være naiv eller dum for å tro på",
      "translation": "for an assertion, story, excuse, or similar: so naive or foolish as to be unbelievable",
      "examples": [
        {
          "no": "nei, den er for tjukk!",
          "en": "no, that's too far-fetched!"
        }
      ]
    }
  ]
