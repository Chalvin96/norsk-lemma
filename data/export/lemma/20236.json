  "definitions": [
    {
      "text": "bevege seg mest mulig friksjonsløst",
      "translation": "to move with minimal friction",
      "examples": []
    },
    {
      "text": "miste festet, skli",
      "translation": "to lose grip, to slip",
      "examples": [
        {
          "no": "skiene glir godt",
          "en": "the skis glide well"
        },
        {
          "no": "gli på isen",
          "en": "slip on the ice"
        },
        {
          "no": "gli ut av hendene på en",
          "en": "slip out of one's hands"
        },
        {
          "no": "sjalet gled ned fra skuldrene",
          "en": "the shawl slipped down from her shoulders"
        }
      ]
    },
    {
      "text": "bevege seg jevnt og stille",
      "translation": "to move smoothly and quietly",
      "examples": []
    },
    {
      "text": "skride, sige",
      "translation": "to glide, to drift",
      "examples": [
        {
          "no": "båten glir gjennom vannet",
          "en": "the boat glides through the water"
        },
        {
          "no": "blikket gled over klassen",
          "en": "his gaze swept over the class"
        },
        {
          "no": "maten gled ned",
          "en": "the food went down easily"
        },
        {
          "no": "grunnen gled ut",
          "en": "the ground gave way"
        }
      ]
    },
    {
      "text": "i overført betydning: flytte eller utvikle seg jevnt",
      "translation": "in a figurative sense: to move or develop smoothly",
      "examples": [
        {
          "no": "dagene glir over i hverandre",
          "en": "the days merge into one another"
        },
        {
          "no": "han gled naturlig inn i gruppa",
          "en": "he slipped naturally into the group"
        }
      ]
    },
    {
      "text": "fungere godt",
      "translation": "to function well",
      "examples": []
    },
    {
      "text": "gå lett",
      "translation": "to go easily",
      "examples": [
        {
          "no": "få samtalen til å gli",
          "en": "get the conversation to flow"
        },
        {
          "no": "samarbeidet glir godt",
          "en": "the cooperation is going smoothly"
        }
      ]
    }
