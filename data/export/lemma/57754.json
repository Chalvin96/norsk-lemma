  "definitions": [
    {
      "text": "berøre lett, særlig med hånden",
      "translation": "to touch lightly, especially with the hand",
      "examples": []
    },
    {
      "text": "jamfør strykende",
      "translation": "",
      "examples": [
        {
          "no": "stryke noen over håret",
          "en": "stroke someone over the hair"
        },
        {
          "no": "han stryker seg over munnen med håndbaken",
          "en": "he runs the back of his hand across his mouth"
        },
        {
          "no": "katten strøk seg rundt beina mine",
          "en": "the cat rubbed itself around my legs"
        }
      ]
    },
    {
      "text": "glatte med strykejern",
      "translation": "to iron, to press with an iron",
      "examples": [
        {
          "no": "stryke skjorter",
          "en": "iron shirts"
        }
      ]
    },
    {
      "text": "streke over",
      "translation": "to cross out",
      "examples": []
    },
    {
      "text": "utslette, fjerne",
      "translation": "to erase, to remove",
      "examples": [
        {
          "no": "stryke ut og skrive på nytt",
          "en": "cross out and write again"
        },
        {
          "no": "hele kapitalen var strøket",
          "en": "the entire capital had been wiped out"
        },
        {
          "no": "sinnet var som strøket av henne",
          "en": "the anger seemed to have been wiped from her"
        }
      ]
    },
    {
      "text": "la utgå",
      "translation": "to omit, to leave out",
      "examples": []
    },
    {
      "text": "sløyfe",
      "translation": "to cancel, to delete",
      "examples": [
        {
          "no": "bli strøket som medlem",
          "en": "be struck off as a member"
        },
        {
          "no": "stryke seg av lista",
          "en": "take oneself off the list"
        },
        {
          "no": "stryke av seg lua",
          "en": "take off one's hat"
        }
      ]
    },
    {
      "text": "føre på i et tynt lag",
      "translation": "to apply in a thin layer",
      "examples": [
        {
          "no": "stryke på maling",
          "en": "apply paint"
        }
      ]
    },
    {
      "text": "føre bue over strengene på strykeinstrument",
      "translation": "to draw a bow across the strings of a string instrument",
      "examples": [
        {
          "no": "han stryker så mykt og fint på fela",
          "en": "he draws the bow across the fiddle so softly and beautifully"
        }
      ]
    },
    {
      "text": "ikke (la) bestå",
      "translation": "to fail (an exam), not to pass",
      "examples": [
        {
          "no": "stryke en kandidat til eksamen",
          "en": "fail a candidate in an exam"
        },
        {
          "no": "han strøk i matte",
          "en": "he failed math"
        }
      ]
    },
    {
      "text": "presse rogn og melke ut av fisk",
      "translation": "to strip roe and milt from fish",
      "examples": [
        {
          "no": "stryke laksen",
          "en": "strip the salmon"
        }
      ]
    },
    {
      "text": "minske (seil)",
      "translation": "to reef (sails)",
      "examples": []
    },
    {
      "text": "jamfør [berge|stryke|reve] seil",
      "translation": "to lower or furl sails",
      "examples": []
    },
    {
      "text": "fare raskt",
