    {
      "text": "redd, veik og feig person",
      "translation": "timid, weak, and cowardly person",
      "examples": [
        {
          "no": "jeg trodde ikke du var en slik stakkar",
          "en": "I didn't think you were such a coward"
        }
      ]
    },
    {
      "text": "brukt i omtale eller tiltale for å vise medfølelse eller ømhet",
      "translation": "used in reference or address to show compassion or tenderness",
      "examples": [
        {
