  "definitions": [
    {
      "text": "bevege, flytte, rokke",
      "translation": "to move, shift, budge",
      "examples": [
        {
          "no": "det var umulig å rikke lasset",
          "en": "it was impossible to budge the load"
        },
        {
          "no": "sleden rikket seg ikke",
          "en": "the sled didn't budge"
        },
        {
          "no": "nåla på vekta har ikke rikket på seg",
          "en": "the needle on the scale hasn't budged"
        }
      ]
    },
    {
      "text": "i overført betydning: få til å endre mening",
      "translation": "figuratively: to make someone change their mind",
      "examples": [
        {
          "no": "når han først har bestemt seg, er han ikke til å rikke",
          "en": "once he's made up his mind, he can't be moved"
        },
        {
          "no": "ingen av partene har rikket på seg",
          "en": "neither party has budged"
        }
      ]
    }
  ]
