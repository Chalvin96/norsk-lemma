  "definitions": [
    {
      "text": "sette i bevegelse om en akse",
      "translation": "to set in motion around an axis",
      "examples": [
        {
          "no": "dreie et hjul",
          "en": "turn a wheel"
        },
        {
          "no": "dreie på hodet",
          "en": "turn your head"
        }
      ]
    },
    {
      "text": "ta en ny retning",
      "translation": "to take a new direction",
      "examples": [
        {
          "no": "vinden dreier",
          "en": "the wind is shifting"
        },
        {
          "no": "dreie til venstre",
          "en": "turn left"
        },
        {
          "no": "dreie inn på en sidevei",
          "en": "turn onto a side road"
        },
        {
          "no": "dreie samtalen inn på et nytt tema",
          "en": "turn the conversation to a new topic"
        }
      ]
    },
    {
      "text": "forme med dreiebenk",
      "translation": "to shape on a lathe",
      "examples": [
        {
          "no": "dreie beina til en stol",
          "en": "turn the legs of a chair"
        }
      ]
    },
    {
      "text": "forme, for eksempel leirgods, ved hjelp av dreieskive",
      "translation": "to shape clay or pottery using a potter's wheel",
      "examples": []
    }
  ]
