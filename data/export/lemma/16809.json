  "cross_reference": null,
  "definitions": [
    {
      "text": "få til å komme senere enn planlagt",
      "translation": "to cause to come later than planned",
      "examples": [
        {
          "no": "være litt forsinket til møtet",
          "en": "be a little late for the meeting"
        },
        {
          "no": "toget er en time forsinket",
          "en": "the train is an hour late"
        },
        {
          "no": "forsinke planene om utbygging",
          "en": "delay the expansion plans"
        },
        {
          "no": "forsinke fredsprosessen",
          "en": "delay the peace process"
        }
      ]
    },
    {
      "text": "få til å bevege seg eller jobbe tregere",
      "translation": "to cause to move or work more slowly",
      "examples": []
    },
    {
      "text": "sinke, trenere",
      "translation": "to slow down, hinder",
      "examples": [
        {
          "no": "det voldsomme snøfallet forsinket oss",
          "en": "the heavy snowfall delayed us"
        },
        {
          "no": "bli forsinket av motorstopp",
          "en": "be delayed by engine trouble"
        },
        {
          "no": "være forsinket av vonde bein",
          "en": "be delayed by sore legs"
        }
      ]
    }
  ]
