  "definitions": [
    {
      "text": "(påbud om) kjøring i bare én retning",
      "translation": "(order for) driving in only one direction",
      "examples": [
        {
          "no": "veien skal utvides fra enveiskjøring til toveis trafikk",
          "en": "the road is to be expanded from one-way to two-way traffic"
        },
        {
          "no": "politiet stoppet en bil som kjørte mot enveiskjøringen",
          "en": "the police stopped a car that was driving the wrong way on a one-way street"
        },
        {
          "no": "innføre enveiskjøring",
          "en": "introduce one-way traffic"
        }
      ]
    },
    {
      "text": "i overført betydning: noe som går bare én vei, særlig om overmakt fra det ene laget i fotball eller lignende",
      "translation": "in a figurative sense: something that goes only one way, especially regarding dominance by one team in football or similar",
      "examples": [
        {
          "no": "det var enveiskjøring fra start til slutt",
          "en": "it was one-way traffic from start to finish"
        }
      ]
    }
