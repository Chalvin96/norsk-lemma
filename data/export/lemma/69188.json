  "definitions": [
    {
      "text": "fastsette en viss (økonomisk) verdi",
      "translation": "determine a certain (economic) value",
      "examples": [
        {
          "no": "verdien på bygget ble vurdert til 17 millioner",
          "en": "the value of the building was assessed at 17 million"
        }
      ]
    },
    {
      "text": "gjøre et (omtrentlig) overslag over størrelsen, omfanget eller kvaliteten av noe",
      "translation": "make an (approximate) estimate of the size, scope, or quality of something",
      "examples": [
        {
          "no": "vurdere avstanden ned til sjøen",
          "en": "estimate the distance down to the sea"
        }
      ]
    },
    {
      "text": "tillegge noe eller noen en bestemt verdi",
      "translation": "attribute a specific value to something or someone",
      "examples": []
    },
    {
      "text": "verdsette",
      "translation": "value",
      "examples": [
        {
          "no": "vurdere en innsats høyt",
          "en": "value an effort highly"
        },
        {
          "no": "bli vurdert i forhold til de andre",
          "en": "be assessed in relation to the others"
        }
      ]
    },
    {
      "text": "gjøre seg opp en mening om et forhold, en tilstand, en hendelse, en utvikling eller lignende",
      "translation": "form an opinion about a situation, condition, event, development",
      "examples": []
    },
    {
      "text": "bedømme",
      "translation": "judge",
      "examples": [
        {
          "no": "vurdere en sak på fritt grunnlag",
          "en": "consider a case on an independent basis"
        },
        {
          "no": "vurdere behovet i framtiden",
          "en": "assess the need in the future"
        }
      ]
    },
    {
      "text": "tenke på (å gjøre noe)",
      "translation": "consider (doing something)",
      "examples": []
    },
    {
      "text": "veie for og imot",
      "translation": "weigh pros and cons",
      "examples": [
        {
          "no": "nye tiltak må vurderes",
          "en": "new measures must be considered"
        },
        {
          "no": "vi vurderer å selge huset",
          "en": "we are considering selling the house"
        }
      ]
    }
