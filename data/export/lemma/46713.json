    {
      "text": "granske noe, for eksempel for å finne ut hvilke egenskaper det har",
      "translation": "examine something to find out its properties",
      "examples": []
    },
    {
      "text": "undersøke, kontrollere, teste",
      "translation": "investigate, check, test",
      "examples": [
        {
          "no": "de prøvde stoffets motstandsdyktighet mot kjemikalier",
          "en": "they tested the material's resistance to chemicals"
        },
        {
