    },
    {
      "text": "øve inn",
      "translation": "rehearse",
      "examples": []
    },
    {
      "text": "framføre på prøve",
      "translation": "perform a trial run",
      "examples": [
        {
          "no": "teateret prøver nå på en ny komedie",
          "en": "the theater is now rehearsing a new comedy"
