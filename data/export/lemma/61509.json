  "definitions": [
    {
      "text": "ha den høyeste eller beste rangeringen",
      "translation": "to have the highest or best ranking",
      "examples": [
        {
          "no": "etter siste serieomgang topper Brann tabellen",
          "en": "after the latest round, Brann tops the table"
        },
        {
          "no": "desember topper listen når det er flest branner i landet",
          "en": "December tops the list for the highest number of fires in the country"
        },
        {
          "no": "han toppet listen over de rikeste i landet",
          "en": "he topped the list of the richest people in the country"
        }
      ]
    },
    {
      "text": "overgå, slå",
      "translation": "to surpass, to beat",
      "examples": []
    },
    {
      "text": "være bedre enn",
      "translation": "to be better than",
      "examples": [
        {
          "no": "denne bragden kan vi vanskelig toppe",
          "en": "we can hardly top this feat"
        }
      ]
    },
    {
      "text": "lage en topp på",
      "translation": "to make a top on",
      "examples": []
    },
    {
      "text": "plassere øverst",
      "translation": "to place at the top",
      "examples": [
        {
          "no": "topp kaken med friske bær",
          "en": "top the cake with fresh berries"
        },
        {
          "no": "salaten var toppet med valnøtter",
          "en": "the salad was topped with walnuts"
        }
      ]
    },
    {
      "text": "lage eller utvikle topp eller aks",
      "translation": "to form or develop a top or shoot",
      "examples": [
        {
          "no": "treet topper seg",
          "en": "the tree is developing a top"
        },
        {
          "no": "knip av de øverste skuddene slik at planten topper seg bedre",
          "en": "pinch off the top shoots so that the plant will branch better at the top"
        }
      ]
    },
    {
      "text": "fjerne eller hogge toppen av",
      "translation": "to remove or cut off the top of",
      "examples": [
        {
          "no": "toppe et tre",
          "en": "top a tree"
        }
      ]
    }
  ]
