  "definitions": [
    {
      "text": "reim eller lenke som binder sammen halsbåndene på hunder",
      "translation": "strap or chain that binds together the collars of dogs",
      "examples": [
        {
          "no": "gå med slakt kobbel",
          "en": "walk with a loose coupling leash"
        }
      ]
    },
    {
      "text": "par eller flokk av hunder som er bundet sammen med kobbel koppel",
      "translation": "pair or pack of dogs tied together with a leash",
      "examples": []
    },
    {
      "text": "i overført betydning: gruppe, gjeng, klikk",
      "translation": "group, gang, clique",
      "examples": [
        {
          "no": "hyre inn et kobbel av advokater",
          "en": "hire a pack of lawyers"
        },
        {
          "no": "et kobbel med pressefolk",
          "en": "a pack of press people"
        }
