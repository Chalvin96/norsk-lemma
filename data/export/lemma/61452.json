  "definitions": [
    {
      "text": "rom eller plass som det ikke er noen eller noe på, eller som ikke er utnyttet eller fylt",
      "translation": "space or place that is empty or not utilized",
      "examples": [
        {
          "no": "et isolerende tomrom mellom veggene",
          "en": "an insulating void between the walls"
        },
        {
          "no": "det er et tomrom midt på raden",
          "en": "there is a gap in the middle of the row"
        }
      ]
    },
    {
      "text": "luke, lakune",
