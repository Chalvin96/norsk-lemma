    },
    {
      "text": "i overført betydning: være full av liv og aktivitet",
      "translation": "figurative: be full of life and activity",
      "examples": [
        {
          "no": "byen syder av aktivitet",
          "en": "the city is buzzing with activity"
        }
      ]
    },
    {
      "text": "gi fra seg en susende eller fresende lyd som når noe koker",
      "translation": "make a rushing or hissing sound like something boiling",
