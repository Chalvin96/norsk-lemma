  "definitions": [
    {
      "text": "tidsrom som faller sammen med nåtiden eller med levetiden til en person, en gruppe eller et fenomen",
      "translation": "a period of time that coincides with the present or with the lifetime of a person, group, or phenomenon",
      "examples": [
        {
          "no": "mange store kunstnere ble lite aktet i sin samtid",
          "en": "many great artists were little esteemed in their own time"
        }
      ]
    },
    {
      "text": "folk som lever (eller levde) på samme tid",
      "translation": "people who live (lived) at the same time",
      "examples": [
        {
          "no": "samtiden foraktet henne",
          "en": "her contemporaries despised her"
        }
      ]
    }
  ]
