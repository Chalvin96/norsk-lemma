  "definitions": [
    {
      "text": "brukt i eiendoms- og tilhørighetsforhold for å vise tilbake til subjektet i setningen når det står i tredje person entall eller flertall",
      "translation": "used in possessive and belonging relationships to refer back to the subject of the sentence when it is in the third person",
      "examples": [
        {
          "no": "hun mistet sekken sin",
          "en": "she lost her backpack"
        },
        {
          "no": "han forstuet beinet sitt",
          "en": "he sprained his leg"
        },
        {
          "no": "de tok pengene sine",
          "en": "they took their money"
        },
        {
          "no": "de har sitt å stri med",
          "en": "they have enough to struggle with"
        }
      ]
    },
    {
      "text": "brukt foran tall for å uttrykke at mengden er omtrentlig eller at den er stor",
      "translation": "used before numbers to express that the quantity is approximate or large",
      "examples": [
        {
          "no": "veie sine 100 kg",
          "en": "weigh a good 100 kg"
        },
        {
          "no": "turen tok sine seks timer",
          "en": "the trip took a good six hours"
        }
      ]
    },
    {
      "text": "brukt trykklett i utrop for å uttrykke at noen er flink til noe",
      "translation": "used unstressed in exclamations to express that someone is good at something",
      "examples": [
        {
          "no": "det var jenta si!",
          "en": "now that's some girl!"
        },
        {
          "no": "det er gutten sin som vet hva han vil!",
          "en": "now that's a boy who knows what he wants!"
        }
      ]
    },
    {
      "text": "brukt trykklett etter pronomen, substantiv eller nomenfrase for å uttrykke eiendoms- og tilhørighetsforhold",
      "translation": "used unstressed after pronouns, nouns, or noun phrases to express possessive and belonging relationships",
      "examples": [
        {
          "no": "hvem sin hatt er det?",
          "en": "whose hat is it?"
        },
        {
          "no": "det er far sin",
          "en": "it is father's"
        },
        {
          "no": "jeg kjenner godt Rud sine",
          "en": "I know Rud's family well"
        }
      ]
    }
  ]
