  "definitions": [
    {
      "text": "person som stjeler eller har stjålet noe",
      "translation": "a person who steals or has stolen something",
      "examples": [
        {
          "no": "tyven kom seg unna med smykker verdt flere hundre tusen kroner",
          "en": "the thief got away with jewelry worth several hundred thousand kroner"
        },
        {
          "no": "tyv tror at hver mann stjeler",
          "en": "a thief believes every man steals"
        }
      ]
    },
    {
      "text": "stykke av brent lysveke som får lyset til å renne",
      "translation": "a piece of burnt candle wick that causes wax to drip",
