  "definitions": [
    {
      "text": "presse noe inn i eller mot noe",
      "translation": "to be oppressive",
      "examples": []
    },
    {
      "text": "jamfør trykkende",
      "translation": "",
      "examples": [
        {
          "no": "hun trykker hånden hans",
          "en": "she squeezes his hand"
        },
        {
          "no": "trykke på knappen",
          "en": "press the button"
        },
        {
          "no": "trykke hardt på bremsen",
          "en": "press hard on the brake"
        },
        {
          "no": "fronten på bilen er trykket inn",
          "en": "the front of the car is pushed in"
        }
      ]
    },
    {
      "text": "være avventende og føle seg pinlig berørt",
      "translation": "to be hesitant and feel embarrassed",
      "examples": []
    },
    {
      "text": "jamfør trykkende og trykket trykt",
      "translation": "to be oppressive and feel pressured",
      "examples": [
        {
          "no": "sitte og trykke en hel kveld",
          "en": "sit there moping all evening"
        }
      ]
    },
    {
      "text": "være i en vanskelig situasjon",
      "translation": "to be in a difficult situation",
      "examples": [
        {
          "no": "vi hjelper hverandre der det trykker",
          "en": "we help each other where the shoe pinches"
        }
      ]
    },
    {
      "text": "om visse småvilt og fuglar: ligge urørlig for ikke å bli sett",
      "translation": "for certain small game and birds: to lie still to avoid being seen",
      "examples": [
        {
          "no": "haren trykte",
          "en": "the hare lay still"
        },
        {
          "no": "rypa trykker og er vanskelig å finne",
          "en": "the ptarmigan lies low and is hard to find"
        }
