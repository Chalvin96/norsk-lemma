  "cross_reference": null,
  "definitions": [
    {
      "text": "slå håndflatene mot hverandre flere ganger",
      "translation": "to strike the palms of the hands together repeatedly",
      "examples": [
        {
          "no": "publikum klappet og klappet",
          "en": "the audience kept clapping and clapping"
        },
        {
          "no": "sangeren ble klappet inn igjen på scenen",
          "en": "the singer was clapped back onto the stage"
        }
      ]
    },
    {
      "text": "slå flater mot hverandre",
      "translation": "to strike surfaces against each other",
      "examples": []
    },
    {
      "text": "slå sammen",
      "translation": "to fold together",
      "examples": [
        {
          "no": "klappe sammen boka",
          "en": "snap the book shut"
        },
        {
          "no": "klappe snøen av skiene",
          "en": "clap the snow off the skis"
        },
        {
          "no": "klapp igjen kjeften!",
          "en": "shut your mouth!"
        }
      ]
    },
    {
      "text": "jevne og banke til",
      "translation": "to pat down and firm",
      "examples": [
        {
          "no": "klappe til jorda rundt en plante",
          "en": "pat down the soil around a plant"
        }
      ]
    },
    {
      "text": "slå lett",
      "translation": "to strike lightly",
      "examples": []
    },
    {
      "text": "stryke mildt",
      "translation": "to stroke gently",
      "examples": [
        {
          "no": "klappe på skulderen",
          "en": "pat on the shoulder"
        },
        {
          "no": "klappe noen kjærlig på kinnet",
          "en": "gently pat someone on the cheek"
        },
        {
          "no": "klappe hunden",
          "en": "pet the dog"
        }
      ]
    },
    {
      "text": "om fartøy: legge til",
      "translation": "for a vessel: to dock",
      "examples": [
        {
          "no": "båten klappet til kai",
          "en": "the boat pulled in to the quay"
        }
      ]
    },
    {
      "text": "om hjerte: slå urolig",
      "translation": "for a heart: to beat irregularly",
      "examples": []
    }
  ]
