        {
          "no": "naboen maler gjerdet grønt",
          "en": "the neighbor is painting the fence green"
        }
      ]
    },
    {
      "text": "lage et maleri",
      "translation": "create a painting",
      "examples": [
        {
          "no": "male landskapsbilder",
          "en": "paint landscapes"
        },
        {
          "no": "Tidemand har malt ‘Haugianerne’",
          "en": "Tidemand painted ‘The Haugeans’"
        }
      ]
    },
    {
      "text": "i overført betydning: framstille, uttrykke",
      "translation": "in a figurative sense: portray, express",
      "examples": [
        {
          "no": "overraskelsen stod malt i ansiktet hennes",
          "en": "the surprise was written all over her face"
        },
        {
          "no": "han maler situasjonen temmelig svart",
          "en": "he paints the situation rather black"
        }
