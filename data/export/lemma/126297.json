    {
      "text": "det å være typisk eller karakteristisk for noe eller noen",
      "translation": "the state of being typical or characteristic of something or someone",
      "examples": [
        {
          "no": "sjøboden innfrir kravet til representativitet for kulturen i distriktet",
          "en": "the boathouse meets the requirement of being representative of the culture in the district"
        }
