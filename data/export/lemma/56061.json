  "definitions": [
    {
      "text": "blinke, glitre, funkle",
      "translation": "blink, glitter, sparkle",
      "examples": [
        {
          "no": "sola spilte i snøkrystallene",
          "en": "the sun sparkled in the snow crystals"
        }
      ]
    },
    {
      "text": "drive med eller delta i lagspill eller lignende",
      "translation": "participate in or play a team game",
      "examples": [
        {
          "no": "spille fotball",
          "en": "play soccer"
        },
        {
          "no": "de spilte mot et utenlandsk lag",
          "en": "they played against a foreign team"
        },
        {
          "no": "vi spiller bra om dagen",
          "en": "we're playing well these days"
        },
        {
          "no": "laget har spilt tre hjemmekamper på rad",
          "en": "the team has played three home games in a row"
        }
      ]
    },
    {
      "text": "delta i spill med kort, terninger eller lignende",
      "translation": "participate in games with cards, dice, or similar",
      "examples": [
        {
          "no": "spille bridge",
          "en": "play bridge"
        }
      ]
    },
    {
      "text": "satse penger",
      "translation": "bet money",
