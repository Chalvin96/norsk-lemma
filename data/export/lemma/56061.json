    },
    {
      "text": "vedde",
      "translation": "wager",
      "examples": [
        {
          "no": "spille på travbanen",
          "en": "bet at the racetrack"
        },
        {
          "no": "ha noen kroner å spille for",
          "en": "have a few kroner to gamble for"
        }
      ]
    },
    {
      "text": "frambringe musikk",
      "translation": "produce music",
      "examples": [
        {
          "no": "de spilte en sonate",
          "en": "they played a sonata"
