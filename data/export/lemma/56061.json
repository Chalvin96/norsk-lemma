        {
          "no": "hun spiller på fiolin",
          "en": "she plays the violin"
        },
        {
          "no": "spille i korps",
          "en": "play in a band"
        }
      ]
    },
    {
      "text": "utføre en teaterrolle, filmrolle eller lignende",
      "translation": "perform a theater role, film role, or similar",
      "examples": []
    },
    {
      "text": "oppføre",
      "translation": "perform",
      "examples": [
        {
          "no": "spille revy",
