    {
      "text": "person som arbeider hardt uten å få tilstrekkelig lønn eller kompensasjon for det",
      "translation": "person who works hard without receiving sufficient pay or compensation",
      "examples": []
    },
    {
      "text": "undertrykt arbeider",
      "translation": "oppressed worker",
      "examples": [
