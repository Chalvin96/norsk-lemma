  "definitions": [
    {
      "text": "påføre skade (slik at noe blir ubrukelig)",
      "translation": "to cause damage (so that something becomes unusable)",
      "examples": []
    },
    {
      "text": "skade, rasere",
      "translation": "damage, wreck",
      "examples": [
        {
          "no": "klimaendringer ødelegger avlinger",
          "en": "climate change is destroying crops"
        },
        {
          "no": "ungene har ødelagt lekene sine",
          "en": "the kids have ruined their toys"
        },
        {
          "no": "jeg ødela visst laderen til mobilen",
          "en": "I think I broke the phone charger"
        },
        {
          "no": "en ødeleggende krig",
          "en": "a devastating war"
        }
      ]
    },
    {
      "text": "påføre psykisk skade",
      "translation": "to cause psychological damage",
      "examples": [
        {
          "no": "hun fikk en oppdragelse som ødela henne",
          "en": "she had an upbringing that damaged her"
        }
      ]
    },
    {
      "text": "gjøre ende på (noe verdifullt)",
      "translation": "to put an end to (something valuable)",
      "examples": [
        {
          "no": "være engstelig for å ødelegge vennskapet",
          "en": "be afraid of ruining the friendship"
        },
        {
          "no": "de havnet i fengsel og fikk ødelagt sitt gode navn og rykte",
          "en": "they ended up in prison and had their good name and reputation ruined"
        },
        {
          "no": "de ødela for hverandre",
          "en": "they ruined things for each other"
        }
      ]
    }
  ]
