  "definitions": [
    {
      "text": "periode der en mister retten til å kjøre motoriserte kjøretøy",
      "translation": "period during which one loses the right to drive motorized vehicles",
      "examples": [
        {
          "no": "sjåføren ble idømt en sperrefrist på to år før han kunne få førerkortet tilbake",
          "en": "the driver was given a two-year disqualification period before he could get his driver's license back"
        }
      ]
    },
    {
      "text": "tidligste tidspunkt da en nyhet kan offentliggjøres, fastsatt av den kunngjørende",
      "translation": "earliest time a news item can be published, set by the announcer",
      "examples": [
        {
          "no": "flere aviser brøt sperrefristen for å komme med tall fra statsbudsjettet",
          "en": "several newspapers broke the embargo in order to publish figures from the state budget"
        }
      ]
