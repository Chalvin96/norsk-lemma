  "definitions": [
    {
      "text": "benk til å slakte på eller dele opp slakt på",
      "translation": "bench for slaughtering or butchering",
      "examples": [
        {
          "no": "en slakterbenk i rustfritt stål",
          "en": "a stainless steel butcher's block"
        }
      ]
    },
    {
      "text": "i overført betydning: sted noen blir sendt for å drepes",
      "translation": "place where someone is sent to be killed",
      "examples": [
        {
          "no": "vi fører unge mennesker rett til slakterbenken",
          "en": "we are leading young people straight to the slaughterhouse"
        }
      ]
    },
    {
      "text": "i overført betydning: det at noe blir (raskt og brutalt) ødelagt, avsluttet eller lignende",
      "translation": "the act of something being (quickly and brutally) destroyed or ended",
      "examples": [
        {
          "no": "avtalen ble lagt på slakterbenken",
          "en": "the agreement was put on the chopping block"
        }
