  "definitions": [
    {
      "text": "knitre, sprake (og sprute) ved steking, brenning eller lignende",
      "translation": "crackle, sputter (and spit) when frying, burning",
      "examples": [
        {
          "no": "fettet freste i panna",
          "en": "the fat sizzled in the pan"
        }
      ]
    },
    {
      "text": "steke raskt ved sterk varme",
      "translation": "fry quickly over high heat",
      "examples": [
        {
          "no": "fres grønnsakene i olje",
          "en": "saute the vegetables in oil"
        }
      ]
    },
    {
      "text": "om dyr eller menneske: gi fra seg en vislende lyd",
      "translation": "of animals or humans: make a hissing sound",
      "examples": []
    },
    {
      "text": "hvese, frøse",
      "translation": "hiss, freeze",
      "examples": [
        {
          "no": "katten freste",
          "en": "the cat hissed"
        },
        {
          "no": "frese av sinne",
          "en": "hiss with anger"
        },
        {
          "no": "‘hold kjeft!’ freste han",
          "en": "'shut up!' he hissed"
        }
      ]
    },
    {
      "text": "dure, suse (av gårde)",
      "translation": "whiz, zoom (away)",
      "examples": [
        {
          "no": "frese forbi",
          "en": "speed past"
        },
        {
          "no": "frese etter veien",
          "en": "speed down the road"
        }
      ]
    }
  ]
