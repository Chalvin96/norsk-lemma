  "cross_reference": null,
  "definitions": [
    {
      "text": "som når et langt stykke oppover (i vertikal retning)",
      "translation": "reaching far upwards (in a vertical direction)",
      "examples": []
    },
    {
      "text": "som har stor høyde høgde",
      "translation": "having great height",
      "examples": [
        {
          "no": "et høyt gjerde",
          "en": "a tall fence"
        },
        {
          "no": "høye bølger",
          "en": "high waves"
        },
        {
          "no": "han er høyere enn henne",
          "en": "he is taller than her"
        },
        {
          "no": "verdens høyeste fjell",
          "en": "the world's highest mountain"
        }
      ]
    },
    {
      "text": "som er langt oppe, i stor vertikal avstand oppover (sett eller regnet fra et visst nivå)",
      "translation": "located far up, at a great vertical distance upwards (seen or calculated from a certain level)",
      "examples": [
        {
          "no": "et høyt punkt",
          "en": "a high point"
        },
        {
          "no": "sola står høyt på himmelen",
          "en": "the sun is high in the sky"
        },
        {
          "no": "høyt oppe på veggen",
          "en": "high up on the wall"
        },
        {
          "no": "høyt henger de og sure er de, sa reven om rognebærene",
          "en": "they hang high and are sour, said the fox about the rowanberries"
        }
      ]
    },
    {
      "text": "som ligger langt oppe på en tenkt eller eksisterende skala",
      "translation": "located far up on an imagined or existing scale",
      "examples": []
    },
    {
      "text": "tallmessig stor eller betydelig",
      "translation": "numerically large or significant",
      "examples": [
        {
          "no": "høy temperatur",
          "en": "high temperature"
        },
        {
          "no": "høy kvalitet",
          "en": "high quality"
        },
        {
          "no": "høye utgifter",
          "en": "high expenses"
        },
        {
          "no": "nå en høy alder",
          "en": "reach an advanced age"
        }
      ]
    },
    {
      "text": "om lyd: som ligger langt oppe på toneskalaen",
      "translation": "of sound: located far up on the musical scale",
      "examples": [
        {
          "no": "en høy tone",
          "en": "a high note"
        }
      ]
    },
    {
      "text": "om lyd: sterk, kraftig",
      "translation": "of sound: loud, strong",
      "examples": [
        {
          "no": "høy musikk",
          "en": "loud music"
        },
        {
          "no": "snakke med høy stemme",
          "en": "speak in a loud voice"
        },
        {
          "no": "lese høyt",
          "en": "read aloud"
        },
        {
          "no": "rope høyt om hjelp",
          "en": "cry loudly for help"
        }
      ]
    },
    {
      "text": "med rang eller posisjon over andre",
      "translation": "having rank or position above others",
      "examples": [
        {
          "no": "ha høy rang",
          "en": "have high rank"
        },
        {
          "no": "ha et høyt verv i organisasjonen",
          "en": "hold a high office in the organization"
        },
        {
          "no": "ha høye tanker om seg selv",
          "en": "have a high opinion of oneself"
        }
      ]
    },
    {
      "text": "ruset av narkotisk stoff, særlig hallusinogener",
      "translation": "intoxicated by narcotic substance, especially hallucinogens",
      "examples": [
        {
          "no": "bli høy på amfetamin",
          "en": "get high on amphetamines"
        }
      ]
    }
