  "definitions": [
    {
      "text": "svulme, svelle, hovne opp",
      "translation": "to swell, bloat, or puff up",
      "examples": [
        {
          "no": "fingeren trutner",
          "en": "the finger swells"
        }
      ]
    },
    {
      "text": "om treverk: svelle eller bli tett av væte",
      "translation": "of wood: swell or become tight from moisture",
      "examples": [
        {
          "no": "båten lakk som en sil før den trutnet",
          "en": "the boat leaked like a sieve before it swelled tight"
        }
      ]
    }
  ]
