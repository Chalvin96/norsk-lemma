  "definitions": [
    {
      "text": "binde sammen forestillinger til tanker, drive tankevirksomhet",
      "translation": "connect ideas to form thoughts, engage in thought activity",
      "examples": [
        {
          "no": "tenke klart",
          "en": "think clearly"
        },
        {
          "no": "tenke farlige tanker",
          "en": "think dangerous thoughts"
        },
        {
          "no": "tenke i bilder",
          "en": "think in images"
        },
        {
          "no": "han tenker ikke før han taler",
          "en": "he doesn't think before he speaks"
        }
      ]
    },
    {
      "text": "rette bevisstheten mot noe",
      "translation": "direct consciousness towards something",
      "examples": [
        {
          "no": "hun tenkte ikke noe mer over det",
          "en": "she didn't think any more about it"
        },
        {
          "no": "han kom til å tenke på broren sin",
          "en": "he happened to think of his brother"
        },
        {
          "no": "prøve å ikke tenke på det",
          "en": "try not to think about it"
        }
      ]
    },
    {
      "text": "forestille seg, se for seg",
      "translation": "imagine, visualize",
      "examples": [
        {
          "no": "la oss tenke oss følgende: …",
          "en": "let's imagine the following: ..."
        },
        {
          "no": "det er lett å tenke seg en slik løsning",
          "en": "it's easy to imagine such a solution"
        },
        {
          "no": "jeg kan tenke meg at det var vanskelig",
          "en": "I can imagine that it was difficult"
        },
        {
          "no": "et tenkt tilfelle",
          "en": "an imagined case"
        }
      ]
    },
    {
      "text": "ha forsett om, ha i sinne",
      "translation": "intend, have in mind",
      "examples": [
        {
          "no": "hva har du tenkt å gjøre?",
          "en": "what are you planning to do?"
        },
        {
          "no": "tenke på å gå",
          "en": "think about leaving"
        },
        {
          "no": "jeg tenker meg til fjells i helgen",
          "en": "I'm thinking of going to the mountains this weekend"
        },
        {
          "no": "jeg har tenkt å flytte",
          "en": "I'm planning to move"
        }
      ]
    },
    {
      "text": "ha omsorg for, ta hensyn til",
      "translation": "care for, consider",
      "examples": [
        {
          "no": "ikke tenk på meg",
          "en": "don't think about me"
        },
        {
          "no": "prøv å tenke litt på andre iblant",
          "en": "try to think a little about others now and then"
        }
      ]
    },
    {
      "text": "ha som synspunkt",
      "translation": "hold as a viewpoint",
      "examples": []
    },
    {
      "text": "mene meine, synes",
      "translation": "believe, think",
      "examples": [
        {
          "no": "hva tenker du om saken?",
          "en": "what do you think about the matter?"
        },
        {
          "no": "ikke bry seg med hva andre tenker",
          "en": "not care about what others think"
        },
        {
          "no": "de tenkte det var lurt å starte tidlig",
          "en": "they thought it was smart to start early"
        },
        {
          "no": "jeg tenker det er for tidlig å si noe sikkert",
          "en": "I think it's too early to say anything for sure"
        }
      ]
    },
    {
      "text": "brukt for å uttrykke forundring",
      "translation": "used to express astonishment",
      "examples": [
        {
          "no": "tenk det!",
          "en": "imagine that!"
        },
        {
