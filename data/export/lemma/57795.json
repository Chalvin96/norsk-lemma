  "definitions": [
    {
      "text": "flyte i sterk strøm",
      "translation": "to flow in a strong current",
      "examples": [
        {
          "no": "vannet strømmer inn i kjelleren",
          "en": "the water is pouring into the basement"
        },
        {
          "no": "regnet strømmet ned",
          "en": "the rain poured down"
        },
        {
          "no": "tårene strømmet",
          "en": "the tears streamed"
        }
      ]
    },
    {
      "text": "komme i store mengder",
      "translation": "to come in large quantities",
      "examples": [
        {
          "no": "bidragene strømmer inn",
          "en": "the contributions are pouring in"
        },
        {
          "no": "kundene strømmer til den nye butikken",
          "en": "customers are flocking to the new store"
        },
        {
          "no": "folk strømmet ut av konsertsalen",
          "en": "people streamed out of the concert hall"
        },
        {
          "no": "gamle minner strømmet på",
          "en": "old memories came flooding back"
        }
      ]
    },
    {
      "text": "om lyd eller andre sanseinntrykk: lyde, velle",
      "translation": "of sound or other sensory impressions: to sound, to well up",
      "examples": [
        {
          "no": "det strømmet musikk ut gjennom vinduet",
          "en": "music streamed out through the window"
        }
      ]
    }
