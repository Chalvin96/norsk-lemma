    {
      "text": "strø utover",
      "translation": "scattered about",
      "examples": []
    },
    {
      "text": "jamfør spredt",
      "translation": "spread out",
      "examples": [
        {
          "no": "spre gjødsel",
          "en": "spread fertilizer"
        },
        {
          "no": "spre kreftene sine",
          "en": "spread oneself too thin"
        },
        {
          "no": "lampen sprer lyset godt",
          "en": "the lamp spreads the light well"
        }
      ]
    },
    {
      "text": "gjøre kjent",
      "translation": "make known",
      "examples": [
        {
          "no": "spre rykter",
          "en": "spread rumors"
        },
        {
          "no": "spre glede rundt seg",
          "en": "spread joy around oneself"
        }
      ]
    },
    {
      "text": "skille fra hverandre",
      "translation": "separate from each other",
      "examples": []
    },
    {
      "text": "splitte, oppløse oppløyse",
      "translation": "split, dissolve",
      "examples": [
