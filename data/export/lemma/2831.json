  "cross_reference": null,
  "definitions": [
    {
      "text": "få noe til eie fra (avdød) person",
      "translation": "to inherit from a deceased person",
      "examples": [
        {
          "no": "arve tronen etter sin mor",
          "en": "inherit the throne from his mother"
        },
        {
          "no": "arve en formue",
          "en": "inherit a fortune"
        },
        {
          "no": "arve klær",
          "en": "inherit clothes"
        }
      ]
    },
    {
      "text": "få, ta over",
      "translation": "to take over, to inherit",
      "examples": [
        {
          "no": "den nye regjeringen arvet mange problemer fra den forrige",
          "en": "the new government inherited many problems from the previous one"
        }
      ]
    },
    {
      "text": "få overført egenskaper eller særtrekk (gjennom kjønnsceller) fra et opphavsindivid",
      "translation": "to inherit traits or characteristics from an ancestor",
      "examples": [
        {
          "no": "jenta har arvet nesen til faren og det gode humøret til moren",
          "en": "the girl has inherited her father's nose and her mother's good humor"
        }
      ]
    }
  ]
