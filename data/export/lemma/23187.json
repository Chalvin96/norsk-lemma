  "cross_reference": null,
  "definitions": [
    {
      "text": "være festet øverst og holdt oppe i en viss avstand fra gulv eller bakke (og med mulighet til å svinge eller dingle)",
      "translation": "to be attached at the top and held at a certain distance from the floor or ground (with the possibility of swinging or dangling)",
      "examples": []
    },
    {
      "text": "sitte fast høyt oppe",
      "translation": "to be stuck high up",
      "examples": [
        {
          "no": "henge og dingle i et tau",
          "en": "hang and dangle from a rope"
        },
        {
          "no": "det henger mye frukt på trærne",
          "en": "there is a lot of fruit hanging on the trees"
        },
        {
          "no": "det hang malerier på alle veggene",
          "en": "paintings hung on all the walls"
        },
        {
          "no": "det hang klessnorer mellom husene",
          "en": "clotheslines hung between the houses"
        }
      ]
    },
    {
      "text": "holde seg svevende på samme sted",
      "translation": "to remain hovering in the same place",
      "examples": [
        {
          "no": "en drone hang i lufta",
          "en": "a drone hung in the air"
        },
        {
          "no": "røyken hang over husene",
          "en": "the smoke hung over the houses"
        },
        {
          "no": "månen henger like over åskanten",
          "en": "the moon hangs just above the edge of the hill"
        }
      ]
    },
    {
      "text": "sige eller bøye seg løst eller slapt ned",
      "translation": "to sag or bend loosely or limply down",
      "examples": [
        {
          "no": "henge med halen",
          "en": "hang one's tail"
        },
        {
          "no": "magen hang ut over beltet",
          "en": "his stomach hung over his belt"
        },
        {
          "no": "stå med hengende armer",
          "en": "stand with arms hanging down"
        },
        {
          "no": "en rose med hengende hode",
          "en": "a rose with a drooping head"
        }
      ]
    },
    {
      "text": "om person: være bøyd (over noe)",
      "translation": "about a person: to be bent (over something)",
      "examples": []
    },
    {
      "text": "være sammensunket",
      "translation": "to be slumped",
      "examples": [
        {
          "no": "hun hang ut av vinduet",
          "en": "she hung out of the window"
        },
        {
          "no": "henge over bøkene",
          "en": "hunch over the books"
        },
        {
          "no": "sitte og henge på stolen",
          "en": "sit slumped in the chair"
        }
      ]
    },
    {
      "text": "oppholde seg et sted uten å ha et bestemt mål eller ærend",
      "translation": "to stay somewhere without a specific purpose or errand",
      "examples": [
        {
          "no": "ungdommer som henger på kjøpesenteret hele dagen",
          "en": "young people who hang around the mall all day"
        }
      ]
    },
    {
      "text": "holde seg fast og la seg slepe med",
      "translation": "to hold on and be dragged along",
      "examples": []
    },
    {
      "text": "klamre seg til",
      "translation": "to cling to",
      "examples": [
        {
          "no": "syklisten hang etter bilen",
          "en": "the cyclist hung onto the car"
        },
        {
          "no": "han hang i armen på faren",
          "en": "he hung onto his father's arm"
        },
        {
          "no": "henge rundt halsen på noen",
          "en": "hang around someone's neck"
        }
      ]
    },
    {
      "text": "være fast eller festet",
      "translation": "to be stuck or attached",
      "examples": [
        {
          "no": "henge fast i noe",
          "en": "be caught on something"
        },
        {
          "no": "øynene hans hang ved henne hele tiden",
          "en": "his eyes stayed on her the whole time"
        },
        {
          "no": "røyklukten hang i klærne",
          "en": "the smell of smoke clung to the clothes"
        },
        {
          "no": "det henger da igjen litt av barnelærdommen",
          "en": "surely a little of what one learned in childhood still remains"
        }
      ]
    }
  ]
