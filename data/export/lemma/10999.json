  "definitions": [
    {
      "text": "dø ved å bli kvalt i vann eller annen væske",
      "translation": "die by being suffocated in water or other liquid",
      "examples": [
        {
          "no": "drukne i elva",
          "en": "drown in the river"
        },
        {
          "no": "falle over bord og drukne",
          "en": "fall overboard and drown"
        },
        {
          "no": "de gikk gjennom isen og druknet",
          "en": "they went through the ice and drowned"
        }
      ]
    },
    {
      "text": "drepe ved å kvele i vann",
      "translation": "kill by suffocating in water",
      "examples": [
        {
          "no": "hun ble anklaget for å ha prøvd å drukne sitt eget barn",
          "en": "she was accused of having tried to drown her own child"
        },
        {
          "no": "han orket ikke mer av livet og druknet seg",
          "en": "he couldn't bear life any longer and drowned himself"
        }
      ]
    },
    {
      "text": "bli overlesset, nedgravd eller overdøvet",
      "translation": "become overwhelmed, buried, or drowned out",
      "examples": []
    },
    {
      "text": "forsvinne eller bli mindre eller svakere",
      "translation": "disappear or become smaller or weaker",
      "examples": [
        {
          "no": "han druknet i farens frakk",
          "en": "he was swallowed up by his father's coat"
        },
        {
          "no": "drukne i mengden",
          "en": "get lost in the crowd"
        },
        {
          "no": "drukne i reklame",
          "en": "be drowned out by advertising"
        },
        {
          "no": "ordene hennes druknet i den høye musikken",
          "en": "her words were drowned out by the loud music"
        }
      ]
    },
    {
      "text": "få til å bli mindre eller forsvinne",
      "translation": "cause to become smaller or disappear",
      "examples": []
    },
    {
      "text": "døyve, dempe",
      "translation": "dull, dampen",
      "examples": [
        {
          "no": "drukne sorgene i alkohol",
          "en": "drown one's sorrows in alcohol"
        }
      ]
    }
  ]
