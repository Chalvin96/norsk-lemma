  "definitions": [
    {
      "text": "som en ikke kan løsne (fra hverandre)",
      "translation": "that cannot be loosened (from each other)",
      "examples": [
        {
          "no": "holde rattet med et uløselig grep",
          "en": "hold the steering wheel with an unyielding grip"
        },
        {
          "no": "være uløselig knyttet til hverandre",
          "en": "be inextricably bound to each other"
        }
      ]
    },
    {
      "text": "som det ikke fins noen løsning på",
      "translation": "that cannot be solved",
      "examples": [
        {
          "no": "et uløselig problem",
          "en": "an unsolvable problem"
        }
      ]
    },
    {
      "text": "som ikke lar seg oppløse",
      "translation": "that cannot be dissolved",
      "examples": [
        {
          "no": "pulveret er uløselig i kaldt vann",
          "en": "the powder is insoluble in cold water"
        }
      ]
    }
  ]
