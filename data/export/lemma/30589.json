  "definitions": [
    {
      "text": "klemme eller presse kraftig",
      "translation": "to squeeze or press hard",
      "examples": [
        {
          "no": "knuge noe i hånden",
          "en": "clench something in one's hand"
        },
        {
          "no": "knuge sine hender i fortvilelse",
          "en": "wring one's hands in despair"
        },
        {
          "no": "hun knuger seg inntil ham",
          "en": "she presses herself against him"
        }
      ]
    },
    {
      "text": "ligge trykkende over",
      "translation": "to lie oppressively over",
      "examples": [
        {
          "no": "være knuget av skyldfølelse",
