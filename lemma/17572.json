  "definitions": [
    {
      "text": "føre fram",
      "translation": "to bring forward",
      "examples": [
        "framstille for retten"
      ]
    },
    {
      "text": "gjengi kunstnerisk, gi et bilde av, skildre, illustrere",
      "translation": "to render artistically, to give a picture of, to depict, to illustrate",
      "examples": [
        "maleriet framstiller et norsk vinterlandskap",
        "romanen framstiller livet i en drabantby",
        "framstille objektivt",
        "jeg har hørt det framstilt på en annen måte"
      ]
    },
    {
      "text": "produsere, fabrikkere",
      "translation": "to produce, to manufacture",
      "examples": [
        "framstille gass",
        "papir framstilles av tremasse"
      ]
