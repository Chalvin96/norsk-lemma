  "definitions": [
    {
      "text": "mørkt område på den siden av noe som vender bort fra lyskilden",
      "translation": "dark area on the side of something facing away from the light source",
      "examples": [
        "sette seg i skyggen",
        "stå i skyggen av huset",
        "det er 20 °C i skyggen",
        "trærne kastet lange skygger"
      ]
    },
    {
      "text": "mørkere farget eller skravert parti på maleri eller tegning",
      "translation": "darker colored shaded area in a painting or drawing",
      "examples": [
        "legge skygge på en tegning",
        "fordele lys og skygge"
      ]
    },
    {
      "text": "mørk flekk",
      "translation": "dark spot",
      "examples": [
        "ha blå skygger under øynene"
      ]
    },
    {
      "text": "skjerm på hodeplagg",
      "translation": "brim on a head covering",
      "examples": [
        "en lue med skygge"
      ]
    },
    {
      "text": "i overført betydning: antydning, snev",
      "translation": "in a figurative sense: hint, trace",
      "examples": [
        "ikke en skygge av tvil",
        "en skygge av et smil"
      ]
    },
    {
      "text": "i overført betydning: alvorlig mine",
      "translation": "in a figurative sense: serious expression",
      "examples": [
        "det la seg en skygge over ansiktet hans"
