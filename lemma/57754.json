  "cross_reference": null,
  "definitions": [
    {
      "text": "berøre lett, særlig med hånden",
      "translation": "to touch lightly, especially with the hand",
      "examples": []
    },
    {
      "text": "jamfør strykende",
      "translation": "stroking",
      "examples": [
        "stryke noen over håret",
        "han stryker seg over munnen med håndbaken",
        "katten strøk seg rundt beina mine"
      ]
    },
    {
      "text": "glatte med strykejern",
      "translation": "to iron, to press with an iron",
      "examples": [
        "stryke skjorter"
      ]
    },
    {
      "text": "streke over",
      "translation": "to cross out",
      "examples": []
    },
    {
      "text": "utslette, fjerne",
      "translation": "to erase, to remove",
      "examples": [
        "stryke ut og skrive på nytt",
        "hele kapitalen var strøket",
        "sinnet var som strøket av henne"
      ]
    },
    {
      "text": "la utgå",
      "translation": "to omit, to leave out",
      "examples": []
    },
    {
      "text": "sløyfe",
      "translation": "to cancel, to delete",
      "examples": [
        "bli strøket som medlem",
        "stryke seg av lista",
        "stryke av seg lua"
      ]
    },
    {
      "text": "føre på i et tynt lag",
      "translation": "to apply in a thin layer",
      "examples": [
        "stryke på maling"
      ]
    },
    {
      "text": "føre bue over strengene på strykeinstrument",
      "translation": "to draw a bow across the strings of a string instrument",
      "examples": [
        "han stryker så mykt og fint på fela"
      ]
    },
    {
      "text": "ikke (la) bestå",
      "translation": "to fail (an exam), not to pass",
      "examples": [
        "stryke en kandidat til eksamen",
        "han strøk i matte"
      ]
    },
    {
      "text": "presse rogn og melke ut av fisk",
      "translation": "to strip roe and milt from fish",
      "examples": [
        "stryke laksen"
      ]
    },
    {
      "text": "minske (seil)",
      "translation": "to reef (sails)",
      "examples": []
    },
    {
      "text": "jamfør [berge|stryke|reve] seil",
      "translation": "to lower or furl sails",
      "examples": []
    },
    {
      "text": "fare raskt",
      "translation": "to move quickly",
      "examples": []
    },
    {
      "text": "jamfør strykende",
      "translation": "streaking, moving rapidly",
      "examples": [
        "stryke av gårde",
        "flyene stryker like over hustakene",
        "skuta strøk inn fjorden for god bør"
      ]
    }
  ]
