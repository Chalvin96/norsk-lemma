  "definitions": [
    {
      "text": "ord eller uttrykk som brukes i stedet for et annet ord eller uttrykk som det har nær sammenheng med, for eksempel når ‘penn’ står for ‘det skrevne’",
      "translation": "a word or expression used instead of another word or expression with which it has a close connection, e.g. 'pen' standing for 'the written word'",
