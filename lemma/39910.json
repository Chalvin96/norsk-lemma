  "definitions": [
    {
      "text": "komme imot noe eller noen som kommer i motsatt retning",
      "translation": "to come towards something or someone moving in the opposite direction",
      "examples": [
        "møte motgåande trafikk",
        "møtende trafikk"
      ]
    },
    {
      "text": "komme til et møte til avtalt tid og sted eller treffes tilfeldig",
      "translation": "to arrive at a meeting at an agreed time and place or to meet by chance",
      "examples": []
    },
    {
      "text": "treffe, støre på",
      "translation": "to meet, encounter",
      "examples": [
        "møte venner",
        "møte i retten",
        "onkel møter dere på stasjonen",
        "jeg møtte henne utenfor butikken",
        "hun har aldri møtt noen av dem"
      ]
    },
    {
      "text": "bli stilt overfor",
      "translation": "to be faced with",
      "examples": []
    },
    {
      "text": "oppleve, erfare",
      "translation": "to experience, undergo",
      "examples": [
        "møte motgang",
        "møte nye utfordringer",
        "bli møtt med skepsis"
      ]
    },
    {
      "text": "gjøre motstand mot",
      "translation": "to resist",
      "examples": []
    },
    {
      "text": "sette seg imot",
      "translation": "to oppose",
      "examples": []
    },
    {
      "text": "hindre, stoppe",
      "translation": "to hinder, stop",
      "examples": [
        "møte krisen med økonomiske tiltak"
      ]
    },
    {
      "text": "kjempe eller spille mot",
      "translation": "to compete or play against",
      "examples": [
        "Brann møter Molde i finalen"
      ]
    }
  ]
