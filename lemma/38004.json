  "definitions": [
    {
      "text": "sette merke på",
      "translation": "to mark",
      "examples": [
        "merke av på lista hvem som er til stede",
        "løypa er merket med røde bånd",
        "merke opp en sti",
        "merke sauer",
        "billett merket Haster"
      ]
    },
    {
      "text": "sette spor etter seg",
      "translation": "to leave a trace",
      "examples": [
        "være merket av sykdommen"
      ]
    },
    {
      "text": "brennemerke, stemple (som uhederlig)",
      "translation": "to brand, to stamp (as dishonorable)",
      "examples": [
        "en merket mann"
      ]
    },
    {
      "text": "bli var, kjenne, erfare",
      "translation": "to notice, to feel, to experience",
      "examples": [
        "merket du ansiktsuttrykket hennes?",
        "mye har hendt siden sist, det vil du få merke",
        "jeg merket at han hadde drukket",
        "merke en uvanlig lukt"
      ]
    }
