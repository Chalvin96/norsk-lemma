  "cross_reference": null,
  "definitions": [
    {
      "text": "merke med et kryss",
      "translation": "mark with a cross",
      "examples": [
        "krysse av i riktig rute",
        "krysse ut de arbeidsoppgavene en er ferdig med"
      ]
    },
    {
      "text": "legge eller få i kryss",
      "translation": "place or get into a crossed position",
      "examples": [
        "krysse beina",
        "han krysset skiene og gikk på hodet"
      ]
    },
    {
      "text": "gå (på skrå) over",
      "translation": "go (diagonally) across",
      "examples": [
        "krysse gata",
        "linjene krysser hverandre",
        "fartøyene krysset hverandres kurs",
        "skøyteløperen krysset foran parkameraten"
      ]
    },
    {
      "text": "om tog: møtes og passere hverandre",
      "translation": "for trains: meet and pass each other",
      "examples": [
        "togene krysser på Otta"
      ]
    },
    {
      "text": "seile over et hav eller havstykke",
      "translation": "sail across a sea or body of water",
      "examples": [
        "de krysset Nordsjøen i en liten båt"
      ]
    },
    {
      "text": "seile på kryss og tvers mot vinden",
      "translation": "sail tacking against the wind",
      "examples": [
        "krysse seg fram",
        "marinefartøyer krysset utenfor kysten"
      ]
    },
    {
      "text": "pare individer av ulike arter eller raser",
      "translation": "breed individuals of different species or breeds",
      "examples": [
        "krysse to storferaser"
      ]
    },
    {
      "text": "i overført betydning: dra eller gå i forskjellige retninger",
      "translation": "in a figurative sense: go or move in different directions",
      "examples": []
    },
    {
      "text": "komme i veien for",
      "translation": "get in the way of",
      "examples": []
    },
    {
      "text": "jamfør krøsse",
      "translation": "thwart",
      "examples": [
        "dette krysser mine planer",
        "ha kryssende interesser"
      ]
    }
  ]
