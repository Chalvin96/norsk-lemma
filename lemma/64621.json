  "definitions": [
    {
      "text": "komme seg unna",
      "translation": "get away",
      "examples": [
        "hun unnslapp forfølgeren",
        "de hoppet i sjøen for å unnslippe flammene"
      ]
    },
    {
      "text": "slippe unna oppmerksomhet",
      "translation": "escape attention",
      "examples": [
        "ikke ett ord av foredraget har unnsluppet meg"
      ]
    },
    {
      "text": "om utrop eller lignende: glippe ut av",
      "translation": "of an exclamation: slip out",
      "examples": [
        "en ufrivillig latter unnslapp meg"
      ]
    }
