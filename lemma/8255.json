  "definitions": [
    {
      "text": "støte imot eller komme borti (så det bremser eller stopper)",
      "translation": "bump into, collide with (so that it slows down, stops)",
      "examples": [
        "knærne butter mot forsetet"
      ]
    },
    {
      "text": "i overført betydning: gå trått",
      "translation": "in a figurative sense: proceed slowly",
      "examples": []
    },
    {
      "text": "støte på hindringer",
      "translation": "encounter obstacles",
      "examples": [
        "nå butter det både privat og på jobb"
      ]
    },
    {
      "text": "legge eller møtes butt i butt",
      "translation": "lay or meet end to end",
      "examples": [
        "bjelkene butter over mellomveggen"
      ]
    }
