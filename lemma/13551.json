  "definitions": [
    {
      "text": "bli eller få til å bli gradvis svakere og så helt borte",
      "translation": "become or cause to become gradually weaker and then disappear completely",
      "examples": [
        "lyset fader langsomt bort",
        "DJ-en fadet låten"
      ]
    },
    {
      "text": "om lyd fra fjerntliggende radiostasjon: forandre styrke og bli forvrengt på grunn av uro i den øvre atmosfæren der radiobølgene blir reflektert",
      "translation": "concerning sound from a distant radio station: change strength and become distorted due to disturbances in the upper atmosphere where radio waves are reflected",
      "examples": []
    }
