  "cross_reference": null,
  "definitions": [
    {
      "text": "diakritisk tegn (^) som angir at en lyd er falt bort, for eksempel i fôr, for eldre foder",
      "translation": "diacritical mark (^) indicating that a sound has been lost, in 'fôr', for older 'foder'",
      "examples": []
    },
    {
      "text": "accent circonflexe, møne",
      "translation": "circumflex accent, ridge",
      "examples": []
    },
    {
      "text": "i språkvitenskap: særskilt (oftest langtrukket eller modulert) tonem i en stavelse, særlig i ord som har hatt vokalbortfall, for eksempel kast for kaste (infinitiv), i visse trønderske og nordnorske dialekter",
      "translation": "special (usually drawn-out or modulated) tone in a syllable, especially in words that have had vowel loss, for example 'kast' for 'kaste' (infinitive), in certain Trøndelag and Northern Norwegian dialects",
      "examples": []
    }
  ]
