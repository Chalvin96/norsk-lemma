  "definitions": [
    {
      "text": "utstøte høye, skingrende lyder",
      "translation": "utter high, piercing sounds",
      "examples": []
    },
    {
      "text": "hyle, yle",
      "translation": "howl, wail",
      "examples": [
        "skrike høyt av smerte"
      ]
    },
    {
      "text": "gråte høyt",
      "translation": "cry loudly",
      "examples": [
        "småbarn skriker når de er sultne"
      ]
    },
    {
      "text": "bruke sterk stemme, særlig for å bli hørt eller uttrykke sterk følelse",
      "translation": "use a strong voice, especially to be heard or express strong emotion",
      "examples": [
        "skrike om hjelp",
        "skrike i munnen på hverandre"
      ]
    },
    {
      "text": "gi fra seg en høy og skjærende eller pipende lyd",
      "translation": "emit a loud and shrill or squeaking sound",
      "examples": []
    },
    {
      "text": "knirke, hvine kvine",
      "translation": "creak, squeak",
      "examples": [
        "porten skrek på hengslene",
        "stormen skrek rundt huset"
      ]
    },
    {
      "text": "i overført betydning: komme kraftig til uttrykk",
      "translation": "be strongly expressed",
      "examples": []
    },
    {
      "text": "jamfør skrikende",
      "translation": "screaming",
      "examples": [
        "nøden skrek mot oss",
        "farger skrek imot oss"
      ]
    }
  ]
