  "definitions": [
    {
      "text": "bygge hus, anlegg eller lignende på et område",
      "translation": "build houses, facilities on an area",
      "examples": []
    },
    {
      "text": "bygge ut",
      "translation": "build out",
      "examples": [
        "boligfeltet er ennå ikke fullt utbygd"
      ]
    },
    {
      "text": "om foss eller elv: knytte til et anlegg som produserer elektrisitet",
      "translation": "regarding a waterfall or river: connect to a facility that produces electricity",
      "examples": [
        "utbygge fossekraften"
      ]
    },
    {
      "text": "om anlegg, infrastuktur, institusjon og lignende: utvikle for å dekke et behov",
      "translation": "regarding facilities, infrastructure, institutions: develop to meet a need",
      "examples": [
        "utbygge den digitale infrastrukturen"
      ]
    },
    {
      "text": "utforme eller utvide i detalj",
      "translation": "design or expand in detail",
