  "cross_reference": null,
  "definitions": [
    {
      "text": "om menneske og dyr: ha små, krampaktige, dirrende bevegelser, ofte av kulde, sinne, frykt eller lignende",
      "translation": "of humans and animals: to have small, convulsive, trembling movements, often from cold, anger, fear",
      "examples": []
    },
    {
      "text": "bevre, dirre, riste",
      "translation": "to quiver, tremble, shake",
      "examples": [
        "skjelve i stemmen",
        "hun frøs så hun skalv",
        "han skjelver på hendene",
        "katten skalv av raseri",
        "han la armen om den skjelvende kroppen",
        "hun ropte ut med skjelvende stemme"
      ]
    },
    {
      "text": "bevege seg fort fram og tilbake, opp og ned",
      "translation": "to move quickly back and forth, up and down",
      "examples": []
    },
    {
      "text": "dirre, riste",
      "translation": "to quiver, shake",
      "examples": [
        "bakken skalv under oss",
        "løvet skjelver i vinden"
      ]
    }
  ]
