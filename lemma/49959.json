  "cross_reference": null,
  "definitions": [
    {
      "text": "stille sammen for å finne innbyrdes likhet og ulikhet",
      "translation": "to place together to find mutual similarity and difference",
      "examples": [
        "sammenligne norske forhold med utenlandske",
        "han er liten sammenlignet med broren sin",
        "sammenligne avskriften med originalen",
        "dette prosjektet kunne ikke sammenlignes med andre bruprosjekter"
      ]
    },
    {
      "text": "brukt som adjektiv: som tar utgangspunkt i sammenligninger for å undersøke hvordan ulike fenomener henger sammen",
      "translation": "used as an adjective: based on comparisons to examine how different phenomena relate to each other",
      "examples": [
        "sammenlignende metoder",
        "gjøre sammenlignende studier"
      ]
    }
  ]
