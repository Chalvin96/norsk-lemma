  "definitions": [
    {
      "text": "i Romerriket: strafferedskap til dødsstraff som bestod av en loddrett stolpe og et tverrtre langt oppe der en hengte opp den dødsdømte",
      "translation": "in the Roman Empire: instrument of punishment for capital punishment consisting of a vertical post and a crossbeam high up on which the condemned was hung",
      "examples": [
        "Jesus led døden på korset"
      ]
    },
    {
      "text": "symbol for kristendommen",
      "translation": "symbol of Christianity",
      "examples": [
        "gjøre korsets tegn",
        "stride for korset"
      ]
    },
    {
      "text": "i overført betydning: tung skjebne, prøvelse",
      "translation": "heavy fate, trial",
      "examples": [
        "enhver har sitt kors"
      ]
    },
    {
      "text": "stor vanske, uløselig problem",
      "translation": "great difficulty, unsolvable problem",
      "examples": []
    },
    {
      "text": "figur eller gjenstand med form som et kors",
      "translation": "figure or object shaped like a cross",
      "examples": []
    },
    {
      "text": "etterligning av kors, ofte benyttet som symbol",
      "translation": "imitation of a cross, often used as a symbol",
      "examples": [
        "reise et kors på graven",
        "bære et kors rundt halsen",
        "korset i det norske flagget"
      ]
    },
    {
      "text": "to linjer eller gjenstander som krysser hverandre",
      "translation": "two lines of objects crossing each other",
      "examples": [
