  "definitions": [
    {
      "text": "slites over",
      "translation": "wear through",
      "examples": []
    },
    {
      "text": "sprekke, revne",
      "translation": "burst, tear",
      "examples": [
        "isen brast under dem",
        "tauet brast"
      ]
    },
    {
      "text": "sprenges av noe som vokser fram",
      "translation": "burst from something growing forth",
      "examples": [
        "knoppene brister",
        "hans hjerte var nær ved å briste"
      ]
    },
    {
      "text": "slå feil",
      "translation": "fail",
      "examples": []
    },
    {
      "text": "svikte",
      "translation": "fail",
      "examples": [
        "håpet brast",
        "resonnementet bygger på bristende forutsetninger"
      ]
    },
    {
      "text": "brått og uoverveid slippe løs følelse, reaksjon eller lignende",
      "translation": "suddenly and rashly release emotion, reaction",
      "examples": [
        "han brister i gråt",
        "de brast i latter"
      ]
    },
    {
      "text": "bli så stort følelsesmessig trykk at en mister kontroll",
      "translation": "become so emotionally pressured that one loses control",
      "examples": [
        "det brast for henne"
      ]
    },
    {
      "text": "om øye: brått miste glansen når døden inntreffer",
      "translation": "of an eye: suddenly lose its gleam when death occurs",
      "examples": [
        "øynene brast"
      ]
    },
    {
      "text": "om stemme: plutselig svikte",
      "translation": "of a voice: suddenly fail",
      "examples": []
    },
    {
      "text": "bli uklar og skurrende",
      "translation": "become unclear and hoarse",
      "examples": [
        "stemmen brast"
      ]
    },
    {
      "text": "om ytring: komme brått, heftig og uoverveid",
      "translation": "of an utterance: come suddenly, intensely, and rashly",
      "examples": [
        "«Drittsekk!» brast det ut av henne"
      ]
    }
