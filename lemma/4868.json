  "definitions": [
    {
      "text": "gjøre følelsesløs med bedøvelsesmiddel",
      "translation": "to make numb with anesthetic",
      "examples": [
        "bedøve tannkjøttet",
        "pasienten ble bedøvet før operasjonen"
      ]
    },
    {
      "text": "gjøre bevisstløs",
      "translation": "to make unconscious",
      "examples": [
        "bli bedøvet av et slag",
        "bedøve noen med sovepiller"
      ]
    },
    {
      "text": "gjøre sløv og omtåket",
      "translation": "to make sluggish and dazed",
      "examples": []
    },
    {
      "text": "lamme",
      "translation": "to paralyze",
      "examples": [
        "bli bedøvet av vinen",
