    },
    {
      "text": "sakslignende gripe- og fangstredskap hos hummer, krabbe og kreps",
      "translation": "pincer-like gripping and catching tool of lobsters, crabs, and crayfish",
      "examples": [
        "en hummer med svære klør"
      ]
    },
    {
      "text": "redskap som ligner en klo",
      "translation": "tool resembling a claw",
      "examples": [
        "kloa på ankeret"
      ]
    },
    {
      "text": "i overført betydning: ubehagelig følelse",
      "translation": "in a figurative sense: unpleasant feeling",
      "examples": [
        "kjenne en klo i magen",
        "få en kald klo i brystet"
      ]
    },
    {
      "text": "rev i råseil råsegl",
      "translation": "reef in a square sail",
      "examples": [
