  "cross_reference": null,
  "definitions": [
    {
      "text": "hente fram fra hukommelsen noe en har sett, hørt, opplevd eller følt",
      "translation": "to retrieve from memory something seen, heard, experienced, or felt",
      "examples": []
    },
    {
      "text": "ha erindring om",
      "translation": "to have recollection of",
      "examples": []
    },
    {
      "text": "komme i hug, minnes",
      "translation": "to recall, to remember",
      "examples": [
        "huske noen fra skoletiden",
        "han husker mye fra barndommen",
        "jeg har kjent henne så lenge jeg kan huske",
        "så vidt jeg husker, var det slik det gikk til"
      ]
    },
    {
      "text": "ha evne til å erindre",
      "translation": "to have the ability to recall",
      "examples": [
        "huske godt",
        "huske dårlig",
        "jeg husker visst feil"
      ]
    },
    {
      "text": "være oppmerksom på",
      "translation": "to be attentive to",
      "examples": []
    },
    {
      "text": "ikke glemme",
      "translation": "not to forget",
      "examples": []
    },
    {
      "text": "ha i tankene",
      "translation": "to keep in mind",
      "examples": [
        "husk å ta med kopp",
        "det er visst ingen som husker på meg",
        "jeg må spørre deg om noe mens jeg husker det",
        "du må huske på at du ikke er noen ungdom lenger"
      ]
    }
  ]
