  "cross_reference": null,
  "definitions": [
    {
      "text": "kutte eller skjære med saks, tang eller maskin",
      "translation": "cut or shear with scissors, pliers, or a machine",
      "examples": [
        "klippe håret",
        "klippe sauene",
        "klippe gresset"
      ]
    },
    {
      "text": "sette merke med saks eller tang",
      "translation": "make a mark with scissors or pliers",
      "examples": [
        "klippe billetter"
      ]
    },
    {
      "text": "bevege raskt",
      "translation": "move quickly",
      "examples": [
        "klippe med øyelokkene"
      ]
    },
    {
      "text": "i IT: merke og ta ut tekst, bilde eller fil som skal flyttes til et annet sted",
      "translation": "in IT: select and mark text, an image, or a file to be moved to another location",
      "examples": [
        "klippe ut et avsnitt",
        "klippe og lime i teksten"
      ]
    },
    {
      "text": "om digitale bilder, filmer og lydopptak: redigere, forme",
      "translation": "for digital images, films, and audio recordings: edit, shape",
      "examples": [
        "klippe til lydopptakene",
        "klippe sammen en kortfilm"
      ]
    }
  ]
