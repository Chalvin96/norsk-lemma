  "cross_reference": null,
  "definitions": [
    {
      "text": "oppheve forbindelsen mellom, skille",
      "translation": "to break the connection between, to separate",
      "examples": [
        "atskille foreldre og barn"
      ]
    },
    {
      "text": "danne skille mellom",
      "translation": "to form a separation between",
      "examples": [
        "en hekk atskiller eiendommene",
        "Kanalen atskiller England og Frankrike"
      ]
    },
    {
      "text": "skjelne, skille mellom",
      "translation": "to distinguish, to differentiate between",
      "examples": [
        "de to typene lar seg ikke atskille"
      ]
    },
    {
      "text": "avvike fra",
      "translation": "to deviate from",
      "examples": [
        "fuglene atskiller seg fra pattedyra ved at de legger egg",
        "rådhuset atskiller seg fra de andre husene i strøket"
      ]
    }
  ]
