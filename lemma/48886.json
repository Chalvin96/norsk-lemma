  "definitions": [
    {
      "text": "i norsk folkekunst: male blomster, blader eller andre figurer som ornament",
      "translation": "in Norwegian folk art: to paint flowers, leaves, or other figures as ornament",
      "examples": []
    },
    {
      "text": "jamfør rosemaling",
      "translation": "Rosemaling",
      "examples": [
        "rosemale en kiste"
      ]
    },
    {
      "text": "i overført betydning: framstille noe som bedre eller finere enn det virkelig er",
      "translation": "to portray something as better or finer than it really is",
      "examples": []
    },
    {
      "text": "pynte på, skjønnmale, idyllisere",
      "translation": "to embellish, to sugarcoat, to idealize",
      "examples": [
        "rosemale forholdene i et land"
      ]
    }
  ]
