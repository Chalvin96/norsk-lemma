  "definitions": [
    {
      "text": "det at et skip synker eller blir ødelagt",
      "translation": "the sinking or destruction of a ship",
      "examples": [
        "lide skipbrudd",
        "hun led skipbrudd like utenfor Kappstaden",
        "han var i flere skipbrudd under krigen"
      ]
    },
    {
      "text": "i overført betydning: det at noe eller noen mislykkes",
      "translation": "the failure of something or someone",
      "examples": [
        "valget var et totalt skipbrudd for politikeren",
        "prosjektet led skipbrudd allerede før start"
      ]
    }
  ]
