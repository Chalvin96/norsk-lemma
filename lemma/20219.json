  "definitions": [
    {
      "text": "(prøve å) bite kjapt og iltert",
      "translation": "(to try to) bite quickly and fiercely",
      "examples": []
    },
    {
      "text": "snappe med munnen",
      "translation": "to snap with the mouth",
      "examples": [
        "hunden glefser",
        "reven glefser etter fuglen"
      ]
    },
    {
      "text": "i overført betydning: svare kort og sint",
      "translation": "in a figurative sense: to answer curtly and angrily",
      "examples": []
    },
    {
      "text": "sende sinte, spydige eller hånlige bemerkelser",
      "translation": "to send angry, sarcastic, or mocking remarks",
      "examples": [
        "unnskyld for at jeg glefset til deg",
        "de ble sinte og begynte å glefse etter hverandre"
      ]
    },
    {
      "text": "ete grådig og fort",
      "translation": "to eat greedily and quickly",
      "examples": []
    },
    {
      "text": "jafse, sluke",
      "translation": "to gobble, to devour",
      "examples": [
        "glefse i seg maten",
        "krokodillen glefset til seg kyllingen"
      ]
    }
  ]
