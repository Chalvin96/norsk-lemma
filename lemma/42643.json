  "definitions": [
    {
      "text": "påføre skade (slik at noe blir ubrukelig)",
      "translation": "to cause damage (so that something becomes unusable)",
      "examples": []
    },
    {
      "text": "skade, rasere",
      "translation": "damage, wreck",
      "examples": [
        "klimaendringer ødelegger avlinger",
        "ungene har ødelagt lekene sine",
        "en ødeleggende krig",
        "en ødelagt leke"
      ]
    },
    {
      "text": "påføre psykisk skade",
      "translation": "to cause psychological damage",
      "examples": [
        "hun fikk en oppdragelse som ødela henne"
      ]
    },
    {
      "text": "gjøre ende på (noe verdifullt)",
      "translation": "to put an end to (something valuable)",
      "examples": [
        "være engstelig for å ødelegge vennskapet",
        "de havnet i fengsel og fikk ødelagt sitt gode navn og rykte",
        "de ødela for hverandre"
      ]
    }
  ]
