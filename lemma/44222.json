  "definitions": [
    {
      "text": "sette noe fra seg, som regel et kjøretøy",
      "translation": "to put something down, usually a vehicle",
      "examples": [
        "parkere bilen"
      ]
    },
    {
      "text": "i overført betydning: plassere (i andres varetekt)",
      "translation": "figuratively: to place (in someone else's care)",
      "examples": [
        "de parkerte barna hos slektninger"
      ]
    },
    {
      "text": "i overført betydning: utsette eller avslutte",
      "translation": "figuratively: to postpone or conclude",
      "examples": [
        "de må parkere saken inntil videre"
      ]
    }
  ]
