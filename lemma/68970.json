  "definitions": [
    {
      "text": "holde vakt over, passe på, ha tilsyn med, verne",
      "translation": "to keep watch over, to look after, to supervise, to protect",
      "examples": [
        "vokte inngangen",
        "vokte noen mot farer"
      ]
    },
    {
      "text": "refleksivt: ta seg i akt, passe seg",
      "translation": "to be careful, to beware",
      "examples": [
        "vokte seg for hva en sier",
        "det skal jeg vokte meg vel for",
        "vokt Dem for hunden!"
      ]
    }
  ]
