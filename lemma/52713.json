  "definitions": [
    {
      "text": "ta i stedet for noe annet",
      "translation": "take instead of something else",
      "examples": [
        "skifte bosted",
        "ansiktet skifter farge",
        "han skiftet skjorte"
      ]
    },
    {
      "text": "kle seg om",
      "translation": "change clothes",
      "examples": [
        "jeg må hjem og skifte først"
      ]
    },
    {
      "text": "flytte (jernbanevogner)",
      "translation": "move (railway cars)",
      "examples": []
    },
    {
      "text": "gi hverandre gjensidig",
      "translation": "give each other mutually",
      "examples": [
        "skifte hogg",
        "skifte øyekast"
      ]
    },
    {
      "text": "fordele verdier, eiendeler og gjeld i et dødsbo",
      "translation": "distribute values, assets, and debts in an estate",
      "examples": [
        "skifte et bo"
      ]
    },
    {
      "text": "endre seg, veksle",
      "translation": "change, alternate",
      "examples": [
        "været skiftet alt i ett",
        "skiftende bris",
        "et skiftende landskap"
      ]
