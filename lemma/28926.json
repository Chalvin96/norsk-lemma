        "han vant med et kast på 76 meter"
      ]
    },
    {
      "text": "det å sette not eller kaste snøre i vann eller sjø",
      "translation": "the act of putting a net or casting a line into water or sea",
      "examples": [
        "gjøre et godt kast",
        "de fikk makrell på hvert kast"
      ]
    },
    {
      "text": "brå bevegelse",
      "translation": "sudden movement",
      "examples": []
    },
    {
      "text": "brått støt",
      "translation": "sudden jolt",
      "examples": [
        "et kast med nakken"
      ]
    },
    {
      "text": "det å legge eller kaste tau, tråd eller lignende rundt noe",
      "translation": "the act of wrapping or throwing a rope, thread around something",
      "examples": [
        "et kast med nålen",
        "et kast rundt en påle"
      ]
    },
    {
      "text": "hopp med vending, særlig i dans",
      "translation": "jump with a turn, especially in dance",
      "examples": [
        "danseren gjorde noen veldige kast"
      ]
    },
    {
      "text": "plagg, tørkle til å slenge på seg",
