    {
      "text": "komme eller gå på en beskjeden måte",
      "translation": "come walking in a modest way",
      "examples": [
        "tusle av gårde",
        "tusle seg inn igjen"
      ]
    },
    {
      "text": "bevege seg stillferdig, pusle",
      "translation": "move quietly, potter about",
      "examples": [
        "gå og tusle for seg selv"
      ]
