  "definitions": [
    {
      "text": "det å lage en mer følbar eller synlig form eller mønster på overflate",
      "translation": "the act of creating a more palpable or visible form or pattern on a surface",
      "examples": [
        "han teksturerer håret sitt med et hårprodukt"
      ]
    },
    {
      "text": "gi (særlig syntetiske) tekstilfibrer en krøllete eller krusete form, slik at en kan tilvirke tøyelig og varmt garn",
      "translation": "give (especially synthetic) textile fibers a curly, crimped form, so that stretchy and warm yarn can be produced",
      "examples": [
        "garnet er grovt teksturert"
      ]
    }
