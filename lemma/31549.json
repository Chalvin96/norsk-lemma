  "definitions": [
    {
      "text": "binde sammen hunder i kobbel koppel",
      "translation": "to leash dogs",
      "examples": []
    },
    {
      "text": "sette kobbel koppel på hund",
      "translation": "to put a leash on a dog",
      "examples": []
    },
    {
      "text": "feste to eller flere enkeltdeler sammen",
      "translation": "to fasten two or more individual parts together",
      "examples": []
    },
    {
      "text": "binde sammen",
      "translation": "to bind together",
      "examples": [
        "koble to elektriske ledninger",
        "batteriet er koblet i serie"
      ]
    },
    {
      "text": "bringe sammen",
      "translation": "to bring together",
      "examples": []
    },
    {
      "text": "forene",
      "translation": "to unite",
      "examples": [
        "koble tradisjoner og det moderne"
      ]
    },
    {
      "text": "finne sammenheng mellom fenomener, hendelser eller personer",
      "translation": "to find a connection between phenomena, events, or people",
      "examples": [
        "koble prostitusjon til menneskehandel"
      ]
    },
    {
      "text": "bringe i nær forbindelse",
      "translation": "to bring into close connection",
      "examples": [
        "de forsøker å koble ham med en kollega"
      ]
    }
  ]
