  "definitions": [
    {
      "text": "løpe i trav",
      "translation": "to run at a trot",
      "examples": []
    },
    {
      "text": "til forskjell fra galoppere",
      "translation": "to move at a trot (as opposed to a gallop)",
      "examples": [
        "hingsten travet opp til stallen"
      ]
    },
    {
      "text": "ri i trav",
      "translation": "to ride at a trot",
      "examples": [
        "rytterne travet gjennom skogen"
      ]
    },
    {
      "text": "gå uten et klart mål eller en klar retning",
      "translation": "to walk without a clear goal or direction",
      "examples": []
    },
    {
      "text": "traske, vandre, flakke",
      "translation": "to trudge, wander, roam",
      "examples": [
        "trave fram og tilbake",
        "han travet hvileløst rundt i rommet"
      ]
    },
    {
      "text": "gå raskt",
      "translation": "to walk quickly",
      "examples": []
    },
    {
      "text": "strene, fare",
      "translation": "to stride, dash",
      "examples": [
        "trave forbi noen"
      ]
    }
  ]
