  "definitions": [
    {
      "text": "flyte i sterk strøm",
      "translation": "to flow in a strong current",
      "examples": [
        "vannet strømmer inn i kjelleren",
        "regnet strømmet ned",
        "tårene strømmet"
      ]
    },
    {
      "text": "komme i store mengder",
      "translation": "to come in large quantities",
      "examples": [
        "bidragene strømmer inn",
        "kundene strømmer til den nye butikken",
        "folk strømmet ut av konsertsalen",
        "gamle minner strømmet på"
      ]
    },
    {
      "text": "om lyd eller andre sanseinntrykk: lyde, velle",
      "translation": "of sound or other sensory impressions: to sound, to well up",
      "examples": [
        "det strømmet musikk ut gjennom vinduet"
      ]
