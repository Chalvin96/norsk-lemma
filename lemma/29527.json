        "de kjente henne på ganglaget",
        "politiet kjenner til saken"
      ]
    },
    {
      "text": "oppfatte med sansene",
      "translation": "to perceive with the senses",
      "examples": []
    },
    {
      "text": "merke, føle",
      "translation": "to notice, to feel",
      "examples": [
        "kjenne smerte",
        "de kjente en rar lukt",
        "hun kjenner seg uvel"
      ]
    },
    {
      "text": "sanse inni seg",
      "translation": "to sense internally",
      "examples": []
    },
    {
      "text": "oppleve, føle",
      "translation": "to experience, to feel",
      "examples": [
        "kjenne sorg",
        "hun kjente på presset",
        "få kjenne følgene av feiltrinnet"
      ]
    },
    {
      "text": "røre ved, ta på, føle",
      "translation": "to touch, to feel",
      "examples": []
    },
    {
      "text": "undersøke, prøve",
      "translation": "to examine, to try",
      "examples": [
