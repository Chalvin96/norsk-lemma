  "definitions": [
    {
      "text": "(fast) tidsrom der det er mulig å gå på besøk, særlig ved sykehus og fengsler",
      "translation": "(fixed) period of time when it is possible to visit, especially at hospitals and prisons",
      "examples": [
        "på søndager er det besøkstid i fengslet"
      ]
    },
    {
      "text": "tidsrom der en kan møte noen eller møte opp på noe",
      "translation": "period of time when one can meet someone or show up for something",
      "examples": [
        "kundeveilederen har besøkstid to timer hver dag",
        "ha besøkstid med barna"
      ]
    }
