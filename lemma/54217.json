  "cross_reference": null,
  "definitions": [
    {
      "text": "avlive og dele opp (hus)dyr som skal brukes til mat",
      "translation": "to slaughter and butcher (domestic) animals for food",
      "examples": [
        "slakte grisen til jul",
        "laksen ble slaktet rett på båten"
      ]
    },
    {
      "text": "drepe eller myrde brutalt og hensynsløst",
      "translation": "to kill or murder brutally and ruthlessly",
      "examples": [
        "hele landsbyen ble slaktet av opprørerne"
      ]
    },
    {
      "text": "kritisere svært hardt",
      "translation": "to criticize severely",
      "examples": [
        "forestillingen ble slaktet av kritikerne",
        "opposisjonen slakter regjeringens forslag"
      ]
    },
    {
      "text": "hogge opp eller dele opp noe og selge det som er av verdi",
      "translation": "to chop up or dismantle something and sell its valuable parts",
      "examples": [
        "banden stjal biler og slaktet dem",
        "utlendingene kjøpte opp bedriften bare for å slakte den"
      ]
    }
  ]
