  "cross_reference": null,
  "definitions": [
    {
      "text": "få til å komme senere enn planlagt",
      "translation": "to cause to come later than planned",
      "examples": [
        "være litt forsinket til møtet",
        "toget er en time forsinket",
        "forsinke planene om utbygging",
        "forsinke fredsprosessen",
        "en forsinket bursdagshilsen",
        "spise forsinket frokost"
      ]
    },
    {
      "text": "få til å bevege seg eller jobbe tregere",
      "translation": "to cause to move or work more slowly",
      "examples": []
    },
    {
      "text": "sinke, trenere",
      "translation": "to slow down, hinder",
      "examples": [
        "det voldsomme snøfallet forsinket oss",
        "bli forsinket av motorstopp",
        "være forsinket av vonde bein"
      ]
    }
  ]
