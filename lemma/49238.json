  "definitions": [
    {
      "text": "sette på plass",
      "translation": "put in place",
      "examples": []
    },
    {
      "text": "gjøre ryddig, ordne",
      "translation": "make tidy, arrange",
      "examples": [
        "rydde i stua",
        "han ryddet av bordet"
      ]
    },
    {
      "text": "bryte (opp), planere og fjerne noe for å gjøre plass til dyrking, vei eller lignende",
      "translation": "break up, level and remove something to make space for cultivation, roads",
      "examples": [
        "rydde ny jord",
        "rydde vei"
      ]
    },
    {
      "text": "fjerne eller rense bort",
      "translation": "remove or clear away",
      "examples": []
    },
    {
      "text": "drive vekk",
      "translation": "drive away",
      "examples": [
        "rydde huset for folk",
        "politiet ryddet lokalet for demonstranter",
        "rydde fortauet for snø"
      ]
