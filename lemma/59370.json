  "definitions": [
    {
      "text": "som hører til i eller ligger i sør",
      "translation": "belonging to or located in the south",
      "examples": [
        "de sørlige delene av landet",
        "sørlige farvann",
        "det sørlige Balkan"
      ]
    },
    {
      "text": "som går eller fører mot sør",
      "translation": "going or leading towards the south",
      "examples": [
        "kursen var sørlig",
        "dra til sørligere breddegrader"
      ]
    },
    {
      "text": "som kommer fra sør",
      "translation": "coming from the south",
      "examples": [
        "sørlig bris"
      ]
    }
  ]
