  "definitions": [
    {
      "text": "bearbeide jord for å få avling",
      "translation": "to cultivate land for harvest",
      "examples": [
        "dyrke jorda",
        "dyrke opp nytt land",
        "gården er på 100 mål dyrket mark"
      ]
    },
    {
      "text": "drive fram grøde",
      "translation": "to grow produce",
      "examples": [
        "dyrke korn",
        "de dyrker gulrøtter bak huset"
      ]
    },
    {
      "text": "tilbe som hellig",
      "translation": "to worship as holy",
      "examples": [
        "dyrke avguder"
      ]
    },
    {
      "text": "akte, beundre, forgude",
      "translation": "to admire, to adore, to idolize",
      "examples": [
