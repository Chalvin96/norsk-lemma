  "definitions": [
    {
      "text": "ødelegge naturen med skadelige stoffer",
      "translation": "to damage nature with harmful substances",
      "examples": []
    },
    {
      "text": "forsøple, gjøre uren, tilgrise",
      "translation": "to litter, to make impure, to soil",
      "examples": [
        "nye biler forurenser mindre enn gamle biler",
        "oljeutslipp har forurenset strendene",
        "lufta forurenses av eksos",
        "forurensede jordmasser er et stort problem",
        "drikkevannet er svært forurenset"
      ]
    },
    {
      "text": "i overført betydning: gjøre utrivelig",
      "translation": "in a figurative sense: to make unpleasant",
      "examples": []
    },
    {
      "text": "forpeste, ødelegge øydelegge, spolere",
      "translation": "to poison, to destroy, to spoil",
      "examples": [
        "han forurenset atmosfæren med sitt vulgære snakk",
        "nattestillheten ble forurenset av støyende musikk"
      ]
    }
  ]
