  "definitions": [
    {
      "text": "måte som fibre, stoffer eller tråder er forbundet på",
      "translation": "manner in which fibers, fabrics, or threads are connected",
      "examples": [
        "teksturen på en bergart",
        "muskelfibrene i torsken har en fast tekstur",
        "en hudkrem med silkemyk tekstur"
      ]
    },
    {
      "text": "synlig, og ofte følbart, mønster som strukturen i et materiale gir en overflate",
      "translation": "visible, and often palpable, pattern created by the structure of a material on a surface",
      "examples": [
        "teksturen i en slipt granittflate",
        "jeg liker teksturen på dette stoffet"
      ]
