  "definitions": [
    {
      "text": "fare med hvinende eller surrende lyd",
      "translation": "move with a whistling or buzzing sound",
      "examples": [
        "piler og spyd svirret gjennom lufta"
      ]
    },
    {
      "text": "fare hit og dit",
      "translation": "move here and there",
      "examples": []
    },
    {
      "text": "flagre urolig",
      "translation": "flutter restlessly",
      "examples": [
        "barna svirrer rundt i alle retninger",
        "nattsvermerne svirret rundt utelampa",
        "det store hjulet svirrer rundt"
      ]
    },
    {
      "text": "om utsagn, tanker eller lignende: være i raskt (og kaotisk) omløp",
      "translation": "about statements, thoughts: be in rapid (and chaotic) circulation",
      "examples": [
        "det svirret med rykter i bygda",
        "påstander svirret om ørene",
        "spørsmålene svirrer i lufta",
        "tanker som svirrer rundt i hodet"
      ]
    }
