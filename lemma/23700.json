  "definitions": [
    {
      "text": "løfte, heve, hale (med tau, vaier eller lignende)",
      "translation": "lift, raise, haul (with rope, cable)",
      "examples": [
        "hive anker",
        "hive opp en båt"
      ]
    },
    {
      "text": "om båt: slingre, rulle",
      "translation": "of a boat: to pitch, roll",
      "examples": [
        "skuta heiv voldsomt i den grove sjøen"
      ]
    },
    {
      "text": "kaste, slenge",
      "translation": "throw, toss",
      "examples": [
        "hive noe ut gjennom vinduet",
        "hive seg ut i noe"
      ]
    },
    {
      "text": "kaste i søpla",
      "translation": "throw in the trash",
      "examples": [
        "hive mat"
      ]
    },
    {
      "text": "puste inn med sterke, hørlige åndedrag",
      "translation": "inhale with strong, audible breaths",
      "examples": []
    },
    {
      "text": "stønne, gispe",
      "translation": "groan, gasp",
      "examples": [
        "hivende pust"
      ]
    }
  ]
