  "definitions": [
    {
      "text": "en slags ball-lek med to lag som går ut på å slå en ball med et balltre og løpe gjennom ulike poster uten å bli brenne",
      "translation": "a type of ball game with two teams where the objective is to hit a ball with a bat and run through various posts without being 'burned'",
      "examples": [
        "spille dødball i skolegården"
      ]
    },
    {
      "text": "det at ballen er ute av spill (særlig i fotball)",
      "translation": "the ball being out of play (especially in football)",
      "examples": [
        "skåre på dødball"
      ]
    }
  ]
