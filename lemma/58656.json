  "cross_reference": null,
  "definitions": [
    {
      "text": "ved en muskelbevegelse i svelg føre mat, drikke eller lignende ned i spiserøret",
      "translation": "to move food, drink down into the esophagus by a muscular movement of the throat",
      "examples": [
        "svelge maten i en fart"
      ]
    },
    {
      "text": "holde igjen en følelsesreaksjon, særlig gråt",
      "translation": "to hold back an emotional reaction, especially crying",
      "examples": [
        "hun svelger gråten"
      ]
    },
    {
      "text": "i overført betydning: bite i seg",
      "translation": "to bite down on",
      "examples": []
    },
    {
      "text": "finne seg i",
      "translation": "to put up with",
      "examples": [
        "han svelget ydmykelsen"
      ]
    },
    {
      "text": "brukt som adjektiv: gapende, bunnløs",
      "translation": "used as: gaping, bottomless",
      "examples": [
        "et svelgende dyp"
      ]
    }
  ]
