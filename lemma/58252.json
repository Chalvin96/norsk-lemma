  "definitions": [
    {
      "text": "dra inn gjennom munn eller nese",
      "translation": "draw in through the mouth or nose",
      "examples": [
        "suge på pipa",
        "suge inn lukten av vår",
        "mange rovdyr suger blodet av byttet sitt"
