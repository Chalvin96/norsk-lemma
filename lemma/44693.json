  "definitions": [
    {
      "text": "lage dråper eller bobler som ligner perle",
      "translation": "to form drops or bubbles resembling pearls",
      "examples": [
        "arbeide så svetten perler",
        "sjampanjen perlet i glasset"
      ]
    },
    {
      "text": "om lyd: risle eller boble",
      "translation": "of sound: to ripple or bubble",
      "examples": [
        "en perlende latter"
      ]
    },
    {
      "text": "sette små perler av plast i mønster på et brett og smelte dem sammen med strykejern",
      "translation": "to arrange small plastic beads in a pattern on a board and melt them together with an iron",
      "examples": [
        "ungene sitter på rommet og perler"
      ]
    }
