  "definitions": [
    {
      "text": "skjære eller hogge raskt",
      "translation": "to cut or chop quickly",
      "examples": [
        "kutte tauet",
        "kutte seg i fingeren"
      ]
    },
    {
      "text": "bryte av, stanse",
      "translation": "to break off, to stop",
      "examples": [
        "kutte strømmen",
        "kutte av midt i talen"
      ]
    },
    {
      "text": "skjære ned, redusere",
      "translation": "to cut down, reduce",
      "examples": [
        "butikken kuttet prisene",
        "vi må kutte utslippene av klimagasser",
        "de måtte kutte i bevilgningene"
      ]
    }
