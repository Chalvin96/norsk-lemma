  "definitions": [
    {
      "text": "framstilling (tegning, film eller lignende) der typiske trekk ved den eller det som framstilles, er overdrevet eller forvrengt på en satirsk eller komisk måte",
      "translation": "representation (drawing, film, or similar) where typical features of the subject are exaggerated or distorted in a satirical or comical way",
