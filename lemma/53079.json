  "definitions": [
    {
      "text": "gjøre skarp",
      "translation": "to make sharp",
      "examples": [
        "skjerpe en kniv"
      ]
    },
    {
      "text": "gjøre streng og skarp",
      "translation": "to make strict and sharp",
      "examples": [
        "skjerpe tonen i samtalen"
      ]
    },
    {
      "text": "gjøre mer oppmerksom",
      "translation": "to make more aware",
      "examples": [
        "skjerpe sansene",
        "et skjerpet blikk"
      ]
    },
    {
      "text": "øke, styrke",
      "translation": "to increase, to strengthen",
      "examples": [
        "skjerpe appetitten",
        "i skjerpende retning var det mye å tilføye"
      ]
    },
    {
      "text": "varme for å gjøre sprø",
      "translation": "to heat to make brittle",
      "examples": [
        "skjerpe brødet"
      ]
    },
    {
      "text": "om tiur under leik: frambringe en skarp, skurrende lyd",
      "translation": "of a capercaillie during mating: to produce a sharp, grating sound",
