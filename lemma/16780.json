  "definitions": [
    {
      "text": "lukke med segl",
      "translation": "to close with a seal",
      "examples": [
        "brevet var forseglet"
      ]
    },
    {
      "text": "validere med segl",
      "translation": "to validate with a seal",
      "examples": [
        "forsegle et dokument"
      ]
    },
    {
      "text": "dekke slik at innholdet ikke kommer ut",
      "translation": "to cover so that the contents cannot escape",
      "examples": [
        "forsegle en melkekartong",
        "forsegle en krukke"
      ]
    },
    {
      "text": "stenge for adgang",
      "translation": "to close off access",
      "examples": []
    },
    {
      "text": "plombere, låse",
      "translation": "to seal, to lock",
      "examples": [
        "politiet forseglet døra til huset"
      ]
    },
    {
      "text": "i overført betydning: fullbyrde, validere gjennom en gest",
      "translation": "in a figurative sense: to complete, to validate through a gesture",
      "examples": [
        "forsegle en avtale med et håndtrykk",
        "forsegle sin kjærlighet med et kyss"
      ]
    }
  ]
