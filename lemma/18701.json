  "definitions": [
    {
      "text": "evne til å oppfatte inntrykk i form av fysisk påvirkning, sosiale forhold og lignende",
      "translation": "ability to perceive impressions in the form of physical influence, social conditions, and the like",
      "examples": [
        "økt følsomhet for radioaktiv stråling",
        "barnet utvikler sin sosiale følsomhet",
        "å skrive en slik tekst krever følsomhet for språk og form"
      ]
    },
    {
      "text": "det å (ofte) oppleve eller uttrykke sterke følelser",
      "translation": "the act of (often) experiencing or expressing strong feelings",
      "examples": [
        "hun satte pris på hans følsomhet og ærlighet",
        "melodien er preget av følsomhet og skjørhet"
      ]
    }
