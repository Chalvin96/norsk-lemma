  "definitions": [
    {
      "text": "gi klang, lyde melodisk",
      "translation": "to make a ringing sound, sound melodious",
      "examples": [
        "klokka klang",
        "instrumentene klinger fint sammen"
      ]
    },
    {
      "text": "om røst, lyd: tone eller lyde rent eller klart",
      "translation": "of a voice, sound: to sound pure or clear",
      "examples": [
        "med flygende faner og klingende spill",
        "en glad og klingende latter"
      ]
    },
    {
      "text": "ha en viss språktone",
      "translation": "to have a certain linguistic tone",
      "examples": [
        "snakke klingende nordlandsk",
        "klingende svensk"
      ]
    },
    {
      "text": "lyde, høres",
