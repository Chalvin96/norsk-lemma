  "definitions": [
    {
      "text": "bruke gaffel (på)",
      "translation": "to use a fork (on)",
      "examples": [
        "gafle innpå"
      ]
    },
    {
      "text": "i orientering: lage løypene slik at løperne må ta (noen av) kontrollpostene i forskjellig rekkefølge (for å unngå at løperne følger etter hverandre)",
      "translation": "in orienteering: to lay out the courses so that the runners must take (some of) the control points in different orders (to prevent runners from following each other)",
      "examples": [
        "første, tredje og femte post var gaflet",
        "gaflede løyper"
      ]
    }
  ]
