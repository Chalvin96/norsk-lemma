  "definitions": [
    {
      "text": "føre fra et sted til et annet",
      "translation": "to move from one place to another",
      "examples": []
    },
    {
      "text": "hale, dra",
      "translation": "to pull, to drag",
      "examples": [
        "trekke noen inntil seg",
        "trekke for gardinene",
        "hesten trakk en vogn etter seg",
        "turistene trekker på store kofferter",
        "han trakk dyna over seg"
      ]
    },
    {
      "text": "flytte seg fra et sted til et annet",
      "translation": "to move oneself from one place to another",
      "examples": [
        "trekke seg unna en ubehagelig situasjon",
        "folkene trakk inn i huset",
        "fotografen bad dem trekke seg litt nærmere hverandre",
        "når kvelden kom, likte hun å trekke seg tilbake"
      ]
    },
    {
      "text": "ta, suge eller lokke til seg",
      "translation": "to take, suck, or lure to oneself",
      "examples": [
        "trekke pusten",
        "naturen trekker turister",
        "støvlene trekker vann",
        "bandet trakk fulle hus overalt på turneen",
        "gå ut for å trekke litt luft"
      ]
    },
    {
      "text": "ta opp eller fram",
      "translation": "to take up or out",
      "examples": [
        "trekke kølapp",
        "trekke kort fra bunken",
        "trekke kniv"
      ]
    },
    {
      "text": "dra med seg",
      "translation": "to drag along with oneself",
      "examples": []
    },
    {
      "text": "bringe inn i en situasjon",
      "translation": "to bring into a situation",
      "examples": [
        "prøve å trekke med seg flere",
        "bli trukket inn i en konflikt"
      ]
    },
    {
      "text": "komme fram til",
      "translation": "to arrive at (a conclusion)",
      "examples": [
        "trekke en rask konklusjon",
        "trekke en grense mellom jobb og privatliv",
        "trekke linjer mellom ulike hendelser"
      ]
    },
    {
      "text": "slutte å la gjelde",
      "translation": "to cease to be valid",
      "examples": [
        "trekke tilbake en tillatelse",
        "partiet trekker forslaget til ny skattereform"
      ]
    },
    {
      "text": "avgjøre ved slump",
      "translation": "to decide by chance",
      "examples": [
        "trekke om hvem som vinner",
        "bli trukket ut til være med"
      ]
    },
    {
      "text": "nøle mens en snakker",
      "translation": "to hesitate while speaking",
      "examples": [
        "trekke lenge på noe",
        "han trakk litt på det før han svarte"
      ]
    },
    {
      "text": "dra fordel av",
      "translation": "to benefit from",
      "examples": []
    },
    {
      "text": "jamfør [trekke|dra] veksler på",
      "translation": "to exploit",
      "examples": [
        "vi må trekke på kompetansen i bedriften"
      ]
    },
    {
      "text": "i matlaging: tilberede ved å la råvaren ligge i væske opp mot kokepunktet",
      "translation": "in cooking: to prepare by letting the raw ingredient steep in liquid near boiling point",
      "examples": [
        "trekke en kopp kaffe",
        "pølsene skal trekke noen minutter"
      ]
    },
    {
      "text": "redusere mengde eller størrelse",
      "translation": "to reduce quantity or size",
      "examples": [
        "trekke to fra fem",
        "bli trukket for mye i skatt"
      ]
    },
    {
      "text": "dra i flokk",
      "translation": "to move in a flock",
      "examples": [
        "reinen trekker til nye beiteområder",
        "fuglene trekker sørover om høsten"
      ]
    },
    {
      "text": "gi trekk",
      "translation": "to cause a draft",
      "examples": [
        "det trekker fra døra",
        "ovnen trekker dårlig"
      ]
    }
  ]
