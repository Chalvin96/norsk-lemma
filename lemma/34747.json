  "definitions": [
    {
      "text": "holde på med lek eller leker",
      "translation": "engage in play or games",
      "examples": []
    },
    {
      "text": "more seg",
      "translation": "amuse oneself",
      "examples": [
        "leke seg",
        "leke med dokker",
        "leke blindebukk",
        "leke sisten"
      ]
    },
    {
      "text": "late som om en er eller gjør noe",
      "translation": "pretend to be or do something",
      "examples": [
        "leke spion",
        "leke mor, far og barn"
      ]
    },
    {
      "text": "være overflatisk opptatt med",
      "translation": "be superficially occupied with",
      "examples": [
        "leke med andres følelser",
        "leke med tanken om en amerikatur"
      ]
    },
    {
      "text": "bevege seg lett og raskt",
      "translation": "move lightly and quickly",
      "examples": [
        "det lekte et smil om munnen hennes"
      ]
    }
  ]
