  "definitions": [
    {
      "text": "slippe inn frisk luft i et rom",
      "translation": "to let fresh air into a room",
      "examples": []
    },
    {
      "text": "sette noe i frisk luft",
      "translation": "to ventilate",
      "examples": [
        "lufte ut i stua",
        "lufte sengeklær",
        "lufte vin",
        "lufte radiatorene"
      ]
    },
    {
      "text": "gå tur med",
      "translation": "to go for a walk with",
      "examples": [
        "lufte hunden"
      ]
    },
    {
      "text": "gi uttrykk eller utløp for",
      "translation": "to express or give vent to",
      "examples": [
        "lufte sin ergrelse"
      ]
    },
    {
      "text": "nevne eller slå frampå om",
      "translation": "to mention or bring up",
      "examples": [
        "lufte et spørsmål for noen",
        "lufte en tanke for noen"
      ]
    }
