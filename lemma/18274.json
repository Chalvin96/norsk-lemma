  "definitions": [
    {
      "text": "bli til is, bli dekket av is, stivne",
      "translation": "become ice, become covered with ice, solidify",
      "examples": []
    },
    {
      "text": "bli frostskadd, lage tele",
      "translation": "become frostbitten, cause frost damage",
      "examples": [
