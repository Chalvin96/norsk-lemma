    },
    {
      "text": "få til å fryse",
      "translation": "cause to freeze",
      "examples": []
    },
    {
      "text": "kjøle noe ned til temperatur under frysepunkt for konservering",
      "translation": "cool something down to a temperature below freezing point for preservation",
      "examples": [
        "plukke bær og fryse dem ned"
      ]
    },
    {
      "text": "i overført betydning: stoppe noe, sette noe i en uendret tilstand",
      "translation": "stop something, put something in an unchanged state",
      "examples": []
    },
    {
      "text": "legge på is",
      "translation": "put on ice",
      "examples": [
