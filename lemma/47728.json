    {
      "text": "koke til mengden væske er blitt mindre",
      "translation": "to boil down (liquid) until the amount is reduced",
      "examples": [
        "tilsett fløte og kraft og reduser til halvparten"
      ]
    },
    {
      "text": "i kjemi: (få et stoff til å) ta opp elektroner",
      "translation": "to cause a substance to accept electrons",
      "examples": []
    },
    {
      "text": "fjerne oksygen fra et stoff",
      "translation": "to remove oxygen from a substance",
      "examples": []
    },
    {
      "text": "til forskjell fra oksidere",
      "translation": "to oxidize",
      "examples": []
    },
    {
      "text": "i matematikk: gjøre om til enklere form",
      "translation": "to convert into a simpler form",
      "examples": [
        "redusere et uttrykk"
      ]
    },
    {
      "text": "brukt som adjektiv: som er blitt mindre eller dårligere",
      "translation": "used as an adjective: that has been reduced or worsened",
      "examples": [
        "kommunen gir et redusert tilbud til innbyggerne",
        "han har redusert helse",
        "hun er blitt veldig redusert det siste året"
