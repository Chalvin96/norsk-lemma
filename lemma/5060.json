  "definitions": [
    {
      "text": "farge tre med visse tynne væsker slik at årer og tegninger skinner igjennom",
      "translation": "to color wood with thin liquids so that grain and patterns show through",
      "examples": [
        "beise huset"
      ]
    },
    {
      "text": "sette inn tøy eller garn med visse kjemiske stoffer i vannoppløsning for at fargestoffet skal feste seg til trådfibrene",
      "translation": "to treat fabric or yarn with chemical substances in aqueous solution so that the dye adheres to the fibers",
      "examples": []
    },
    {
      "text": "rense (metall) med syre",
      "translation": "to clean metal with acid",
      "examples": []
    },
    {
      "text": "fjerne smittestoffer fra såkorn eller verne frø mot skadedyr ved hjelp av varmt vann eller kjemikalier (i oppløsning eller pulverform)",
      "translation": "to remove infectious agents from seed grain, protect seeds from pests using hot water or chemicals (in solution or powder form)",
      "examples": []
    }
