        "røde og såre øyne",
        "såre føtter"
      ]
    },
    {
      "text": "som er preget av sjelelig smerte, lidelse eller sorg",
      "translation": "marked by emotional pain, suffering, or grief",
      "examples": [
        "såre hulk",
        "en sår gråt",
        "en sår følelse"
      ]
    },
    {
      "text": "som lett blir fornærmet fornærma eller snurt",
      "translation": "easily offended or touchy",
      "examples": []
    },
    {
      "text": "jamfør hårsår",
      "translation": "touchy",
      "examples": [
        "ha lett for å bli sår"
      ]
    },
    {
      "text": "som adverb: bittert, smertefullt",
      "translation": "bitterly, painfully",
      "examples": [
