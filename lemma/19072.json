    },
    {
      "text": "stirre dumt eller forundret (med åpen munn)",
      "translation": "to stare stupidly or in amazement (with an open mouth)",
      "examples": [
        "han ble sittende og gape"
      ]
    },
    {
      "text": "rope, skråle",
      "translation": "to shout, yell",
      "examples": [
