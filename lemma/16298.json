  "definitions": [
    {
      "text": "overtrekke med et tynt lag gull eller materiale som ligner gull",
      "translation": "to cover with a thin layer of gold or gold-like material",
      "examples": [
        "forgylle en ramme"
      ]
    },
    {
      "text": "gi gulaktig, skinnende skjær",
      "translation": "to give a yellowish, shiny sheen",
      "examples": []
    },
    {
      "text": "gjøre gyllen",
      "translation": "to make golden",
      "examples": [
        "sola forgyller åskammen"
      ]
    },
    {
      "text": "gjøre vakrere enn virkeligheten",
      "translation": "to make more beautiful than reality",
      "examples": []
    },
    {
      "text": "forskjønne, gylle",
      "translation": "to beautify, to gild",
      "examples": [
        "verket forgyller samfunnet"
      ]
    }
