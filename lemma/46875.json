  "definitions": [
    {
      "text": "suge eller presse væske eller gass gjennom (rør)ledning eller kanal ved hjelp av en pumpe",
      "translation": "to suck or press liquid or gas through a pipe or channel using a pump",
      "examples": [
        "pumpe vann",
        "pumpe opp en fotball"
      ]
    },
    {
      "text": "bevege seg rytmisk eller støtvis",
      "translation": "to move rhythmically, in a jerky manner",
      "examples": [
        "blodet pumpet ut av såret"
      ]
    }
  ]
