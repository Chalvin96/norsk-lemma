  "definitions": [
    {
      "text": "plutselig og voldsom start, framvekst eller lignende av noe",
      "translation": "sudden and violent start, emergence of something",
      "examples": [
        "utbruddet av omgangssyke",
        "vulkanen hadde utbrudd i forrige uke"
      ]
    },
    {
      "text": "det at en hvilende sykdom som herpes eller eksem gir symptomer som utslett, sår eller lignende",
      "translation": "the occurrence of symptoms such as rash or sores in a dormant disease like herpes or eczema",
      "examples": []
    },
    {
      "text": "i sykkelritt eller løp: det å (forsøke å) bryte ut fra en gruppe",
      "translation": "in cycling races or running: the act of (attempting to) break away from a group",
      "examples": [
        "tre av løperne forsøkte seg på et utbrudd"
      ]
    },
    {
      "text": "plutselig følelsesuttrykk",
      "translation": "sudden emotional expression",
      "examples": []
    },
    {
      "text": "brå ytring",
