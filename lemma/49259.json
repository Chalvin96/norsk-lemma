  "definitions": [
    {
      "text": "trekke fort til seg",
      "translation": "pull quickly towards oneself",
      "examples": []
    },
    {
      "text": "nappe hardt, dra",
      "translation": "tug hard, pull",
      "examples": [
        "rykke i båndet",
        "han rykker til seg armen",
        "han rykket seg løs fra henne",
        "hun rykket i døra, men den stod bom fast"
      ]
    },
    {
      "text": "brå og skjelvende bevegelse i (en del av) kroppen, ofte ufrivillig",
      "translation": "sudden and jerky movement in (a part of) the body, often involuntary",
      "examples": [
        "det rykket i øyelokkene hennes",
        "plutselig rykket det voldsomt i beinet hans"
      ]
    },
    {
      "text": "flytte seg (raskt og bestemt) i en retning",
      "translation": "move (quickly and decisively) in a direction",
      "examples": []
    },
    {
      "text": "fare",
      "translation": "fare",
      "examples": [
        "hæren rykket vestover",
        "køen rykker ganske raskt fremover"
      ]
