    {
      "text": "berøre lett",
      "translation": "to touch lightly",
      "examples": []
    },
    {
      "text": "støte lett ved eller på",
      "translation": "to bump lightly against or on",
      "examples": [
        "tennisballen tøtsjet nettkanten",
        "bilen tøtsjer borti gjerdet"
      ]
    },
    {
      "text": "så vidt nevne eller ta for seg",
      "translation": "to mention or deal with only slightly",
      "examples": [
        "tøtsje innom spørsmålet",
        "han tøtsjet bare emnet"
      ]
    }
  ]
