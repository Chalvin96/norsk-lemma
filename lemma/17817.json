  "cross_reference": null,
  "definitions": [
    {
      "text": "det å bli eller gjøre fremmed overfor noe",
      "translation": "the act of becoming alienated from something",
      "examples": []
    },
    {
      "text": "følelse av å stå utenfor og være maktesløs i det miljøet en er i",
      "translation": "feeling of being an outsider and powerless in one's environment",
      "examples": [
        "fremmedgjøringen i det moderne industrisamfunnet",
        "menneskets fremmedgjøring",
        "sosial fremmedgjøring"
      ]
    },
    {
      "text": "i marxistisk teori: det at mennesket mister kontrollen over resultatene av virksomheten sin og blir fremmed for sine egne produkter",
      "translation": "in Marxist theory: the loss of control over the results of one's labor and becoming estranged from one's own products",
      "examples": []
    }
  ]
