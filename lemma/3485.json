  "definitions": [
    {
      "text": "gjøre slutt på, løse en strid eller et tvilsspørsmål",
      "translation": "to put an end to, resolve a dispute or a question",
      "examples": [
        "avgjøre hvem som er sterkest",
        "det avgjør saken"
      ]
    },
    {
      "text": "bestemme, beslutte",
      "translation": "to decide, to resolve",
      "examples": [
        "det kan vi avgjøre senere",
        "det må du selv avgjøre",
        "det skal hun avgjøre"
      ]
    },
    {
      "text": "gjøre endelig vedtak i en sak",
      "translation": "to make a final decision in a case",
      "examples": [
        "saken blir avgjort i statsråd"
      ]
    },
    {
      "text": "gjøre utslaget",
      "translation": "to be decisive",
      "examples": [
        "kondisjonen avgjorde kampen"
      ]
    }
