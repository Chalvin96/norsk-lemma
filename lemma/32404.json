  "definitions": [
    {
      "text": "tørkede (og ofte pulveriserte) plantedeler med sterk smak og lukt som brukes som smakstilsetning i mat",
      "translation": "dried (and often powdered) plant parts with a strong taste and smell used as a flavoring in food",
      "examples": [
        "bruke mye krydder i maten"
      ]
    },
    {
      "text": "i overført betydning: noe som frisker opp eller setter farge på noe",
      "translation": "in a figurative sense: something that livens up or adds color to something",
      "examples": [
        "virke som krydder i hverdagen"
      ]
    }
