  "cross_reference": null,
  "definitions": [
    {
      "text": "feste med tau, bånd eller lignende",
      "translation": "fasten with rope, band or similar",
      "examples": [
        "binde båten ved brygga",
        "binde et tau rundt noe",
        "binde opp håret i en hestehale"
      ]
    },
    {
      "text": "lage eller gjøre i stand ved å flette, knytte eller feste på annen måte",
      "translation": "make or prepare by braiding, tying or fastening in another way",
      "examples": [
        "binde en not",
        "binde kranser",
        "binde inn en bok"
      ]
    },
    {
      "text": "holde på plass",
      "translation": "hold in place",
      "examples": []
    },
    {
      "text": "få til å feste seg",
      "translation": "cause to adhere",
      "examples": [
        "limet binder godt",
        "vann binder støvet",
        "steinene binder hverandre i muren"
      ]
    },
    {
      "text": "i kjemi: være knyttet til",
      "translation": "in chemistry: be attached to",
      "examples": [
        "jern forekommer ikke fritt, men bundet til andre stoffer"
      ]
    },
    {
      "text": "være, bli (fast) knyttet til eller avhengig av noe eller noen",
      "translation": "be, become (firmly) attached to or dependent on something or someone",
      "examples": [
        "være bundet til familien",
        "være bundet til rullestolen",
        "være bundet av taushetsplikten"
      ]
    },
    {
      "text": "bringe, knytte til hverandre",
      "translation": "bring, connect to each other",
      "examples": [
        "veien binder bygdene sammen"
      ]
    }
  ]
