  "definitions": [
    {
      "text": "vedta at et område, en dyre- eller planteart skal vernes mot alle inngrep",
      "translation": "to decree that an area, an animal or plant species shall be protected from all intervention",
      "examples": []
    },
    {
      "text": "jamfør frede",
      "translation": "to protect",
      "examples": [
        "de vil totalfrede hummeren i fjorden"
      ]
    },
    {
      "text": "i overført betydning: unnta fra kritikk, nedskjæringer, oppsigelser eller lignende",
      "translation": "to exempt from criticism, cutbacks, dismissals",
      "examples": [
        "lederen er totalfredet i omstillingsprosessen"
      ]
