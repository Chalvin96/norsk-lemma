  "cross_reference": null,
  "definitions": [
    {
      "text": "omringe og isolere en by, en festning eller lignende med en hærstyrke for å tvinge den til å overgi seg",
      "translation": "surround and isolate a city or fortress with an army to force it to surrender",
      "examples": [
        "beleire en by"
      ]
    },
    {
      "text": "i overført betydning: samle seg tett rundt noe eller noen for å oppnå noe",
      "translation": "gather closely around something or someone to achieve something",
      "examples": [
        "hotellet ble beleiret av pressefolk",
        "politiet beleiret huset"
      ]
    }
  ]
