  "definitions": [
    {
      "text": "kjøre inn under tak",
      "translation": "drive in under cover",
      "examples": [
        "alt høyet er innkjørt"
      ]
    },
    {
      "text": "ta igjen deltager i billøp, sykkelløp eller lignende",
      "translation": "catch up to a participant in a race",
      "examples": []
    },
    {
      "text": "innhente",
      "translation": "catch up",
      "examples": [
        "bli innkjørt i oppløpet"
      ]
    },
    {
      "text": "vinne penger, premier eller lignende i et løp",
      "translation": "win money, prizes in a race",
      "examples": [
        "alpinisten har passert 200 000 kroner innkjørt i år"
      ]
    },
    {
      "text": "om bruksdyr: temmet så det kan kjøres med",
      "translation": "for draft animals: tamed so it can be driven",
      "examples": [
        "hestene var innkjørte og skulle gå i tospann"
      ]
    },
    {
      "text": "prøve ut og gjøre skikket til vanlig drift",
      "translation": "test and make fit for normal operation",
      "examples": [
        "en motor må innkjøres før den kan yte sitt beste",
        "det nye systemet er ikke innkjørt ennå"
      ]
    }
