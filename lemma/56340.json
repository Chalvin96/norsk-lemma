  "definitions": [
    {
      "text": "få til å eksplodere eller springe i stykker",
      "translation": "cause to explode or burst into pieces",
      "examples": [
        "de sprengte en mine",
        "sprenge noe i lufta",
        "vi sprenger ut en tunnel",
        "naboen har sprengt vekk fjell"
      ]
    },
    {
      "text": "bryte (opp)",
      "translation": "break (open)",
      "examples": [
        "sprenge en låst dør",
        "han sprenger lenkene",
        "koalisjonen ble sprengt"
      ]
    },
    {
      "text": "ødelegge ved overanstrengelse",
      "translation": "ruin by overexertion",
      "examples": [
