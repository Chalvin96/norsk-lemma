      ]
    },
    {
      "text": "overskride, overbelaste",
      "translation": "exceed, overload",
      "examples": [
        "sprenge et budsjett",
        "alle hoteller er sprengt"
      ]
    },
    {
      "text": "presse, trenge",
      "translation": "push, press",
      "examples": [
