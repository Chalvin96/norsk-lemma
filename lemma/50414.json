  "definitions": [
    {
      "text": "stor duk, ofte trekantet eller firkantet, som er festet i en mast eller lignende på en båt, et skip eller annet fartøy, og som fanger vinden og driver fartøyet framover",
      "translation": "large piece of fabric, often triangular or square, attached to a mast on a boat, ship, or other vessel, which catches the wind and propels the vessel forward",
      "examples": [
        "heise seil",
        "skuta hadde alle seilene oppe",
        "store, hvite seil"
      ]
    },
    {
      "text": "utspent duk eller presenning som brukes for å fange opp noe eller til vern mot noe",
      "translation": "stretched fabric or tarpaulin used to catch something for protection against something",
      "examples": [
        "sitte under seilet"
      ]
    }
  ]
