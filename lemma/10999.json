  "cross_reference": null,
  "definitions": [
    {
      "text": "dø ved å bli kvalt i vann eller annen væske",
      "translation": "die by being suffocated in water or other liquid",
      "examples": [
        "drukne i elva",
        "falle over bord og drukne",
        "de gikk gjennom isen og druknet"
      ]
    },
    {
      "text": "drepe ved å kvele i vann",
      "translation": "kill by suffocating in water",
      "examples": [
        "hun ble anklaget for å ha prøvd å drukne sitt eget barn",
        "han orket ikke mer av livet og druknet seg"
      ]
    },
    {
      "text": "bli overlesset, nedgravd eller overdøvet",
      "translation": "become overwhelmed, buried, or drowned out",
      "examples": []
    },
    {
      "text": "forsvinne eller bli mindre eller svakere",
      "translation": "disappear or become smaller or weaker",
      "examples": [
        "han druknet i farens frakk",
        "drukne i mengden",
        "drukne i reklame",
        "ordene hennes druknet i den høye musikken"
      ]
    },
    {
      "text": "få til å bli mindre eller forsvinne",
      "translation": "cause to become smaller or disappear",
      "examples": []
    },
    {
      "text": "døyve, dempe",
      "translation": "dull, dampen",
      "examples": [
        "drukne sorgene i alkohol"
      ]
    }
  ]
