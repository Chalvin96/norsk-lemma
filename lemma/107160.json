  "definitions": [
    {
      "text": "i idrett: lede, trene, instruere lag eller utøver med vekt på det mentale",
      "translation": "in sports: to lead, train, instruct a team or athlete with an emphasis on the mental aspect",
      "examples": [
        "coache laget gjennom kampen"
      ]
    },
    {
      "text": "veilede noen når det gjelder personlig utvikling, menneskelige relasjoner eller lignende, ofte i arbeidslivet",
      "translation": "to guide someone regarding personal development or human relations, often in the workplace",
      "examples": [
        "coache de ansatte til å innta et nytt tankesett"
      ]
    }
  ]
