  "cross_reference": null,
  "definitions": [
    {
      "text": "stikke eller hekte (hake, krok eller lignende) inn i ring eller annen åpning",
      "translation": "to stick or hook (hook, crook) into a ring or other opening",
      "examples": [
        "huke båtshaken i fortøyningsringen",
        "huke en nøkkel inn på nøkkelringen"
      ]
    },
    {
      "text": "gripe eller dra til seg med hake, krok eller lignende",
      "translation": "to grab or pull in with a hook, crook",
      "examples": [
        "huke fisken opp i båten"
      ]
    },
    {
      "text": "få tak i",
      "translation": "to get hold of",
      "examples": []
    },
    {
      "text": "fakke, arrestere",
      "translation": "to nab, arrest",
      "examples": [
        "tyvene ble raskt huket"
      ]
    }
  ]
