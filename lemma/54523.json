  "cross_reference": null,
  "definitions": [
    {
      "text": "slutte å brenne eller lyse",
      "translation": "stop burning or shining",
      "examples": [
        "bålet har sloknet",
        "lampa sloknet"
      ]
    },
    {
      "text": "blekne bleikne, svinne",
      "translation": "fade, dwindle",
      "examples": [
        "stjernene sloknet"
      ]
    },
    {
      "text": "miste sin glans",
      "translation": "lose one's luster",
      "examples": [
        "øynene hennes sloknet",
        "smilet slokner i ansiktet"
      ]
    },
    {
      "text": "i overført betydning: sovne",
      "translation": "fall asleep",
      "examples": [
        "jeg hadde sloknet fullt påkledd"
      ]
    },
    {
      "text": "i overført betydning: slutte å leve",
      "translation": "stop living",
      "examples": [
        "hunden sloknet i armene hans"
      ]
    },
    {
      "text": "gå i stå",
      "translation": "stop, stall",
      "examples": []
    },
    {
      "text": "stanse",
      "translation": "stop, halt",
      "examples": [
        "motoren sloknet"
      ]
    }
  ]
