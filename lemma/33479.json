    },
    {
      "text": "fylle med elektrisk energi",
      "translation": "to charge with electrical energy",
      "examples": [
        "lade et bilbatteri",
        "mobilen er ladet"
      ]
    },
    {
      "text": "i overført betydning: fylle med en bestemt følelse, stemning, betydning eller lignende",
      "translation": "to imbue with a specific feeling, atmosphere, or meaning",
      "examples": [
        "det tomme huset var ladet med uhygge",
        "et negativt ladet ord"
      ]
    },
    {
