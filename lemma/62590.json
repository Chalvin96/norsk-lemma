  "definitions": [
    {
      "text": "presse, klemme",
      "translation": "to press, to squeeze",
      "examples": []
    },
    {
      "text": "jamfør trykkende",
      "translation": "to be oppressive",
      "examples": [
        "hun trykker hånden hans",
        "trykke på knappen",
        "trykke hardt på bremsen",
        "fronten på bilen er trykket inn",
        "trykk deigen flat med hendene",
        "trykke sammen søppelet for å gjør det mer kompakt",
        "jenta trykker seg inn til pappaen sin",
        "folk trykket seg sammen i heisen"
      ]
    },
    {
      "text": "være avventende og føle seg pinlig berørt",
      "translation": "to be hesitant and feel embarrassed",
      "examples": []
    },
    {
      "text": "jamfør trykkende og trykket trykt",
      "translation": "to be oppressive and feel pressured",
      "examples": [
        "sitte og trykke en hel kveld"
      ]
    },
    {
      "text": "være i en vanskelig situasjon",
      "translation": "to be in a difficult situation",
      "examples": [
        "vi hjelper hverandre der det trykker"
      ]
    },
    {
      "text": "om visse småvilt og fuglar: ligge urørlig for ikke å bli sett",
      "translation": "for certain small game and birds: to lie still to avoid being seen",
      "examples": [
        "haren trykte",
        "rypa trykker og er vanskelig å finne"
      ]
    }
