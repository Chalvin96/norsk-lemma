  "definitions": [
    {
      "text": "ekteskap som er inngått av praktiske grunner framfor kjærlighet",
      "translation": "marriage entered into for practical reasons rather than love",
      "examples": [
        "de levde sammen i et fornuftsekteskap"
      ]
    },
    {
      "text": "i overført betydning: samarbeid eller allianse som er inngått av praktiske grunner og ikke av genuin lyst eller interesse",
      "translation": "in a figurative sense: cooperation or alliance entered into for practical reasons and not out of genuine desire or interest",
      "examples": [
        "koalisjonsregjeringen er et fornuftsekteskap",
        "alliansen mellom landene kan best betegnes som et fornuftsekteskap"
      ]
    }
