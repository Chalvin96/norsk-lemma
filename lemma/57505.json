  "definitions": [
    {
      "text": "gi straff, refse eller tukte for en misgjerning",
      "translation": "to punish, to reprimand or chastise for a misdeed",
      "examples": [
        "faren straffet barna strengt når de var ulydige"
      ]
    },
    {
      "text": "dømme for lovbrudd",
      "translation": "to convict for an offense",
      "examples": [
        "tiltalte er ikke tidligere straffet"
      ]
    },
    {
      "text": "i idrett: overgå eller forbedre",
      "translation": "to surpass or improve",
      "examples": [
        "hun straffet den tidligere rekorden med 2 tidels sekund",
        "utlendingene straffer oss på lengdene",
        "ingen kunne straffe henne i kretsmesterskapet"
      ]
    }
