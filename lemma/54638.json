  "definitions": [
    {
      "text": "kaste noe rundt noe",
      "translation": "to throw something around something",
      "examples": []
    },
    {
      "text": "sno, flette",
      "translation": "to twist, to braid",
      "examples": [
        "slynge armene rundt noen"
      ]
    },
    {
      "text": "kaste eller slenge med stor kraft",
      "translation": "to throw or fling with great force",
      "examples": [
        "sola slynger ut enorme gasskyer",
        "han ble slynget ut av båten i fart"
      ]
    },
    {
      "text": "sentrifugere (for eksempel salat eller vokskaker) for å skille ut væske",
      "translation": "to centrifuge (e.g., salad or wax cakes) to extract liquid",
      "examples": [
        "slynge salatbladene tørre",
        "slynge honning"
      ]
    }
  ]
