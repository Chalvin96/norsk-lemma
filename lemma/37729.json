  "definitions": [
    {
      "text": "hvit eller gulhvit næringsrik væske som blir skilt ut av melkekjertlene hos hunnpattedyr, særlig kyr",
      "translation": "white or yellowish-white nutritious liquid secreted by the mammary glands of female mammals, especially cows",
      "examples": [
        "drikke melk til maten",
        "homogenisert og pasteurisert melk",
        "skummet melk",
        "melka har skilt seg",
        "kua gir mye  melk"
      ]
    },
    {
      "text": "væske som plante skiller ut, og som ligner på melk mjølk",
      "translation": "liquid secreted by a plant, resembling milk",
