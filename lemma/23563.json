  "definitions": [
    {
      "text": "om land, øyer langt unna: se ut til å sveve i lufta over horisonten",
      "translation": "to appear to float in the air above the horizon (of land, distant islands)",
      "examples": [
        "hildre opp over horisonten",
        "øyer og holmer hildret i solglansen"
      ]
    },
    {
      "text": "vise seg i fantasien som noe uvirkelig eller uoppnåelig",
      "translation": "to appear in the imagination as something unreal or unattainable",
      "examples": []
    },
    {
      "text": "dåre, fortrylle",
      "translation": "to fool, enchant",
      "examples": [
        "han ble hildret av trollkvinnen",
        "hun var hildrende vakker"
      ]
    }
  ]
