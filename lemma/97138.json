  "definitions": [
    {
      "text": "det å vurdere andre kulturer og nasjoner ut fra de gjeldende verdiene, normene og praksisene i sin egen kultur eller å sette sin egen nasjon og kultur høyere enn andre",
      "translation": "the act of evaluating other cultures and nations based on the prevailing values, norms, and practices of one's own culture, or placing one's own nation and culture above others",
