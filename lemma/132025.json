  "definitions": [
    {
      "text": "det at noe blir gjort eller skjer på rett tidspunkt i forhold til noe annet",
      "translation": "the fact that something is done or happens at the right moment in relation to something else",
      "examples": [
        "det var dårlig timing at du kom nå",
        "komikeren har god timing"
      ]
    },
    {
      "text": "det å organisere eller fastsette tidspunkt og tidsramme for en eller flere aktiviteter",
      "translation": "the act of organizing or setting the time and timeframe for one or more activities",
      "examples": [
        "få til rett timing på arrangementet",
