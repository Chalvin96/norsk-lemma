  "definitions": [
    {
      "text": "skjøte eller flette sammen to tauender",
      "translation": "join or splice together two rope ends",
      "examples": [
        "elevene lærte å spleise tau"
      ]
    },
    {
      "text": "i overført betydning: føre sammen personer så de blir et par eller en gruppe",
      "translation": "bring people together so they become a couple or a group",
      "examples": [
        "han ble spleiset med en utenlandsk kvinne",
        "spleise elevene enda bedre sammen"
      ]
    },
    {
      "text": "legge sammen penger for å betale for noe",
      "translation": "pool money to pay for something",
      "examples": [
        "de spleiset på en gave til kollegaen"
      ]
    }
  ]
