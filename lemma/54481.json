  "cross_reference": null,
  "definitions": [
    {
      "text": "bli løs eller fri",
      "translation": "to become loose or free",
      "examples": []
    },
    {
      "text": "få bevege seg fritt",
      "translation": "to be allowed to move freely",
      "examples": [
        "hun slapp ut av karantenen",
        "de slapp fra forfølgeren",
        "jeg slipper ikke fra hjemme i dag",
        "han prøvde å slippe unna politiet",
        "gislene ble sluppet fri",
        "vi slipper ikke inn i bygget",
        "varene har sluppet gjennom kontrollen",
        "vi slapp tidligere på skolen i dag"
      ]
    },
    {
      "text": "bli fritatt eller spart for",
      "translation": "to be exempted or spared from",
      "examples": []
    },
    {
      "text": "bli kvitt",
      "translation": "to get rid of",
      "examples": [
        "de slapp lett fra ulykken",
        "vi slipper å rydde i dag",
        "jeg slapp heldigvis å betale full pris",
        "de håper å slippe millitærtjenesten",
        "fatet slapp ut av hendene mine"
      ]
    },
    {
      "text": "miste eller løsne taket i noe",
      "translation": "to lose grip on something",
      "examples": []
    },
    {
      "text": "la noe eller noen bevege seg fritt",
      "translation": "to let something or someone move freely",
      "examples": [
        "hun slapp koppen i gulvet",
        "han slipper hunden løs",
        "selja slipper barken",
        "slipp meg!",
        "sykdommen har sluppet taket",
        "de slapp ham ut av fengselet",
        "hun slapp sinnet løs"
      ]
    },
    {
      "text": "la seg gli",
      "translation": "to slide",
      "examples": []
    },
    {
      "text": "falle",
      "translation": "to fall",
      "examples": [
        "slippe seg ned fra en gren"
      ]
    },
    {
      "text": "slutte å interessere",
      "translation": "to stop being interesting",
      "examples": []
    },
    {
      "text": "slutte å holde fast ved",
      "translation": "to stop holding onto",
      "examples": [
        "ideen ville ikke slippe meg",
        "de ville ikke slippe samtaleemnet"
      ]
    },
    {
      "text": "bryte av",
      "translation": "to break off",
      "examples": []
    },
    {
      "text": "stanse",
      "translation": "to stop",
      "examples": [
        "vi begynner igjen der vi slapp"
      ]
    }
  ]
