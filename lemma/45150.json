  "cross_reference": null,
  "definitions": [
    {
      "text": "sette en plante med røttene i jord",
      "translation": "to set a plant with its roots in soil",
      "examples": [
        "plante et epletre",
        "de planter roser i bedet"
      ]
    },
    {
      "text": "bygge opp et område ved å sette en stor mengde planter i jorda",
      "translation": "to build up an area by setting a large number of plants in the ground",
      "examples": [
        "plante skog",
        "de plantet en vingård"
      ]
    },
    {
      "text": "plassere noe fast og stødig",
      "translation": "to place something firmly and steadily",
      "examples": [
        "plante neven i bordet",
        "hun planter begge beina i gulvet"
      ]
    },
    {
      "text": "i hemmelighet plassere noe eller noen et sted for å skade eller avsløre",
      "translation": "to secretly place something or someone somewhere to harm or expose",
      "examples": [
        "plante en spion i fiendens leir",
        "noen hadde plantet narkotika i leiligheten hennes"
      ]
    }
  ]
