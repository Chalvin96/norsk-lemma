  "definitions": [
    {
      "text": "gjøre mørkere",
      "translation": "to make darker",
      "examples": [
        "skyer formørket himmelen"
      ]
    },
    {
      "text": "stenge utsikten til en lyskilde",
      "translation": "to block the view of a light source",
      "examples": []
    },
    {
      "text": "skygge for",
      "translation": "to cast a shadow over",
      "examples": [
        "månen formørker sola"
      ]
    },
    {
      "text": "i overført betydning: gjøre dyster og trist",
      "translation": "in a figurative sense: to make gloomy and sad",
      "examples": [
        "formørke tilværelsen",
        "tiden ble formørket av krig",
        "du må ikke la dette formørke livet ditt"
      ]
    }
