  "definitions": [
    {
      "text": "ha flagg heist eller hengt ut",
      "translation": "to have a flag hoisted or displayed",
      "examples": [
        "flagge for noen",
        "hele byen flagger i dag"
      ]
    },
    {
      "text": "gi tegn med flagg",
      "translation": "to signal with flags",
      "examples": [
        "bli flagget inn som vinner av billøpet"
      ]
    },
    {
      "text": "gjøre kjent, vise fram",
      "translation": "to make known, to show off",
      "examples": []
    },
    {
      "text": "briske seg",
      "translation": "to boast",
      "examples": [
        "flagge sin misnøye",
        "partiet har flagget sitt standpunkt i saken",
        "ikke ha så mye å flagge med"
      ]
    }
