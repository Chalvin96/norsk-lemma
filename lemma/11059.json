  "definitions": [
    {
      "text": "få til å vare eller nå lenger",
      "translation": "make last or reach further",
      "examples": []
    },
    {
      "text": "gjøre drøy dryg",
      "translation": "make dry, last longer",
      "examples": [
        "drøye kjøttdeigen med soyamel",
        "i slike tider var det vanlig å drøye melet med bark"
      ]
    },
    {
      "text": "vare lenge eller forlenge",
      "translation": "last long or extend",
      "examples": []
    },
    {
      "text": "dra ut",
      "translation": "drag out",
      "examples": [
        "møtet drøyde ut",
        "vi drøyde tiden med å se oss litt rundt"
      ]
    },
    {
      "text": "utsette eller bli utsatt",
      "translation": "postpone or be postponed",
      "examples": [
