    {
      "text": "ha som navn",
      "translation": "to have as a name",
      "examples": [
        "jeg heter Leah, hva heter du?",
        "han heter Christian etter bestefaren",
        "hva het firmaet du arbeidet for?",
        "hovedstaden i Norge heter Oslo",
