  "definitions": [
    {
      "text": "rette våpen, apparat eller instrument mot et mål",
      "translation": "to aim a weapon, apparatus, or instrument at a target",
      "examples": [
        "sikte på noen med et gevær"
      ]
    },
    {
      "text": "ta øyemål",
      "translation": "to take visual aim",
      "examples": [
        "sikte for å se om stolpene står på linje"
      ]
    },
    {
      "text": "prøve å oppnå noe",
      "translation": "to try to achieve something",
      "examples": []
    },
    {
      "text": "ha som mål",
      "translation": "to have as a goal",
      "examples": [
        "jeg sikter ikke så høyt"
      ]
