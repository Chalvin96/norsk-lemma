  "definitions": [
    {
      "text": "hvert av to høreorganer hos mennesker og dyr, plassert på hver side av hodet",
      "translation": "each of two hearing organs in humans and animals, placed on each side of the head",
      "examples": [
        "ha store, utstående ører",
        "ha ringer i ørene",
        "en katt med dusker på ørene"
      ]
    },
    {
      "text": "øre brukt særlig med tanke på det å få eller oppfatte hørselsinntrykk",
      "translation": "ear used especially with regard to the act of receiving or perceiving auditory impressions",
      "examples": [
        "en svak lyd nådde ørene",
        "høre dårlig på det høyre øret",
        "ikke tro sine egne ører",
        "slikt lyder rart for et norsk øre"
      ]
    },
