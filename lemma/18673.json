      ]
    },
    {
      "text": "komme etter (som neste ledd)",
      "translation": "to come after (as the next item)",
      "examples": []
    },
    {
      "text": "avløse",
      "translation": "to succeed",
      "examples": [
        "en vond tid fulgte",
        "brev følger",
        "følge etter en på tronen"
      ]
    },
    {
      "text": "dra langsetter",
      "translation": "to travel alongside",
      "examples": [
        "vi fulgte E6 til Oppdal",
        "hunden følger sporene"
      ]
    },
    {
      "text": "rette oppmerksomheten mot",
      "translation": "to direct attention towards",
      "examples": []
    },
    {
      "text": "observere, oppfatte, studere",
      "translation": "to observe, perceive, study",
      "examples": [
