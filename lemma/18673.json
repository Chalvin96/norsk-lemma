        "greie å følge et resonnement",
        "følge utviklingen nøye",
        "følge en med øynene"
      ]
    },
    {
      "text": "handle i samsvar med",
      "translation": "to act in accordance with",
      "examples": []
    },
    {
      "text": "rette seg etter",
      "translation": "to comply with",
      "examples": [
        "følge en innskytelse",
        "følge spillereglene",
