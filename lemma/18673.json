  "definitions": [
    {
      "text": "fare, gå eller bevege seg sammen med",
      "translation": "to travel, go or move together with",
      "examples": []
    },
    {
      "text": "ledsage, eskortere",
      "translation": "to accompany, to escort",
      "examples": [
        "følge gjestene til døra",
        "følge strømmen",
