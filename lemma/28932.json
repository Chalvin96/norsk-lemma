  "cross_reference": null,
  "definitions": [
    {
      "text": "sende noe eller noen gjennom lufta med hånden eller et redskap",
      "translation": "to send something or someone through the air with the hand or an implement",
      "examples": [
        "kaste terninger",
        "han kastet kofferten på sofaen",
        "de kastet jord på kisten"
      ]
    },
    {
      "text": "slenge eller legge fra seg",
      "translation": "to fling or lay down",
      "examples": [
        "kaste alt en har i hendene",
        "de kaster løvet i en haug",
        "han kastet genseren på stolen",
        "de kastet fram et forslag",
        "trærne har kastet bladene"
      ]
    },
    {
      "text": "bevege brått",
      "translation": "to move suddenly",
      "examples": [
        "kaste børsa til kinnet",
        "de kaster seg ned",
        "hun kastet bilen til side",
        "du kaster bort tiden",
        "de kastet regjeringen",
        "han har kastet alle hemninger"
      ]
    },
    {
      "text": "sette not eller line i sjøen",
      "translation": "to set net or line in the sea",
      "examples": [
        "kaste etter sild"
      ]
    },
    {
      "text": "sende",
      "translation": "to send",
      "examples": []
    },
    {
      "text": "lage",
      "translation": "to make",
      "examples": [
        "kaste skygge",
        "lyden ble kastet tilbake"
      ]
    },
    {
      "text": "i overført betydning: sende, overføre, skape",
      "translation": "to send, transfer, create",
      "examples": [
        "han prøver å kaste mistanken over på søsteren",
        "de kastet frifinnelsen i tvil"
      ]
    },
    {
      "text": "flytte med makt",
      "translation": "to move by force",
      "examples": []
    },
    {
      "text": "jage ut, fordrive",
      "translation": "to drive out, expel",
      "examples": [
        "de kastet ham i fengsel"
      ]
    },
    {
      "text": "om dyr: føde for tidlig",
      "translation": "of animals: to give birth prematurely",
      "examples": [
        "kua kastet kalven"
      ]
    },
    {
      "text": "sy over stoffkant med kastesting",
      "translation": "to sew over the edge of fabric with a catch stitch",
      "examples": []
    }
  ]
