  "cross_reference": null,
  "definitions": [
    {
      "text": "straffe eller prøve med ulykke, motgang eller lignende",
      "translation": "to punish or test with misfortune, adversity",
      "examples": [
        "fedrenes synder hjemsøkes på barna"
      ]
    },
    {
      "text": "om ulykke, plage, motgang: ramme, plage",
      "translation": "concerning misfortune, plague, adversity: to strike, to plague",
      "examples": [
        "landet ble hjemsøkt av uår og sult",
        "indre stridigheter hjemsøker partiet",
        "de vonde minnene hjemsøkte ham resten av livet"
      ]
    },
    {
      "text": "om spøkelse, ånd eller lignende: oppsøke en person eller et sted, særlig for å plage eller hevne seg",
      "translation": "concerning ghosts, spirits: to visit a person or place, especially to plague or take revenge",
      "examples": [
        "familien ble hjemsøkt av onde ånder",
        "han ble hjemsøkt av sin døde fars gjenferd",
        "et hjemsøkt hus"
      ]
    }
  ]
