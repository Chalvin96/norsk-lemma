  "definitions": [
    {
      "text": "slå eller hogge gjentatte ganger (med skarpt redskap)",
      "translation": "to strike or chop repeatedly (with a sharp tool)",
      "examples": [
        "hakke med kniven i en plankestubb",
        "hakke hull på isen",
        "hønene hakket hverandre"
      ]
    },
    {
      "text": "dele i småbiter",
      "translation": "to divide into small pieces",
      "examples": [
        "hakke urter",
        "hakke opp kjøtt",
        "hakke i stykker noe"
      ]
    },
    {
      "text": "lyde ujevnt eller støtvis",
      "translation": "to sound uneven or intermittent",
      "examples": [
        "motoren hakket og harket",
        "han hakket og stammet"
      ]
    },
    {
      "text": "i håndarbeid: hekle på en spesiell måte",
      "translation": "in needlework: to crochet in a special way",
      "examples": []
    }
  ]
