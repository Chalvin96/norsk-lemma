  "definitions": [
    {
      "text": "gjøre rund eller avrundet",
      "translation": "to make round or rounded",
      "examples": [
        "runde kantene"
      ]
    },
    {
      "text": "bevege seg i en bue rundt noe",
      "translation": "to move in an arc around something",
      "examples": [
        "runde et gatehjørne",
        "båten rundet odden",
        "runde en motspiller"
      ]
    },
    {
      "text": "passere et høyt, rundt antall",
      "translation": "to pass a high, round number",
      "examples": [
        "runde 50 år",
        "hun har rundet millionen i inntekt"
      ]
    }
  ]
