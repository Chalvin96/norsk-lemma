  "definitions": [
    {
      "text": "gå til angrep på",
      "translation": "to go on the attack",
      "examples": [
        "fiendtlige styrker har angrepet hovedstaden",
        "bærplukkeren ble angrepet av en bjørn"
      ]
    },
    {
      "text": "i lagidett: forsøke å få mål",
      "translation": "in team sports: to try to score",
      "examples": [
        "laget angrep gjennom hele kampen"
      ]
    },
    {
      "text": "kritisere, polemisere mot",
      "translation": "to criticize, to polemicize against",
      "examples": [
        "regjeringens politikk ble sterkt angrepet"
      ]
    },
    {
      "text": "tære på, bryte ned, ødelegge øydelegge",
      "translation": "to wear down, break down, destroy",
      "examples": [
        "bli angrepet av en sykdom",
        "huset var angrepet av sopp og råte"
      ]
    },
    {
      "text": "ordne opp i",
      "translation": "to deal with",
      "examples": []
    },
    {
      "text": "løse løyse, takle",
      "translation": "to solve, tackle",
      "examples": [
        "angripe saken fra gal side",
        "hvordan skal dette angripes?"
      ]
    }
