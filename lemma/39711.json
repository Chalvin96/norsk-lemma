  "definitions": [
    {
      "text": "som har nådd voksen alder, i Norge 18 år, og som kan gjøre avtaler og rå over egne midler uten medvirkning av verge",
      "translation": "having reached the age of majority (18 in Norway), and able to make agreements and manage own assets without a guardian",
      "examples": []
    },
    {
      "text": "til forskjell fra mindreårig og umyndig",
      "translation": "in contrast to minor and legally incompetent",
      "examples": [
        "nå myndig alder",
        "han ble myndig i januar"
      ]
    },
    {
      "text": "som vitner om makt og autoritet",
      "translation": "showing power and authority",
      "examples": []
    },
    {
      "text": "fast, verdig, bestemt",
      "translation": "firm, dignified, determined",
      "examples": [
        "tale i en myndig tone",
        "gripe inn med myndig hånd",
        "en myndig leder",
        "opptre myndig"
