  "definitions": [
    {
      "text": "bevege seg raskt framover på føttene",
      "translation": "move forward quickly on foot",
      "examples": [
        "springe om kapp",
        "springe etter noen",
        "springe opp bakkene",
        "han springer fra de andre"
      ]
    },
    {
      "text": "endre eller flytte seg raskt",
      "translation": "change or move quickly",
      "examples": []
    },
    {
      "text": "hoppe, sprette, fyke",
      "translation": "jump, leap, dart",
      "examples": [
        "springe ut av bilen",
        "springe over noe",
        "prisene sprang i været",
        "øynene sprang nesten ut av hodet på dem",
        "døra sprang opp"
      ]
    },
    {
      "text": "brukt som adjektiv: usammenhengende",
      "translation": "used as an adjective: disjointed",
      "examples": [
