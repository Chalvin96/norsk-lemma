  "cross_reference": null,
  "definitions": [
    {
      "text": "gjøre (væske eller masse) mindre konsentrert",
      "translation": "to make (a liquid or mass) less concentrated",
      "examples": []
    },
    {
      "text": "fortynne, spe ut",
      "translation": "to dilute, to water down",
      "examples": [
        "vi tynner malingen med terpentin"
      ]
    },
    {
      "text": "hamre ut eller slipe eggen på",
      "translation": "to hammer out, to sharpen the edge of",
      "examples": [
        "tynne ljåen"
      ]
    },
    {
      "text": "gjøre (mer) glissen",
      "translation": "to make (more) sparse",
      "examples": []
    },
    {
      "text": "gjøre mindre tett",
      "translation": "to make less dense",
      "examples": [
        "tynne håret",
        "de tynner og planter i skogen"
      ]
    }
  ]
