  "definitions": [
    {
      "text": "noe en er pålagt å gjøre, for eksempel av myndigheter, arbeidsgiver eller som følge av en bindende avtale",
      "translation": "something one is obliged to do, for example by authorities, an employer, or as a result of a binding agreement",
      "examples": [
        "ha plikt til å møte opp",
        "offisielle plikter"
      ]
    },
    {
      "text": "noe en etter moralske eller religiøse leveregler føler seg bundet til å gjøre",
      "translation": "something one feels bound to do according to moral or religious principles",
      "examples": [
        "moralsk plikt",
        "gjøre noe av plikt",
        "det var hans simple plikt å hjelpe"
      ]
    }
