  "cross_reference": null,
  "definitions": [
    {
      "text": "lage bilde av eller gjengi ved hjelp av streker",
      "translation": "to create a picture of or represent using lines",
      "examples": [
        "lære å tegne",
        "tegne etter naturen",
        "han tegner en blomst"
      ]
    },
    {
      "text": "framstille skisse, plan eller lignende med streker",
      "translation": "to produce a sketch, plan, or similar using lines",
      "examples": [
        "tegne et hus",
        "tegne nye møbelmodeller"
      ]
    },
    {
      "text": "skrive, notere",
      "translation": "to write, to note down",
      "examples": [
        "tegne ned noen ord"
      ]
    },
    {
      "text": "gi en forpliktende underskrift på brev, kontrakter eller lignende",
      "translation": "to sign, to obtain a share in, to become the owner of",
      "examples": [
        "tegne nye medlemmer",
        "tegne seg på talerlista"
      ]
    },
    {
      "text": "sikre seg, få del i, bli eier av",
      "translation": "to secure, to get a share of, to become the owner of",
      "examples": [
        "tegne forsikring",
        "hun tegnet seg for 1000 kr på gavelista"
      ]
    },
    {
      "text": "vise tegn til",
      "translation": "to show signs of",
      "examples": []
    },
    {
      "text": "peke i retning av",
      "translation": "to point in the direction of",
      "examples": [
        "begynnelsen tegnet bra"
      ]
    },
    {
      "text": "skildre i ord",
      "translation": "to depict in words",
      "examples": [
        "tegne et dystert bilde av framtiden"
      ]
    }
  ]
