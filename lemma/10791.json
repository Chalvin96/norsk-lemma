      ]
    },
    {
      "text": "ta en ny retning",
      "translation": "to take a new direction",
      "examples": [
        "vinden dreier",
        "dreie til venstre",
        "dreie inn på en sidevei",
        "dreie samtalen inn på et nytt tema"
      ]
    },
    {
      "text": "forme med dreiebenk",
      "translation": "to shape on a lathe",
      "examples": [
        "dreie beina til en stol"
      ]
    },
    {
