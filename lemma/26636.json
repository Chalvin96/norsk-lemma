  "definitions": [
    {
      "text": "leddsetning der en innrømmer at det fins visse omstendigheter som taler mot det som blir sagt i hovedsetningen",
      "translation": "subordinate clause in which one admits that certain circumstances exist that speak against what is said in the main clause",
      "examples": [
        "‘selv om det regner’ er en innrømmelsessetning i hovedsetningen ‘selv om det regner, drar vi på tur’"
      ]
