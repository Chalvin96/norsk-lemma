  "definitions": [
    {
      "text": "improvisert gruppearbeid der deltakerne spiller gitte roller i tenkte situasjoner fra det virkelige liv",
      "translation": "improvised group work where participants play given roles in imagined situations from real life",
      "examples": [
        "kurset består av forelesninger, samtalegrupper og ulike rollespill"
      ]
    },
    {
      "text": "spill eller lek der hver deltaker spiller en rolle med gitte egenskaper, satt i en fiktiv verden, hvor de forteller en historie gjennom spillet",
      "translation": "game or play where each participant plays a role with given characteristics, set in a fictional world, where they tell a story through the game",
      "examples": [
        "rollespillet var satt i et fantasiverden med draker og demoner",
        "de spilte rollespill på dataen"
      ]
    }
  ]
