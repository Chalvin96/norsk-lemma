  "definitions": [
    {
      "text": "gi skygge",
      "translation": "to cast shade",
      "examples": [
        "skygge for sollyset",
        "skygge med hånden over øynene"
      ]
    },
    {
      "text": "i overført betydning: skjule, formørke",
      "translation": "to obscure, to darken (figuratively)",
      "examples": [
        "du må ikke la en detalj skygge for det faktum at resten er feilfritt"
      ]
    },
    {
      "text": "holde øye med i skjul",
      "translation": "to watch secretly",
      "examples": []
    },
    {
      "text": "spionere på",
      "translation": "to spy on",
      "examples": [
