  "cross_reference": null,
  "definitions": [
    {
      "text": "byggverk som lager vei over en hindring, særlig over elv eller sund",
      "translation": "structure that creates a path over an obstacle, especially over a river or strait",
      "examples": [
        "brua over elva",
        "kapteinen står på brua"
      ]
    },
    {
      "text": "kunstig tann festet i egne tenner",
      "translation": "artificial tooth attached to own teeth",
      "examples": [
        "sette inn en bru i overkjeven"
      ]
    },
    {
      "text": "stilling med ryggsiden ned og kroppen i bue slik at bare hender og fotsåler er i kontakt med underlaget",
      "translation": "position with the back down and the body arched so that only the hands and soles of the feet are in contact with the ground",
      "examples": [
        "gå ned i bru",
        "stå i bru"
      ]
    }
  ]
