        "det skal jeg aldri glemme deg for"
      ]
    },
    {
      "text": "legge igjen ved et uhell",
      "translation": "leave behind by accident",
      "examples": [
        "glemme boka hjemme",
        "jeg glemte lommeboka på butikken"
      ]
    },
    {
      "text": "ikke gjøre",
      "translation": "not do",
      "examples": []
    },
    {
      "text": "forsømme, unnlate",
      "translation": "neglect, fail to",
      "examples": [
