  "definitions": [
    {
      "text": "utestenge fra (plassering i) idrettskonkurranse på grunn av regelbrudd",
      "translation": "to disqualify from (a placement in) a sports competition due to a rule violation",
      "examples": [
        "A-laget ble diskvalifisert i stafetten"
