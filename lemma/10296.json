    },
    {
      "text": "gjøre uskikket",
      "translation": "to make unfit or unsuitable",
      "examples": [
        "med en slik uttalelse diskvalifiserer han seg selv",
        "fortiden hennes diskvalifiserer henne for dette oppdraget"
      ]
