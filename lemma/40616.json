  "definitions": [
    {
      "text": "si nei til",
      "translation": "to say no to",
      "examples": []
    },
    {
      "text": "avslå, avvise",
      "translation": "to decline, to reject",
      "examples": [
        "nekte militærtjeneste",
        "jeg nekter å bli med",
        "de var så beruset at de ble nektet servering"
      ]
    },
    {
      "text": "bestride riktigheten av",
      "translation": "to dispute the correctness of",
      "examples": []
    },
    {
      "text": "tvile på",
      "translation": "to doubt",
      "examples": [
        "nekte for Guds eksistens",
        "det kan du ikke nekte for",
        "den anklagede nektet seg skyldig",
        "det står ikke til å nekte for at kvaliteten er dårlig"
      ]
    },
    {
      "text": "i grammatikk: uttrykke et negativt forhold eller en nekting",
      "translation": "to express a negative relationship or a refusal",
      "examples": [
        "en nektende setning"
      ]
    }
