  "definitions": [
    {
      "text": "frambringe toner med stemmen",
      "translation": "produce tones with the voice",
      "examples": [
        "synge en sang",
        "juble og synge",
        "synge i et kor",
        "han har gått og sunget i flere år",
        "synge på en tilstelning",
        "synge julen inn",
        "alle sang med",
        "gå og synge på en slager"
      ]
    },
    {
      "text": "kvitre, spille spelle",
      "translation": "chirp, play",
      "examples": [
        "fuglene sang",
        "gresshoppene sang langs veikanten"
      ]
    },
    {
      "text": "skifte mellom høye og lave toner når en snakker",
      "translation": "shift between high and low tones when speaking",
      "examples": [
        "nordlendingene synger så når de snakker",
        "det sang i stålet når hammeren traff",
        "han slo i bordet så det sang",
        "bekken synger i sommerkvelden",
        "det suste og sang for ørene",
        "som dikteren synger om"
      ]
    }
  ]
