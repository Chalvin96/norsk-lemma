  "definitions": [
    {
      "text": "være uten",
      "translation": "to be without",
      "examples": []
    },
    {
      "text": "mangle",
      "translation": "to lack",
      "examples": [
        "ikke savne noe",
        "vi savner et teater her i byen"
      ]
    },
    {
      "text": "oppdage at en har mistet noe, at noe er borte",
      "translation": "to discover that something is lost or gone",
      "examples": [
        "savne lommeboka si",
        "to mann er savnet i fjellet",
        "de savnede er funnet i god behold"
      ]
    },
    {
      "text": "kjenne (smertelig) lengsel etter noe(n)",
      "translation": "to feel (painful) longing for someone or something",
      "examples": [
        "savne selskap",
        "være dypt savnet"
      ]
    }
  ]
