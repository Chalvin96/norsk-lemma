  "definitions": [
    {
      "text": "merke vei, sti eller lignende ved å sette opp staker eller lignende",
      "translation": "mark path or trail by setting up stakes",
      "examples": []
    },
    {
      "text": "åpne en trang passasje med bøyelig stang, stålfjær eller lignende",
      "translation": "open a narrow passage with a flexible rod or steel spring",
      "examples": [
        "stake opp en kloakkledning"
      ]
    },
    {
      "text": "skyve fram (med stake eller skistaver)",
      "translation": "push forward (with a pole or ski poles)",
      "examples": [
        "stake en elvebåt",
        "skiløperen staket oppover bakken"
      ]
