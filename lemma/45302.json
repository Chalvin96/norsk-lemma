  "definitions": [
    {
      "text": "brekke eller rykke løs (særlig del av plante)",
      "translation": "to break or pull off (especially a part of a plant)",
      "examples": []
    },
    {
      "text": "samle, sanke",
      "translation": "to gather, to collect",
      "examples": [
        "plukke blomster",
        "de plukker blåbær",
        "de plukket epler",
        "plukke poeng"
      ]
    },
    {
      "text": "rive, nappe",
      "translation": "to tear, to pluck",
      "examples": [
        "plukke øyebrynene",
        "plukke fjærene av en fugl"
      ]
    },
    {
      "text": "fingre, pirke, pille",
      "translation": "to fiddle, to pick at",
      "examples": [
        "sitte og plukke på noe"
      ]
    }
