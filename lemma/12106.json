  "definitions": [
    {
      "text": "vise fram",
      "translation": "to show off",
      "examples": [
        "eksponere sine ferdigheter",
        "eksponere en vare",
        "mange unge har lav terskel for å eksponere seg selv offentlig"
      ]
    },
    {
      "text": "(la) være omgitt og påvirkes av",
      "translation": "to be surrounded and affected by",
      "examples": [
        "ikke eksponer mobiltelefonen for sterk varme og sollys",
        "bli eksponert for helseskadelige faktorer som støy, lys, stråling, gass eller smitte",
        "barn lærer morsmålet ved å bli eksponert for språket"
      ]
    },
    {
      "text": "la lys virke på film eller sensor ved fotografering",
      "translation": "to let light act on film or sensor during photography",
      "examples": [
        "eksponere en film"
      ]
