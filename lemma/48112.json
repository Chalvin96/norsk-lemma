  "definitions": [
    {
      "text": "om væske eller masse: strømme, flyte, sige",
      "translation": "of liquid or mass: to flow, stream, pour",
      "examples": [
        "tårene renner",
        "elva rant stri",
        "en strøm av gjørme har rent ned fra vulkanen",
        "smeltevannet renner ut i havet",
        "melet rant ut av posen",
        "rennende vann"
      ]
    },
    {
      "text": "gi fra seg eller bli fylt av væske",
      "translation": "to give off or be filled with liquid",
      "examples": [
        "vannkranen rant",
        "nedbørsmåleren rant full",
        "rennende nese",
        "ha rennende øyne"
      ]
    },
    {
      "text": "fare av sted",
      "translation": "to rush along",
      "examples": []
    },
    {
      "text": "gli",
      "translation": "to slide",
      "examples": [
        "steinblokkene renner ned fjellsiden",
        "sinnet rant bort"
      ]
    },
    {
      "text": "komme opp, stige opp",
      "translation": "to come up, to rise up",
      "examples": []
    },
    {
      "text": "jamfør solrenning",
      "translation": "sunrise",
      "examples": [
        "nå fjelltoppen idet sola renner",
        "det var ikke lenge til dagen rant"
      ]
    },
    {
      "text": "spire, gro",
      "translation": "to sprout, to grow",
      "examples": [
        "åkeren vil snart renne"
      ]
    }
  ]
