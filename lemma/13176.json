  "definitions": [
    {
      "text": "legge (for) stor vekt på det estetisk aspektet av en hendelse, en handling, et objekt eller lignende",
      "translation": "to place (too much) emphasis on the aesthetic aspect of an event, action, object, or similar",
      "examples": []
    },
    {
      "text": "framstille noe vakrere eller mer positivt enn det er",
      "translation": "to portray something as more beautiful or positive than it is",
      "examples": []
    },
    {
      "text": "idealisere, romantisere, glorifisere",
      "translation": "to idealize, romanticize, glorify",
      "examples": []
    }
