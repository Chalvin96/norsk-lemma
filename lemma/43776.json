  "definitions": [
    {
      "text": "få eller ta til eie (eller ta i bruk) noe som en annen har eid (eller brukt)",
      "translation": "to acquire or take ownership of (or take into use) something that another has owned (or used)",
      "examples": []
    },
    {
      "text": "ta over drift av",
      "translation": "to take over operation of",
      "examples": [
        "han overtok gården etter faren"
      ]
    },
    {
      "text": "ta på seg ansvar, oppgave eller lignende som en annen har hatt før",
      "translation": "to take on responsibility or a task that another has held before",
      "examples": []
    },
    {
      "text": "gå inn i stilling, verv eller lignende etter en annen",
      "translation": "to enter a position or office after another",
      "examples": [
        "overta ansvaret for noe",
        "han skal overta som statsminister"
      ]
    },
    {
      "text": "komme i stedet for",
      "translation": "to come in place of",
      "examples": []
    },
    {
      "text": "fylle plassen til",
      "translation": "to fill the place of",
      "examples": [
        "perioden da cd-en overtok for vinylplatene"
      ]
    }
  ]
