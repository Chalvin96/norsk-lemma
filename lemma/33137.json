  "cross_reference": null,
  "definitions": [
    {
      "text": "drepe ved å stanse lufttilførselen til lungene",
      "translation": "to kill by stopping the supply of air to the lungs",
      "examples": [
        "bli kvelt av røyk",
        "den drepte var kvalt med et skjerf"
      ]
    },
    {
      "text": "slokke eller hindre fra å vokse ved å stanse lufttilførsel",
      "translation": "to extinguish or prevent from growing by stopping the air supply",
      "examples": [
        "kvele ilden med et teppe",
        "denne planten kveler annen vegetasjon"
      ]
    },
    {
      "text": "i overført betydning: dempe, undertrykke følelser eller ansiktsuttrykk",
      "translation": "in a figurative sense: to dampen, suppress feelings or facial expressions",
      "examples": [
        "kvele en gjesp",
        "han prøvde å kvele latteren"
      ]
    },
    {
      "text": "i overført betydning: holde noen nede",
      "translation": "in a figurative sense: to keep someone down",
      "examples": []
    },
    {
      "text": "hindre noen i å utfolde seg",
      "translation": "to prevent someone from developing",
      "examples": [
        "kvele all opposisjon"
      ]
    }
  ]
