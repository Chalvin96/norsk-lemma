  "definitions": [
    {
      "text": "kaste eller styrte (seg) med hodet foran",
      "translation": "throw or plunge (oneself) headfirst",
      "examples": [
        "kaste klærne og stupe i sjøen",
        "stupe fra timeteren",
        "hauken stuper rett ned på byttet",
        "jagerflyene stupte ned fra 5000 meters høyde"
      ]
    },
    {
      "text": "falle framover",
      "translation": "fall forward",
      "examples": [
        "stupe så lang en er"
      ]
    },
    {
      "text": "segne fordi en er utslitt",
      "translation": "sink down from exhaustion",
      "examples": [
        "drive på til en stuper"
      ]
    },
    {
      "text": "gå rett ned i",
      "translation": "go straight down into",
      "examples": [
        "fjellet stupte rett i sjøen"
      ]
    },
    {
      "text": "minke i omfang eller verdi",
      "translation": "decrease in scope or value",
      "examples": [
        "temperaturen stuper",
        "omsetningen stupte i januar",
        "stupende omsetning"
      ]
