  "definitions": [
    {
      "text": "trekke pusten dypt inn og slippe den hørbart ut igjen",
      "translation": "to inhale deeply and exhale audibly",
      "examples": [
        "sukke tungt",
        "sukke og stønne",
        "sukke lettet",
        "sukke under åket",
        "sukke etter regn"
      ]
    },
    {
      "text": "blåse, suse",
      "translation": "to blow, to rustle",
      "examples": [
        "vinden sukket i trekronene"
      ]
    },
    {
      "text": "skvulpe, klukke",
      "translation": "to lap, to gurgle",
      "examples": [
        "det sukket og skvulpet rundt båten"
      ]
    }
