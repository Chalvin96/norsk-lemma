  "definitions": [
    {
      "text": "vei som er kortere eller raskere enn den vanlige og mest brukte veien",
      "translation": "road that is shorter and faster than the usual and most used road",
      "examples": []
    },
    {
      "text": "beinvei beinveg benveg benvei, gjenvei gjenveg",
      "translation": "shortcut, crossroad",
      "examples": [
        "en snarvei gjennom skogen"
      ]
    },
    {
      "text": "i IT: tastekombinasjon på tastatur eller ikon som gir raskere tilgang til noe",
      "translation": "in IT: key combination on a keyboard or icon that provides faster access to something",
      "examples": [
        "snarveien Ctrl+c brukes for å kopiere",
        "legge til en snarvei på skrivebordet"
      ]
    },
    {
      "text": "i overført betydning: lettvint metode for å oppnå noe på kortere tid",
      "translation": "in a figurative sense: easy method to achieve something in a shorter time",
      "examples": [
        "eleven tok en snarvei ved å kopiere leksene",
        "det fins ingen snarvei til evig ungdom"
      ]
