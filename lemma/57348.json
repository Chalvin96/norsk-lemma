  "definitions": [
    {
      "text": "glad og fornøyd eller triumferende over noe eller noen en har en særlig tilknytning til, for eksempel en prestasjon eller noe en eier",
      "translation": "happy and satisfied or triumphant about something or someone one has a special connection to, an achievement, or something one owns",
      "examples": []
    },
    {
      "text": "byrg, kry",
      "translation": "proud, haughty",
      "examples": [
        "hun er stolt av den nye bilen og viser den fram til alle",
        "han var veldig stolt over datteren"
      ]
    },
    {
      "text": "som kjenner sin egen verdi og setter omdømmet sitt (overdrevent) høyt",
      "translation": "aware of one's own worth and (excessively) valuing one's reputation",
      "examples": []
    },
    {
      "text": "hovmodig, storlåten, kaut",
      "translation": "haughty, grandiose, conceited",
      "examples": [
        "jeg var for stolt til å ta imot hjelp"
      ]
    },
    {
      "text": "som fører med seg heder og ære",
      "translation": "bringing honor and glory",
      "examples": []
    },
    {
      "text": "som en opplever som stor",
      "translation": "experienced as great",
      "examples": [
        "mitt livs stolteste øyeblikk",
        "stolte drømmer"
      ]
    },
    {
      "text": "flott, staselig",
      "translation": "splendid, stately",
      "examples": [
        "et stolt kvinnfolk",
        "en stolt skute"
      ]
    }
  ]
