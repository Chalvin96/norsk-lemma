  "definitions": [
    {
      "text": "lage en knute",
      "translation": "make a knot",
      "examples": []
    },
    {
      "text": "binde sammen",
      "translation": "tie together",
      "examples": []
    },
    {
      "text": "feste med knute",
      "translation": "fasten with a knot",
      "examples": [
        "knytte en knute",
        "knytte slipset",
        "knytte skolissene",
        "knytte tepper"
      ]
    },
    {
      "text": "i overført betydning: sette eller være i forbindelse med",
      "translation": "connect or be connected with",
      "examples": []
    },
    {
      "text": "forbinde, assosiere",
      "translation": "connect, associate",
      "examples": [
        "hun var knyttet til instituttet i fem år",
        "de nordiske landene er knyttet nær sammen",
        "det knytter seg mange lyse minner til denne tiden"
      ]
    },
    {
      "text": "i overført betydning: feste til noen med følelser",
      "translation": "attach to someone with feelings",
      "examples": [
        "han var sterkt knyttet til barndomshjemmet",
        "hun klarer ikke å knytte seg til noen"
      ]
    }
  ]
