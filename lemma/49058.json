  "cross_reference": null,
  "definitions": [
    {
      "text": "bevege seg (bortover et underlag) ved å dreie seg rundt sin egen akse",
      "translation": "to move (along a surface) by turning around its own axis",
      "examples": [
        "rulle over ende",
        "bilen ruller nedover",
        "flyet rullet rundt i lufta"
      ]
    },
    {
      "text": "få til å rulle",
      "translation": "to cause to roll",
      "examples": [
        "de rullet en tønne nedover bakken"
      ]
    },
    {
      "text": "jevne med rull eller rulle",
      "translation": "to level with a roller or rolling",
      "examples": []
    },
    {
      "text": "glatte, slette",
      "translation": "to smooth, to flatten",
      "examples": [
        "rulle tøy",
        "de ruller åkeren"
      ]
    },
    {
      "text": "lage (noe som ligner) en kule eller rull",
      "translation": "to make (something) into a ball or roll",
      "examples": [
        "rulle en sigarett",
        "hun har rullet sammen teppet"
      ]
    },
    {
      "text": "gå i bølgegang",
      "translation": "to surge, to break (waves)",
      "examples": [
        "havet ruller mot stranda"
      ]
    },
    {
      "text": "om fartøy: bevege seg fra side til side i bølgene",
      "translation": "of a vessel: to move from side to side in the waves",
      "examples": [
        "båten rullet kraftig"
      ]
    },
    {
      "text": "om lyd: drønne",
      "translation": "to rumble, to boom",
      "examples": []
    },
    {
      "text": "rumle lenge",
      "translation": "to rumble for a long time",
      "examples": [
        "tordenen ruller"
      ]
    },
    {
      "text": "uttale norsk ‘r’ med tungespissen",
      "translation": "to pronounce the Norwegian 'r' with the tip of the tongue",
      "examples": []
    },
    {
      "text": "til forskjell fra skarre",
      "translation": "to trill, to roll the 'r'",
      "examples": [
        "rulle på r-ene"
      ]
    }
  ]
}