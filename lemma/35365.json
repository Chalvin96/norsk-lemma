  "definitions": [
    {
      "text": "lee forsiktig på noe som sitter fast eller er vanskelig å få på plass",
      "translation": "to gently move something that is stuck or difficult to move",
      "examples": [
        "lirke seg løs",
        "lirke nøkkelen inn i låsen",
        "hun lirket av seg skoene"
      ]
    },
    {
      "text": "i overført betydning: få fram med list og lempe",
      "translation": "in a figurative sense: to elicit with cunning and persuasion",
      "examples": [
        "lirke og lure",
        "de fikk lirket hemmeligheten ut av ham"
      ]
    }
  ]
