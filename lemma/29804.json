      ]
    },
    {
      "text": "om kjøretøy: være i fart",
      "translation": "of a vehicle: to be in motion",
      "examples": []
    },
    {
      "text": "gå, trafikkere",
      "translation": "to run, to operate (e.g., public transport)",
      "examples": [
