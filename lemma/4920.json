  "cross_reference": null,
  "definitions": [
    {
      "text": "bringe hannlig kjønnscelle kjønnsselle sammen med hunnlig kjønnscelle (hos menneske, dyr eller plante) slik at det vokser fram et nytt individ",
      "translation": "to bring a male gamete together with a female gamete (in humans, animals, or plants) so that a new individual develops",
      "examples": [
        "sædcellen befrukter eggcellen",
        "bier befrukter blomster",
        "befruktede egg"
      ]
    },
    {
      "text": "i overført betydning, ofte som adjektiv: gi impulser",
      "translation": "in a figurative sense, often as: to provide impulses",
      "examples": []
    },
    {
      "text": "inspirere, stimulere",
      "translation": "to inspire, to stimulate",
      "examples": [
        "ulike fagområder som virker befruktende på hverandre",
        "et samarbeid som er gjensidig befruktende"
      ]
    }
  ]
