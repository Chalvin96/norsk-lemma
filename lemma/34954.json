  "definitions": [
    {
      "text": "gjøre lettere",
      "translation": "make lighter",
      "examples": []
    },
    {
      "text": "gjøre mindre vanskelig",
      "translation": "make less difficult",
      "examples": [
        "lette en byrde",
        "det vil lette arbeidet",
        "lette adgangen til høyere utdanning"
      ]
    },
    {
      "text": "frigjøre (fra plager og bekymringer)",
      "translation": "free (from suffering and worries)",
      "examples": []
    },
    {
      "text": "gjøre mindre trykkende, lindre, mildne",
      "translation": "make less oppressive, relieve, mitigate",
      "examples": [
        "lette trykket i beholderen",
        "jeg skulle ønske jeg kunne lette sorgen for deg",
        "kjenne seg lettet over noe",
        "de lettet ham for både kort og kontanter"
      ]
    },
    {
      "text": "løfte litt",
      "translation": "lift a little",
      "examples": []
    },
    {
      "text": "heve (seg)",
      "translation": "raise (oneself)",
      "examples": [
        "lette på skapet for å kikke under",
        "lette på lokket",
        "fuglene lettet",
        "det er på tide at vi letter på oss og går hjem"
      ]
    },
    {
      "text": "letne, klarne",
      "translation": "clear up, become clear",
      "examples": [
        "tåka lettet",
        "det ser ut til at det letter opp"
      ]
