  "definitions": [
    {
      "text": "trykke, presse noe hardt sammen slik at det endrer form",
      "translation": "to press, squeeze something hard so that it changes shape",
      "examples": [
        "klemme noe flatt",
        "klemme fingeren i dørsprekken",
        "skoen klemmer"
      ]
    },
    {
      "text": "gi en klem",
      "translation": "to give a hug",
      "examples": [
        "kysse og klemme"
      ]
    },
    {
      "text": "presse i en viss retning",
      "translation": "to press in a certain direction",
      "examples": [
        "klemme seg fram",
        "klemme seg sammen"
      ]
    },
    {
      "text": "tynge, knuge",
