  "definitions": [
    {
      "text": "svinge regelmessig fram og tilbake",
      "translation": "swing regularly back and forth",
      "examples": [
        "pendle fra den ene siden til den andre"
      ]
    },
    {
      "text": "reise fram og tilbake mellom to steder, særlig med lang reisetid mellom hjem og arbeidssted",
      "translation": "travel back and forth between two places, especially with a long travel time between home and workplace",
      "examples": [
        "pendle mellom Halden og Oslo"
      ]
    },
    {
      "text": "i overført betydning: vingle",
      "translation": "waver",
      "examples": [
        "pendle mellom ulike standpunkter"
      ]
