  "definitions": [
    {
      "text": "frambringe eller lage ved hjelp av prikker",
      "translation": "to produce or make using dots",
      "examples": [
        "prikke en linje",
        "prikke opp et mønster",
        "prikke hull på en ballong"
      ]
    },
    {
      "text": "kjenne som stikk",
      "translation": "to feel like pricks",
      "examples": []
    },
    {
      "text": "jamfør prikkende",
      "translation": "prickling",
      "examples": [
        "det begynte å prikke i fingeren"
      ]
    },
    {
      "text": "berøre, slå lett",
      "translation": "to touch, lightly hit",
      "examples": [
        "prikke noen på skulderen"
      ]
    },
    {
      "text": "pirke på",
      "translation": "to pick at",
      "examples": []
    },
    {
      "text": "kritisere",
      "translation": "to criticize",
      "examples": [
        "du prikker på alt mulig"
      ]
    },
    {
      "text": "i ballspill: sparke, sende (i mål)",
      "translation": "in ball games: to kick, send (into goal)",
      "examples": [
        "prikke ballen i mål"
      ]
    }
