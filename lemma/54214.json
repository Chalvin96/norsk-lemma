  "definitions": [
    {
      "text": "løse på et tau, en line eller lignende",
      "translation": "to loosen a rope or line",
      "examples": []
    },
    {
      "text": "gjøre noe slakk, mindre stramt eller fast",
      "translation": "to make something slack, less tight or firm",
      "examples": [
        "slakke på en trosse",
        "kusken slakket på tømmene",
        "far slakker alltid ut beltet etter julemiddagen"
      ]
    },
    {
      "text": "redusere",
      "translation": "to reduce",
      "examples": []
    },
    {
      "text": "minke",
      "translation": "to decrease",
      "examples": [
        "bilen slakket farten",
        "slakke på kravene",
        "vi må ikke slakke på prinsippene våre"
      ]
    },
    {
      "text": "om is: bli mindre tett eller fast",
