  "definitions": [
    {
      "text": "la væske renne eller strømme ut av en beholder, rør eller lignende ved å åpne tapp, spuns, kran eller lignende",
      "translation": "let liquid run or flow out of a container, pipe or similar by opening a tap, bung, faucet or similar",
      "examples": [
        "tappe blod",
        "tappe øl fra fat",
        "eplemosten er tappet på flasker",
        "hun tapper vann i badekaret"
      ]
    },
    {
      "text": "frata, tømme",
      "translation": "deprive, empty",
      "examples": [
        "tappe bankkontoen",
        "landet blir tappet for valuta",
        "vinterkulda kan tappe batteriet",
        "bygda blir tappet for arbeidskraft",
        "tappe en myr"
      ]
    },
    {
      "text": "få tak i informasjon på ulovlig måte ved å kople seg på dataanlegg, telefoner eller lignende",
      "translation": "obtain information illegally by connecting to computer systems, telephones or similar",
      "examples": [
        "tappe informasjon fra databaser",
        "avlytte og tappe telefonen for opplysninger"
      ]
    },
    {
      "text": "føye sammen to trestykker ved hjelp av tapp",
      "translation": "join two pieces of wood using a tenon",
