  "definitions": [
    {
      "text": "passe og stelle et sykt eller svakt menneske eller dyr",
      "translation": "to care for and tend to a sick or weak person or animal",
      "examples": [
        "pleie den syke",
        "han pleide den gamle moren sin"
      ]
    },
    {
      "text": "stelle (en del av) kroppen så den holdes ren og sunn",
      "translation": "to groom (a part of) the body so it is kept clean and healthy",
      "examples": [
        "pleie kroppen sin",
        "hun pleier neglene regelmessig"
      ]
    },
    {
      "text": "holde noe i god stand",
      "translation": "to keep something in good condition",
      "examples": [
        "hun pleide bilen med voks",
        "pleie kulturlandskapet"
      ]
    },
    {
      "text": "holde ved like",
      "translation": "to maintain",
      "examples": [
        "de pleier kontakt med venner",
        "ha tid til å pleie sine interesser"
      ]
    }
  ]
