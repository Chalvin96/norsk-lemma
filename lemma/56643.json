  "cross_reference": null,
  "definitions": [
    {
      "text": "arbeide noe tett og fast sammen med tramping, støting eller banking",
      "translation": "to work something tightly and firmly together by treading, pounding, or beating",
      "examples": [
        "jordveggene var stampet",
        "han stamper jorden godt ned",
        "stampe grøt"
      ]
    },
    {
      "text": "behandle ulltøy for å gjøre det tettere",
      "translation": "to treat woolen fabric to make it denser",
      "examples": [
        "stampe vadmel"
      ]
    },
    {
      "text": "tråkke, trampe",
      "translation": "to tread, to stamp",
      "examples": []
    },
    {
      "text": "støte foten hardt mot underlaget",
      "translation": "to strike the foot hard against the ground",
      "examples": [
        "stampe i golvet",
        "gå og stampe i høy snø"
      ]
    },
    {
      "text": "om fartøy: hogge hugge med framstavnen i sjøen uten å komme seg framover",
      "translation": "for a vessel: to pitch with the stem in the sea without making headway",
      "examples": [
        "båten stampet i sjøen"
      ]
    },
    {
      "text": "i bridge: melde stampemelding",
      "translation": "in bridge: to bid a \"stamp bid\"",
      "examples": []
    }
  ]
