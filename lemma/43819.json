  "definitions": [
    {
      "text": "om person: oppholde seg vinteren over (på et sted, særlig i arktiske strøk)",
      "translation": "for a person: to stay over the winter (in a place, especially in arctic regions)",
      "examples": [
        "de overvintret på Grønland"
      ]
    },
    {
      "text": "om fugl eller dyr: leve og greie seg vinteren over på et sted",
      "translation": "for birds or animals: to live and manage over the winter in a place",
      "examples": [
        "det er ofte knapt med mat for de fuglene som overvintrer her i landet"
      ]
    },
    {
      "text": "om planter: leve mer enn en sommer og være i dvale- eller hviletilstand om vinteren",
      "translation": "for plants: to live longer than one summer and be in a dormant state in winter",
      "examples": [
        "rugsorten overvintrer godt her"
      ]
    }
  ]
