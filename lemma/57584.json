  "cross_reference": null,
  "definitions": [
    {
      "text": "dra fra sted til sted uten noe bestemt mål",
      "translation": "to travel from place to place without a specific goal",
      "examples": []
    },
    {
      "text": "farte, flakke",
      "translation": "to roam, to wander",
      "examples": [
        "de streifet omkring i skogen"
      ]
    },
    {
      "text": "berøre lett og kortvarig",
      "translation": "to touch lightly and briefly",
      "examples": []
    },
    {
      "text": "snerte, sneie",
      "translation": "to graze, to brush against",
      "examples": [
        "hånden streifet så vidt kinnet",
        "kulen hadde bare streifet skulderen"
      ]
    },
    {
      "text": "se som snarest på",
      "translation": "to glance at briefly",
      "examples": [
        "hun streifer ham med blikket"
      ]
    },
    {
      "text": "omtale flyktig",
      "translation": "to mention fleetingly",
      "examples": []
    },
    {
      "text": "så vidt komme inn på",
      "translation": "to touch upon briefly",
      "examples": [
        "spørsmålet ble så vidt streifet"
      ]
    },
    {
      "text": "om tanke, idé eller lignende: falle inn",
      "translation": "of a thought, idea: to occur",
      "examples": [
        "tanken har ikke streifet meg engang"
      ]
    }
  ]
