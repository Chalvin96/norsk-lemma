  "cross_reference": null,
  "definitions": [
    {
      "text": "lage tråd ved å tvinne sammen fibre (av ull, bomull, lin eller lignende)",
      "translation": "to make thread by twisting together fibers (of wool, cotton, linen)",
      "examples": [
        "hun spant lingarn til renning"
      ]
    },
    {
      "text": "om edderkopp og visse larver: lage tråd til fangstnett eller kokong",
      "translation": "for spiders and certain larvae: to make thread for a catching net or cocoon",
      "examples": [
        "en edderkopp har spunnet et fint nett i gresset"
      ]
    },
    {
      "text": "i overført betydning: dikte opp, finne på",
      "translation": "to invent, to make up",
      "examples": []
    },
    {
      "text": "jamfør oppspinn",
      "translation": "fabrication",
      "examples": [
        "spinne sammen historier"
      ]
    },
    {
      "text": "i overført betydning: føre videre",
      "translation": "to pass on",
      "examples": []
    },
    {
      "text": "utvikle",
      "translation": "to develop",
      "examples": [
        "spinne videre på en idé"
      ]
    },
    {
      "text": "gå rundt uten å få feste",
      "translation": "to rotate without gaining traction",
      "examples": []
    },
    {
      "text": "komme i spinn",
      "translation": "to spin out of control",
      "examples": [
        "bakhjulene spinner i søla",
        "flyet spant flere ganger og gikk i sjøen"
      ]
    },
    {
      "text": "dure svakt",
      "translation": "to hum softly",
      "examples": [
        "motoren spant jevnt og fint"
      ]
    }
  ]
