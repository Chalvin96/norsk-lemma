  "definitions": [
    {
      "text": "hylse til å vikle noe opp på eller som noe er viklet opp på, for eksempel tråd, garn, film, lydbånd",
      "translation": "husk for winding something up on, or on which something is wound up, e.g. thread, yarn, film, tape",
      "examples": [
        "fiskesnøret raste ut fra spolen",
        "vikle filmen inn i spolen"
      ]
    },
    {
      "text": "isolert ledning viklet opp på en sylindrisk kjerne, og som det går elektrisk strøm gjennom",
      "translation": "insulated wire wound on a cylindrical core, through which electric current flows",
      "examples": [
        "spolen i en transformator"
      ]
    }
