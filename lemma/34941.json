  "definitions": [
    {
      "text": "bli lettere av vekt",
      "translation": "to become lighter in weight",
      "examples": [
        "grønnsakene letner under lagring"
      ]
    },
    {
      "text": "om været: klarne opp",
      "translation": "regarding weather: to clear up",
      "examples": []
    },
    {
      "text": "bli opphold",
      "translation": "to stop raining",
      "examples": [
        "været letnet på ettermiddagen",
        "det ser ut til at det letner nå"
      ]
    },
    {
      "text": "løse seg opp",
      "translation": "to dissipate",
      "examples": [
        "tåka letnet"
      ]
    },
    {
      "text": "bli gladere",
      "translation": "to become happier",
      "examples": []
    },
    {
      "text": "bli mindre nedstemt eller trykkende",
      "translation": "to become less somber or oppressive",
      "examples": [
        "stemningen letnet",
        "jeg letnet flere kilo da jeg hørte at alt var i orden med dem"
      ]
    }
