  "cross_reference": null,
  "definitions": [
    {
      "text": "ta seg et bad",
      "translation": "to take a bath",
      "examples": []
    },
    {
      "text": "la vann skylle over (seg selv eller andre)",
      "translation": "to let water flow over (oneself or others)",
      "examples": []
    },
    {
      "text": "legge kroppen i vann (for å vaske den)",
      "translation": "to put the body in water (to wash it)",
      "examples": [
        "bade og legge ungene",
        "bade i sjøen",
        "bade i fontenen"
      ]
    },
    {
      "text": "dyppe, skylle i en væske",
      "translation": "to dip, rinse in a liquid",
      "examples": []
    },
    {
      "text": "være innhyllet av fuktighet",
      "translation": "to be enveloped by moisture",
      "examples": [
        "bade kjøttet i marinade",
        "ligge badet i svette"
      ]
    },
    {
      "text": "i overført betydning: la seg innhylle, være omgitt av (noe annet enn væske)",
      "translation": "in a figurative sense: to let oneself be enveloped, be surrounded by (something other than liquid)",
      "examples": [
        "bygda lå badet i sol",
        "bade i gjørme",
        "gatene bader i søppel"
      ]
    }
  ]
