  "definitions": [
    {
      "text": "arbeide hardt",
      "translation": "work hard",
      "examples": []
    },
    {
      "text": "slite, kave",
      "translation": "struggle, toil",
      "examples": [
        "ha mye å stri med",
        "han stred og slet alle sine dager",
        "stri seg fram mot uværet"
      ]
    },
    {
      "text": "kjempe for å overvinne problemer eller vonde følelser",
      "translation": "strive to overcome problems or bad feelings",
      "examples": [
        "stri mot overmakten",
        "de har stridd seg gjennom vinteren",
        "han stred med gråten"
      ]
    },
    {
      "text": "kjempe i krig",
      "translation": "fight in war",
      "examples": []
    },
    {
      "text": "jamfør stridende",
      "translation": "combatant",
      "examples": [
        "de har stridd for fedrelandet"
      ]
    },
    {
      "text": "krangle, trette",
      "translation": "argue, quarrel",
      "examples": []
    },
    {
      "text": "jamfør strides",
      "translation": "dispute",
      "examples": [
        "de stred om hvem som skulle få arven"
      ]
    },
    {
      "text": "stå i motstrid med",
      "translation": "be contrary to",
      "examples": [
        "det stred mot loven",
        "dette strir mot sunn fornuft"
      ]
    }
  ]
