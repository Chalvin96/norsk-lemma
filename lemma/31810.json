  "cross_reference": null,
  "definitions": [
    {
      "text": "stå i en viss pris, komme på",
      "translation": "to have a certain price, to cost",
      "examples": [
        "dressen koster 900 kr"
      ]
    },
    {
      "text": "føre med seg utgifter",
      "translation": "to entail expenses",
      "examples": [
        "å holde bil koster mange tusen for året",
        "koste mer enn det smaker"
      ]
    },
    {
      "text": "kreve, føre med seg",
      "translation": "to require, to entail",
      "examples": [
        "det vil koste kamp",
        "det kostet mye arbeid",
        "dette kan koste deg jobben"
      ]
    },
    {
      "text": "bruke penger på",
      "translation": "to spend money on",
      "examples": [
        "koste på seg en ny dress",
        "koste på huset"
      ]
    },
    {
      "text": "skaffe penger til",
      "translation": "to provide money for",
      "examples": [
        "han kostet selv oppholdet",
        "koste utdanning på barna"
      ]
    }
  ]
