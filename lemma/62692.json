    },
    {
      "text": "bevege seg til fots",
      "translation": "move on foot",
      "examples": [
        "han trådde opp trappa",
        "hun trådde inn i stua"
      ]
    },
    {
      "text": "presse foten mot brett, pedal eller lignende",
      "translation": "press the foot against a board, pedal",
      "examples": [
        "trå gassen i bånn",
        "trå sykkelen opp bakken"
      ]
    },
    {
      "text": "bli virksom i",
      "translation": "become active in",
