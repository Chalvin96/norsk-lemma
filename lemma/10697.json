  "cross_reference": null,
  "definitions": [
    {
      "text": "trekke eller føre fra et sted til et annet, slite, rykke",
      "translation": "to pull or move from one place to another, to strain, to tug",
      "examples": [
        "hal i og dra!",
        "dra fisk",
        "dra opp fisk",
        "dra nota",
        "dra gardinene til side"
      ]
    },
    {
      "text": "hale, slepe (noe tungt)",
      "translation": "to haul, to drag (something heavy)",
      "examples": [
        "dra på en tung koffert"
      ]
    },
    {
      "text": "ta fram våpen (av hylster og true med det)",
      "translation": "to draw a weapon (from its holster and threaten with it)",
      "examples": [
        "dra sverdet"
      ]
    },
    {
      "text": "risse, markere",
      "translation": "to score, to mark",
      "examples": [
        "dra opp retningslinjer"
      ]
    },
    {
      "text": "røre på muskel for å uttrykke følelse",
      "translation": "to move a muscle to express a feeling",
      "examples": [
        "dra på skuldrene",
        "dra på smilebåndet"
      ]
    },
    {
      "text": "i overført betydning: virke tillokkende",
      "translation": "to be appealing",
      "examples": [
        "byen drar"
      ]
    },
    {
      "text": "gjøre haltende bevegelse",
      "translation": "to move with a limping gait",
      "examples": [
        "dra på det ene beinet"
      ]
    },
    {
      "text": "i idrett: ligge fremst (og dermed bestemme farten)",
      "translation": "to be in front (and thus determine the speed)",
      "examples": [
        "ligge foran og dra"
      ]
    },
    {
      "text": "gi drivkraft til",
      "translation": "to provide motive power to",
      "examples": [
        "dra slipesteinen",
        "motoren drar saga"
      ]
    },
    {
      "text": "samle, vinne",
      "translation": "to gather, to gain",
      "examples": [
        "dra lærdom av noe",
        "dra nytte av noe"
      ]
    },
    {
      "text": "i overført betydning: tenke seg til, slutte logisk",
      "translation": "to infer, to conclude logically",
      "examples": [
        "dra noe i tvil",
        "det ene drar det andre med seg",
        "dra kjensel på noen"
      ]
    },
    {
      "text": "suge, trekke til seg",
      "translation": "to inhale, to draw in",
      "examples": [
        "dra pusten"
      ]
    },
    {
      "text": "reise, fare",
      "translation": "to travel, to go",
      "examples": [
        "dra sin vei",
        "hun har dratt til utlandet",
        "dra på tur",
        "dra til fjells",
        "dra til sjøs",
        "dra til byen",
        "dra i krigen",
        "dra deg unna!"
      ]
    },
    {
      "text": "om vær: bevege seg over et område",
      "translation": "about weather: to move across an area",
      "examples": [
        "uværet dro forbi"
      ]
    }
  ]
}