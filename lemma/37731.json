  "definitions": [
    {
      "text": "dra eller suge (med maskin) melk ut av spener",
      "translation": "to draw milk out of udders (with a machine)",
      "examples": [
        "være flink til å melke",
        "melke en ku",
        "hun melker geitene ute",
        "de melker med maskin"
      ]
    },
    {
      "text": "i overført betydning: utnytte maksimalt",
      "translation": "to exploit to the fullest",
      "examples": []
    },
    {
      "text": "trekke penger eller andre verdier ut av noe",
      "translation": "to extract money or other assets from something",
      "examples": [
        "de melket landet for råstoffer"
      ]
    },
    {
      "text": "gi melk",
      "translation": "to give milk",
      "examples": [
        "kua melker godt",
        "kua har sluttet å melke"
      ]
    }
  ]
