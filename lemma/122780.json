    {
      "text": "i kjemi: (om stoff) som har tatt opp i seg størst mulig mengde av et annet stoff",
      "translation": "(of a substance) that has absorbed the largest possible amount of another substance",
      "examples": [
        "mettet vanndamp",
        "mettede fettsyrer",
        "en mettet løsning",
        "i mettet tilstand"
      ]
    },
    {
      "text": "som er fylt opp helt eller fylt opp av noe annet",
      "translation": "completely filled with something else",
      "examples": [
        "et mettet marked gjorde det vanskelig å tjene penger på mobilsalg"
      ]
    },
    {
      "text": "intens eller konsentrert",
      "translation": "intense or concentrated",
      "examples": [
        "få en mettet gjengivelse av fargen med god fargedybde"
      ]
