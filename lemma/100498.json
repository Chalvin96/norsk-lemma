  "definitions": [
    {
      "text": "lage nettverk til å brodere eller fylle ut med tråd for å lage dekorative mønster",
      "translation": "to create a network for embroidery or filling with thread to create decorative patterns",
      "examples": []
    },
    {
      "text": "stoppe inn mønster på bunn av tråd som er knyttet sammen i nettverk med firkantede hull",
      "translation": "to stitch a pattern into the base of thread connected in a network with square holes",
      "examples": []
    },
    {
      "text": "i musikk: la en tone strømme ut jevnt og lenge",
      "translation": "in music: to let a tone flow out smoothly and for a long time",
      "examples": [
        "filere tonen"
