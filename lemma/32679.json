  "definitions": [
    {
      "text": "bearbeide jord eller annen natur for å få avling",
      "translation": "to work soil or other land to produce crops",
      "examples": [
        "kultivere myra"
      ]
    },
    {
      "text": "drive fram planter",
      "translation": "to grow plants",
      "examples": []
    },
    {
      "text": "dyrke",
      "translation": "to cultivate",
      "examples": [
        "kultivere prydbusker"
      ]
    },
    {
      "text": "utvikle og odle fram en planteart eller dyrerase",
      "translation": "to develop and breed a plant species or animal breed",
      "examples": [
        "kultivere fram nye saueraser"
      ]
    },
    {
      "text": "i overført betydning: holde ved like",
      "translation": "to maintain",
      "examples": []
    },
    {
      "text": "pleie, dyrke",
      "translation": "to nurture, to cultivate",
      "examples": []
    },
    {
      "text": "forme, skape",
      "translation": "to shape, to create",
      "examples": [
        "kultivere sine kontakter",
        "han kultiverte rollen som nerd",
        "de prøver å kultivere fram en forståelse mellom folkene"
