  "definitions": [
    {
      "text": "vise fram og forklare hvordan noe fungerer eller skal gjøres",
      "translation": "show and explain how something works or should be done",
      "examples": [
        "demonstrere et hjelpemiddel",
        "demonstrere et dataprogram",
        "hjelpekorpset demonstrerer hvordan man får folk opp av vannet"
      ]
    },
    {
      "text": "vise på en tydelig eller overbevisende måte",
      "translation": "show in a clear or convincing way",
      "examples": [
