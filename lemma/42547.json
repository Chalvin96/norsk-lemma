  "cross_reference": null,
  "definitions": [
    {
      "text": "få et stoff til å blande seg med et annet stoff, særlig en væske, slik at det blir en ensartet blanding",
      "translation": "to cause a substance to mix with another substance, especially a liquid, to form a uniform mixture",
      "examples": [
        "oppløse sukker i vann",
        "pulveret ble oppløst i vann",
        "sukkerbiten oppløste seg i tevannet"
      ]
    },
    {
      "text": "få til å skille seg i mindre bestanddeler",
      "translation": "to cause to separate into smaller components",
      "examples": []
    },
    {
      "text": "løse opp, dekomponere",
      "translation": "dissolve, decompose",
      "examples": [
        "forsamlingen skal oppløses i grupper"
      ]
    },
    {
      "text": "sette ut av kraft, gjøre slutt på",
      "translation": "to set aside, to end",
      "examples": []
    },
    {
      "text": "oppheve, heve, avslutte",
      "translation": "repeal, revoke, terminate",
      "examples": [
        "oppløse Stortinget",
        "unionen ble oppløst",
        "oppløse et ekteskap"
      ]
    },
    {
      "text": "gi fri fra militærtjeneste",
      "translation": "to release from military service",
      "examples": [
        "kapteinene oppløste avdelingen"
      ]
    },
    {
      "text": "brytes ned, gå i forråtnelse",
      "translation": "to break down, to rot",
      "examples": [
        "liket var sterkt oppløst"
      ]
    },
    {
      "text": "forsvinne litt og litt",
      "translation": "to disappear little by little",
      "examples": [
        "hun fryktet at kjærligheten deres skulle oppløse seg og forsvinne for alltid"
      ]
    }
  ]
}