  "definitions": [
    {
      "text": "samle inn og få årets avling under tak",
      "translation": "gather and bring in the year's harvest",
      "examples": [
        "de kommer til å høste tidlig i år",
        "eplene må høstes snart",
        "har de høstet hveten ennå?",
        "vi høstet honningen fra bikubene"
      ]
    },
    {
      "text": "i overført betydning: få eller oppnå noe som belønning eller resultat av en innsats",
      "translation": "receive or achieve something as a reward or result of an effort",
      "examples": [
        "hun høstet anerkjennelse for arbeidet",
        "han høstet stor applaus fra tilhørerne"
      ]
    }
