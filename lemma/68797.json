  "definitions": [
    {
      "text": "om plante eller plantedel: som har mistet farge og kraft til å vokse",
      "translation": "of a plant or plant part: having lost color and the strength to grow",
      "examples": [
        "en vissen blomst",
        "vissent løv",
        "visne blader"
      ]
    },
    {
      "text": "om kroppsdel: slapp og kraftløs",
      "translation": "of a body part: limp and powerless",
      "examples": [
        "armen ble vissen av slaget",
        "den livløse og visne hånden"
      ]
    },
    {
      "text": "om person: tuslete, stakkarslig",
      "translation": "of a person: frail, pathetic",
      "examples": [
        "en liten, vissen fyr"
      ]
    }
