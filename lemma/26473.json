  "definitions": [
    {
      "text": "hente inn, få tak i, skaffe seg",
      "translation": "to fetch, to get hold of, to acquire",
      "examples": [
        "innhente opplysninger",
        "innhente anbud",
        "innhente tillatelse til å starte en virksomhet"
      ]
    },
    {
      "text": "ta igjen, nå igjen",
      "translation": "to catch up with, to overtake",
      "examples": [
        "innhente et forsprang",
        "innhente det forsømte",
        "bli innhentet av lovens lange arm"
      ]
    }
  ]
