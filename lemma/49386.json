  "definitions": [
    {
      "text": "bevege, lee (særlig lemmer)",
      "translation": "move, stir (especially limbs)",
      "examples": [
        "røre ben og armer",
        "hun kunne ikke røre en finger"
      ]
    },
    {
      "text": "blande masse eller væske med sleiv, tvare eller lignende",
      "translation": "mix a mass with liquid using a spoon or stirrer",
      "examples": [
        "røre i malingen",
        "han rørte sammen melk og egg",
        "rør sukkeret inn i eggene"
      ]
    },
    {
      "text": "blande bær og sukker",
      "translation": "mix berries and sugar",
      "examples": [
        "skal vi lage syltetøy eller bare røre bærene?",
        "far rørte blåbærene vi skulle ha til pannekakene",
        "vafler med rørte jorbær"
      ]
    },
    {
      "text": "ta på",
      "translation": "touch",
      "examples": []
    },
    {
      "text": "komme borti, berøre",
      "translation": "come into contact with, touch",
      "examples": [
        "se, men ikke røre",
        "ikke rør kniven!",
        "han rørte ikke maten"
      ]
    },
    {
      "text": "ha med å gjøre",
      "translation": "have to do with",
      "examples": [
        "pengene i banken skal vi ikke røre",
        "han rører ikke alkohol"
      ]
    },
    {
      "text": "snakke uten egentlig mening",
      "translation": "talk without real meaning",
      "examples": []
    },
    {
      "text": "tulle, vrøvle",
      "translation": "talk nonsense, rave",
