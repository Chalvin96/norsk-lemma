  "cross_reference": null,
  "definitions": [
    {
      "text": "pakke hardt sammen og fylle eller tette noe",
      "translation": "to pack tightly together and fill or seal something",
      "examples": [
        "de stappet mose i veggsprekkene",
        "stappe klærne i ryggsekken"
      ]
    },
    {
      "text": "fylle med noe en pakker hardt sammen",
      "translation": "to fill with something that is packed tightly together",
      "examples": [
        "stappe pipa"
      ]
    },
    {
      "text": "putte eller stikke gjennom en åpning",
      "translation": "to put or stick through an opening",
      "examples": [
        "han stapper hendene i lomma"
      ]
    },
    {
      "text": "røre sammen",
      "translation": "to mash together",
      "examples": []
    },
    {
      "text": "knuse, mose",
      "translation": "to crush, to mash",
      "examples": [
        "stappe potetene i sausen"
      ]
    }
  ]
