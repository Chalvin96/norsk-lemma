  "definitions": [
    {
      "text": "i fotografering: belyse for mye, slik at bildet blir for lyst",
      "translation": "in photography: to illuminate too much, so that the image becomes too bright",
      "examples": []
    },
    {
      "text": "jamfør undereksponere",
      "translation": "underexpose",
      "examples": [
        "filmen var overeksponert"
      ]
    },
    {
      "text": "(la) være for sterkt utsatt for",
      "translation": "to be too strongly exposed to",
      "examples": [
        "bli overeksponert for forurensing"
      ]
    },
    {
      "text": "i overført betydning: legge for stor vekt på eller vise fram i overdreven grad",
      "translation": "to place too much emphasis on or display to an excessive degree",
      "examples": [
        "jeg synes forfatteren overeksponerer skjevhetene i samfunnet"
      ]
