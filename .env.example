# Copy to .env and fill in values.
# Only needed for the `translate` stage (LLM-based translation).
# The `hydrate` workflow (fetch → hydrate → pronounce → export) requires no API key.

OPENROUTER_API_KEY=

# Audio upload (scripts/upload_audio.py) — S3-compatible object store.
# Only the access/secret keys are secret; endpoint/bucket are public config.
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# Set only if the store supports per-object ACLs; otherwise use a public-read
# bucket policy. Leave blank for R2 / Garage.
# S3_OBJECT_ACL=public-read
